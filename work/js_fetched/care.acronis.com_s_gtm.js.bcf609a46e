<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-HLFTTSZW7L"></script>
<script async src="https://service.force.com/embeddedservice/5.0/esw.min.js"></script> 

<script> 
var chatFields;
var userLang = "en_US";
const allowedLanguages = ['es', 'it', 'fr', 'de', 'ja'];
console.log('test');
// Determine language from document
let pageLang = (document.documentElement.lang || 'en').split('-')[0];
if (allowedLanguages.includes(pageLang)) {
    userLang = pageLang;
}

window.addEventListener('message', (event) => {
	if (event.data?.type === 'CHAT_FIELDS' && event.data.fields) {
    	const expectedOrigin = window.location.origin;
		console.log('expectedOrigin: '+expectedOrigin);
    	if (event.origin !== expectedOrigin) {
        	console.warn('Message ignored: unexpected origin', event.origin);
            return;
        }
        chatFields = event.data.fields;
        console.log('Received chat fields:', chatFields);
    }
});
  window.addEventListener('message', function(event) {
                if (event.data.type === 'LWC_READY') {
        console.log('LWC_READY ');
         const iframe = document.querySelector('#embedded-messaging iframe');
        console.log('iframe',iframe);
                    if (iframe && iframe.contentWindow) {
                        iframe.contentWindow.postMessage({ type: 'PRE_CHAT_FIELDS',chatFields: chatFields}, '*');
                    }
                 
                }
  });

let userLat = null;
let userLng = null;
let messagingReady = false;

// Function to set hidden fields
function setHiddenFields() {
    console.log('setHiddenFields:', userLat, userLng);
    const referrer = document.referrer;
    const url = window.location.href;
    console.log('setHiddenFields url: ',url)

    embeddedservice_bootstrap.prechatAPI.setHiddenPrechatFields({
        Language: userLang,
        Referrer_URL: referrer,
        Geolocation_Latitude: userLat !== null ? userLat.toString() : null,
    	Geolocation_Longitude: userLng !== null ? userLng.toString() : null
    });
}

// Get geolocation
navigator.geolocation.getCurrentPosition(
    (pos) => {
        userLat = pos.coords.latitude;
        userLng = pos.coords.longitude;
        console.log('User location:', userLat, userLng);

        // Only set hidden fields if messaging is ready
        if (messagingReady) setHiddenFields();
    },
    (err) => {
        console.error('Geolocation error:', err);

        // Still set hidden fields if messaging is ready
        if (messagingReady) setHiddenFields();
    }
);

window.addEventListener("onEmbeddedMessageSent", async (event) => {
    const entry = event.detail?.conversationEntry;
    
    if (!entry) return;

    const isSystem = entry.sender?.role?.toLowerCase() === "system";
     
    if (isSystem) {
        console.log("SYSTEM MESSAGE - IGNORED");
        return;
    }
    
    const payload = {
        sessionId: entry.relatedRecords?.[0]
    };

     try {

        const res = await fetch("/services/apexrest/messaging/event", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
        });

        const text = await res.text();

    } catch (e) {
        console.error("FETCH FAILED:", e);
    }

});   
// Listen for Embedded Messaging ready
window.addEventListener('onEmbeddedMessagingReady', () => {
    messagingReady = true;

    // Always set hidden fields, even if geolocation not yet available
    setHiddenFields();
});

document.addEventListener("chatEvent", chatClickHandler, false);

function chatClickHandler(ev) {
    if (ev.detail.startChat === true) {
        startChat();
    }
}

function startChat() {
    if (typeof embeddedservice_bootstrap !== "undefined" &&
        embeddedservice_bootstrap.utilAPI &&
        typeof embeddedservice_bootstrap.utilAPI.launchChat === "function") {
		console.log('userLang:'+userLang);
        embeddedservice_bootstrap.settings.language = userLang;
        embeddedservice_bootstrap.settings.enableUserInputForConversationWithBot = false;
        embeddedservice_bootstrap.utilAPI.launchChat();
    }
}
 window.addEventListener('clear_messaging_session', () => {
    console.log('Logout detected, clearing all localStorage...');

    // Optional: end chat on Salesforce server side if needed
   if (embeddedservice_bootstrap?.userVerificationAPI?.clearSession) {
        embeddedservice_bootstrap.userVerificationAPI.clearSession(true).then(() => {
            embeddedservice_bootstrap.utilAPI.removeAllComponents();
            console.log('Chat session fully cleared');
        });
    }
});

    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-HLFTTSZW7L');
</script>

