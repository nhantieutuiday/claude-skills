<script>
    // The function overriding used for tracking of Page changes in Single Page Application (SPA). The function overrides the inbuilt MDN pushstate function and dispatch a push state event for customizations 
    // do not edit this code
    window.history.pushState = ( f => function pushState(){
        var ret = f.apply(this, arguments);
        window.dispatchEvent(new Event('pushstate'));
        return ret;
    })(history.pushState);
</script>

<script>  
      document.addEventListener('analyticsSupport', function(e) {
          let payload = JSON.parse(JSON.stringify(e.detail));
          console.log('got analytics with detail: ' + payload)

          gtag('event', payload.event, payload.detail);
      });
</script>

<!-- SEO PART -->

<!--SEO: CANONICALS INSERTION -->
<script> 
     function createAlternateCanonicalsForRegularUrls(languages) {
          for (let langItem of languages) {
                let link = document.createElement('link');
                link.setAttribute('rel', 'alternate');
                link.setAttribute('hreflang', langItem.toUpperCase());
                link.setAttribute('href', window.location.origin + window.location.pathname + '?language=' + langItem);
                link.setAttribute('data-owner', 'setSEOProperties');
          		document.head.appendChild(link);
          }
     }
    
    
      function createAlternateCanonicalsForArticle(canonicals) {
          for (let canonicItem of canonicals) {
                let link = document.createElement('link');
                link.setAttribute('rel', 'alternate');
                link.setAttribute('hreflang', canonicItem.language);
                link.setAttribute('href', window.location.origin + '/s/article/' + canonicItem.url);
                link.setAttribute('data-owner', 'setSEOProperties');
          		document.head.appendChild(link);
          }
      }
    
      document.addEventListener('insert_canonicals', function(e) { 
          let canonicals = JSON.parse(JSON.stringify(e.detail));
          createAlternateCanonicalsForArticle(canonicals);
      });
</script>

<!--SEO: CANONICALS UPDATE (article wasn't opened by direct url) -->
<script>   
      document.addEventListener('update_canonicals', function(e) {
          console.log('in update_canonicals');
          let old_canonicals = document.querySelectorAll('link[data-owner="setSEOProperties"]');
            for (let oldCan of old_canonicals) {
                oldCan.remove()
            }
          
          let canonicals;
          if (e && e.detail) {
              canonicals = JSON.parse(JSON.stringify(e.detail));
          }
          // create canonical with language from path
          let urlParams = new URLSearchParams(window.location.search);
          let languageParam = urlParams.get('language'); 
          let link = document.createElement('link');
          link.setAttribute('rel', 'canonical');
          link.setAttribute('hreflang', languageParam);
          if (languageParam !== null) {
              link.setAttribute('href', location.origin + location.pathname + '?language=' + languageParam);
          } else {
              link.setAttribute('href', location.origin + location.pathname + '?language=en_US');
          }
          link.setAttribute('data-owner', 'setSEOProperties');
          document.head.appendChild(link); 
	
          // create x-default canonical 
          let xlink = document.createElement('link');
          xlink.setAttribute('rel', 'alternate');
          xlink.setAttribute('hreflang', "x-default");
          xlink.setAttribute('href', location.origin + location.pathname + '?language=en_US');
          xlink.setAttribute('data-owner', 'setSEOProperties');
          document.head.appendChild(xlink); 
          
          // create other (alternate) canonicals
          if (window.location.href.indexOf('/s/article/') !== -1) {
              createAlternateCanonicalsForArticle(canonicals);
          } else {
              // langs
              createAlternateCanonicalsForRegularUrls(canonicals);
          }
      });
    
</script>




<script>  
      document.addEventListener('clear_description_metas', function(e) {
            let metas = document.getElementsByTagName('meta')
            for (let metaItem of metas) {
          		if (metaItem && metaItem.getAttribute('data-owner') && metaItem.getAttribute('data-owner') === 'setSEOProperties') {
                	metaItem.content = removeTagsAndSomeSymbols(metaItem.content)
                }
            }
      }) 
      function removeTagsAndSomeSymbols(html) {
          // console.log('data-owner: ', html.getAttribute('data-owner'))
          let tmp = document.createElement("div");
          tmp.innerHTML = html;
          let textresult = tmp.textContent || tmp.innerText || "";
          textresult = textresult.replace(/[&\/\\%.'":*]/g, '')
          return textresult;
      }
</script>

<!--SEO: INSERT/UPDATE STRUCTURED DATA -->
<script>  
      document.addEventListener('upsert_structured_data', function(e) {
          console.log('upsert_structured_data')
          let article = JSON.parse(JSON.stringify(e.detail));
          // console.log(`article: ${article}`)
          updateStructuredData(article)
      });
    
    
    function updateStructuredData(record) {
        // Generate new structured data
        const structuredData = {
            "@context": "https://schema.org",
            "@type": "Article",
            "name": removeTagsAndSomeSymbols(record.Title),
            "headline": removeTagsAndSomeSymbols(record.Title),
            "datePublished": record.CreatedDateText__c,
            "dateModified": record.LastPublishedDate__c,
            "description": removeTagsAndSomeSymbols(record.Summary),
            "mainEntityOfPage": {
                "@type": "WebPage",
                "@id": record.CanonicalURL__c
            },
            "publisher": {
                "@type": "Organization",
                "name": "Acronis"
            }
        };

        const structuredDataScript = document.createElement('script');
        structuredDataScript.type = 'application/ld+json';
        structuredDataScript.textContent = JSON.stringify(structuredData, null, 2);

        // Remove any old structured data
        const oldStructuredData = document.querySelector('script[type="application/ld+json"]');
        if (oldStructuredData) {
            oldStructuredData.remove();
        }

        // Add new structured data
        document.head.appendChild(structuredDataScript);
    }
</script> 

<!-- SEO: add noindex/nofollow for certain article's urls -->
<script>
    
let noIndexArticlesUrlsSet = new Set([
	'service-notification-migration',
	'FRA-data-center-migration-service-provider',
	'FRA-data-center-migration-business',
	'FRA-data-center-migration-individuals',
	'Acronis-True-Image-Troubleshooting-issues-after-FRA-Data-center-migration',
	'Acronis-Cyber-Protect-Troubleshooting-issues-after-FRA-Data-center-migration',
	'Acronis-Cyber-Protect-Cloud-Troubleshooting-issues-after-FRA-Data-center-migration',
]);

let makePageNoIndexedIfFromSet = function() {
    for (let item of noIndexArticlesUrlsSet) {
        if (window.location.href.toLowerCase().indexOf(item.toLowerCase()) !== -1) {
            let meta = document.createElement('meta'); 
            meta.name = 'robots'; 
            meta.content = 'noindex'; 
            document.head.appendChild(meta);
        }
    }
}
makePageNoIndexedIfFromSet();    
</script>

