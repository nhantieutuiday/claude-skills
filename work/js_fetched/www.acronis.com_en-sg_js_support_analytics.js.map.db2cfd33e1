}
.wacom-content {
/*background: #00204d;*/
margin: 0 auto;
padding: 47px 0 96px;
position: relative;
max-width: 960px;
width: 100%;
}
.wacom-content .enterprise { overflow: auto; }
.inner {
max-width: 960px;
width: 100%;
margin: 0 auto;
}
.gray { background-color: #f1f3f4; } 
/* REWRITES */ 
.wacom-content .a-main-content-wrapper,
.wacom-content .a-content-tabs-wrapper,
.wacom-content .a-content-tabs-ct,
.wacom-content .a-content-tabs,
.wacom-content .a-content {
