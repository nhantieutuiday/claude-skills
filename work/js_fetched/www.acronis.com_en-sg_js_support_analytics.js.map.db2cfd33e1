.promo-banner { background-color: #f1f3f4; color: #b40e0e; display: block; font: 700 32px/28px "Open Sans",Arial,sans-serif; margin: 0; padding: 7px 10px 25px; position: relative; text-align: center; width: 300px; }
.promo-banner b { color: #0d3d7b; display: block; font-size: 14px; padding: 20px 0 5px; text-transform: uppercase; }
.promo-banner u { display: block; font-size: 20px; line-height: 18px; padding-top: 10px; text-decoration: none; }
.promo-banner a { background-color: #b40e0e; color: #ffffff; display: inline-block; font-size: 14px; font-style: normal; line-height: 17px; margin: 25px 0 12px; padding: 20px 10px 19px; text-align: center; text-decoration: none; text-transform: uppercase; width: 159px; }
.promo-banner a:hover { color: #fff; }
.promo-banner i { color: #6f7683; display: block; font-size: 16px; font-style: normal; font-weight: normal; }
.menu-navigation .menu-item-business .menu-promo a.promo-wbd { position: absolute; left: 0; top: 0; }
.s-main-header { position: absolute; top: 24px; width: 100%; z-index: 400 }
.s-main-header__logo-container { width: calc((100% - 176px)/12*3 + 32px) }
.s-main-header__logo { height: 27px; width: 133px }
.s-main-header__content { z-index: 400; display: -webkit-box; display: -ms-flexbox; display: flex; -webkit-box-pack: justify; -ms-flex-pack: justify; justify-content: space-between; -webkit-box-align: center; -ms-flex-align: center; align-items: center }
.s-main-header__nav { z-index: 100; margin-bottom: -40px; padding-bottom: 40px; padding-left: 24px; padding-right: 24px }
.s-main-header__menu { display: none; position: absolute; top: 100%; left: 0; width: 100%; height: 0; background: #fff }
.s-main-header__menu-item { margin: 0; padding: 10px 0 }
.s-main-header__buttons { position: relative; display: -webkit-box; display: -ms-flexbox; display: flex; -webkit-box-align: center; -ms-flex-align: center; align-items: center; margin-left: auto; margin-right: 8px; z-index: 105 }
.s-main-header__buttons:before { content: ""; position: absolute; top: 50%; right: 0; -webkit-transform: translateY(-50%); transform: translateY(-50%); width: 1px; height: 26px }
.s-main-header__button-item { margin-right: 16px }
.s-main-header__button-item:last-child { margin-right: 0 }
.s-main-header__menu-link { font-size: 16px; line-height: 24px; padding: 0 12px; background: none; border: none; color: #0065e3; cursor: pointer }
.s-main-header__menu-link:before { opacity: 0; content: ""; position: absolute; z-index: 100; top: calc(100% + 12px); left: 50%; -webkit-transform: translateX(-50%) rotate(45deg); transform: translateX(-50%) rotate(45deg); width: 27px; height: 27px; border: 1px solid rgba(38,104,197, .3); background: linear-gradient(135deg,#fff 10px,hsla(0,0%,100%,0) 0); pointer-events: none }
.s-main-header__menu-link:after { opacity: 0; content: ""; position: absolute; z-index: 100; top: calc(100% + 17px); left: 50%; -webkit-transform: translateX(-50%); transform: translateX(-50%); width: 38px; height: 34px; background-color: #fff; pointer-events: none }
.s-main-header .menu-toggler { position: relative; display: -webkit-box; display: -ms-flexbox; display: flex; -webkit-box-align: center; -ms-flex-align: center; align-items: center; -webkit-box-pack: end; -ms-flex-pack: end; justify-content: flex-end; min-width: 80px; padding: 0; background: none; border: none; cursor: pointer; z-index: 100 }
.s-main-header .menu-toggler__caption { font-size: 14px; line-height: 20px }
.s-main-header .menu-toggler__caption-opened-text { position: absolute; top: 50%; left: 0; -webkit-transform: translateY(-50%); transform: translateY(-50%); opacity: 0 }
.s-main-header .menu-toggler__icon { margin-left: 16px; width: 24px; height: 24px; fill: #fff }
.s-main-header .menu-toggler .a-glyph__close { margin-right: 8px }
.s-main-header .menu-toggler_state_active .menu-toggler__caption-default-text { opacity: 0 }
.s-main-header .menu-toggler_state_active .menu-toggler__caption-opened-text { opacity: 1; color: #408bea }
.s-main-header .menu-toggler_state_active .menu-toggler__icon { margin-left: 8px; color: #408bea }
.s-main-header .s-main-menu { position: absolute; top: 48px; left: 0; right: 0; z-index: 75; width: 100%; min-height: calc(100vh - 75px); background: #fff; border: 1px solid rgba(38,104,197, .3); -webkit-box-shadow: 0 10px 20px rgba(35,49,67, .2); box-shadow: 0 10px 20px rgba(35,49,67, .2); }
.s-main-header .s-main-menu__tabs-wrapper { position: relative; margin: auto; width: 100%; max-width: 1312px }
.s-main-header .s-main-menu__disable { display: none }
.s-main-header .s-main-menu__accordion-wrapper { width: 100%; padding: 16px 0 0 }
