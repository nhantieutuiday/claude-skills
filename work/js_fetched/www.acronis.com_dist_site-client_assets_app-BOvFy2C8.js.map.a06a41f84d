eACN,UAAW,IAAMO,EAAYP,EAAmB,MAAM,GAE1D,CACI,KAAM,sBACN,KAAM,oBACN,UAAW,IAAMO,EAAYP,EAAmB,WAAW,GAE/D,CACI,KAAM,4BACN,KAAM,2BACN,UAAW,IAAMO,EAAYP,EAAmB,QAAQ,EAC5D,EAEJ,CAACY,EAAiB,EAAG,CACjB,CACI,KAAM,eACN,KAAM,mBACN,UAAW,IAAML,EAAYK,GAAmB,SAAS,EACzD,mBAAoB,CAAE,OAAQ,GAAK,CACvC,CACJ,GAGU5F,CAAM,GAAK,GAGtB,SAAS6F,GAAc5L,EAAS6L,EAAO,CAC1C,IAAIC,EAAgBJ,GAAU1L,EAAQ,OAAO,MAAM,EAGnD,GAAIA,EAAQ,OAAO,eAAgB,CAC/B,MAAM+L,EAAWD,EAAc,KAAMlM,GAAMA,EAAE,OAAS,gBAAgB,EAEtE,IAAIoM,EAAY,mBAEZF,EAAc,KAAMlM,GAAMA,EAAE,KAAK,WAAW,WAAW,CAAC,IACxDoM,EAAY,4BAEZF,EAAc,KAAMlM,GAAMA,EAAE,KAAK,WAAW,SAAS,CAAC,IACtDoM,EAAY,0BAShBF,EAAgB,CANH,CACT,GAAGC,EACH,KAAMC,EACN,oBAAqB,EAAC,CAGL,CACzB,CAOA,OALeC,GAAa,CACxB,QAASJ,IAAU,MAAQK,GAAA,EAAwBC,GAAA,EACnD,OAAQL,CAAA,CACX,CAGL,CClmBO,SAASM,GAAUpM,EAAkD,CACxE,MAAMqM,EAAMC,GAAaC,EAAG,EAQ5B,GANAF,EAAI,OAAO,iBAAiB,KAAOA,EACnCA,EAAI,OAAO,gCAAkC,GAG7CA,EAAI,MAAMG,EAAc,EAEpBxM,GAAW,QAASA,GAAW,QAASA,EAAS,CACjDqM,EAAI,OAAO,iBAAiB,YAAcrM,EAC1C,MAAMzB,EAAQgM,GAAavK,CAAO,EAC5ByM,EAASb,GAAc5L,EAAS,KAAK,EAC3C,OAAAqM,EAAI,IAAI9N,CAAK,EACb8N,EAAI,IAAII,CAAM,EACP,CAAE,IAAAJ,EAAK,MAAA9N,EAAO,OAAAkO,EACzB,CAEA,MAAMlO,EAAQgM,GAAavK,GAAW,EAAE,EAClCyM,EAASb,GAAc5L,GAAW,GAAI,SAAS,EACrD,OAAAqM,EAAI,IAAI9N,CAAK,EACb8N,EAAI,IAAII,CAAM,EACP,CAAE,IAAAJ,EAAK,MAAA9N,EAAO,OAAAkO,CAAA,CACzB,CC5BA,eAAeC,IAAO,CAElB,MAAMlC,GADmB7L,GAAO,KAAK,MAAM,SAAS,eAAeA,CAAE,GAAG,aAAe,IAAI,GACtD,WAAW,EAC1CqB,EAAUwK,EAAa,QAEvB,CAAE,IAAA6B,EAAK,OAAAI,EAAQ,MAAAlO,CAAA,EAAU6N,GAAUpM,CAAO,EAChDzB,EAAM,aAAaiM,CAAY,EAE/B,MAAMiC,EAAO,UACbJ,EAAI,MAAM,OAAQ,EAAI,CAC1B,CAEAK,GAAA","names":["_sfc_main","defineComponent","utm","cleverbridge","targetNode","config","query","key","item","element","url","surl","options","hash","el","scrollMargin","sticky","acc","next","utmContent","searchParams","pair","x","startedAt","CURRENT","defaultTracker","opts","_hoisted_1","_openBlock","_createElementBlock","_ctx","_hoisted_2","_createCommentVNode","_createVNode","_component_router_view","academy","store","courses","state","awards","id","getAgent","ignoreSSLErrors","https","AssignHttpsAgent","axios","ObservePromAPILatency","summary","getMetric","observeFn","resp","elapsedMs","error","childLogger","Logger","WrapAxiosWithRequestLogger","loggerFn","r","serializeFn","qs","getAPIProduct","context","defaults","params","baseURL","instance","flow","it","postCustomMapper","post","SECTION_SLUG_BY_ID","blog","shape","args","request","client","status","StatusCodes","response","_","stateID","locale","LOCALE_DEFAULT","requestTemplate","ProductAPIQueryBuilder","SECTION_ID_BLOG","CARD_FIELDS_SUBSET","localizedReq","fallbackReq","items","getAPIService","data","_state","_getters","root","countries","getFilterFormDefaults","events","commit","location","email","cfg","ServiceAPIError","domain","normalizedDomain","formData","eventsFeed","translations","i","eventDetails","eventUtils","storeID","allLocaleMappings","currentLocaleMappings","groupsPromises","groupID","grouped","group","country","flat","uniq","optsDefault","req","expressSignup","API_ENDPOINT","geolocation","fromPocket","getDataFromPocket","fromApi","flag","lang","inapp","httpStatus","message","HttpRejection","FIELDS_EXCEPT","licenses","cleverbridgeIDs","currency","paginate","locales","localeData","res","pages","pageData","payload","newPageData","processedPageData","propName","partners","token","partnersLocator","locator","FIELDS_PRIVATE","popup","slug","siteID","now","popups","convertToConsumableObjects","pressReleases","currentLocale","getAvailableLocales","httpRejectEmptyState","filters","page","queryBuilder","PR_MAX_RELEASES_PEG_PAGE","pressReleasesFeed","releasesRequest","processed","year","getLanguageCodeFromLocale","feed","PAGINATE_SIZE","getProductsListPage","mapProduct","product","products","currentPage","totalPages","productId","result","isPayloadObject","rating","reviews","promotions","translation","value","promotion","list","discounts","promises","discount","publications","resourceCenter","searchData","generateSearchQuery","ribbon","ribbons","ROUTES_CONFIG_NAME","seo","slapfive","boardID","slices","column","region","slice","merge","solutions","integrations","integration","categories","getAPIAccount","_context","trial","_recaptchaResponse","actionURL","formUtils","queryStringData","user","vroi","productCodes","currentPriceListId","perPage","allItems","papiFetchAllPagesClient","workday","StoreFactory","initialState","modules","c.SITE_ID_SOLUTIONS","c.SITE_ID_EVENTS","c.SITE_ID_DEVELOPER","c.SITE_ID_SCS","c.SITE_ID_TRUEIMAGE","c.SITE_ID_ACADEMY","c.SITE_ID_WWW","augmented","createStore","getModules","__vitePreload","wrappedModulesCache","viewFactory","view","path","mod","getRoutes","c.SITE_ID_TOOLBOX","RouterFactory","scene","currentRoutes","route404","fixedPath","createRouter","createMemoryHistory","createWebHistory","createApp","app","createSSRApp","App","sliceNameMixin","router","main"],"ignoreList":[],"sources":["../../../src/vue3/root.vue","../../../src/vue3/store/modules/academy.ts","../../../src/vue3/store/modules/awards.ts","../../../src/api/plugins/https-agent.ts","../../../src/api/plugins/prom-api-latency.ts","../../../src/api/plugins/request-logger.ts","../../../src/api/product.ts","../../../src/vue3/store/modules/blog.ts","../../../src/api/service.ts","../../../src/vue3/store/modules/cleverbridge.ts","../../../src/vue3/store/modules/config.ts","../../../src/vue3/store/modules/countries.ts","../../../src/vue3/store/modules/events.ts","../../../src/vue3/store/modules/events-feed.ts","../../../src/vue3/store/modules/express-signup.ts","../../../src/vue3/store/modules/geolocation.ts","../../../src/vue3/store/modules/inapp.ts","../../../src/vue3/store/modules/licenses.ts","../../../src/vue3/store/modules/locales.ts","../../../src/vue3/store/modules/pages.ts","../../../src/vue3/store/modules/partners.ts","../../../src/vue3/store/modules/partners-locator.ts","../../../src/vue3/store/modules/popup.ts","../../../src/vue3/store/modules/press-releases.ts","../../../src/vue3/store/modules/press-releases-feed.ts","../../../src/vue3/store/modules/products.ts","../../../src/vue3/store/modules/promotions.ts","../../../src/vue3/store/modules/publications.ts","../../../src/vue3/store/modules/resource-center.ts","../../../src/vue3/store/modules/ribbon.ts","../../../src/vue3/store/modules/seo.ts","../../../src/vue3/store/modules/slapfive.ts","../../../src/vue3/store/modules/slices.ts","../../../src/vue3/store/modules/solutions.ts","../../../src/api/account.ts","../../../src/vue3/store/modules/trial.ts","../../../src/vue3/store/modules/user.ts","../../../src/vue3/store/modules/vroi.ts","../../../src/vue3/store/modules/workday.ts","../../../src/vue3/store/store-factory.ts","../../../src/vue3/views/router-factory.ts","../../../src/vue3/main.ts","../../../src/vue3/entry-client.ts"],"sourcesContent":["<template>\n    <div id=\"root\">\n        <div v-if=\"isOneTrustPopupOpened && !isOneTrustPopupClosed\" class=\"onetrust-overlay\" />\n        <router-view id=\"router-view\" />\n    </div>\n</template>\n\n<script lang=\"ts\">\nimport { defineComponent } from 'vue';\nimport cleverbridge from '@core/mixins/cleverbridge.js';\nimport utm from '@core/mixins/utm.js';\nimport type { SSRContext } from '@model/ssr/context';\nimport 'the-new-css-reset/css/reset.css';\nimport 'highlight.js/styles/atom-one-light.css';\nimport '@core/styles/vars.pcss';\nimport '@core/styles/defaults.pcss';\nimport '@core/styles/vars/grid-system.scss';\nimport '@core/styles/spacings.scss';\nimport '@core/styles/cols.scss';\nimport '@core/styles/custom-fonts.scss';\n// NB: font stylesheet is preload + async import in root.html for better UX\n\ndeclare global {\n    interface Window {\n        google: any;\n        markerClusterer: any;\n        dataLayer: unknown[];\n        ga: any;\n        VWO_OUTCOME: 'pending' | 'regular' | 'redirect',\n    }\n}\n\nexport default defineComponent({\n    name: 'AppRoot',\n\n    mixins: [utm, cleverbridge],\n    data() {\n        return {\n            isOneTrustPopupClosed: true,\n            isOneTrustPopupOpened: true,\n            oneTrustObserver: null as MutationObserver | null,\n        };\n    },\n\n    async mounted() {\n        await this.deleteSensitiveQueryParams();\n        this.pushGaEvents();\n        this.handleClick();\n        this.handleURLHash();\n        this.storeLocalUTM();\n        this.storeSessionUTM();\n        this.observeOneTrustPopup();\n        window.addEventListener('OneTrust.OnConsentChanged', this.refreshOneTrustPopupState);\n    },\n\n    beforeMount() {\n        window.addEventListener('load', this.addLabelUTM);\n    },\n\n    beforeUnmount() {\n        window.removeEventListener('load', this.addLabelUTM);\n        if (this.oneTrustObserver) {\n            this.oneTrustObserver.disconnect();\n        }\n        window.removeEventListener('OneTrust.OnConsentChanged', this.refreshOneTrustPopupState);\n    },\n\n    methods: {\n        observeOneTrustPopup() {\n            const targetNode = document.body;\n            const config = { childList: true, subtree: true };\n\n            this.oneTrustObserver = new MutationObserver(() => {\n                this.refreshOneTrustPopupState();\n            });\n\n            this.oneTrustObserver.observe(targetNode, config);\n\n            this.refreshOneTrustPopupState();\n        },\n\n        refreshOneTrustPopupState() {\n            if (typeof window?.OneTrust?.IsAlertBoxClosed === 'function') {\n                this.isOneTrustPopupOpened = window.Optanon.GetDomainData?.()?.ShowAlertNotice;\n                this.isOneTrustPopupClosed = window.OneTrust.IsAlertBoxClosed();\n            }\n        },\n\n        async deleteSensitiveQueryParams() {\n            // we clear potential first_name and last_name params to prevent them from being sent to facebook\n            if (Object.keys(this.$route?.query).length) {\n                this.$store.commit('trial/SET_QUERY_STRING_DATA', this.$route.query);\n\n                const query = { ...this.$route.query };\n                const expectedKeys = [\n                    'osauid',\n                    'aan',\n                    'company',\n                    'email',\n                    'first_name',\n                    'last_name',\n                    'phone',\n                    'country',\n                    'currency',\n                    'price',\n                    'opportunity_id',\n                    'tenantId',\n                ];\n\n                expectedKeys.forEach((key) => (delete query[key]));\n\n                if (JSON.stringify(query) !== JSON.stringify(this.$route.query)) {\n                    await this.$router.replace({\n                        path: this.$route.path,\n                        query,\n                        hash: this.$route.hash,\n                    });\n                }\n            }\n        },\n\n        pushGaEvents() {\n            window.dataLayer = window.dataLayer || [];\n\n            this.initAnonymousGATrackerDelayed(new Date());\n\n            const customPageEvents = this.$store.state.pages?.page?.settings?.pushEventToDataLayer || [];\n            customPageEvents.forEach((item) => window.dataLayer.push(item));\n        },\n\n        addLabelUTM() {\n            if (!this.getSessionUTM.length) {\n                return;\n            }\n            Array.from(document.getElementsByTagName('a')).forEach((element: HTMLAnchorElement): void => {\n                const url = this.setQueryString(element.href);\n                if (url) element.setAttribute('href', url);\n            });\n        },\n\n        handleClick(): void {\n            document.body.addEventListener('click', (e: any) => {\n                // WEB-42890: Support dynamically injected surl links from the api content\n                if (e.target.dataset?.surl) {\n                    e.preventDefault();\n                    const surl = JSON.parse(e.target.dataset.surl);\n                    const options = this.storeOptionsSURL(surl);\n                    this.redirectToCleverbridge(options);\n                    return;\n                }\n                if (e.target.dataset?.event) {\n                    window.dataLayer.push({\n                        eventLabel: e.target.href,\n                        ...e.target.dataset,\n                    });\n                }\n            });\n        },\n\n        handleURLHash(): void {\n            const hash = this.$route.hash.replace('/', ''); // TODO: why replace?\n            if (!hash) {\n                return;\n            }\n\n            if (window.location.hash !== hash) {\n                window.location.hash = hash;\n            }\n\n            document.addEventListener('readystatechange', () => this.scrollToSlice(hash));\n        },\n\n        scrollToSlice(hash: string): void {\n            if (document.readyState !== 'complete') {\n                return;\n            }\n\n            // hash can contain virtually anything so querySelector can throw an invalid selector error\n            let el = null;\n            try {\n                el = document.querySelector(hash);\n            } catch (e) {\n                // NO OP\n            }\n\n            if (!el) {\n                return;\n            }\n\n            const scrollMargin = Array.from(document.querySelectorAll('.directive-v-sticky'))\n                .map((sticky: HTMLElement) => sticky.offsetHeight || 0)\n                .reduce((acc: number, next: number) => acc + next, 0);\n\n            window.scroll({\n                top: el.getBoundingClientRect().top + window.scrollY - scrollMargin,\n                behavior: 'smooth',\n            });\n        },\n\n        storeLocalUTM(): void {\n            if (!window.localStorage) {\n                return;\n            }\n\n            const utmContent = new URL(window.location.href).searchParams.get('utm_content');\n            const allowedKeys = new Set(['smart', 'Smart', 'SmartDisplay']);\n\n            if (allowedKeys.has(utmContent)) {\n                localStorage.setItem('utm_content', utmContent);\n            }\n        },\n\n        storeSessionUTM(): void {\n            if (!window.sessionStorage) {\n                return;\n            }\n\n            const searchParams = new URL(window.location.href).searchParams;\n\n            const labels = [\n                'utm_campaign',\n                'utm_content',\n                'utm_medium',\n                'utm_source',\n                'utm_term',\n                'x-audience',\n                'x-opp-id',\n                'x-tenant_id',\n                'x-wave',\n            ];\n\n            labels\n                .map((key) => ({ key, val: searchParams.get(key) }))\n                .filter((pair) => Boolean(pair.val))\n                .forEach((x) => sessionStorage.setItem(x.key, x.val));\n        },\n\n        initAnonymousGATrackerDelayed(startedAt: any): void {\n            // Universal Google Analytics now require a tracker name for its calls: `ga(\"gtm5.send\", ...)`\n            // For some 3rd party libs (Onetrust, maybe more)\n            // it's necessary to have an unnamed tracker: `ga(\"send\", ...)`\n            // As GTM doesn't fire a `ga_loaded` event of any kind, we must check it in a timer callback\n\n            const MAX_DETECT_TIME = 10000; // ms\n            const DETECT_INTERVAL = 100; // ms\n            const CURRENT:any = new Date();\n\n            if (window.ga && window.ga.loaded && window.ga.getAll()[0]) {\n                const defaultTracker = window.ga.getAll()[0];\n                const opts = {\n                    cookieDomain: 'auto',\n                    allowLinker: true,\n                };\n                window.ga('create', defaultTracker.get('trackingId'), opts);\n            } else if (CURRENT - startedAt > MAX_DETECT_TIME) {\n                // It took too long, we just give up\n                // return;\n            } else {\n                setTimeout(() => this.initAnonymousGATrackerDelayed(startedAt), DETECT_INTERVAL);\n            }\n        },\n    },\n\n    async serverPrefetch(): Promise<void> {\n        if (!import.meta.env.SSR) return;\n\n        const ctx = this.$ssrContext as SSRContext;\n\n        switch (ctx.req.l10n.localizationStrategy) {\n            case 'locale': {\n                await Promise.all([\n                    this.$store.dispatch('geolocation/updateRequestedLocale', ctx.req.l10n.requestedLocale),\n                    this.$store.dispatch('geolocation/updateDesiredLocale', ctx.req.l10n.desiredLocale),\n                    this.$store.dispatch('geolocation/updateFinalLocale', ctx.req.l10n.requestedLocale),\n                ]);\n                break;\n            }\n            case 'language': {\n                await Promise.all([\n                    this.$store.dispatch('geolocation/updateRequestedLocale', ctx.req.l10n.requestedLocale),\n                    this.$store.dispatch('geolocation/updateDesiredLocale', ctx.req.l10n.desiredLocale),\n                    this.$store.dispatch('geolocation/updateFinalLocale', ctx.req.l10n.requestedLocale),\n                    this.$store.dispatch('geolocation/updateIsLanguageAwareFlag', true),\n                    this.$store.dispatch('geolocation/updateLanguage', ctx.req.l10n.language),\n                ]);\n                break;\n            }\n            default: {\n                // Fallback for containers which are not using `ServerPrefetchLocalizedProbe`\n                await this.$store.dispatch('geolocation/updateFinalLocale', this.$route.params.locale);\n                break;\n            }\n        }\n\n        ctx.res.pocket.splits = await ctx.Synced.slicesData.query('splits', 'null') ?? {};\n        ctx.res.pocket.matomo = { baseUrl: ctx.env.HEAD_SITE_MAIN_PUBLIC_BASE_URL_MATOMO };\n        ctx.res.pocket.public_context = ctx.public;\n\n        // placeholders to rewrite on LB\n        ctx.res.pocket.clientinfo = {\n            ipSource: '%%CLIENT_IP_SOURCE%%',\n            ja3: '%%CLIENT_JA3%%',\n            ja4: '%%CLIENT_JA4%%',\n        };\n    },\n});\n</script>\n","import type { AugmentedStore } from '@model/vue-store/augmented-store';\nimport type { ActionContext } from 'vuex';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        courses: [],\n    }),\n\n    actions: {\n        async getCourses(this: AugmentedStore, store: ActionContext<any, any>) {\n            const courses = await this.$context.Synced.academy.getList();\n            store.commit('setCourses', courses);\n        },\n    },\n\n    mutations: {\n        setCourses(state: any, courses: any) {\n            state.courses = courses;\n        },\n    },\n};\n","import type { AugmentedStore } from '@model/vue-store/augmented-store';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        items: {},\n    }),\n\n    actions: {\n        async getAward(this: AugmentedStore, store, id) {\n            const item = await this.$context.Synced.awards.query(id.toString());\n            store.commit('setAward', { id, item });\n        },\n    },\n\n    mutations: {\n        setAward(state, { id, item }) {\n            state.items[id] = item;\n        },\n    },\n};\n","import https from 'https'; // eslint-disable-line n/prefer-node-protocol\nimport { AxiosInstance } from 'axios';\n\nconst getAgent = (ignoreSSLErrors: boolean): https.Agent | undefined => {\n    if (!https.Agent) return undefined;\n\n    return new https.Agent({\n        rejectUnauthorized: !ignoreSSLErrors,\n    });\n};\n\nexport const AssignHttpsAgent = (axios: AxiosInstance, ignoreSSLErrors: boolean): AxiosInstance => {\n    // eslint-disable-next-line no-param-reassign\n    axios.defaults.httpsAgent = getAgent(ignoreSSLErrors);\n    return axios;\n};\n","import { AxiosInstance, AxiosResponse } from 'axios';\nimport { Summary } from 'prom-client';\nimport { getMetric } from '@utils/prometheus-client';\n\nexport const ObservePromAPILatency = (axios: AxiosInstance): AxiosInstance => {\n    if (!axios || typeof axios.request !== 'function') {\n        return axios;\n    }\n\n    const summary = getMetric<Summary>('api_request_latency');\n    if (!summary) {\n        return axios;\n    }\n\n    const startedAt = Date.now();\n\n    const observeFn = (resp: AxiosResponse): AxiosResponse => {\n        try {\n            const url = new URL(resp.config.url, resp.config.baseURL || 'https://example.com');\n            const elapsedMs = Date.now() - startedAt;\n            summary.labels(url.hostname, url.pathname).observe(elapsedMs);\n        } catch (error) {\n            // eslint-disable-next-line no-console\n            console.error('⚠️ ObservePromAPILatency error:', error);\n        }\n\n        return resp;\n    };\n\n    axios.interceptors.response.use(observeFn);\n\n    return axios;\n};\n","import { AxiosInstance, InternalAxiosRequestConfig, ParamsSerializerOptions } from 'axios';\nimport qs from 'qs';\nimport { Logger } from '@utils/logger';\n\nconst childLogger = Logger.child({ name: 'Axios' });\n\nexport const WrapAxiosWithRequestLogger = (axios: AxiosInstance): AxiosInstance => {\n    if (!axios || typeof axios.request !== 'function') {\n        return axios;\n    }\n\n    if (!Logger.isLevelEnabled || !Logger.isLevelEnabled('debug')) return axios;\n\n    const loggerFn = (config: InternalAxiosRequestConfig): InternalAxiosRequestConfig => {\n        let r = `${config.method.toUpperCase()} ${config.baseURL}${config.url}`;\n        if (config.params) {\n            const serializer = config.paramsSerializer as ParamsSerializerOptions;\n            const serializeFn = serializer?.serialize || qs.stringify;\n            r += `?${serializeFn(config.params)}`;\n        }\n        childLogger.debug({ r }, 'Request sent');\n        return config;\n    };\n\n    axios.interceptors.request.use(loggerFn);\n\n    return axios; // ✅ Ensures Axios instance is always returned\n};\n","import axios, { AxiosInstance, RawAxiosRequestConfig } from 'axios';\nimport { flow } from 'lodash-es';\nimport qs from 'qs';\nimport type { SSRContext } from '@model/ssr/context';\nimport { AssignHttpsAgent } from './plugins/https-agent';\nimport { ObservePromAPILatency } from './plugins/prom-api-latency';\nimport { WrapAxiosWithRequestLogger } from './plugins/request-logger';\n\nconst getAPIProduct = (context: SSRContext): AxiosInstance => {\n    const defaults: RawAxiosRequestConfig = {\n        validateStatus: () => true,\n        timeout: 10000,\n        paramsSerializer: {\n            serialize: (params) => qs.stringify(params, { encodeValuesOnly: true }),\n        },\n        maxRedirects: 0,\n    };\n\n    const baseURL = typeof window === 'undefined'\n        ? context.public.env.HEAD_SITE_MAIN_PUBLIC_BASE_URL_PRODUCT_API_SERVER\n        : context.public.env.HEAD_SITE_MAIN_PUBLIC_BASE_URL_PRODUCT_API_CLIENT;\n\n    const instance = axios.create({\n        ...defaults,\n        baseURL,\n    });\n\n    return flow(\n        (it: AxiosInstance) => AssignHttpsAgent(it, context.env?.HEAD_SITE_MAIN_FEATURE_CLIENT_IGNORE_SSL_ERRORS),\n        (it: AxiosInstance) => WrapAxiosWithRequestLogger(it),\n        (it: AxiosInstance) => ObservePromAPILatency(it),\n    )(instance);\n};\n\nexport default getAPIProduct;\n","import { RawAxiosRequestConfig, AxiosResponse } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport { ActionContext, Store } from 'vuex';\nimport { ProductAPIQueryBuilder, Storage } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport { SECTION_SLUG_BY_ID, SECTION_ID_BLOG, CARD_FIELDS_SUBSET } from '@model/const/blog';\nimport { LOCALE_DEFAULT } from '@model/const/locales';\nimport { Logger } from '@utils/logger';\n\nconst postCustomMapper = (post) => ({\n    ...post,\n    pathname: `/${SECTION_SLUG_BY_ID[post.section_id]}/posts/${post.slug}/`,\n});\n\nexport default {\n    namespaced: true,\n\n    state: () => {\n        // WARN: empty state shape can cause reactivity issues on mutation\n        const shape = () => ({\n            id: '',\n            httpStatus: 0,\n            locale: '',\n            pagination: {},\n            items: [],\n        });\n\n        return {\n            topPost: shape(),\n            latestPost: shape(),\n            latestCards: shape(),\n            CPCNews: shape(),\n            CPCNewsCategory: shape(),\n            spotlightedCPC: shape(),\n            featuredCPC: shape(),\n            featuredBlog: shape(),\n            popularBlog: shape(),\n            category: shape(),\n            categories: shape(),\n            post: shape(),\n            tag: shape(),\n            authors: shape(),\n            author: shape(),\n            news: shape(),\n            cards: shape(),\n            previousPost: shape(),\n            nextPost: shape(),\n            morePosts: shape(),\n            tags: shape(),\n            audiences: shape(),\n            cta: shape(),\n            ctaData: shape(),\n            postTranslationsList: shape(),\n            categoryTranslationsList: shape(),\n            sectionTranslationsList: shape(),\n            authorTranslationsList: shape(),\n            tagTranslationsList: shape(),\n            // ==== Custom actions\n            latestBlogPosts: shape(),\n            insightsNews: shape(),\n            relatedBlogPosts: shape(),\n        };\n    },\n\n    actions: {\n        async getEntity(store: ActionContext<any, any>, args: { request: Storage }) {\n            const request = args.request;\n\n            const client = getAPIProduct(this.$context);\n\n            const opts: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                timeout: typeof window !== 'undefined' ? 30000 : 6000,\n                method: 'GET',\n                url: request.entityPath,\n                params: request.params,\n            };\n\n            try {\n                const response = await client.request(opts);\n                store.commit('setEntity', { request, response });\n            } catch (error) {\n                Logger.error({ error });\n                store.commit('setHttpStatus', { request, status: error.status || StatusCodes.GATEWAY_TIMEOUT });\n            }\n        },\n\n        deleteEntity(store: ActionContext<any, any>, id: string) {\n            store.commit('deleteEntity', id);\n        },\n\n        async sendViewBeacon(_: never, args: { request: Storage }) {\n            const request = args.request;\n\n            const client = getAPIProduct(this.$context);\n\n            const opts: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.CREATED,\n                timeout: 30000,\n                method: 'POST',\n                url: '/api/blog/posts/views/',\n                params: request.params,\n            };\n\n            // This is a fire-n-forget action\n            try {\n                await client.request(opts);\n            } catch (error) {\n                Logger.error({ error });\n            }\n        },\n\n        // ==== Custom actions \"facade\" for some slices; require to build an actual request to the API so it can't be in @core\n        // s-blog-posts, homepage spotlight, company, etc\n        async getLatestBlogPosts(store: ActionContext<any, any>, options: { locale?: string, limit: number, productID?: number }) {\n            const stateID = 'latestBlogPosts';\n            const locale = options.locale || LOCALE_DEFAULT;\n\n            const requestTemplate = new ProductAPIQueryBuilder(stateID)\n                .setEntityPath('/api/blog/posts/')\n                .addMatchesAll('section_id', '=', SECTION_ID_BLOG.toString())\n                .setCustomParam('has', options.productID ? { products: [options.productID] } : null)\n                .setCustomParam('process-macros', '1')\n                .setOutputOnly(CARD_FIELDS_SUBSET)\n                .addSort('translation.published_at', 'desc')\n                .addSort('id', 'desc')\n                .setPaginate(1, options.limit);\n\n            // trying to get a localized version\n            const localizedReq = requestTemplate\n                .clone(stateID)\n                .setLocales([locale])\n                .toObject();\n            await store.dispatch('getEntity', { request: localizedReq });\n\n            if (store.state[stateID].items?.length || locale === LOCALE_DEFAULT) return;\n\n            // fall back to default locale\n            const fallbackReq = requestTemplate\n                .clone(stateID)\n                .setLocales([LOCALE_DEFAULT])\n                .toObject();\n            await store.dispatch('getEntity', { request: fallbackReq });\n        },\n    },\n\n    mutations: {\n        setHttpStatus(state: Store<any>, args: { request: Storage, status: number }) {\n            state[args.request.id] = state[args.request.id] || {};\n\n            state[args.request.id].id = args.request.id;\n            state[args.request.id].httpStatus = args.status;\n            state[args.request.id].pagination = state[args.request.id].pagination || {};\n            state[args.request.id].pagination.loading = false;\n        },\n\n        setEntity(state: Store<any>, args: { request: Storage, response: AxiosResponse }) {\n            state[args.request.id] = state[args.request.id] || {};\n\n            state[args.request.id].locale = args.request.params?.locales?.[0] || LOCALE_DEFAULT;\n\n            state[args.request.id].id = args.request.id;\n            state[args.request.id].httpStatus = args.response.status;\n            state[args.request.id].pagination = args.response.data.pagination;\n            state[args.request.id].pagination.loading = false;\n\n            let items = args.request.addMore\n                ? [...state[args.request.id].items, ...args.response.data.data]\n                : args.response.data.data;\n\n            // Desperate times call for desperate measures\n            // TODO: can we do it more elegant?\n            if (args.request.entityPath?.endsWith('/blog/posts/')) {\n                items = items.map(postCustomMapper);\n            }\n\n            state[args.request.id].items = items;\n        },\n\n        deleteEntity(state: Store<any>, id: string) {\n            state[id].items = [];\n        },\n    },\n};\n","import axios, { AxiosInstance, RawAxiosRequestConfig } from 'axios';\nimport { flow } from 'lodash-es';\nimport type { SSRContext } from '@model/ssr/context';\nimport { AssignHttpsAgent } from './plugins/https-agent';\nimport { ObservePromAPILatency } from './plugins/prom-api-latency';\nimport { WrapAxiosWithRequestLogger } from './plugins/request-logger';\n\nconst getAPIService = (context: SSRContext): AxiosInstance => {\n    const defaults: RawAxiosRequestConfig = {\n        validateStatus: () => true,\n        timeout: 60000,\n        maxRedirects: 0,\n    };\n\n    const baseURL = typeof window === 'undefined'\n        ? context.public.env.HEAD_SITE_MAIN_PUBLIC_BASE_URL_SERVICE_API_SERVER\n        : context.public.env.HEAD_SITE_MAIN_PUBLIC_BASE_URL_SERVICE_API_CLIENT;\n\n    const instance = axios.create({\n        ...defaults,\n        baseURL,\n    });\n\n    return flow(\n        (it: AxiosInstance) => AssignHttpsAgent(it, context.env?.HEAD_SITE_MAIN_FEATURE_CLIENT_IGNORE_SSL_ERRORS),\n        (it: AxiosInstance) => WrapAxiosWithRequestLogger(it),\n        (it: AxiosInstance) => ObservePromAPILatency(it),\n    )(instance);\n};\n\nexport default getAPIService;\n","import { StatusCodes } from 'http-status-codes';\nimport getAPIService from '@api/service';\nimport { Logger } from '@utils/logger';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({}),\n\n    actions: {\n        async get(store: never, data: Record<string, any>) {\n            try {\n                const client = getAPIService(this.$context);\n\n                const options = {\n                    method: 'POST',\n                    url: '/svc/v1/cleverbridge/surl',\n                    timeout: 30000,\n                    validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                    data,\n                    withCredentials: true,\n                };\n\n                const response = await client.request(options);\n                return response;\n            } catch (error) {\n                Logger.error({ error });\n                return null;\n            }\n        },\n    },\n};\n","// TODO: remove this. Creates much more problems than it solves.\n// Make serverside to read directly from @utils/env, while clientside to read from @utils/<you-name-it>.\n// @utils/<you-name-it> in its turn just gets some data from a pre-rendered DOM node in the <head>.\n// Additionally can be routed with webpack/vite rewiring,\n// in a manner that every env just reads from @utils/<universal-env>\nexport default {\n    namespaced: true,\n\n    state: () => ({}),\n\n    getters: {\n        $config(_state: never, _getters: never, root: any) {\n            return root.context.public;\n        },\n    },\n};\n","import type { AugmentedStore } from '@model/vue-store/augmented-store';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        items: [],\n    }),\n\n    actions: {\n        async getCountries(this: AugmentedStore, store) {\n            const countries = await this.$context.Synced.countries.getList();\n            store.commit('setCountries', countries);\n        },\n    },\n\n    mutations: {\n        setCountries(state, countries) {\n            state.items = countries;\n        },\n    },\n};\n","import { RawAxiosRequestConfig, AxiosResponse } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport { ActionContext, Store } from 'vuex';\nimport { Storage, ProductAPIQueryBuilder } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport getAPIService from '@api/service';\nimport { ServiceAPIError } from '@model/http/service-api-error';\nimport { Logger } from '@utils/logger';\n\nconst getFilterFormDefaults = () => ({\n    category: '',\n    product: '',\n    date: null,\n    audience: '',\n    language: '',\n    sorting: 'recent',\n});\n\nexport default {\n    namespaced: true,\n\n    state: () => {\n        // WARN: empty state shape can cause reactivity issues on mutation\n        const shape = () => ({\n            id: '',\n            httpStatus: 0,\n            pagination: {},\n            items: [],\n        });\n\n        return {\n            country: {\n                id: null,\n                isConfirmed: false,\n            },\n            event: shape(),\n            searchResults: shape(),\n            banners: shape(),\n            inPersonEvents: shape(),\n            inPersonHybridEvents: shape(),\n            upcomingEvents: shape(),\n            virtualEvents: shape(),\n            virtualHybridEvents: shape(),\n            pastEvents: shape(),\n            otherEvents: shape(),\n            onDemandEvents: shape(),\n            audiences: shape(),\n            categories: shape(),\n            videos: shape(),\n            languages: shape(),\n            filterForm: getFilterFormDefaults(),\n            mainSiteEvents: shape(),\n            highlightedEvent: shape(),\n        };\n    },\n\n    actions: {\n        setCountry({ commit }, location) {\n            commit('setCountry', {\n                countryId: location.countryId,\n                isConfirmed: location.isConfirmed,\n            });\n        },\n\n        setFilterForm({ commit }, data) {\n            commit('setFilterForm', data);\n        },\n\n        resetFilterForm({ commit }) {\n            commit('resetFilterForm');\n        },\n\n        async getEntity(store: ActionContext<any, any>, args: { request: Storage }) {\n            store.commit('initEntityLoading', args);\n\n            const request = args.request;\n\n            const client = getAPIProduct(this.$context);\n\n            const opts: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                timeout: typeof window !== 'undefined' ? 30000 : 6000,\n                method: 'GET',\n                url: request.entityPath,\n                params: request.params,\n            };\n\n            try {\n                const response = await client.request(opts);\n                store.commit('setEntity', { request, response });\n            } catch (error) {\n                Logger.error({ error });\n                store.commit('setHttpStatus', { request, status: error.status || StatusCodes.GATEWAY_TIMEOUT });\n            }\n        },\n\n        async checkEmailInSpDomain(store: never, email: string) {\n            const client = getAPIService(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 30 * 1000,\n                validateStatus: () => true,\n                method: 'GET',\n                url: '/svc/v1/marketing/forms/leads/sp-email',\n                params: { email },\n            };\n\n            const response = await client.request(cfg);\n\n            if (response.status as StatusCodes !== StatusCodes.OK) {\n                Logger.error({ error: response });\n                throw ServiceAPIError.FromAxiosResponse(response);\n            }\n\n            return response.data;\n        },\n\n        async checkEmailIn6senseList(store: never, domain: string): Promise<boolean> {\n            const normalizedDomain = domain.toLowerCase().trim();\n\n            const request = new ProductAPIQueryBuilder('checkEmailIn6senseList')\n                .setEntityPath('/api/customers/companies')\n                .addMatchesAll('domain', '=', normalizedDomain)\n                .toObject();\n\n            const client = getAPIProduct(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 30 * 1000,\n                validateStatus: () => true,\n                method: 'GET',\n                url: request.entityPath,\n                params: request.params,\n            };\n\n            const response = await client.request(cfg);\n\n            if (response.status as StatusCodes !== StatusCodes.OK) {\n                Logger.error({ error: response });\n                throw ServiceAPIError.FromAxiosResponse(response);\n            }\n\n            return response.data.data[0]?.domain === normalizedDomain;\n        },\n    },\n\n    mutations: {\n        setCountry(state, location) {\n            state.country.id = location.countryId;\n            state.country.isConfirmed = location.isConfirmed;\n        },\n\n        setFilterForm(state, formData) {\n            state.filterForm = formData;\n        },\n\n        resetFilterForm(state) {\n            state.filterForm = getFilterFormDefaults();\n        },\n\n        initEntityLoading(state, args: { request: Storage }) {\n            state[args.request.id] = state[args.request.id] || {};\n\n            state[args.request.id].httpStatus = null;\n            state[args.request.id].pagination = state[args.request.id].pagination || {};\n            state[args.request.id].pagination.loading = true;\n        },\n\n        setHttpStatus(state: Store<any>, args: { request: Storage, status: number }) {\n            state[args.request.id] = state[args.request.id] || {};\n\n            state[args.request.id].id = args.request.id;\n            state[args.request.id].httpStatus = args.status;\n            state[args.request.id].pagination = state[args.request.id].pagination || {};\n            state[args.request.id].pagination.loading = false;\n        },\n\n        setEntity(state: Store<any>, args: { request: Storage, response: AxiosResponse }) {\n            state[args.request.id] = state[args.request.id] || {};\n\n            state[args.request.id].id = args.request.id;\n            state[args.request.id].httpStatus = args.response.status;\n            state[args.request.id].pagination = args.response.data.pagination;\n            state[args.request.id].pagination.loading = false;\n\n            const items = args.request.addMore\n                ? [...state[args.request.id].items, ...args.response.data.data]\n                : args.response.data.data;\n\n            state[args.request.id].items = items;\n        },\n    },\n};\n","import { StatusCodes } from 'http-status-codes';\nimport { uniq } from 'lodash-es';\nimport { ActionContext } from 'vuex';\nimport { ProductAPIQueryBuilder } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport { LOCALE_DEFAULT } from '@model/const/locales';\nimport type { SSRContext } from '@model/ssr/context';\nimport type { AugmentedStore } from '@model/vue-store/augmented-store';\nimport eventUtils from '@utils/events.js';\nimport { Logger } from '@utils/logger';\nimport type { RawAxiosRequestConfig } from 'axios';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        eventsFeed: {\n            items: [],\n        },\n    }),\n\n    getters: {\n        getEventCards: (state: any) => (events: any, translations: any, locale = LOCALE_DEFAULT) => {\n            const { items } = state.eventsFeed;\n            return items.map((item: any, i: number) => {\n                const eventDetails = eventUtils.getEventCardFields(item, translations, { locale });\n                return {\n                    ...eventDetails,\n                    theme: 'main',\n                    link: `//acronis.events${eventDetails.link}`,\n                    image: eventDetails.imageId || events.eventImages[i % events.eventImages.length],\n                };\n            });\n        },\n    },\n\n    actions: {\n        async getFeed(this: AugmentedStore, store: ActionContext<any, any>, args: { limit: number, locale: string }) {\n            // ==== Init vars\n            const storeID = 'eventsFeed';\n            const locale = args.locale;\n\n            const allLocaleMappings = await this.$context.Synced.slicesData.query(\n                'events-locale-mappings',\n                LOCALE_DEFAULT,\n            );\n\n            if (!allLocaleMappings) return;\n\n            const currentLocaleMappings = allLocaleMappings[locale] as any;\n\n            // Calc countries list\n            let countries = [];\n            {\n                const groupsIds: number[] = currentLocaleMappings?.countryGroups ?? [];\n\n                const groupsPromises = groupsIds.map(\n                    (groupID: number) => this.$context.Synced.countryGroups.query(groupID.toString()),\n                );\n                const groups = await Promise.all(groupsPromises);\n\n                const grouped = groups\n                    .flatMap((group) => group.countries)\n                    .map((country) => country.id);\n\n                const flat = currentLocaleMappings?.countries ?? [];\n\n                countries = uniq([...grouped, ...flat]);\n            }\n\n            if (!countries.length) return;\n\n            // ==== Setup client\n            const client = getAPIProduct(this.$context as unknown as SSRContext);\n\n            const optsDefault: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                timeout: typeof window !== 'undefined' ? 30000 : 6000,\n                method: 'GET',\n                url: '/api/events/events/',\n            };\n\n            // ==== Request cards\n            let items = [];\n\n            {\n                const req = new ProductAPIQueryBuilder(storeID)\n                    .setCustomParam('has-occurrences', { from: new Date().toISOString() })\n                    .setCustomParam('has', { countries })\n                    .setCustomParam('process-macros', '1')\n                    .addMatchesAny('is_on_demand', '<>', '1')\n                    .addSort('is_featured', 'desc')\n                    .addSort('dynamic_next_occurrence', 'asc')\n                    .setPaginate(1, args.limit)\n                    .toObject();\n\n                const opts = { ...optsDefault, params: req.params };\n\n                try {\n                    const resp = await client.request(opts);\n                    items = [...resp.data.data];\n                } catch (error) {\n                    Logger.error({ error });\n                    return;\n                }\n            }\n\n            if (items.length === args.limit) {\n                store.commit('setFeedItems', items);\n                return;\n            }\n\n            {\n                const req = new ProductAPIQueryBuilder(storeID)\n                    .setCustomParam('has', { countries })\n                    .addMatchesAny('is_on_demand', '=', '1')\n                    .addMatchesAll('is_for_partners', '<>', '1')\n                    .setCustomParam('process-macros', '1')\n                    .addSort('is_featured', 'desc')\n                    .addSort('dynamic_last_occurrence', 'desc')\n                    .setPaginate(1, args.limit - items.length)\n                    .toObject();\n\n                const opts = { ...optsDefault, params: req.params };\n\n                try {\n                    const resp = await client.request(opts);\n                    items = [...items, ...resp.data.data];\n                } catch (error) {\n                    Logger.error({ error });\n                    return;\n                }\n            }\n\n            store.commit('setFeedItems', items);\n        },\n    },\n\n    mutations: {\n        setFeedItems(state: any, items: any) {\n            state.eventsFeed = { items };\n        },\n    },\n};\n","import { RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport getAPIService from '@api/service';\nimport { ServiceAPIError } from '@model/http/service-api-error';\nimport { Logger } from '@utils/logger';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({}),\n\n    actions: {\n        async doExpressSignupRequest(store: never, data: Record<string, any>) {\n            const client = getAPIService(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 30 * 1000,\n                validateStatus: () => true,\n                method: 'POST',\n                url: '/svc/v1/marketing/forms/leads',\n                data,\n            };\n\n            const response = await client.request(cfg);\n\n            if (response.status as StatusCodes !== StatusCodes.OK) {\n                Logger.error({ error: response });\n                throw ServiceAPIError.FromAxiosResponse(response);\n            }\n\n            return response.data;\n        },\n    },\n};\n","import axios from 'axios';\nimport { Logger } from '@utils/logger';\nimport { getDataFromPocket } from '@utils/pocket';\n\n// NB: always use production instance here; staging can't detect your IP because it's internal\nconst API_ENDPOINT = 'https://websiteapi.acronis.com/geo/location/v1/ip/geolocation';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        location: null,\n        showLocaleSelector: false,\n        requestedLocale: null,\n        desiredLocale: null,\n        finalLocale: null,\n        isLanguageAware: false,\n        language: null,\n    }),\n\n    actions: {\n        async getGeoLocation(store) {\n            try {\n                if (store.state.location) {\n                    return;\n                }\n\n                const fromPocket = getDataFromPocket('geo', false);\n\n                if (fromPocket) {\n                    // NB: don't address `.data` here; pocket uses `fetch()`\n                    store.commit('setGeolocation', fromPocket);\n                    return;\n                }\n\n                const fromApi = await axios.get(API_ENDPOINT);\n\n                if (!fromApi.data) {\n                    throw new Error('Error: getGeoLocation');\n                }\n\n                store.commit('setGeolocation', fromApi.data);\n            } catch (error) {\n                Logger.error({ error });\n            }\n        },\n\n        updateRequestedLocale(store, locale) {\n            store.commit('setRequestedLocale', locale);\n        },\n\n        updateDesiredLocale(store, locale) {\n            store.commit('setDesiredLocale', locale);\n        },\n\n        updateFinalLocale(store, locale) {\n            store.commit('setFinalLocale', locale);\n        },\n\n        updateIsLanguageAwareFlag(store, flag) {\n            store.commit('setIsLanguageAware', flag);\n        },\n\n        updateLanguage(store, lang) {\n            store.commit('setLanguage', lang);\n        },\n    },\n\n    mutations: {\n        setGeolocation(state, location) {\n            state.location = location;\n        },\n\n        setRequestedLocale(state, locale) {\n            state.requestedLocale = locale;\n        },\n\n        setDesiredLocale(state, locale) {\n            state.desiredLocale = locale;\n        },\n\n        setFinalLocale(state, locale) {\n            state.finalLocale = locale;\n        },\n\n        setIsLanguageAware(state, flag) {\n            state.isLanguageAware = flag;\n        },\n\n        setLanguage(state, lang) {\n            state.language = lang;\n        },\n    },\n};\n","import { AxiosResponse, RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport { ActionContext, Store } from 'vuex';\nimport getAPIProduct from '@api/product';\nimport { HttpRejection } from '@model/http/rejection';\nimport { Logger } from '@utils/logger';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        page: {},\n    }),\n\n    actions: {\n        async getEntity(store: ActionContext<any, any>, args: { request: Storage, httpRejectEmptyState: boolean }) {\n            const request = args.request;\n            const client = getAPIProduct(this.$context);\n\n            const opts: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                timeout: typeof window !== 'undefined' ? 30000 : 6000,\n                method: 'GET',\n                url: request.entityPath,\n                params: request.params,\n            };\n\n            try {\n                const response = await client.request(opts);\n                store.commit('setEntity', { request, response });\n            } catch (error) {\n                Logger.error({ error });\n                const httpStatus = error.status || StatusCodes.GATEWAY_TIMEOUT;\n                const message = error.message || 'Premature rendering stop';\n                throw new HttpRejection(message, httpStatus);\n            }\n        },\n    },\n\n    mutations: {\n        setEntity(state: Store<any>, args: { request: Storage, response: AxiosResponse }) {\n            state[args.request.id] = args.response.data.data[0];\n        },\n    },\n};\n","import { RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport { ActionContext } from 'vuex';\nimport { ProductAPIQueryBuilder } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport { Logger } from '@utils/logger';\n\nconst FIELDS_EXCEPT = [\n    'alias',\n    'created_at',\n    'created_by',\n    'id',\n    'updated_at',\n];\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        data: [],\n    }),\n\n    actions: {\n        async getList(store: ActionContext<any, any>, args: any) {\n            const { cleverbridgeIDs, currency, locale, paginate } = args;\n\n            if (!cleverbridgeIDs.filter(Number).length) return;\n\n            const payload = new ProductAPIQueryBuilder('licenses')\n                .addMatchesAll('locale', '=', locale)\n                .addMatchesAll('currency', '=', currency)\n                .addMatchesAll('cleverbridge_id', 'in', cleverbridgeIDs)\n                .setCustomParam('process-macros', '1')\n                .setOutputExcept(FIELDS_EXCEPT)\n                .setPaginate(paginate.number, paginate.size)\n                .toObject();\n\n            const options: RawAxiosRequestConfig = {\n                method: 'GET',\n                params: payload.params,\n                url: '/api/finance/licenses',\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n            };\n\n            try {\n                const licenses = await getAPIProduct(this.$context).request(options);\n                store.commit('setAll', licenses.data.data);\n            } catch (error) {\n                Logger.error({ error });\n            }\n        },\n    },\n\n    mutations: {\n        setAll(state: any, licenses = []) {\n            state.data = [...state.data, ...licenses];\n        },\n    },\n};\n","import type { AugmentedStore } from '@model/vue-store/augmented-store';\nimport type { ActionContext } from 'vuex';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        locale: {},\n        locales: [],\n    }),\n\n    actions: {\n        async getLocaleData(this: AugmentedStore, store: ActionContext<any, any>, args: { locale: string }) {\n            if (!this.$context.Synced?.locales) return;\n            const map = await this.$context.Synced.locales.getMap();\n            const localeData = map.get(args.locale);\n            store.commit('setLocale', localeData);\n        },\n\n        async getAll(this: AugmentedStore, store: ActionContext<any, any>) {\n            if (!this.$context.Synced?.locales) return;\n            const res = await this.$context.Synced.locales.getList();\n            store.commit('setLocales', res);\n        },\n    },\n\n    mutations: {\n        setLocale(state: any, locale: Record<string, any>) {\n            state.locale = locale;\n        },\n\n        setLocales(state: any, locales: any) {\n            state.locales = locales;\n        },\n    },\n};\n","import { StatusCodes } from 'http-status-codes';\nimport { Storage } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport { Logger } from '@utils/logger';\nimport type { AxiosResponse, RawAxiosRequestConfig } from 'axios';\nimport type { ActionContext, Store } from 'vuex';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        httpStatus: 0,\n        page: null,\n        audiences: null,\n        types: null,\n        loading: false,\n    }),\n\n    actions: {\n        async getEntity(store: ActionContext<any, any>, args: { request: Storage }) {\n            const request = args.request;\n\n            const client = getAPIProduct(this.$context);\n\n            const opts: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                timeout: typeof window !== 'undefined' ? 30000 : 6000,\n                method: 'GET',\n                url: request.entityPath,\n                params: request.params,\n            };\n\n            try {\n                const response = await client.request(opts);\n                store.commit('setEntity', { request, response });\n            } catch (error) {\n                Logger.error({ error });\n                store.commit('setHttpStatus', { request, status: error.status || StatusCodes.GATEWAY_TIMEOUT });\n            }\n        },\n        async getPage(store: ActionContext<any, any>, args: { request: Storage }) {\n            const request = args.request;\n\n            const client = getAPIProduct(this.$context);\n\n            const opts: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                timeout: typeof window !== 'undefined' ? 30000 : 6000,\n                method: 'GET',\n                url: request.entityPath,\n                params: request.params,\n            };\n\n            try {\n                const { data, status } = await client.request(opts);\n\n                if (!data?.data) {\n                    throw new Error('Invalid page data');\n                }\n\n                let pageData: object;\n                // normal case\n                if (Array.isArray(data.data)) {\n                    pageData = data.data[0];\n                } else { // cached preview case\n                    try {\n                        pageData = JSON.parse(data.data);\n                    } catch {\n                        throw new Error('Invalid page data');\n                    }\n                }\n\n                store.commit('setHttpStatus', status);\n                store.commit('setPage', pageData);\n            } catch (error) {\n                Logger.error({ error });\n                store.commit('setHttpStatus', { request, status: error.status || StatusCodes.GATEWAY_TIMEOUT });\n            }\n        },\n        setLoading(store: ActionContext<string, any>, payload: boolean) {\n            store.commit('changeLoading', payload);\n        },\n        // NB: usage is strongly discouraged. Only needed for resolving `dataFrom` in container\n        modifyPageBody(store: ActionContext<string, any>, payload: any[]) {\n            store.commit('modifyPageBody', payload);\n        },\n    },\n\n    mutations: {\n        setHttpStatus(state: any, status: number) {\n            state.httpStatus = status;\n        },\n\n        setPage(state: any, newPageData: object) {\n            const processedPageData: any = { ...newPageData };\n            const propsToParse = ['meta', 'body', 'schema', 'settings'];\n\n            propsToParse.forEach((propName) => {\n                if (typeof processedPageData[propName] === 'string') {\n                    try {\n                        processedPageData[propName] = JSON.parse(processedPageData[propName]);\n                    } catch {\n                        processedPageData[propName] = null;\n                    }\n                }\n            });\n\n            state.page = processedPageData;\n        },\n\n        changeLoading(state, payload: boolean) {\n            state.loading = payload;\n        },\n\n        setEntity(state: Store<any>, args: { request: Storage, response: AxiosResponse }) {\n            state[args.request.id] = state[args.request.id] || {};\n\n            state[args.request.id].id = args.request.id;\n            state[args.request.id].httpStatus = args.response.status;\n\n            if (args.response.data?.pagination) {\n                state[args.request.id].pagination = args.response.data.pagination;\n                state[args.request.id].pagination.loading = false;\n            }\n\n            if (Array.isArray(args.response.data.data)) {\n                state[args.request.id].items = args.request.addMore\n                    ? [...state[args.request.id].items, ...args.response.data.data]\n                    : args.response.data.data;\n            } else {\n                state[args.request.id].data = args.response.data.data;\n            }\n        },\n\n        modifyPageBody(state: any, payload: any[]) {\n            state.page.body = payload;\n        },\n    },\n};\n","import axios, { RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport getAPIService from '@api/service';\nimport { Logger } from '@utils/logger';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({}),\n\n    actions: {\n        async sendContactUsForm(store: never, data: Record<string, any>): Promise<any> {\n            const client = getAPIService(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 60 * 1000,\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                method: 'POST',\n                url: '/svc/v1/partners-portal/contact-us/case',\n                data,\n            };\n\n            try {\n                const response = await client.request(cfg);\n                return response.data;\n            } catch (error) {\n                Logger.error({ error });\n                return null;\n            }\n        },\n\n        async loadFormData(store: never, token: string): Promise<any> {\n            const client = axios.create();\n\n            const url = `https://www.acronis.com/en-us/api/v1/lead/${token}`;\n\n            try {\n                const response = await client.get(url);\n                return response.data;\n            } catch (error) {\n                Logger.error({ error });\n                return null;\n            }\n        },\n\n        async checkSerialNumber(store: never, data: Record<string, any>): Promise<any> {\n            const client = getAPIService(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 60 * 1000,\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                method: 'POST',\n                url: '/svc/v1/grouplogic/entitlement-check',\n                withCredentials: false,\n                data,\n            };\n\n            try {\n                const response = await client.request(cfg);\n                return response.data;\n            } catch (error) {\n                Logger.error({ error });\n                return null;\n            }\n        },\n    },\n};\n","import { RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport getAPIService from '@api/service';\nimport { Logger } from '@utils/logger';\n\ninterface LocatorRequest {\n    type?: 'partners' | 'distributors';\n    country?: string;\n}\n\nexport default {\n    namespaced: true,\n\n    state: () => ({}),\n\n    actions: {\n        async getCountryList(store: never, locator: LocatorRequest = {}): Promise<any> {\n            const client = getAPIService(this.$context);\n\n            const options: RawAxiosRequestConfig = {\n                timeout: 60 * 1000,\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                method: 'GET',\n                url: `/svc/v1/partners-portal/locator/${locator.type || 'partners'}/countries`,\n            };\n\n            try {\n                const response = await client.request(options);\n                return response.data;\n            } catch (error) {\n                Logger.error({ error });\n                return null;\n            }\n        },\n\n        async getCompanyList(store: never, locator: LocatorRequest = {}): Promise<any> {\n            const client = getAPIService(this.$context);\n\n            const options: RawAxiosRequestConfig = {\n                timeout: 60 * 1000,\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                method: 'GET',\n                url: `/svc/v1/partners-portal/locator/${locator.type || 'partners'}/partners`,\n                params: { country: locator.country || '' },\n            };\n\n            try {\n                const response = await client.request(options);\n                return response.data;\n            } catch (error) {\n                Logger.error({ error });\n                return null;\n            }\n        },\n    },\n};\n","import { RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport { ProductAPIQueryBuilder } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport { convertToConsumableObjects } from '@utils/api-response';\nimport { Logger } from '@utils/logger';\n\nconst FIELDS_PRIVATE = [\n    'created_at',\n    'updated_at',\n    'creator',\n    'creator_id',\n    'page_audiences',\n    'page_types',\n    'products',\n];\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        data: [],\n    }),\n\n    actions: {\n        async getAll(store, args) {\n            const locale = args.locale;\n            const slug = args.slug.replace(/\\/$/, '');\n            const siteID = args.siteID;\n\n            const now = new Date().toISOString();\n\n            const req = new ProductAPIQueryBuilder('popups')\n                .setCustomParam('page', { locale, slug, website_id: siteID })\n                .addMatchesAll('is_active', '=', '1')\n                .addMatchesAll('is_active_since', '<=', now)\n                .addMatchesAll('is_active_until', '>=', now)\n                .setCustomParam('process-macros', '1')\n                .addSort('created_at', 'desc')\n                .addSort('id', 'desc');\n\n            const options: RawAxiosRequestConfig = {\n                method: 'GET',\n                url: '/api/core/popups',\n                timeout: 2000,\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                params: req.toObject().params,\n            };\n\n            try {\n                const response = await getAPIProduct(this.$context).request(options);\n\n                // Convert response to consumable popup objects\n                const popups = convertToConsumableObjects(response.data.data, FIELDS_PRIVATE);\n                store.commit('setAll', popups);\n            } catch (error) {\n                Logger.error({ error });\n            }\n        },\n    },\n\n    mutations: {\n        setAll(state, popups = []) {\n            state.data = popups;\n        },\n    },\n};\n","import { AxiosResponse, RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport qs from 'qs';\nimport { ActionContext, Store } from 'vuex';\nimport { ProductAPIQueryBuilder, Storage } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport { PR_MAX_RELEASES_PEG_PAGE } from '@model/const/press-releases';\nimport { HttpRejection } from '@model/http/rejection';\nimport { getAvailableLocales } from '@utils/locales';\nimport { Logger } from '@utils/logger';\n\nexport default {\n    namespaced: true,\n\n    state: () => {\n        const shape = () => ({\n            httpStatus: 0,\n            pagination: {},\n            items: [],\n            data: null,\n        });\n\n        return {\n            pressReleases: shape(),\n            pressRelease: shape(),\n            pressReleaseAuthor: shape(),\n            availableLocales: shape(),\n        };\n    },\n\n    getters: {\n        getAvailableLocales: (state: any) => (currentLocale: string) => {\n            interface LocaleItem {\n                locale: string;\n                published_at: string;\n            }\n\n            const locales = getAvailableLocales(state.availableLocales.items, currentLocale);\n\n            return state.availableLocales.items\n                .filter((item: LocaleItem) => locales.includes(item.locale))\n                .filter(Boolean)\n                .map((item: LocaleItem) => ({\n                    locale: item.locale,\n                    year: parseInt(item.published_at, 10),\n                }));\n        },\n    },\n\n    actions: {\n        async getEntity(store: ActionContext<any, any>, args: { request: Storage, httpRejectEmptyState: boolean }) {\n            const request = args.request;\n            const httpRejectEmptyState = args.httpRejectEmptyState === undefined ? true : args.httpRejectEmptyState;\n\n            const client = getAPIProduct(this.$context);\n\n            const opts: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                timeout: typeof window !== 'undefined' ? 30000 : 6000,\n                maxRedirects: 0,\n                paramsSerializer: {\n                    serialize: (params) => qs.stringify(params, { encodeValuesOnly: true }),\n                },\n                method: 'GET',\n                url: request.entityPath,\n                params: request.params,\n            };\n\n            try {\n                const response = await client.request(opts);\n                store.commit('setEntity', { request, response });\n\n                if (httpRejectEmptyState && !store.state[request.id]?.items?.length) {\n                    throw new HttpRejection('Premature rendering stop', StatusCodes.NOT_FOUND);\n                }\n            } catch (error) {\n                Logger.error({ error });\n\n                const httpStatus = error.status || error.httpStatusCode || error.response?.status || StatusCodes.GATEWAY_TIMEOUT;\n                const message = error.message || 'Premature rendering stop';\n\n                store.commit('setHttpStatus', { request, status: httpStatus });\n\n                throw new HttpRejection(message, httpStatus);\n            }\n        },\n\n        async applyHomeFilters(store: ActionContext<any, any>, { filters, locale }) {\n            const page = filters.page || 1;\n            const queryBuilder: ProductAPIQueryBuilder = new ProductAPIQueryBuilder('pressReleases')\n                .setEntityPath('/api/press-releases/press-releases/')\n                .setLocales([locale])\n                .setCustomParam('process-macros', '1')\n                .addSort('translation.published_at', 'desc')\n                .setPaginate(page, PR_MAX_RELEASES_PEG_PAGE);\n\n            if (filters.year) {\n                queryBuilder.addMatchesAll('translation.published_at', 'like', `${filters.year}%`);\n            }\n\n            const request = queryBuilder.toObject();\n\n            await store.dispatch('getEntity', { request });\n        },\n    },\n\n    mutations: {\n        setHttpStatus(state: Store<any>, args: { request: Storage, status: number }) {\n            state[args.request.id] = state[args.request.id] || {};\n\n            state[args.request.id].httpStatus = args.status;\n            state[args.request.id].pagination = state[args.request.id].pagination || {};\n            state[args.request.id].pagination.loading = false;\n        },\n\n        setEntity(state: Store<any>, args: { request: Storage, response: AxiosResponse }) {\n            state[args.request.id] = state[args.request.id] || {};\n\n            state[args.request.id].httpStatus = args.response.status;\n\n            if (args.response.data?.pagination) {\n                state[args.request.id].pagination = args.response.data.pagination;\n                state[args.request.id].pagination.loading = false;\n            }\n\n            if (Array.isArray(args.response.data.data)) {\n                state[args.request.id].items = args.request.addMore\n                    ? [...state[args.request.id].items, ...args.response.data.data]\n                    : args.response.data.data;\n            } else {\n                state[args.request.id].data = args.response.data.data;\n            }\n        },\n    },\n};\n","import { StatusCodes } from 'http-status-codes';\nimport { ProductAPIQueryBuilder } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport { getLanguageCodeFromLocale } from '@utils/languages';\nimport { Logger } from '@utils/logger';\nimport type { ActionContext } from 'vuex';\n\ninterface S {\n    feed: Record<string, string>[];\n}\n\nexport default {\n    namespaced: true,\n\n    state: (): S => ({\n        feed: [],\n    }),\n\n    actions: {\n        async getFeed(store: ActionContext<S, any>, args: { limit: number, locale: string }) {\n            const releasesRequest = new ProductAPIQueryBuilder('pressReleases')\n                .setEntityPath('/api/press-releases/press-releases/')\n                .setLocales([args.locale])\n                .setCustomParam('process-macros', '1')\n                .setOutputOnly(['id', 'slug', 'title', 'published_at'])\n                .addSort('translation.published_at', 'desc')\n                .setPaginate(1, args.limit)\n                .toObject();\n\n            const client = getAPIProduct(this.$context);\n\n            try {\n                const response = await client.request({\n                    url: releasesRequest.entityPath,\n                    params: releasesRequest.params,\n                });\n\n                if (response.status as StatusCodes !== StatusCodes.OK) {\n                    return;\n                }\n\n                const processed = response.data.data.map((item: Record<string, any>) => {\n                    const publishedAt = new Date(item.published_at);\n                    const year = publishedAt.getFullYear();\n\n                    return {\n                        ...item,\n                        link: `/${getLanguageCodeFromLocale(args.locale)}/pr/${year}/${item.slug}/`,\n                    };\n                });\n\n                store.commit('setFeed', processed);\n            } catch (error) {\n                Logger.error({ error });\n            }\n        },\n    },\n\n    mutations: {\n        setFeed(state: S, feed: S['feed']) {\n            state.feed = feed;\n        },\n    },\n};\n","import { RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport qs from 'qs';\nimport { ActionContext } from 'vuex';\nimport { ProductAPIQueryBuilder } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport getAPIService from '@api/service';\nimport { LOCALE_DEFAULT } from '@model/const/locales';\nimport { Logger } from '@utils/logger';\n\nconst PAGINATE_SIZE = 50;\n\nasync function getProductsListPage(context: any, payload: any) {\n    const options: RawAxiosRequestConfig = {\n        method: 'GET',\n        params: payload.params,\n        url: '/api/core/products/',\n        paramsSerializer: { serialize: (params) => qs.stringify(params, { encodeValuesOnly: true }) },\n        validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n    };\n\n    try {\n        const response = await getAPIProduct(context).request(options);\n        return response.data;\n    } catch (error) {\n        Logger.error({ error });\n        return {};\n    }\n}\n\nfunction mapProduct(product) {\n    return {\n        ...product,\n        parameters: JSON.parse(product.parameters),\n    };\n}\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        items: {},\n        g2rating: 0,\n        g2reviews: [],\n        g2ratingByProductId: {},\n        g2reviewsByProductId: {},\n    }),\n\n    actions: {\n        async getProducts(store: ActionContext<any, any>, locale: string) {\n            let currentPage = 1;\n            let totalPages = 1;\n\n            while (currentPage <= totalPages) {\n                const currentLocale = locale || LOCALE_DEFAULT;\n                const payload = new ProductAPIQueryBuilder('products')\n                    .setLocales([currentLocale])\n                    .setPaginate(currentPage, PAGINATE_SIZE)\n                    .setCustomParam('process-macros', '1')\n                    .toObject();\n\n                // eslint-disable-next-line no-await-in-loop\n                const res = await getProductsListPage(this.$context, payload);\n\n                res.data\n                    .map(mapProduct)\n                    .forEach((product) => store.commit('setProduct', product));\n\n                totalPages = res.pagination.pages_total;\n\n                currentPage++;\n            }\n        },\n\n        async getG2ProductRating(store: ActionContext<any, any>, productId: string) {\n            if (!productId) return 0;\n\n            const client = getAPIService(this.$context);\n            const options: RawAxiosRequestConfig = {\n                method: 'GET',\n                url: `/svc/v1/g2/products/${productId}`,\n                paramsSerializer: { serialize: (params) => qs.stringify(params, { encodeValuesOnly: true }) },\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n            };\n\n            try {\n                const response = await client.request(options);\n                const result = response.data.data.rating;\n\n                store.commit('setG2Rating', { productId, rating: result });\n\n                return result;\n            } catch (error) {\n                Logger.error({ error });\n                return 0;\n            }\n        },\n\n        async getG2ProductReviews(store: ActionContext<any, any>, productId: string) {\n            if (!productId) return [];\n\n            const client = getAPIService(this.$context);\n            const options: RawAxiosRequestConfig = {\n                method: 'GET',\n                url: `/svc/v1/g2/products/${productId}/reviews`,\n                paramsSerializer: { serialize: (params) => qs.stringify(params, { encodeValuesOnly: true }) },\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n            };\n\n            try {\n                const response = await client.request(options);\n                const result = response.data.data;\n\n                store.commit('setG2Reviews', { productId, reviews: result });\n\n                return result;\n            } catch (error) {\n                Logger.error({ error });\n                return [];\n            }\n        },\n    },\n\n    mutations: {\n        setProduct(state, product) {\n            state.items[product.id] = product;\n        },\n        setG2Rating(state, payload) {\n            const isPayloadObject = payload !== null && typeof payload === 'object';\n            const rating = isPayloadObject ? payload.rating : payload;\n            const productId = isPayloadObject ? payload.productId : null;\n\n            state.g2rating = rating;\n\n            if (productId) {\n                state.g2ratingByProductId[productId] = rating;\n            }\n        },\n        setG2Reviews(state, payload) {\n            const isPayloadObject = payload !== null && typeof payload === 'object';\n            const reviews = isPayloadObject ? payload.reviews : payload;\n            const productId = isPayloadObject ? payload.productId : null;\n\n            state.g2reviews = reviews;\n\n            if (productId) {\n                state.g2reviewsByProductId[productId] = reviews;\n            }\n        },\n    },\n};\n","import { RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport { ActionContext } from 'vuex';\nimport { ProductAPIQueryBuilder } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport { HttpRejection } from '@model/http/rejection';\nimport { Logger } from '@utils/logger';\n\nconst FIELDS_EXCEPT = [\n    'created_by',\n    'created_at',\n    'updated_at',\n    'is_active',\n    'is_active_since',\n    'is_active_until',\n    'locale',\n    'name',\n    'product',\n];\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        data: [],\n    }),\n\n    actions: {\n\n        async getPromotionTranslation(store: ActionContext<string, any>, args: { locale: string, id: string, discount: string }) {\n            const client = getAPIProduct(this.$context);\n\n            const request = new ProductAPIQueryBuilder('translation')\n                .setEntityPath('/api/finance/promotions/translations/')\n                .addMatchesAll('locale', '=', args.locale)\n                .addMatchesAll('promotion_id', '=', args.id)\n                .setOutputExcept(['id', ...FIELDS_EXCEPT])\n                .toObject();\n\n            const cfg: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                timeout: typeof window !== 'undefined' ? 30000 : 6000,\n                method: 'GET',\n                url: request.entityPath,\n                params: request.params,\n            };\n\n            try {\n                const response = await client.request(cfg);\n                const translation = response?.data?.data?.[0] || {};\n\n                if (args.discount) {\n                    Object.entries(translation).forEach(([key, value]) => {\n                        if (typeof value !== 'string') return;\n                        translation[key] = value.replaceAll('XX', args.discount);\n                    });\n                }\n\n                store.commit('setPromotionTranslation', translation);\n            } catch (error) {\n                Logger.error({ error });\n                const httpStatus = error.status || StatusCodes.GATEWAY_TIMEOUT;\n                const message = error.message || 'Premature rendering stop';\n                throw new HttpRejection(message, httpStatus);\n            }\n        },\n\n        async getPromotions(store: ActionContext<string, any>, locale: string) {\n            const now = new Date().toISOString();\n\n            const req = new ProductAPIQueryBuilder('promotions')\n                .addMatchesAll('is_active', '=', '1')\n                .addMatchesAll('is_active_since', '<=', now)\n                .addMatchesAll('is_active_until', '>=', now)\n                .setCustomParam('locales', [locale])\n                .setOutputExcept(FIELDS_EXCEPT)\n                .addSort('created_at', 'desc')\n                .addSort('id', 'desc');\n\n            const options: RawAxiosRequestConfig = {\n                method: 'GET',\n                url: '/api/finance/promotions/',\n                timeout: 2000,\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                params: req.toObject().params,\n            };\n\n            try {\n                const response = await getAPIProduct(this.$context).request(options);\n                const promotions = response.data.data\n                    .map((promotion: any) => {\n                        const list = promotion.discounts || '[]';\n                        const discounts = JSON.parse(list).map((item: any) => ({\n                            list: item?.productList?.products.map((product: any) => product.id),\n                            discount: item?.discount?.pricePercentageValues?.[0]?.value || 0,\n                        }));\n                        return {\n                            ...promotion,\n                            discounts,\n                            license_ids: discounts.map((item: any) => item.list).flat(),\n                            discount: Math.max(0, ...discounts.map((item: any) => item.discount)),\n                        };\n                    });\n\n                store.commit('setPromotions', promotions);\n\n                const promises = promotions.map((item: any) => {\n                    const id = item.id;\n                    const discount = item.discount;\n                    return store.dispatch('getPromotionTranslation', { locale, id, discount });\n                });\n                await Promise.all(promises);\n            } catch (error) {\n                Logger.error({ error });\n            }\n        },\n    },\n\n    mutations: {\n        setPromotions(state: any, promotions = []) {\n            state.data = promotions;\n        },\n        setPromotionTranslation(state: any, translation: any) {\n            state.data = state.data.map((item: any) => {\n                if (item.id !== translation.promotion_id) return item;\n                return { ...item, promoSettings: translation };\n            });\n        },\n    },\n};\n","/* eslint-disable @typescript-eslint/no-unsafe-enum-comparison */\nimport { RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport { ActionContext, Store } from 'vuex';\nimport getAPIService from '@api/service';\nimport { LOCALE_DEFAULT } from '@model/const/locales';\nimport { Logger } from '@utils/logger';\n\ninterface Feed {\n    pressReleases: Record<string, string>[];\n}\n\ninterface S {\n    feed: Feed;\n}\n\nexport default {\n    namespaced: true,\n\n    state: (): S => ({\n        feed: {\n            pressReleases: [],\n        },\n    }),\n\n    actions: {\n        async getFeed(store: ActionContext<S, any>, args: { locale: string }) {\n            const client = getAPIService(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 5000,\n                method: 'GET',\n            };\n\n            try {\n                cfg.url = `/svc/v1/acronis-publications/feed/${args.locale}`;\n                cfg.validateStatus = (status: number) => [StatusCodes.OK, StatusCodes.NOT_FOUND].includes(status);\n                const response = await client.request(cfg);\n                if (response.status === StatusCodes.OK) {\n                    store.commit('setFeed', response.data.data);\n                    return;\n                }\n            } catch (error) {\n                Logger.error({ error });\n                return;\n            }\n\n            // Fallback to default locale if localized is not supported\n            try {\n                cfg.url = `/svc/v1/acronis-publications/feed/${LOCALE_DEFAULT}`;\n                cfg.validateStatus = (status: number) => status === StatusCodes.OK;\n                const response = await client.request(cfg);\n                store.commit('setFeed', response.data.data);\n            } catch (error) {\n                Logger.error({ error });\n            }\n        },\n    },\n\n    mutations: {\n        setFeed(state: Store<S>, feed: Feed) {\n            state.feed = feed;\n        },\n    },\n};\n","import { AxiosResponse, RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport { ActionContext, Store } from 'vuex';\nimport { Storage } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport { getAvailableLocales } from '@utils/locales';\nimport { Logger } from '@utils/logger';\nimport { generateSearchQuery } from '@utils/resource-center';\n\nexport default {\n    namespaced: true,\n\n    state: () => {\n        const shape = () => ({\n            id: '',\n            httpStatus: 0,\n            pagination: {},\n            items: [],\n            data: null,\n        });\n\n        return {\n            resource: shape(),\n            resources: shape(),\n            tags: shape(),\n            types: shape(),\n            audiences: shape(),\n            industries: shape(),\n            banners: shape(),\n            cta: shape(),\n            ctaData: shape(),\n            locales: shape(),\n            featuredResources: shape(),\n            caseStudyResources: shape(),\n            analystReportsResources: shape(),\n            availableLocales: shape(),\n        };\n    },\n\n    getters: {\n        getAvailableLocales: (state) => (currentLocale) => getAvailableLocales(state.availableLocales.items, currentLocale),\n    },\n\n    actions: {\n        async getEntity(store: ActionContext<any, any>, args: { request: Storage }) {\n            const request = args.request;\n\n            const client = getAPIProduct(this.$context);\n\n            const opts: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                timeout: typeof window !== 'undefined' ? 30000 : 6000,\n                method: 'GET',\n                url: request.entityPath,\n                params: request.params,\n            };\n\n            try {\n                const response = await client.request(opts);\n                store.commit('setEntity', { request, response });\n            } catch (error) {\n                Logger.error({ error });\n                store.commit('setHttpStatus', { request, status: error.status || StatusCodes.GATEWAY_TIMEOUT });\n            }\n        },\n\n        async applySearchData(store: ActionContext<any, any>, { searchData, locale }) {\n            const request: Storage = generateSearchQuery(searchData, locale);\n            await store.dispatch('getEntity', { request });\n        },\n\n        async sendViewBeacon(_: never, args: { request: Storage }) {\n            const request = args.request;\n            const client = getAPIProduct(this.$context);\n\n            const opts: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.CREATED,\n                timeout: 30000,\n                method: 'POST',\n                url: request.entityPath,\n                params: request.params,\n            };\n\n            // This is a fire-n-forget action\n            try {\n                await client.request(opts);\n            } catch (error) {\n                Logger.error({ error });\n            }\n        },\n    },\n\n    mutations: {\n        setHttpStatus(state: Store<any>, args: { request: Storage, status: number }) {\n            state[args.request.id] = state[args.request.id] || {};\n\n            state[args.request.id].id = args.request.id;\n            state[args.request.id].httpStatus = args.status;\n            state[args.request.id].pagination = state[args.request.id].pagination || {};\n            state[args.request.id].pagination.loading = false;\n        },\n\n        setEntity(state: Store<any>, args: { request: Storage, response: AxiosResponse }) {\n            state[args.request.id] = state[args.request.id] || {};\n\n            state[args.request.id].id = args.request.id;\n            state[args.request.id].httpStatus = args.response.status;\n\n            if (args.response.data?.pagination) {\n                state[args.request.id].pagination = args.response.data.pagination;\n                state[args.request.id].pagination.loading = false;\n            }\n\n            if (Array.isArray(args.response.data.data)) {\n                state[args.request.id].items = args.request.addMore\n                    ? [...state[args.request.id].items, ...args.response.data.data]\n                    : args.response.data.data;\n            } else {\n                state[args.request.id].data = args.response.data.data;\n            }\n        },\n    },\n};\n","import { RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport { ProductAPIQueryBuilder } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport { convertToConsumableObjects } from '@utils/api-response';\nimport { Logger } from '@utils/logger';\n\nconst FIELDS_PRIVATE = [\n    'created_at',\n    'updated_at',\n    'creator',\n    'creator_id',\n    'page_audiences',\n    'page_types',\n    'products',\n];\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        data: [],\n    }),\n\n    actions: {\n        async getAll(store, args) {\n            const locale = args.locale;\n            const slug = args.slug.replace(/\\/$/, '');\n            const siteID = args.siteID;\n\n            const now = new Date().toISOString();\n\n            const req = new ProductAPIQueryBuilder('ribbon')\n                .setCustomParam('page', { locale, slug, website_id: siteID })\n                .addMatchesAll('is_active', '=', '1')\n                .addMatchesAll('is_active_since', '<=', now)\n                .addMatchesAll('is_active_until', '>=', now)\n                .addSort('created_at', 'desc')\n                .addSort('id', 'desc');\n\n            const options: RawAxiosRequestConfig = {\n                method: 'GET',\n                url: '/api/core/ribbons',\n                timeout: 2000,\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                params: req.toObject().params,\n            };\n\n            try {\n                const response = await getAPIProduct(this.$context).request(options);\n\n                // Convert response to consumable ribbons objects\n                const ribbons = convertToConsumableObjects(response.data.data, FIELDS_PRIVATE);\n                store.commit('setAll', ribbons);\n            } catch (error) {\n                Logger.error({ error });\n            }\n        },\n    },\n\n    mutations: {\n        setAll(state, ribbons = []) {\n            state.data = ribbons;\n        },\n    },\n};\n","import type { AugmentedStore } from '@model/vue-store/augmented-store';\n\nconst ROUTES_CONFIG_NAME = 'routes-config';\n\nexport default {\n    namespaced: true,\n\n    state: () => {\n        // WARN: empty state shape can cause reactivity issues on mutation\n        const shape = () => ({\n            items: [],\n        });\n\n        return {\n            config: shape(),\n        };\n    },\n\n    getters: {\n        getRoutesConfig(state: any) {\n            const config = state.config.items.find((item) => item.key === ROUTES_CONFIG_NAME) || {};\n            return config?.data || [];\n        },\n\n        getStaticConfigs(state: any) {\n            return state.config.items\n                .filter((item) => item.key !== ROUTES_CONFIG_NAME)\n                .map((item) => item.data);\n        },\n    },\n\n    actions: {\n        async getSyncedData(this: AugmentedStore, store, args) {\n            const { key, locale } = args;\n            const data = await this.$context.Synced.seoData.query(key, locale);\n            store.commit('setSyncedData', { key, data });\n        },\n    },\n\n    mutations: {\n        setSyncedData(state, data) {\n            state.config.items.push(data);\n        },\n    },\n};\n","import { RawAxiosRequestConfig, AxiosResponse } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport getAPIService from '@api/service';\nimport { Logger } from '@utils/logger';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({}),\n\n    actions: {\n        async board(store: never, boardID: string): Promise<AxiosResponse> {\n            const client = getAPIService(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 5000,\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                method: 'GET',\n                url: `/svc/v1/slapfive/board/${boardID}`,\n            };\n\n            try {\n                return await client.request(cfg);\n            } catch (error) {\n                Logger.error({ error });\n                return null;\n            }\n        },\n    },\n};\n","import { merge } from 'lodash-es';\nimport type { AugmentedStore } from '@model/vue-store/augmented-store';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        items: {},\n    }),\n\n    getters: {\n        getLocales(state) {\n            if (!state.items['s-locale-selector']) return [];\n            return state.items['s-locale-selector']?.columns?.flatMap(\n                (column) => column.regions.flatMap((region) => region.locales),\n            );\n        },\n    },\n\n    actions: {\n        async getSyncedData(this: AugmentedStore, store, args) {\n            const { slice, locale } = args;\n            const response = await this.$context.Synced.slicesData.query(slice, locale);\n            const translations = response?.translations || {};\n            const data = merge({}, response, translations);\n\n            return store.commit('setSyncedData', { slice, data });\n        },\n    },\n\n    mutations: {\n        setSyncedData(state, { slice, data }) {\n            state.items[slice] = data;\n        },\n    },\n};\n","import type { AugmentedStore } from '@model/vue-store/augmented-store';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        integrations: [],\n        integration: {},\n        categories: [],\n    }),\n\n    actions: {\n        async getIntegrations(this: AugmentedStore, store) {\n            const integrations = await this.$context.Synced.solutionsIntegrations.getList();\n            store.commit('setIntegrations', integrations);\n        },\n\n        async getIntegration(this: AugmentedStore, store, args) {\n            const map = await this.$context.Synced.solutionsIntegrations.getMap();\n            const integration = map.get(args.slug);\n            store.commit('setIntegration', integration);\n        },\n\n        async getCategories(this: AugmentedStore, store) {\n            const categories = await this.$context.Synced.solutionsCategories.getList();\n            store.commit('setCategories', categories);\n        },\n    },\n\n    mutations: {\n        setIntegrations(state, integrations) {\n            state.integrations = integrations;\n        },\n\n        setIntegration(state, integration) {\n            state.integration = integration;\n        },\n\n        setCategories(state, categories) {\n            state.categories = categories;\n        },\n    },\n};\n","import axios, { AxiosInstance, RawAxiosRequestConfig } from 'axios';\n\nconst getAPIAccount = (_context: any): AxiosInstance => {\n    const defaults: RawAxiosRequestConfig = {\n        timeout: 10000,\n        baseURL: 'https://account.acronis.com', // should it be configurable?\n        withCredentials: true,\n    };\n\n    const instance = axios.create(defaults);\n    // can wrap plugins here\n    return instance;\n};\n\nexport default getAPIAccount;\n","import { RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport getAPIAccount from '@api/account';\nimport getAPIService from '@api/service';\nimport { ServiceAPIError } from '@model/http/service-api-error';\nimport formUtils from '@utils/form.js';\nimport { Logger } from '@utils/logger';\n\n// TODO: for some reason every action here checks some particular HTTP statuses and log them. Why?\n// Shouldn't we just put them to `validateStatus`?\n// TODO: there's no timeouts handling in this module, because axios will THROW a real error in case of timeout exceeded\n\ninterface RecaptchaGuarded {\n    _recaptchaResponse?: string;\n}\n\ntype SubscribeRequest = Record<string, any> & RecaptchaGuarded;\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        queryStringData: {},\n    }),\n\n    actions: {\n        async sendLead(store: never, request: SubscribeRequest) {\n            // eslint-disable-next-line @typescript-eslint/naming-convention\n            const { _recaptchaResponse, actionURL, ...data } = request;\n\n            // WEB-44946\n            data.uit = formUtils.getSecondsOnPage();\n\n            const client = getAPIService(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 60 * 1000,\n                validateStatus: () => true,\n                method: 'POST',\n                headers: {},\n                url: actionURL || '/svc/v1/marketing/forms/leads',\n                data,\n            };\n\n            if (_recaptchaResponse) {\n                cfg.headers['X-GRecaptcha-Response'] = _recaptchaResponse;\n            }\n\n            const response = await client.request(cfg);\n\n            if (response.status as StatusCodes !== StatusCodes.OK) {\n                Logger.error({ error: response });\n                throw ServiceAPIError.FromAxiosResponse(response);\n            }\n\n            return response.data;\n        },\n\n        async accountRegister(store: never, data: Record<string, any>) {\n            const client = getAPIAccount(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 60 * 1000,\n                validateStatus: () => true,\n                method: 'POST',\n                url: '/v2/auth/register',\n                data,\n            };\n\n            // loggedStatuses: [200, 422]\n\n            const response = await client.request(cfg);\n            return response;\n        },\n\n        async accountLogin(store: never, data: Record<string, any>) {\n            const client = getAPIAccount(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 60 * 1000,\n                validateStatus: () => true,\n                method: 'POST',\n                url: '/v2/auth/login',\n                withCredentials: true,\n                data,\n            };\n\n            // loggedStatuses: [200, 401]\n\n            const response = await client.request(cfg);\n            return response;\n        },\n\n        async accountUpdate(store: never, data: Record<string, any>) {\n            const client = getAPIAccount(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 60 * 1000,\n                validateStatus: () => true,\n                method: 'PUT',\n                url: '/v2/account',\n                withCredentials: true,\n                data,\n            };\n\n            // loggedStatuses: !200\n\n            const response = await client.request(cfg);\n            return response;\n        },\n\n        async accountAgreement(store: never, data: Record<string, any>) {\n            const client = getAPIAccount(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 60 * 1000,\n                validateStatus: () => true,\n                method: 'PUT',\n                url: '/v2/account/agreement',\n                withCredentials: true,\n                data,\n            };\n\n            // loggedStatuses: !200\n\n            const response = await client.request(cfg);\n            return response;\n        },\n\n        async accountTrial(store: never, data: Record<string, any>) {\n            const client = getAPIAccount(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 60 * 1000,\n                validateStatus: () => true,\n                method: 'POST',\n                url: '/v2/products/trial',\n                withCredentials: true,\n                data,\n            };\n\n            // loggedStatuses: !200\n\n            const response = await client.request(cfg);\n            return response;\n        },\n\n        async getOptInStatus(store: never, email: string) {\n            const client = getAPIService(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 30 * 1000,\n                validateStatus: () => true,\n                method: 'GET',\n                url: '/svc/v1/marketing/forms/leads/opt-in',\n                params: {\n                    email,\n                },\n            };\n\n            const response = await client.request(cfg);\n\n            if (response.status as StatusCodes !== StatusCodes.OK) {\n                Logger.error({ error: response });\n                throw ServiceAPIError.FromAxiosResponse(response);\n            }\n\n            return response.data;\n        },\n\n        async isEmailValid(\n            store: never,\n            data: { email: string, form_id: string, recaptchaResponse?: string },\n        ): Promise<boolean> {\n            const client = getAPIService(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                timeout: 30 * 1000,\n                validateStatus: () => true,\n                method: 'POST',\n                headers: {},\n                url: '/svc/v1/marketing/forms/leads/email/validate',\n                data: {\n                    email: data.email,\n                    form_id: data.form_id,\n                },\n            };\n\n            if (data.recaptchaResponse) {\n                cfg.headers['X-GRecaptcha-Response'] = data.recaptchaResponse;\n            }\n\n            const response = await client.request(cfg);\n\n            if (response.status as StatusCodes !== StatusCodes.OK) {\n                Logger.error({ error: response });\n                throw ServiceAPIError.FromAxiosResponse(response);\n            }\n\n            return response.data.is_valid;\n        },\n    },\n\n    mutations: {\n        SET_QUERY_STRING_DATA(state: any, queryStringData: object) {\n            state.queryStringData = queryStringData;\n        },\n    },\n};\n","import axios, { RawAxiosRequestConfig } from 'axios';\nimport { StatusCodes } from 'http-status-codes';\nimport getAPIAccount from '@api/account';\nimport { Logger } from '@utils/logger';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        data: null,\n    }),\n\n    actions: {\n        async get(store) {\n            try {\n                const client = getAPIAccount(this.$context);\n\n                const cfg: RawAxiosRequestConfig = {\n                    validateStatus: (status: number) => [StatusCodes.OK, StatusCodes.UNAUTHORIZED].includes(status),\n                    method: 'GET',\n                    url: '/v2/account',\n                };\n\n                const resp = await client.request(cfg);\n                store.commit('setUser', resp.data.account);\n            } catch (error) {\n                Logger.error({ error });\n            }\n        },\n\n        async logout(store) {\n            try {\n                const client = getAPIAccount(this.$context);\n\n                const cfg: RawAxiosRequestConfig = {\n                    validateStatus: (status: number) => [StatusCodes.NO_CONTENT].includes(status),\n                    method: 'POST',\n                    url: '/v2/auth/logout',\n                };\n\n                await client.request(cfg);\n                store.commit('setUser', null);\n            } catch (error) {\n                Logger.error({ error });\n            }\n        },\n\n        async getUserCloud(store: never, token: string): Promise<any> {\n            try {\n                const defaults: RawAxiosRequestConfig = {\n                    timeout: 10000,\n                    withCredentials: true,\n                };\n                const client = axios.create(defaults);\n                const url = `https://www.acronis.com/en-us/inapp/home/ati/matrix/cloud.html?ott=${token || ''}`;\n                const { data } = await client.get(url);\n                return data;\n            } catch (error) {\n                Logger.error({ error });\n                return null;\n            }\n        },\n    },\n\n    mutations: {\n        setUser(state, user) {\n            state.data = user;\n        },\n    },\n};\n","import { StatusCodes } from 'http-status-codes';\nimport { ProductAPIQueryBuilder } from '@api/builders/product';\nimport getAPIProduct from '@api/product';\nimport getAPIService from '@api/service';\nimport { HttpRejection } from '@model/http/rejection';\nimport type { AugmentedStore } from '@model/vue-store/augmented-store';\nimport { Logger } from '@utils/logger';\nimport { papiFetchAllPagesClient } from '@utils/papi-fetch-paginated-client';\nimport type { RawAxiosRequestConfig, AxiosResponse } from 'axios';\nimport type { ActionContext, Store } from 'vuex';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        pricingMethod: 1,\n        currency: null,\n        discountAfter: null,\n        group: null,\n        requirements: {\n            workloads: 20,\n            storage: 200,\n        },\n        unitPrices: [],\n        currentPriceList: {\n            id: null,\n            name: null,\n        },\n        priceLists: [],\n        prices: null,\n        items: {},\n    }),\n\n    actions: {\n        async createLeadRequest(store: never, data: Record<string, any>) {\n            const client = getAPIService(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                method: 'POST',\n                url: '/svc/v1/marketing/forms/leads',\n                timeout: 60 * 1000,\n                validateStatus: (status: number) => status === 200,\n                data,\n            };\n\n            const response = await client.request(cfg);\n            return response;\n        },\n\n        async updateLeadRequest(store: never, data: Record<string, any>) {\n            const client = getAPIService(this.$context);\n\n            const cfg: RawAxiosRequestConfig = {\n                method: 'PUT',\n                url: `/svc/v1/marketing/forms/leads/${data.osauid}`,\n                timeout: 60 * 1000,\n                validateStatus: (status: number) => status === 200,\n                data,\n            };\n\n            const response = await client.request(cfg);\n            return response;\n        },\n\n        async getSyncedData(this: AugmentedStore, store, args) {\n            const { key, locale } = args;\n            const data = await this.$context.Synced.vroiData.query(key, locale);\n            store.commit('setSyncedData', { key, data });\n        },\n\n        async getEntity(store: ActionContext<any, any>, args: { request: Storage, httpRejectEmptyState: boolean }) {\n            const request = args.request;\n            const client = getAPIProduct(this.$context);\n\n            const opts: RawAxiosRequestConfig = {\n                validateStatus: (status: StatusCodes) => status === StatusCodes.OK,\n                timeout: typeof window !== 'undefined' ? 30000 : 6000,\n                method: 'GET',\n                url: request.entityPath,\n                params: request.params,\n            };\n\n            try {\n                const response = await client.request(opts);\n                store.commit('setEntity', { request, response });\n            } catch (error) {\n                Logger.error({ error });\n                const httpStatus = error.status || StatusCodes.BAD_GATEWAY;\n                const message = error.message || 'Premature rendering stop';\n                throw new HttpRejection(message, httpStatus);\n            }\n        },\n\n        async getPriceLists(store: ActionContext<any, any>) {\n            const queryBuilder: ProductAPIQueryBuilder = new ProductAPIQueryBuilder('priceLists')\n                .setEntityPath('/api/finance/price-lists/')\n                .setPaginate(1, 50);\n            const request = queryBuilder.toObject();\n\n            await store.dispatch('getEntity', { request });\n        },\n\n        async getPricesForPriceBook(store: ActionContext<any, any>, productCodes: string) {\n            if (typeof window === 'undefined') return;\n\n            const currentPriceListId = store.state.currentPriceList.id;\n            const perPage = 50;\n            const client = getAPIProduct(this.$context);\n\n            const responses = await papiFetchAllPagesClient(client, (page) => {\n                const request = new ProductAPIQueryBuilder('unitPrices')\n                    .setEntityPath('/api/finance/price-lists/prices')\n                    .addMatchesAll('price_list_id', '=', currentPriceListId)\n                    .addMatchesAll('product_code', 'in', productCodes)\n                    .setPaginate(page, perPage)\n                    .toObject();\n\n                return {\n                    method: 'GET',\n                    url: request.entityPath,\n                    params: request.params,\n                };\n            });\n\n            const allItems = responses.flatMap((r) => r.data.data);\n            store.commit('setEntity', {\n                request: { id: 'unitPrices' },\n                response: {\n                    data: {\n                        data: allItems,\n                    },\n                },\n            });\n        },\n    },\n    mutations: {\n        setEntity(state: Store<any>, args: { request: Storage, response: AxiosResponse }) {\n            state[args.request.id] = args.response.data.data;\n        },\n        setSyncedData(state, { key, data }) {\n            state.items[key] = data;\n        },\n        setDiscountAfter(state, payload) {\n            state.discountAfter = payload;\n        },\n        setCurrency(state, payload) {\n            state.currency = payload;\n        },\n        setPricingMethod(state, payload) {\n            state.pricingMethod = payload;\n        },\n        setCurrentPriceList(state, payload) {\n            state.currentPriceList.id = payload.id;\n            state.currentPriceList.name = payload.name;\n        },\n        setGroup(state, payload) {\n            state.group = payload;\n        },\n        setStorageOptions(state, payload) {\n            state.storageOptions = payload;\n        },\n    },\n};\n","import type { AugmentedStore } from '@model/vue-store/augmented-store';\n\nexport default {\n    namespaced: true,\n\n    state: () => ({\n        items: [],\n    }),\n\n    actions: {\n        async getAllJobs(this: AugmentedStore, store) {\n            const items = await this.$context.Synced.workdayJobs.getList();\n            store.commit('setJobs', items);\n            return items;\n        },\n\n        async getJobById(this: AugmentedStore, store, id: string) {\n            const map = await this.$context.Synced.workdayJobs.getMap();\n            const item = map.get(id);\n            store.commit('setJobs', [item]);\n            return item;\n        },\n    },\n\n    mutations: {\n        setJobs(state, items) {\n            state.items = items;\n        },\n    },\n};\n","import { createStore, Store } from 'vuex';\n\nimport * as c from '@model/const/sites';\nimport academy from './modules/academy';\nimport awards from './modules/awards';\nimport blog from './modules/blog';\nimport cleverbridge from './modules/cleverbridge';\nimport config from './modules/config';\nimport countries from './modules/countries';\nimport events from './modules/events';\nimport eventsFeed from './modules/events-feed';\nimport expressSignup from './modules/express-signup';\nimport geolocation from './modules/geolocation';\nimport inapp from './modules/inapp';\nimport licenses from './modules/licenses';\nimport locales from './modules/locales';\nimport pages from './modules/pages';\nimport partners from './modules/partners';\nimport partnersLocator from './modules/partners-locator';\nimport popup from './modules/popup';\nimport pressReleases from './modules/press-releases';\nimport pressReleasesFeed from './modules/press-releases-feed';\nimport products from './modules/products';\nimport promotions from './modules/promotions';\nimport publications from './modules/publications';\nimport resourceCenter from './modules/resource-center';\nimport ribbon from './modules/ribbon';\nimport seo from './modules/seo';\nimport slapfive from './modules/slapfive';\nimport slices from './modules/slices';\nimport solutions from './modules/solutions';\nimport trial from './modules/trial';\nimport user from './modules/user';\nimport vroi from './modules/vroi';\nimport workday from './modules/workday';\n\ninterface AugmentedStore {\n    $context: Record<string, any>;\n}\n\nexport function StoreFactory(context: any, initialState?: any): AugmentedStore {\n    const siteID = context.public.siteID;\n    const modules = {\n        ...(() => {\n            switch (siteID) {\n                case c.SITE_ID_SOLUTIONS:\n                    return {\n                        config,\n                        slices,\n                        solutions,\n                        geolocation,\n                    };\n                case c.SITE_ID_EVENTS:\n                    return {\n                        awards,\n                        config,\n                        countries,\n                        geolocation,\n                        events,\n                        licenses,\n                        locales,\n                        products,\n                        slices,\n                        seo,\n                        trial,\n                        user,\n                        vroi,\n                    };\n                case c.SITE_ID_DEVELOPER:\n                    return {\n                        awards,\n                        blog,\n                        cleverbridge,\n                        config,\n                        countries,\n                        events,\n                        eventsFeed,\n                        geolocation,\n                        locales,\n                        pages,\n                        partners,\n                        partnersLocator,\n                        popup,\n                        products,\n                        publications,\n                        ribbon,\n                        slices,\n                        trial,\n                        user,\n                    };\n                case c.SITE_ID_SCS:\n                    return {\n                        awards,\n                        blog,\n                        cleverbridge,\n                        config,\n                        countries,\n                        events,\n                        eventsFeed,\n                        geolocation,\n                        licenses,\n                        locales,\n                        pages,\n                        partners,\n                        partnersLocator,\n                        products,\n                        publications,\n                        slices,\n                        trial,\n                        user,\n                    };\n                case c.SITE_ID_TRUEIMAGE:\n                    return {\n                        awards,\n                        blog,\n                        cleverbridge,\n                        config,\n                        countries,\n                        events,\n                        eventsFeed,\n                        geolocation,\n                        licenses,\n                        locales,\n                        pages,\n                        partners,\n                        partnersLocator,\n                        popup,\n                        products,\n                        promotions,\n                        publications,\n                        ribbon,\n                        seo,\n                        slices,\n                        trial,\n                        user,\n                    };\n                case c.SITE_ID_ACADEMY:\n                    return {\n                        academy,\n                        config,\n                        geolocation,\n                        slices,\n                        user,\n                    };\n                case c.SITE_ID_WWW:\n                default:\n                    return {\n                        awards,\n                        blog,\n                        cleverbridge,\n                        config,\n                        countries,\n                        events,\n                        eventsFeed,\n                        expressSignup,\n                        geolocation,\n                        inapp,\n                        licenses,\n                        locales,\n                        pages,\n                        partners,\n                        partnersLocator,\n                        popup,\n                        pressReleases,\n                        pressReleasesFeed,\n                        products,\n                        promotions,\n                        publications,\n                        resourceCenter,\n                        ribbon,\n                        seo,\n                        slapfive,\n                        slices,\n                        solutions,\n                        trial,\n                        user,\n                        vroi,\n                        workday,\n                    };\n            }\n        })(),\n    };\n\n    const store = createStore({\n        state: () => ({\n            context: {\n                public: context.public,\n            },\n        }),\n        ...initialState,\n        // eslint-disable-next-line @typescript-eslint/dot-notation\n        devtools: typeof window !== 'undefined' && Boolean(window['__VUE_DEVTOOLS_GLOBAL_HOOK__']),\n        modules,\n    }) as unknown as AugmentedStore;\n\n    const augmented = store as Store<any> & AugmentedStore;\n    augmented.$context = context;\n    return augmented;\n}\n","import { defineComponent } from 'vue';\nimport { createRouter, createMemoryHistory, createWebHistory } from 'vue-router';\nimport * as c from '@model/const/sites';\n\n// Fooling rollup here, so it doesn't statically link all containers to the app chunk.\n// For SSR, eagerly import all containers, for client make it lazy\nlet modules = null;\nfunction getModules() {\n    if (modules) {\n        return modules;\n    }\n\n    modules = import.meta.glob('/src/vue3/views/**/container.vue', { eager: import.meta.env.SSR });\n\n    return modules;\n}\n\n// Don't re-wrap the same module on every request\nconst wrappedModulesCache = new Map<string, any>();\n\nconst viewFactory = async (siteID, view) => {\n    const path = `/src/vue3/views/${siteID}/${view}/container.vue`;\n\n    if (wrappedModulesCache.has(path)) {\n        return wrappedModulesCache.get(path);\n    }\n\n    const mod = getModules()[path];\n\n    if (!mod) {\n        throw new Error(`Component not found: ${path}`);\n    }\n\n    // For client, just return as is, no wrapping or caching required\n    if (!import.meta.env.SSR) {\n        return await mod();\n    }\n\n    // For SSR we need to wrap the default export to intercept the serverPrefetch\n    const original = mod.default;\n\n    const wrapped = defineComponent({\n        ...original,\n        name: `${original.name}-interruptible`,\n        async serverPrefetch() {\n            if (!original.serverPrefetch) {\n                return;\n            }\n\n            try {\n                await original.serverPrefetch.call(this);\n            } catch (err) {\n                this.$ssrContext.rejection = err;\n            }\n        },\n        render() {\n            if (typeof window === 'undefined' && this.$ssrContext?.rejection) {\n                throw this.$ssrContext.rejection;\n            }\n\n            return original.render.call(this);\n        },\n    });\n\n    wrappedModulesCache.set(path, wrapped);\n\n    return wrapped;\n};\n\nconst getRoutes = (siteID) => {\n    const routes: Record<string, any[]> = {\n        [c.SITE_ID_WWW]: [\n            // Inapp\n            {\n                name: 'inapp',\n                path: '/:locale/inapp/:pathMatch(.*)*/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'inapp/pages'),\n                pathToRegexpOptions: { strict: true },\n            },\n            // Blog\n            {\n                name: 'blog-home',\n                path: '/:lang/blog/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/home'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-home-page',\n                path: '/:lang/blog/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/home'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-post-draft',\n                path: '/:lang/blog/posts/:slug/draft-:draftKey/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/post'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-post',\n                path: '/:lang/blog/posts/:slug/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/post'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-category',\n                path: '/:lang/blog/categories/:category/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/category'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-category-page',\n                path: '/:lang/blog/categories/:category/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/category'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-tag',\n                path: '/:lang/blog/tags/:tag/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/tag'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-tag-page',\n                path: '/:lang/blog/tags/:tag/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/tag'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-authors',\n                path: '/:lang/blog/authors/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/authors'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-author-posts',\n                path: '/:lang/blog/authors/:author/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/author-posts'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-author-posts-page',\n                path: '/:lang/blog/authors/:author/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/author-posts'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-search',\n                path: '/:lang/blog/search/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'blog/search'),\n                pathToRegexpOptions: { strict: true },\n            },\n            // Blog CPC (TRU Security)\n            {\n                name: 'blog-cpc-home',\n                path: '/:lang/tru/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'cpc/home'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-cpc-about',\n                path: '/:lang/tru/about/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'cpc/about'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-cpc-home-page',\n                path: '/:lang/tru/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'cpc/home'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-cpc-news',\n                path: '/:lang/tru/posts/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'cpc/news'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-cpc-news-page',\n                path: '/:lang/tru/posts/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'cpc/news'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-cpc-post-draft',\n                path: '/:lang/tru/posts/:slug/draft-:draftKey/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'cpc/post'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-cpc-post',\n                path: '/:lang/tru/posts/:slug/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'cpc/post'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-cpc-author-posts',\n                path: '/:lang/tru/authors/:author/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'cpc/author-posts'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-cpc-author-posts-page',\n                path: '/:lang/tru/authors/:author/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'cpc/author-posts'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-cpc-category',\n                path: '/:lang/tru/categories/:slug/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'cpc/category'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-cpc-category-page',\n                path: '/:lang/tru/categories/:slug/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'cpc/category'),\n                pathToRegexpOptions: { strict: true },\n            },\n            // TRU Threat Catalog\n            {\n                name: 'blog-threat-catalog-home',\n                path: '/:lang/tru/threat-catalog/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'threat-catalog/home'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-threat-catalog-post',\n                path: '/:lang/tru/threat-catalog/:slug(.*)/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'threat-catalog/post'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'blog-threat-catch-normalized-schema',\n                path: '/:lang/threat/posts/:slug(.*)',\n                component: () => viewFactory(c.SITE_ID_WWW, 'threat-catalog/catch-normalized-schema'),\n                pathToRegexpOptions: { strict: true },\n            },\n            // Careers Job page\n            {\n                name: 'careers-job',\n                path: '/:lang/careers/job/:id?/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'careers-job'),\n                pathToRegexpOptions: { strict: true },\n            },\n            // PR\n            {\n                name: 'pr-home-page',\n                path: '/:lang/pr/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'pr-home-page'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'pr-home-page-page',\n                path: '/:lang/pr/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'pr-home-page'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'pr-media-contacts',\n                path: '/:lang/pr/media-sources/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'pr-media-contacts'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'pr-by-year',\n                path: '/:lang/pr/:year/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'pr-by-year'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'pr-by-year-page',\n                path: '/:lang/pr/:year/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'pr-by-year'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'pr-press-release-draft',\n                path: '/:lang/pr/:year(\\\\d+)/:slug/draft-:draftKey/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'pr-press-release'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'pr-press-release',\n                path: '/:lang/pr/:year(\\\\d+)/:slug/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'pr-press-release'),\n                pathToRegexpOptions: { strict: true },\n            },\n            // RC\n            {\n                name: 'resource-center-home',\n                path: '/:lang/resource-center/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'resource-center-home'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'resource-center-category',\n                path: '/:lang/resource-center/category/:slug/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'resource-center-category'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'resource-center-category-page',\n                path: '/:lang/resource-center/category/:slug/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'resource-center-category'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'resource-center-audience',\n                path: '/:lang/resource-center/audience/:slug/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'resource-center-audience'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'resource-center-audience-page',\n                path: '/:lang/resource-center/audience/:slug/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'resource-center-audience'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'resource-center-tag',\n                path: '/:lang/resource-center/tag/:slug/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'resource-center-tag'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'resource-center-tag-page',\n                path: '/:lang/resource-center/tag/:slug/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'resource-center-tag'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'resource-center-resource-draft',\n                path: '/:lang/resource-center/resource/:slug/draft-:draftKey/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'resource-center-resource'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'resource-center-resource',\n                path: '/:lang/resource-center/resource/:slug/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'resource-center-resource'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'resource-center-search',\n                path: '/:lang/resource-center/search/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'resource-center-search'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'resource-center-search-page',\n                path: '/:lang/resource-center/search/page/:page/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'resource-center-search'),\n                pathToRegexpOptions: { strict: true },\n            },\n            // Errors\n            {\n                name: 'http-error-404',\n                path: '/:lang/http-errors/404/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'http-error-404'),\n                pathToRegexpOptions: { strict: true },\n            },\n            // Pages && catch-all\n            {\n                name: 'pages-preview',\n                path: '/:lang/preview/:previewId/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'pages'),\n            },\n            {\n                name: 'pages-page',\n                path: '/:lang/:pathMatch(.*)*/',\n                component: () => viewFactory(c.SITE_ID_WWW, 'pages'),\n            },\n        ],\n        [c.SITE_ID_TRUEIMAGE]: [\n            // NOTES:\n            // - TI site is basically cloned from SITE_ID_WWW, but with a small subset of views only – this is the scope of Phase 1.\n            // - While these views are (almost) identical, it's not recommended to reuse original ones, because more changes are coming.\n            {\n                name: 'http-error-404',\n                path: '/:locale/http-errors/404/',\n                component: () => viewFactory(c.SITE_ID_TRUEIMAGE, 'http-error-404'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'pages-preview',\n                path: '/:locale/preview/:previewId/',\n                component: () => viewFactory(c.SITE_ID_TRUEIMAGE, 'pages'),\n            },\n            {\n                name: 'pages-page',\n                path: '/:locale/:pathMatch(.*)*/',\n                component: () => viewFactory(c.SITE_ID_TRUEIMAGE, 'pages'),\n            },\n        ],\n        [c.SITE_ID_EVENTS]: [\n            {\n                name: 'archive',\n                path: '/archive/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'archive'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'archive-localized',\n                path: '/:locale/archive/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'archive'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'ot-events',\n                path: '/category/ot-industrial-events/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'ot-events'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'ot-events-localized',\n                path: '/:locale/category/ot-industrial-events/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'ot-events'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'category',\n                path: '/category/:category/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'category'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'category-localized',\n                path: '/:locale/category/:category/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'category'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'event',\n                path: '/event/:slug/:key?/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'event'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'event-localized',\n                path: '/:locale/event/:slug/:key?/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'event'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'http-error-404',\n                path: '/http-errors/404/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'http-error-404'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'http-error-404-localized',\n                path: '/:locale/http-errors/404/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'http-error-404'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'home',\n                path: '/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'home'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'home-localized',\n                path: '/:locale/',\n                component: () => viewFactory(c.SITE_ID_EVENTS, 'home'),\n                pathToRegexpOptions: { strict: true },\n            },\n        ],\n        [c.SITE_ID_SCS]: [\n            {\n                name: 'http-error-404',\n                path: '/http-errors/404/',\n                component: () => viewFactory(c.SITE_ID_SCS, 'http-error-404'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'pages-preview',\n                path: '/preview/:previewId/',\n                component: () => viewFactory(c.SITE_ID_SCS, 'pages'),\n            },\n            {\n                name: 'pages-page',\n                path: '/:pathMatch(.*)*',\n                component: () => viewFactory(c.SITE_ID_SCS, 'pages'),\n            },\n        ],\n        [c.SITE_ID_SOLUTIONS]: [\n            {\n                name: 'http-error-404',\n                path: '/:locale/http-errors/404/',\n                component: () => viewFactory(c.SITE_ID_SOLUTIONS, 'http-error-404'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                path: '/:locale/',\n                name: 'solutions-home',\n                component: () => viewFactory(c.SITE_ID_SOLUTIONS, 'home'),\n            },\n            {\n                path: '/:locale/page/:page/',\n                name: 'solutions-home-page',\n                component: () => viewFactory(c.SITE_ID_SOLUTIONS, 'home'),\n            },\n            {\n                path: '/:locale/category/:category/:subcategory?/',\n                name: 'solutions-home-category',\n                component: () => viewFactory(c.SITE_ID_SOLUTIONS, 'home'),\n            },\n            {\n                path: '/:locale/category/:category/page/:page/',\n                name: 'solutions-home-category-page',\n                component: () => viewFactory(c.SITE_ID_SOLUTIONS, 'home'),\n            },\n            {\n                path: '/:locale/category/:category/:subcategory/page/:page/',\n                name: 'solutions-home-subcategory-page',\n                component: () => viewFactory(c.SITE_ID_SOLUTIONS, 'home'),\n            },\n            {\n                path: '/:locale/integrations/:slug/',\n                name: 'solutions-integration',\n                component: () => viewFactory(c.SITE_ID_SOLUTIONS, 'integration'),\n            },\n            // \"Catch all\" path to capture & redirect old URLs scheme\n            // TODO: this is probably obsolete after a year\n            {\n                path: '/:locale/:pathMatch(.*)*',\n                name: 'solutions-catch-all',\n                component: () => viewFactory(c.SITE_ID_SOLUTIONS, 'catch-all'),\n            },\n        ],\n        [c.SITE_ID_DEVELOPER]: [\n            {\n                name: 'http-error-404',\n                path: '/:locale/http-errors/404/',\n                component: () => viewFactory(c.SITE_ID_DEVELOPER, 'http-error-404'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                name: 'pages-preview',\n                path: '/:locale/preview/:previewId/',\n                component: () => viewFactory(c.SITE_ID_DEVELOPER, 'pages'),\n            },\n            {\n                name: 'pages-page',\n                path: '/:locale/:pathMatch(.*)*/',\n                component: () => viewFactory(c.SITE_ID_DEVELOPER, 'pages'),\n            },\n        ],\n        [c.SITE_ID_ACADEMY]: [\n            {\n                name: 'http-error-404',\n                path: '/:locale/http-errors/404/',\n                component: () => viewFactory(c.SITE_ID_ACADEMY, 'http-error-404'),\n                pathToRegexpOptions: { strict: true },\n            },\n            {\n                path: '/:locale/',\n                name: 'academy-home',\n                component: () => viewFactory(c.SITE_ID_ACADEMY, 'home'),\n            },\n            {\n                path: '/:locale/catalogue/',\n                name: 'academy-catalogue',\n                component: () => viewFactory(c.SITE_ID_ACADEMY, 'catalogue'),\n            },\n            {\n                path: '/:locale/catalogue/:slug/',\n                name: 'academy-catalogue-course',\n                component: () => viewFactory(c.SITE_ID_ACADEMY, 'course'),\n            },\n        ],\n        [c.SITE_ID_TOOLBOX]: [\n            {\n                name: 'builder-page',\n                path: '/slices-builder/',\n                component: () => viewFactory(c.SITE_ID_TOOLBOX, 'builder'),\n                pathToRegexOptions: { string: true },\n            },\n        ],\n    };\n\n    return routes[siteID] || [];\n};\n\nexport function RouterFactory(context, scene) {\n    let currentRoutes = getRoutes(context.public.siteID);\n\n    // Hack routes list to leave only page 404 alive. See @model/ssr/context.ts for explanation\n    if (context.public.isNotFoundTrap) {\n        const route404 = currentRoutes.find((r) => r.name === 'http-error-404');\n\n        let fixedPath = '/:pathMatch(.*)*';\n\n        if (currentRoutes.some((r) => r.path.startsWith('/:locale/'))) {\n            fixedPath = '/:locale/:pathMatch(.*)*';\n        }\n        if (currentRoutes.some((r) => r.path.startsWith('/:lang/'))) {\n            fixedPath = '/:lang/:pathMatch(.*)*';\n        }\n\n        const trap = {\n            ...route404,\n            path: fixedPath,\n            pathToRegexpOptions: {},\n        };\n\n        currentRoutes = [trap];\n    }\n\n    const router = createRouter({\n        history: scene === 'ssr' ? createMemoryHistory() : createWebHistory(),\n        routes: currentRoutes,\n    });\n\n    return router;\n}\n","import { createSSRApp } from 'vue';\nimport sliceNameMixin from '@core/mixins/slice-name.js';\nimport type { SSRContext as EngineSSRContext } from '@model/ssr/context';\nimport App from './root.vue';\nimport { StoreFactory } from './store/store-factory';\nimport { RouterFactory } from './views/router-factory';\n\nexport function createApp(context?: EngineSSRContext | Record<string, any>) {\n    const app = createSSRApp(App);\n\n    app.config.globalProperties.$app = app;\n    app.config.throwUnhandledErrorInProduction = true;\n\n    // See: https://pmc.acronis.work/browse/WEB-48408\n    app.mixin(sliceNameMixin);\n\n    if (context && 'req' in context && 'res' in context) {\n        app.config.globalProperties.$ssrContext = context;\n        const store = StoreFactory(context);\n        const router = RouterFactory(context, 'ssr');\n        app.use(store);\n        app.use(router);\n        return { app, store, router };\n    }\n\n    const store = StoreFactory(context ?? {});\n    const router = RouterFactory(context ?? {}, 'browser');\n    app.use(store);\n    app.use(router);\n    return { app, store, router };\n}\n","import { createApp } from './main';\n\nasync function main() {\n    const parseJSONScript = (id) => JSON.parse(document.getElementById(id)?.textContent || '{}');\n    const initialState = parseJSONScript('app-state');\n    const context = initialState.context;\n\n    const { app, router, store } = createApp(context); // pass initialState.context\n    store.replaceState(initialState);\n\n    await router.isReady();\n    app.mount('#app', true);\n}\n\nmain();\n"],"file":"app-BOvFy2C8.js"}