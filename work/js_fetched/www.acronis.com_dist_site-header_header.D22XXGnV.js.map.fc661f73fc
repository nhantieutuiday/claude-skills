PThresholds,B as INPThresholds,N as LCPThresholds,H as TTFBThresholds,b as onCLS,T as onFCP,S as onINP,x as onLCP,$ as onTTFB};\n","// Explanation on web-vitals abbreviations https://web.dev/vitals/\nimport { onINP, onLCP, onFCP, onTTFB, onCLS } from 'web-vitals';\nimport { Logger } from '../../utils/logger';\nimport { getDataFromPocket } from '../../utils/pocket';\nimport type { PublicContext } from './utils-pocket-models';\nimport type { INPMetric, LCPMetric, FCPMetric, TTFBMetric, CLSMetric } from 'web-vitals';\n\ntype Metric = INPMetric | LCPMetric | FCPMetric | TTFBMetric | CLSMetric;\n\nexport function sendWebVitals() {\n    const watchDog = new Set();\n\n    const namesMap = {\n        INP: 'interaction-to-next-paint',\n        LCP: 'largest-contentful-paint',\n        FCP: 'first-contentful-paint',\n        TTFB: 'time-to-first-byte',\n        CLS: 'cumulative-layout-shift',\n    };\n\n    const publicContext = getDataFromPocket<PublicContext>('public_context')!;\n\n    const report = (metric: Metric) => {\n        const readableName = namesMap[metric.name];\n        if (!readableName) {\n            Logger.error(`Unknown metric name: ${metric.name}`);\n            return;\n        }\n\n        const payload = {\n            latency: metric.value,\n            url: window.location.href,\n            bag: [] as Record<string, unknown>[],\n        };\n\n        switch (metric.name) {\n            case 'INP':\n                payload.bag = metric.entries.map((entry) => ({\n                    eventName: entry.name,\n                    targetClasses: (entry.target as HTMLElement)?.className,\n                }));\n                break;\n            case 'LCP':\n                payload.bag = metric.entries.map((entry) => ({\n                    loadTime: entry.loadTime,\n                    renderTime: entry.renderTime,\n                    size: entry.size,\n                    url: entry.url,\n                    targetClasses: entry.element?.className,\n                }));\n                break;\n            case 'FCP':\n                break;\n            case 'TTFB':\n                payload.bag = metric.entries.map((entry) => ({\n                    size: entry.decodedBodySize,\n                    domComplete: entry.domComplete,\n                    domInteractive: entry.domInteractive,\n                    download: entry.responseEnd - entry.responseStart,\n                    status: entry.responseStatus,\n                }));\n                break;\n            case 'CLS':\n                payload.bag = metric.entries.map((entry) => ({\n                    startTime: entry.startTime,\n                    value: entry.value,\n                    shifts: entry.sources.map((source) => (source.node as HTMLElement)?.className),\n                }));\n                break;\n            default:\n                metric satisfies never;\n        }\n\n        const payloadSerialized = JSON.stringify(payload);\n        const opts = { type: 'application/json' };\n        const blob = new Blob([payloadSerialized], opts);\n\n        const sendBeacon = navigator.sendBeacon.bind(navigator);\n\n        const endpoint = `${publicContext.env['HEAD_SITE_MAIN_PUBLIC_BASE_URL_SERVICE_API_CLIENT']}/svc/v1/metrics/latency/${readableName}`;\n\n        sendBeacon(endpoint, blob);\n    };\n\n    const reportOnce = (metric: Metric) => {\n        if (!watchDog.has(metric.name)) {\n            watchDog.add(metric.name);\n        } else {\n            return;\n        }\n\n        report(metric);\n    };\n\n    try {\n        onINP(report);\n        onLCP(reportOnce);\n        onFCP(reportOnce);\n        onTTFB(reportOnce);\n        onCLS(report);\n    } catch (error) {\n        Logger.error({ error });\n    }\n}\n","export class YoutubePlayerReadyBus {\n    private youtubeAPIisReallyReady = false;\n\n    private subscribers: (() => void)[] = [];\n\n    constructor() {\n        window.onYouTubePlayerAPIReady = () => {\n            this.youtubeAPIisReallyReady = true;\n            this.subscribers.forEach((callback) => callback());\n        };\n    }\n\n    public subscribe(callback: () => void) {\n        if (this.youtubeAPIisReallyReady) {\n            callback();\n        } else {\n            this.subscribers.push(callback);\n        }\n    }\n}\n","/*\n * This is the header.js entrypoint consisting of critical JS code, all bundled.\n * Whenever you need to introduce something which should run before the main Vue app hydrated, put it here.\n *\n * NB: the current boot sequence:\n * 0) booting absolutely critical sections (Sentry, splits, etc.)\n * 1) unconditionally exposing 1st party library code (YouTube events bus, etc.)\n * 2) monkey-patching `window._vwo_evq.push` to hook into redirect event\n * 3) setting up VWO init code and initiating VWO\n * 4) pre-pushing userType GA event, initiating GTM, starting VWO result polling\n * 5) [in VWO polling complete, if no redirect] filling initial dataLayer events (BOGO, businessGeo)\n * 6) unconditionally initiating Matomo and pushing the pageview\n*/\n\nimport { Logger } from '../../utils/logger';\nimport { getGeolocation } from './boot-geolocation';\nimport { initGTM } from './boot-gtm';\nimport { injectVWOCode } from './boot-inject-vwo-code.js';\nimport { initMatomo } from './boot-matomo';\nimport { increaseNavvaticCounter } from './boot-navvatic-counter';\nimport { sendBogoEvent } from './boot-send-bogo';\nimport { sendBusinessLocationEvent } from './boot-send-business-location';\nimport { initSplits } from './boot-splits';\nimport { injectSVGSprite } from './boot-svg-sprite';\nimport { monkeyPatchVWO, initVWO } from './boot-vwo';\nimport { initSentry } from './utils-sentry';\nimport { getVWOOutcome } from './utils-wait-for-vwo-outcome';\nimport { sendWebVitals } from './utils-web-vitals';\nimport { YoutubePlayerReadyBus } from './utils-youtube-player-ready-bus';\n\nfunction safeBootSection(fn: () => void, logName: string) {\n    try {\n        fn();\n    } catch (e) {\n        Logger.error(e, `Failed to boot ${logName}`);\n    }\n}\n\nasync function safeBootSectionAsync(fn: () => Promise<void>, logName: string) {\n    try {\n        await fn();\n    } catch (e) {\n        Logger.error(e, `Failed to boot ${logName}`);\n    }\n}\n\nexport async function bootHeader() {\n    await safeBootSectionAsync(injectSVGSprite, 'bootSVGSprite');\n    safeBootSection(initSplits, 'splits');\n    safeBootSection(sendWebVitals, 'sendWebVitals');\n    safeBootSection(initSentry, 'initSentry');\n    safeBootSection(increaseNavvaticCounter, 'increaseNavvaticCounter');\n\n    window.youtubePlayerReadyBus = new YoutubePlayerReadyBus();\n\n    safeBootSection(monkeyPatchVWO, 'monkeyPatchVWO');\n    safeBootSection(injectVWOCode, 'injectVWOCode');\n    safeBootSection(initVWO, 'initVWO');\n    safeBootSection(initGTM, 'initGTM');\n    safeBootSectionAsync(initMatomo, 'initMatomo');\n\n    if (typeof window !== 'undefined') {\n        const consentGiven = window.OptanonActiveGroups?.includes('C0002');\n        if (consentGiven) {\n            window.ytTracker?.init();\n        }\n    }\n\n    // Code which requires VWO decision making goes here (only some GA events for now)\n    const vwoOutcome = await getVWOOutcome();\n    if (vwoOutcome !== 'redirect') {\n        await getGeolocation();\n        sendBusinessLocationEvent();\n        sendBogoEvent();\n    }\n}\n","import { bootHeader } from './header/entrypoint';\n\nbootHeader();\n"],"names":["require_header_001","__commonJSMin","exports","module","bind","fn","thisArg","toString","getPrototypeOf","iterator","toStringTag","kindOf","cache","thing","str","kindOfTest","type","typeOfTest","isArray","isUndefined","isBuffer","val","isFunction","isArrayBuffer","isArrayBufferView","result","isString","isNumber","isObject","isBoolean","isPlainObject","prototype","isEmptyObject","isDate","isFile","isReactNativeBlob","value","isReactNative","formData","isBlob","isFileList","isStream","getGlob