, 'APAC', 'ANZ', 'ANZ'],\n    SB: ['APJ & ME', 'APAC', 'ANZ', 'ANZ'],\n    TL: ['APJ & ME', 'APAC', 'ANZ', 'ANZ'],\n    TK: ['APJ & ME', 'APAC', 'ANZ', 'ANZ'],\n    TO: ['APJ & ME', 'APAC', 'ANZ', 'ANZ'],\n    VU: ['APJ & ME', 'APAC', 'ANZ', 'ANZ'],\n    WF: ['APJ & ME', 'APAC', 'ANZ', 'ANZ'],\n    BN: ['APJ & ME', 'APAC', 'South East Asia', 'Rest of South East Asia'],\n    CX: ['APJ & ME', 'APAC', 'South East Asia', 'Rest of South East Asia'],\n    CC: ['APJ & ME', 'APAC', 'South East Asia', 'Rest of South East Asia'],\n    TP: ['APJ & ME', 'APAC', 'South East Asia', 'Rest of South East Asia'],\n    LA: ['APJ & ME', 'APAC', 'South East Asia', 'Rest of South East Asia'],\n    TV: ['APJ & ME', 'APAC', 'South East Asia', 'Rest of South East Asia'],\n    MO: ['APJ & ME', 'APAC', 'GCR', 'GCR'],\n    BT: ['APJ & ME', 'APAC', 'India and South Asia', 'South Asia'],\n    IO: ['APJ & ME', 'APAC', 'India and South Asia', 'South Asia'],\n    KP: ['APJ & ME', 'APAC', 'Korea', 'Korea'],\n    AC: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    BV: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    BI: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    CV: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    CF: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    DJ: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    GQ: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    ER: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    TF: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    GW: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    LR: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    MG: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    MR: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    NE: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    SH: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    ST: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    SC: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    SL: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    SO: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    SD: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    SZ: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    TG: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    EH: ['Europe, Israel & Africa', 'Africa', 'Rest of Africa', 'Rest of Africa'],\n    AF: ['APJ & ME', 'Middle East', 'Middle East', 'Rest of Middle East'],\n    IR: ['APJ & ME', 'Middle East', 'Middle East', 'Rest of Middle East'],\n    SY: ['APJ & ME', 'Middle East', 'Middle East', 'Rest of Middle East'],\n    AX: ['Europe, Israel & Africa', 'Northern Europe', 'Nordics', 'Nordics'],\n    GL: ['Europe, Israel & Africa', 'Northern Europe', 'Nordics', 'Nordics'],\n    SJ: ['Europe, Israel & Africa', 'Northern Europe', 'Nordics', 'Nordics'],\n    GG: ['Europe, Israel & Africa', 'Northern Europe', 'UK - Ireland', 'United Kingdom'],\n    IM: ['Europe, Israel & Africa', 'Northern Europe', 'UK - Ireland', 'United Kingdom'],\n    JE: ['Europe, Israel & Africa', 'Northern Europe', 'UK - Ireland', 'United Kingdom'],\n    AZ: ['Europe, Israel & Africa', 'Rest of Europe', 'Balkans - Turkey - Mediterranean - CIS', 'Balkans - Mediterranean - CIS'],\n    BY: ['Europe, Israel & Africa', 'Rest of Europe', 'Balkans - Turkey - Mediterranean - CIS', 'Balkans - Mediterranean - CIS'],\n    GE: ['Europe, Israel & Africa', 'Rest of Europe', 'Balkans - Turkey - Mediterranean - CIS', 'Balkans - Mediterranean - CIS'],\n    XK: ['Europe, Israel & Africa', 'Rest of Europe', 'Balkans - Turkey - Mediterranean - CIS', 'Balkans - Mediterranean - CIS'],\n    KG: ['Europe, Israel & Africa', 'Rest of Europe', 'Balkans - Turkey - Mediterranean - CIS', 'Balkans - Mediterranean - CIS'],\n    TJ: ['Europe, Israel & Africa', 'Rest of Europe', 'Balkans - Turkey - Mediterranean - CIS', 'Balkans - Mediterranean - CIS'],\n    TM: ['Europe, Israel & Africa', 'Rest of Europe', 'Balkans - Turkey - Mediterranean - CIS', 'Balkans - Mediterranean - CIS'],\n    UZ: ['Europe, Israel & Africa', 'Rest of Europe', 'Balkans - Turkey - Mediterranean - CIS', 'Balkans - Mediterranean - CIS'],\n    YU: ['Europe, Israel & Africa', 'Rest of Europe', 'Balkans - Turkey - Mediterranean - CIS', 'Balkans - Mediterranean - CIS'],\n    AD: ['Europe, Israel & Africa', 'Rest of Europe', 'France', 'France'],\n    MC: ['Europe, Israel & Africa', 'Rest of Europe', 'France', 'France'],\n    IC: ['Europe, Israel & Africa', 'Rest of Europe', 'Iberia', 'Spain'],\n    VA: ['Europe, Israel & Africa', 'Rest of Europe', 'Italy', 'Italy'],\n    RU: ['Russia', 'Russia', 'Russia', 'Russia'],\n};\n","import { Logger } from '../../utils/logger';\nimport { getDataFromPocket } from '../../utils/pocket';\nimport { BusinessLocationsRegistry } from './registry-business-locations';\n\nexport function sendBusinessLocationEvent() {\n    const geo: any = getDataFromPocket('geo', false);\n\n    if (!geo || !geo.data?.country?.code) {\n        return;\n    }\n\n    const descriptor = BusinessLocationsRegistry[geo.data.country.code];\n    if (!descriptor) {\n        Logger.warn('No descriptor for country', geo.data.country.code);\n        return;\n    }\n\n    const event = {\n        country: geo.data.country.name,\n        geography: descriptor[0],\n        region: descriptor[1],\n        subRegion: descriptor[2],\n        budgetRegion: descriptor[3],\n    };\n\n    window.dataLayer.push(event);\n}\n","import { Logger } from '../../utils/logger';\nimport { getDataFromPocket } from '../../utils/pocket';\n\n// ==== Model\nconst STORAGE_KEY = 'acronis_ab_storage';\n\ninterface SplitVariant {\n    id: string;\n    size: number;\n    isControl: boolean;\n}\n\ninterface SplitURLRestriction {\n    reg: string;\n    flags: string;\n}\n\ninterface Split {\n    id: string;\n    dimension: string;\n    variants: SplitVariant[];\n    urlsAllowed: SplitURLRestriction[];\n}\n\ntype Storage = Record<string, string>;\n\n// ==== Helpers\nfunction isControlMode(): boolean {\n    return !window.localStorage || !window.localStorage.getItem;\n}\n\nfunction hasStrongerRandSupport(): boolean {\n    return Boolean(window.crypto?.getRandomValues);\n}\n\nfunction diceRollClassic(): number {\n    return Math.floor(Math.random() * 100);\n}\n\nfunction diceRollModern(): number {\n    const bytes = new Uint32Array(1);\n    crypto.getRandomValues(bytes);\n\n    let val = (bytes[0] as number) / (0xffffffff + 1);\n    val = Math.floor(val * 100);\n\n    return val;\n}\n\nconst diceRoll = hasStrongerRandSupport() ? diceRollModern : diceRollClassic;\n\n// ==== Storage\nfunction unpackStorage(): Storage {\n    try {\n        const data = window.localStorage.getItem(STORAGE_KEY) || '{}';\n        return JSON.parse(data) as Storage;\n    } catch (e) {\n        return {};\n    }\n}\n\nconst storage: Storage = unpackStorage();\n\nfunction packStorage() {\n    const json = JSON.stringify(storage, null, 2);\n    window.localStorage.setItem(STORAGE_KEY, json);\n}\n\n// ==== Splits logic\nfunction hasStoredVariant(id: string): boolean {\n    return id in storage;\n}\n\nfunction getStoredVariant(id: string): string | undefined {\n    return storage[id];\n}\n\nfunction storeVariant(id: string, val: string) {\n    storage[id] = val;\n}\n\nfunction getCalculatedVariant(variants: SplitVariant[]): string | null {\n    const token = diceRoll();\n\n    let treshold = 0;\n\n    // eslint-disable-next-line no-restricted-syntax\n    for (const variant of variants) {\n        treshold += variant.size;\n\n        if (token < treshold) {\n            return variant.id;\n        }\n    }\n\n    return null;\n}\n\nfunction isSplitValid(split: Split): boolean {\n    const isValid = split.id &&\n        split.variants.find((x) => x.isControl) &&\n        split.variants.reduce((acc, next) => acc + next.size, 0) === 100;\n\n    return Boolean(isValid);\n}\n\nfunction isSplitAllowedOnURL(split: Split) {\n    if (!split.urlsAllowed || !split.urlsAllowed.length) {\n        return true;\n    }\n\n    // eslint-disable-next-line no-restricted-syntax\n    for (const target of split.urlsAllowed) {\n        try {\n            const r = new RegExp(target.reg, target.flags || 'i');\n            if (r.test(window.location.toString())) {\n                return true;\n            }\n        } catch (e) {\n            Logger.error(target, '[AB] Failed to construct urlsAllowed regexp');\n        }\n    }\n\n    return false;\n}\n\n// ==== Public interface\nexport function initSplits() {\n    const synced = getDataFromPocket<{ items: Split[] }>('splits')!;\n\n    const master = synced.items.filter(isSplitValid);\n\n    const active = master.map((split) => {\n        const id = split.id;\n\n        if (isControlMode() || !isSplitAllowedOnURL(split)) {\n            const variant = split.variants.find((x) => x.isControl) as SplitVariant;\n\n            return {\n                id,\n                variant: variant.id,\n                dimension: null,\n            };\n        }\n\n        if (hasStoredVariant(id)) {\n            return {\n                id,\n                variant: getStoredVariant(id)!,\n                dimension: split.dimension,\n            };\n        }\n\n        const res = {\n            id,\n            variant: getCalculatedVariant(split.variants)!,\n            dimension: split.dimension,\n        };\n\n        storeVariant(id, res.variant);\n        packStorage();\n\n        return res;\n    });\n\n    const domRoot = document.querySelector('html')!;\n    active.forEach((x) => {\n        if (x.dimension) {\n            domRoot.classList.add(`split-${x.id}-${x.variant}`);\n        }\n    });\n\n    // As this script is in \"critical JS path\", we have to share the state globally\n    window.splitsCurrentActiveSet = active;\n\n    if (isControlMode()) {\n        Logger.info('[AB] Control mode');\n        return;\n    }\n\n    // Removing obsolete records\n    const currentActiveSet = new Set(synced.items.map((x) => x.id));\n\n    Object.keys(storage)\n        .filter((id) => !currentActiveSet.has(id))\n        .forEach((id) => {\n            delete storage[id];\n        });\n\n    packStorage();\n}\n","import { Logger } from './logger';\n\nexport const injectSprite = async (id: string, path: string) => {\n    try {\n        if (typeof document === 'undefined') return;\n\n        const svgText = await fetch(path).then((r) => r.text());\n        const temp = document.createElement('div');\n        temp.innerHTML = svgText;\n\n        const incomingSvg = temp.querySelector('svg');\n        if (!incomingSvg) return;\n\n        let container = document.getElementById(id);\n        if (!container) {\n            container = document.createElement('div');\n            container.id = id;\n            container.className = 'hidden';\n            container.style.cssText =\n                'position:absolute;width:0;height:0;overflow:hidden;';\n            container.appendChild(incomingSvg);\n            document.body.prepend(container);\n            return;\n        }\n\n        const existingSvg = container.querySelector('svg');\n        if (!existingSvg) {\n            container.appendChild(incomingSvg);\n            return;\n        }\n\n        incomingSvg.querySelectorAll('symbol').forEach((s) => {\n            try {\n                if (!document.getElementById(s.id)) {\n                    existingSvg.appendChild(s);\n                }\n            } catch {\n                // Empty to avoid console errors\n            }\n        });\n    } catch (error) {\n        Logger.error({ error });\n    }\n};\n","import { getDataFromPocket } from '../../utils/pocket';\nimport { injectSprite } from '../../utils/svg';\n\nexport async function injectSVGSprite() {\n    const meta = getDataFromPocket<string[]>('svg_symbols', false);\n\n    if (!meta?.length) return;\n\n    await injectSprite('svg-sprite-critical', `/dist/svg/?q=${meta.join(',')}`);\n}\n","import { getDataFromPocket } from '../../utils/pocket';\n\n/* eslint-disable no-underscore-dangle */\n\nexport function monkeyPatchVWO() {\n    window.VWO_OUTCOME = 'pending';\n\n    // to store a flag of \"vwo redirect happened on the previous url\"\n    const VWO_EVENT_SESSION_KEY = 'VWO_REDIRECT';\n\n    const vwoOpts = getDataFromPocket<{ enabled: boolean }>('vwo_opts', false);\n    if (!vwoOpts?.enabled) {\n        window.VWO_OUTCOME = 'regular';\n    }\n\n    const vwoFlag = window.sessionStorage.getItem(VWO_EVENT_SESSION_KEY);\n    if (vwoFlag === 'true') {\n        window.sessionStorage.removeItem(VWO_EVENT_SESSION_KEY);\n        window.VWO_OUTCOME = 'regular';\n    }\n\n    // monkey patch .push() method to capture redirect flag\n    window._vwo_evq = window._vwo_evq || [];\n\n    const vwoPushOriginal = window._vwo_evq.push;\n\n    window._vwo_evq.push = (...args: unknown[]): number => {\n        const eventData = args[0] as string[];\n\n        if (eventData[0] === 'rD') {\n            // It will be set to true if a redirection is going to be done by VWO.\n            const willRedirectionOccur = eventData[1];\n            window.VWO_OUTCOME = willRedirectionOccur ? 'redirect' : 'regular';\n\n            if (willRedirectionOccur) {\n                window.dataLayer = window.dataLayer || [];\n                window.dataLayer.push({ vwoRedirect: 'true' });\n                window.sessionStorage.setItem(VWO_EVENT_SESSION_KEY, 'true');\n            }