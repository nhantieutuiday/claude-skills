ils-pocket-models';\n\ninterface MatomoOptions {\n    baseUrl: string;\n}\n\nconst TDUID_KEY = 'tduid';\n\nfunction storeTduid(value: string): void {\n    try {\n        localStorage.setItem(TDUID_KEY, value);\n        return;\n    } catch { /* localStorage unavailable */ }\n\n    try {\n        sessionStorage.setItem(TDUID_KEY, value);\n        return;\n    } catch { /* sessionStorage unavailable */ }\n\n    window.dataLayer = window.dataLayer || [];\n    window.dataLayer.push({ [TDUID_KEY]: value });\n}\n\nexport async function initMatomo() {\n    const opts = getDataFromPocket<MatomoOptions>('matomo')!;\n\n    // Script init\n    // eslint-disable-next-line no-underscore-dangle\n    window._paq = window._paq ?? [];\n\n    // eslint-disable-next-line no-underscore-dangle\n    const matomoDataLayer = window._paq;\n\n    // Exclude the `webrtc` component: since v1.7 it opens an RTCPeerConnection\n    // and parses the SDP offer, which leaks local network addresses.\n    const { thumbmark: userId } = await (new Thumbmark({ exclude: ['webrtc'] })).get();\n\n    storeTduid(userId);\n\n    matomoDataLayer.push(['setCookieDomain', '*.acronis.com']);\n    matomoDataLayer.push(['setDomains', ['*.acronis.com', '*.acronis.events', '*.trueimage.com']]);\n    matomoDataLayer.push(['enableCrossDomainLinking']);\n    matomoDataLayer.push(['disableCookies']);\n    matomoDataLayer.push(['enableLinkTracking']);\n    matomoDataLayer.push(['setTrackerUrl', `${opts.baseUrl}/mat/matomo.php`]);\n    matomoDataLayer.push(['setSiteId', '1']);\n    matomoDataLayer.push(['setUserId', userId]);\n\n    const script = document.createElement('script');\n    script.async = true;\n    script.src = `${opts.baseUrl}/mat/matomo.js`;\n    const targetNode = document.getElementsByTagName('script')[0]!;\n    targetNode.parentNode!.insertBefore(script, targetNode);\n\n    // Pageview event\n    const getBrowserDimensions = () => {\n        function roundToNearestHundred(value: number): number {\n            return Math.round(value / 100) * 100;\n        }\n\n        const width = roundToNearestHundred(window.innerWidth);\n        const height = roundToNearestHundred(window.innerHeight);\n\n        return `${width},${height}`;\n    };\n\n    const getSiteLocale = () => {\n        const match = window.location.pathname.match(/^[/]([a-z][a-z]-[a-z][a-z])[/]/);\n        return match && match[1] ? match[1] : null;\n    };\n\n    const dlParams = getDataFromPocket<DLParams>('ga_dl_params', false) || {};\n    const rcParams = getDataFromPocket<RCParams>('ga_rc_params', false) || {};\n    const jobParams = getDataFromPocket<JobParams>('ga_job_params', false) || {};\n\n    const dimensions = [\n        { id: 2, val: Cookies.get('AcronisUID.en') },\n        { id: 6, val: getBrowserDimensions() },\n        { id: 5, val: window.devicePixelRatio?.toFixed(2) },\n        { id: 14, val: getSiteLocale() },\n        { id: 1, val: dlParams.DL_PageType },\n        { id: 3, val: dlParams.DL_Audience },\n        { id: 4, val: dlParams.DL_Product },\n        { id: 15, val: rcParams.rcCategory },\n        { id: 16, val: rcParams.rcFeatured },\n        { id: 17, val: rcParams.rcProduct },\n        { id: 18, val: rcParams.rcType },\n        { id: 19, val: jobParams.pageDetailsA },\n        { id: 20, val: jobParams.pageDetailsB },\n        { id: 21, val: jobParams.pageDetailsC },\n        { id: 22, val: getClientIpSource() },\n        { id: 23, val: getClientJA3() },\n        { id: 24, val: getClientJA4() },\n    ];\n\n    dimensions\n        .filter(({ val }) => val !== undefined && val !== null && val !== '(not set)' && val.toString().trim())\n        .forEach((dim) => matomoDataLayer.push(['setCustomDimension', dim.id, dim.val]));\n\n    matomoDataLayer.push(['trackPageView']);\n}\n","export function increaseNavvaticCounter() {\n    Object.keys(localStorage || {})\n        .filter((name) => name.startsWith('demoButtonClickHops'))\n        .forEach((name) => {\n            const value = p