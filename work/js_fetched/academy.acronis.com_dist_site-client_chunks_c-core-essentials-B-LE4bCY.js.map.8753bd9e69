4 5.53499 49.6564 5.65499C50.0764 5.80499 50.6314 5.84999 51.2314 5.92499C51.8764 5.98499 52.4764 6.08999 53.0164 6.34499C53.7214 6.65999 54.1864 7.33499 54.1864 8.23499C54.1864 9.82499 52.9564 10.785 50.7364 10.785C48.3214 10.785 47.2264 9.70499 47.1064 8.23499Z\" fill=\"white\" />\n            <path d=\"M43.8032 1.83V0H45.7082V1.83H43.8032ZM43.8482 10.635V2.715H45.6632V10.635H43.8482Z\" fill=\"white\" />\n            <path d=\"M34.8655 10.635V2.71499H36.4555L36.5305 3.61499H36.5755C37.1605 2.92499 38.0005 2.56499 39.0355 2.56499C40.2955 2.56499 41.9455 3.20999 41.9455 5.65499V10.635H40.1305V5.95499C40.1305 4.66499 39.4405 4.15499 38.5405 4.15499C37.5355 4.15499 36.6805 4.79999 36.6805 6.16499V10.635H34.8655Z\" fill=\"white\" />\n            <path d=\"M29.1346 10.785C26.7046 10.785 24.9346 9.11999 24.9346 6.67499C24.9346 4.22999 26.7046 2.56499 29.1346 2.56499C31.5646 2.56499 33.3346 4.22999 33.3346 6.67499C33.3346 9.11999 31.5646 10.785 29.1346 10.785ZM29.1496 9.19499C30.4846 9.19499 31.4746 8.23499 31.4746 6.67499C31.4746 5.11499 30.4846 4.15499 29.1346 4.15499C27.7996 4.15499 26.7946 5.11499 26.7946 6.67499C26.7946 8.23499 27.7996 9.19499 29.1496 9.19499Z\" fill=\"white\" />\n            <path d=\"M20.0491 10.635V2.715H21.7291L21.7741 3.87H21.8191C22.3141 3.09 23.0641 2.715 23.9041 2.715H24.3691V4.56H23.6941C22.7941 4.56 21.8491 4.89 21.8491 6.69V10.635H20.0491Z\" fill=\"white\" />\n            <path d=\"M14.711 10.785C12.281 10.785 10.616 9.11999 10.616 6.67499C10.616 4.22999 12.371 2.56499 14.771 2.56499C16.766 2.56499 18.281 3.79499 18.581 5.71499H16.751C16.511 4.70999 15.746 4.10999 14.726 4.10999C13.376 4.10999 12.476 5.14499 12.476 6.67499C12.476 8.20499 13.376 9.23999 14.741 9.23999C15.716 9.23999 16.451 8.68499 16.736 7.75499H18.566C18.191 9.59999 16.646 10.785 14.711 10.785Z\" fill=\"white\" />\n            <path d=\"M0 10.635L3.705 0.434998H6.3L10.035 10.635H7.965L7.11 8.235H2.88L2.025 10.635H0ZM3.495 6.495H6.495L6 5.1C5.445 3.51 5.16 2.715 4.98 1.98H4.95C4.755 2.79 4.335 4.035 3.975 5.115L3.495 6.495Z\" fill=\"white\" />\n        </svg>\n    </div>\n</template>\n\n<script>\nexport default {\n    name: 'ATruLogo',\n    props: {\n        full: {\n            type: Boolean,\n            default: false,\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.tru-logo {\n    display: flex;\n    align-items: center;\n}\n\n.logo {\n    flex-shrink: 0;\n}\n\n.logo-text {\n    display: none;\n    flex-shrink: 0;\n\n    margin-inline-start: 24px;\n\n    @media (--viewport-mobile-wide) {\n        display: block;\n    }\n\n    @media (--viewport-desktop-wide) {\n        margin-inline-start: 14px;\n    }\n}\n</style>\n","import { mapGetters } from 'vuex';\nimport { SITE_ID_TRUEIMAGE } from '@model/const/sites.ts';\n\n// TI site requires its own slice-setting content, see https://pmc.acronis.work/browse/WEB-47984.\n// Extracted to a mixin because this decision is needed in two slices:\n// s-locale-selector and s-locale-selector-ribbon\n\nexport default {\n    computed: {\n        ...mapGetters('config', ['$config']),\n\n        localeSelectorDataSourceName() {\n            switch (this.$config.siteID) {\n                case SITE_ID_TRUEIMAGE:\n                    return 's-locale-selector-true-image';\n                default:\n                    return 's-locale-selector';\n            }\n        },\n\n        localeSelectorRibbonDataSourceName() {\n            switch (this.$config.siteID) {\n                case SITE_ID_TRUEIMAGE:\n                    return 's-locale-selector-ribbon-true-image';\n                default:\n                    return 's-locale-selector-ribbon';\n            }\n        },\n    },\n};\n","import Cookies from 'js-cookie';\n\nexport default {\n    data() {\n        return {\n            // Only used on nginx side for redirection of unlocalized links like https://www.acronis.com/products/.\n            // Will be set on mounted if the locale is not default or explicitly clicked in the ribbon\n            COOKIE_NAME_LANGUAGE_PREFIX: 'language_prefix',\n            // Used for self-ID in the desired_locale mechanics.\n            // Will ONLY be set with a user deliberate action.\n            COOKIE_NAME_DESIRED_LOCALE: 'desired_locale',\n            COOKIE_LOCALE_EXPIRATION: 30,\n        };\n    },\n\n    computed: {\n        locale() {\n            return this.$store.state.geolocation.finalLocale || 'en-us';\n        },\n    },\n\n    methods: {\n        storeLanguagePrefix(locale) {\n            if (!locale) return;\n\n            Cookies.set(this.COOKIE_NAME_LANGUAGE_PREFIX, locale, {\n                path: '/',\n                expires: this.COOKIE_LOCALE_EXPIRATION,\n            });\n        },\n\n        storeDesiredLocale(locale) {\n            if (!locale) return;\n\n            Cookies.set(this.COOKIE_NAME_DESIRED_LOCALE, locale, {\n                path: '/',\n                expires: this.COOKIE_LOCALE_EXPIRATION,\n            });\n        },\n    },\n};\n","import { mapActions } from 'vuex';\nimport formHelper from '@utils/form.js';\n\nexport default {\n    data() {\n        return {\n            instance: {\n                event_id: null,\n                email: null,\n                osauid: null,\n                gated_unlock_osauid: null,\n            },\n            ytTrack: {\n                ytId: null,\n                progress: 0,\n                duration: 0,\n                current: 0,\n            },\n            searchParams: null,\n        };\n    },\n    beforeMount() {\n        this.searchParams = new URL(document.location).searchParams;\n    },\n    methods: {\n        ...mapActions({\n            createLeadRequest: 'vroi/createLeadRequest',\n            updateLeadRequest: 'vroi/updateLeadRequest',\n        }),\n        setYtTrackId(payload) {\n            if (typeof window === 'undefined') return;\n\n            this.instance.event_id = payload;\n            this.instance.gated_unlock_osauid = localStorage.getItem(`track_id_${payload}`);\n            this.instance.email = localStorage.getItem(`track_email_${payload}`);\n        },\n        setYtEventData(payload) {\n            this.instance.email = payload?.email || null;\n            this.instance.gated_unlock_osauid = payload.osauid || null;\n            localStorage.setItem(`track_id_${this.instance.event_id}`, this.instance.gated_unlock_osauid);\n            localStorage.setItem(`track_email_${this.instance.event_id}`, this.instance.email);\n        },\n        setYtTrackData(payload) {\n            this.ytTrack.progress = payload?.progress || 0;\n            this.ytTrack.current = payload?.current || 0;\n            this.ytTrack.duration = payload?.duration || 0;\n            this.ytTrack.ytId = payload?.ytId || null;\n            this.updateOrCreateTrack();\n        },\n        async updateOrCreateTrack() {\n            if (!this.instance.email) return;\n            if (!this.instance.osauid) {\n                await this.ytTrackRequest('create');\n                return;\n            }\n\n            try {\n                await this.ytTrackRequest('update');\n            } catch (error) {\n                const status = error.response?.status;\n                if (!status || ![409, 404].includes(status)) return;\n                await this.ytTrackRequest('create');\n            }\n        },\n        async ytTrackRequest(action = 'create') {\n            const payload = {\n                ...this.instance,\n                ...this.ytTrack,\n                form_id: 'events_video_progress',\n                ck: formHelper.getCookies(formHelper.MRKTO_COOKIE_NAME) || formHelper.createMarketoToken(),\n                google_analytics_trackingid: formHelper.GA_TRACKING_ID,\n                google_analytics_userid: formHelper.getCookies(formHelper.UID_COOKIE_NAME) || '',\n                google_analytics_clientid: formHelper.getCIDval() || '[ERROR] Client ID not generated',\n                ...formHelper.labelsUTM(),\n                ...formHelper.sfdcCampaign(),\n                ...formHelper.sfdcCampaignSmart(),\n            };\n            const updateOrCreate = action === 'update' ? this.updateLeadRequest : this.createLeadRequest;\n            const response = await updateOrCreate(payload);\n            this.instance.osauid = response.data.data.osauid;\n        },\n    },\n};\n","import { mapState } from 'vuex';\n\nexport default {\n    computed: {\n        ...mapState({\n            productItems: (state) => state.products.items,\n            productId: (state) => state.pages?.page.product_id,\n            currency: (state) => state.locales?.locale?.currency || 'USD',\n            currencyFormat: (state) => state.locales?.locale?.currency_format || '12,345,678.91',\n            currencyList: (state) => state.slices?.items?.currency?.list || [],\n            countryCode: (state) => state.geolocation.location?.data?.country?.code || '',\n            licensesItems: (state) => state.licenses?.data || {},\n        }),\n\n        currencyItem() {\n            if (!this.hasDifferentCurrencies) return {};\n            return this.currencyList.find((item) => item.countryCodes?.includes(this.countryCode)) || {};\n        },\n\n        productCurrency() {\n            if (this.currencyItem.currency) return this.currencyItem.currency;\n            return this.productItems?.[this.productID]?.parameters?.common?.currency || this.currency;\n        },\n\n        hasDifferentCurrencies() {\n            return ['en-en', 'pt-br'].includes(this.$store.state.geolocation.desiredLocale);\n        },\n    },\n\n    data() {\n        return {\n            isLoadedPrices: true,\n        };\n    },\n\n    methods: {\n        setCurrency(value, settings = {}) {\n            const matches = this.productCurrencyFormat(settings).match(\n                /^([^\\d\\s]*)(\\s*)(\\d+)([^\\d])?(\\d{3})([^\\d])?(\\d{3})(([^\\d])(\\d+))?(\\s*)([^\\d\\s]*)$/,\n            );\n\n            const price = !value && settings?.zeroByDefault ? 0 : parseFloat(value);\n            if (!settings?.zeroByDefault && (!matches || price <= 0)) {\n                return '???';\n            }\n\n            const currency = {\n                symbol: matches[1] ? matches[1] : matches[12],\n                space: matches[1] ? matches[2] : matches[11],\n                position: matches[1] ? 'before' : 'after',\n                decimalsDrop: !matches[8],\n                decimalsCustom: matches[10] ? matches[10].length : 0,\n                decimalDelimiter: matches[9] ? matches[9] : '.',\n                groupDelimiter: matches[4] && matches[6] && matches[4] === matches[6] ? matches[4] : '',\n                postfix: matches[1] ? matches[11] + matches[12] : '',\n            };\n\n            const source = String(\n                currency.decimalsDrop ? Math.ceil(price) : price.toFixed(currency.decimalsCustom),\n            );\n            const integer = source.split('.')[0];\n            const groupsCount = integer.length > 3 ? integer.length % 3 : 0;\n            let result = groupsCount ? integer.substr(0, groupsCount) + currency.groupDelimiter : '';\n            result += integer.substr(groupsCount).replace(/(\\d{3})(?=\\d)/g, `$1${currency.groupDelimiter}`);\n\n            const fraction = source.split('.')[1] || 0;\n            result += !currency.decimalsDrop ? currency.decimalDelimiter + fraction : '';\n\n            if (settings && settings.withoutCurrencySymbol) {\n                currency.symbol = '';\n            }\n\n            currency.space = currency.space ? ' ' : '';\n            if (currency.position === 'before') {\n                result = currency.symbol + currency.space + result + currency.postfix;\n            } else {\n                result += currency.space + currency.symbol;\n            }\n\n            return result\n                .replace(/(&euro;|&pound;|&yen;)/g, '<sup>$1</sup>')\n                .replaceAll(' ', '&nbsp;')\n                .replace(/\\$&/g, '&dollar;&'); // $& inserts the matched substring\n        },\n\n        productCurrencyFormat(settings) {\n            if (this.currencyItem.currencyFormat) {\n                return this.currencyItem.currencyFormat;\n            }\n            if (settings.format) {\n                return settings.format;\n            }\n            const productId = settings.productId || this.productId;\n            const productItem = this.productItems?.[productId] || {};\n            return productItem.parameters?.common?.currency_format || this.currencyFormat;\n        },\n\n        async getCurrency() {\n            if (!this.hasDifferentCurrencies) return;\n\n            this.isLoadedPrices = false;\n\n            await this.$store.dispatch('geolocation/getGeoLocation');\n\n            if (!this.currencyItem.locale || !this.currencyItem.currencyFormat) {\n                this.isLoadedPrices = true;\n                return;\n            }\n\n            await this.getLicenses({\n                locale: this.currencyItem.locale,\n                isPurchase: Boolean(this.isPurchase),\n                cleverBridgeCartList: this.licensesItems.map((item) => item.cleverbridge_id),\n            });\n\n            this.isLoadedPrices = true;\n        },\n    },\n\n    async serverPrefetch() {\n        // The currency of the country selected by the user should be used.\n        const locale = this.$store.state.geolocation.desiredLocale || this.$store.state.geolocation.requestedLocale;\n        await this.$store.dispatch('locales/getLocaleData', { locale });\n        await this.$store.dispatch('slices/getSyncedData', { slice: 'currency', locale });\n    },\n};\n","export const GOOGLE_MAP_API_KEY = 'AIzaSyBjxiXjlbfwB6XYedcmed29xNKQlQPbIAM';\nexport const RECAPTCHA_ENTERPRISE_INVISIBLE_KEY = '6LcMQSEjAAAAAPWFRMLg7n6NERJhIndKRAbBcoKo';\nexport const RECAPTCHA_SCRIPT_SRC = 'https://www.google.com/recaptcha/enterprise.js?render=explicit';\nexport const RECAPTCHA_SCRIPT_SRC_CHINA = 'https://www.recaptcha.net/recaptcha/enterprise.js?render=explicit';\nexport const GOOGLE_SEARCH_CX_KEY = '368730cd75f71415a';\nexport const GOOGLE_SEARCH_API_KEY = 'AIzaSyBx70YZuWyyzRfP22ZBpFqLrosyrYrzg08';\n","import {\n    RECAPTCHA_SCRIPT_SRC,\n    RECAPTCHA_SCRIPT_SRC_CHINA,\n    RECAPTCHA_ENTERPRISE_INVISIBLE_KEY,\n} from '@model/const/api-keys.ts';\n\nexport default {\n    data() {\n        return {\n            captchaError: false,\n            recaptchaResponse: '',\n            recaptchaWidgetId: null,\n        };\n    },\n\n    computed: {\n        hasRecaptchaInvisible() {\n            const rc = this.content?.recaptcha || this.form?.registration?.recaptcha || {};\n            return rc.isActive && rc.isInvisible;\n        },\n\n        recaptchaAction() {\n            if (this.form?.form_id !== 'events_hub_main') return '';\n\n            const result = ['utm_medium', 'utm_source', 'utm_term', 'utm_campaign']\n                .filter((key) => window.sessionStorage.getItem(key))\n                .map((key) => `${window.sessionStorage.getItem(key)}`)\n                .join('/');\n\n            return `form_events/${result}`.slice(0, 100).replace(/[^A-Za-z/_]/g, '_');\n        },\n    },\n\n    methods: {\n        recaptchaActive() {\n            return window.grecaptcha.enterprise || window.grecaptcha;\n        },\n\n        recaptchaInject(country) {\n            const callbackUniqueName = `gr_callback_${Math.random().toString().replace('.', '_')}`;\n            window[callbackUniqueName] = this.recaptchaRender;\n\n            const script = document.createElement('script');\n            const src = ['CN', 'MO', 'HK'].includes(country) ? RECAPTCHA_SCRIPT_SRC_CHINA : RECAPTCHA_SCRIPT_SRC;\n            script.src = `${src}&onload=${callbackUniqueName}`;\n            document.body.appendChild(script);\n        },\n\n        recaptchaRender() {\n            // Avoid flacky tests\n            // eslint-disable-next-line no-underscore-dangle\n            if (typeof window !== 'undefined' && window.__vitest_browser__ && !this.$refs.recaptcha) return;\n\n            this.recaptchaWidgetId = this.recaptchaActive().render(this.$refs.recaptcha, {\n                sitekey: RECAPTCHA_ENTERPRISE_INVISIBLE_KEY,\n                action: this.recaptchaAction,\n                callback: this.recaptchaCallback,\n                size: 'invisible',\n            });\n        },\n\n        recaptchaCallback(response) {\n            this.recaptchaResponse = response;\n        },\n    },\n};\n","import { type Result, ok, err } from './result';\n\nexport function sleep(dur: number): Promise<void> {\n    // eslint-disable-next-line no-promise-executor-return\n    return new Promise((resolve) => setTimeout(resolve, dur));\n}\n\nexport interface BackoffOptions<T> {\n    // Max number of attempts\n    retries: number,\n    // If not provided, exponential backoff with base=10 will be used (1000ms, 10000ms, etc.)\n    delayFn?: (i: number) => number,\n    // A closure to perform an attempt\n    worker: () => Promise<T>,\n}\n\nexport async function backoff<T>(options: BackoffOptions<T>): Promise<Result<T>> {\n    if (options.retries <= 0) {\n        throw new Error('Retries must be a positive number');\n    }\n\n    const delayFn = options.delayFn ?? ((i: number) => 10 ** (i + 3));\n\n    let lastError: Error | undefined;\n\n    for (let i = 0; i < options.retries; i++) {\n        /* eslint-disable no-await-in-loop */\n        try {\n            const res = await options.worker();\n            return ok(res);\n        } catch (error) {\n            lastError = error as Error;\n            await sleep(delayFn(i));\n        }\n        /* eslint-enable */\n    }\n\n    // eslint-disable-next-line @typescript-eslint/no-unnecessary-type-assertion\n    return err(lastError!);\n}\n","let db = null;\n\nexport async function getDB() {\n    if (!db) {\n        const { Dexie } = await import('dexie/dist/modern/dexie.mjs');\n        db = new Dexie('form');\n        db.version(1).stores({ fields: '++id' });\n    }\n\n    return db;\n}\n","<template>\n    <component :is=\"tag\" :class=\"classNames\" :style=\"style\">\n        <slot />\n    </component>\n</template>\n\n<script lang=\"ts\">\nexport default {\n    name: 'ACol',\n\n    props: {\n        span: {\n            type: Number,\n            default: 24,\n        },\n        tag: {\n            type: String,\n            default: 'div',\n        },\n        offset: {\n            type: Number,\n            default: 0,\n        },\n        xs: {\n            type: [Number, Object],\n            default: undefined,\n        },\n        sm: {\n            type: [Number, Object],\n            default: undefined,\n        },\n        md: {\n            type: [Number, Object],\n            default: undefined,\n        },\n        lg: {\n            type: [Number, Object],\n            default: undefined,\n        },\n        xl: {\n            type: [Number, Object],\n            default: undefined,\n        },\n    },\n\n    computed: {\n        gutter() {\n            let parent = this.$parent;\n            while (parent && parent.$options.name !== 'ARow') {\n                parent = parent.$parent;\n            }\n            return parent ? parent.gutter : 0;\n        },\n\n        style() {\n            if (!this.gutter) return {};\n\n            const padding = `${this.gutter / 2}px`;\n            return {\n                paddingLeft: padding,\n                paddingRight: padding,\n            };\n        },\n\n        classNames() {\n            const classList = ['a-form-col'];\n\n            if (this.span) {\n                classList.push(`a-form-col-${this.span}`);\n            }\n\n            if (this.offset) {\n                classList.push(`a-form-col-offset-${this.offset}`);\n            }\n\n            ['xs', 'sm', 'md', 'lg', 'xl'].forEach((size) => {\n                if (typeof this[size] === 'number') {\n                    classList.push(`a-form-col-${size}-${this[size]}`);\n                } else if (typeof this[size] === 'object') {\n                    const props = this[size];\n                    Object.keys(props).forEach((prop) => {\n                        classList.push(prop !== 'span'\n                            ? `a-form-col-${size}-${prop}-${props[prop]}`\n                            : `a-form-col-${size}-${props[prop]}`);\n                    });\n                }\n            });\n\n            return classList;\n        },\n    },\n};\n</script>\n","<template>\n    <component :is=\"tag\" :class=\"classNames\" :style=\"style\">\n        <slot />\n    </component>\n</template>\n\n<script lang=\"ts\">\nexport default {\n    name: 'ARow',\n\n    props: {\n        align: {\n            type: String,\n            default: 'top',\n        },\n        gutter: {\n            type: Number,\n            default: 0,\n        },\n        justify: {\n            type: String,\n            default: 'start',\n        },\n        tag: {\n            type: String,\n            default: 'div',\n        },\n    },\n\n    computed: {\n        style() {\n            if (!this.gutter) return {};\n\n            const margin = `-${this.gutter / 2}px`;\n            return {\n                marginLeft: margin,\n                marginRight: margin,\n            };\n        },\n\n        classNames() {\n            return {\n                'a-form-row': true,\n                [`is-justify-${this.justify}`]: this.justify !== 'start',\n                [`is-align-${this.align}`]: this.align !== 'top',\n            };\n        },\n    },\n};\n</script>\n<style lang=\"postcss\" scoped>\n.a-form-row {\n    position: relative;\n    box-sizing: border-box;\n\n    &.is-justify-center {\n      justify-content: center;\n    }\n\n    &.is-justify-end {\n      justify-content: flex-end;\n    }\n\n    &.is-justify-space-between {\n      justify-content: space-between;\n    }\n\n    &.is-justify-space-around {\n      justify-content: space-around;\n    }\n\n    &.is-align-middle {\n      align-items: center;\n    }\n\n    &.is-align-bottom {\n      align-items: flex-end;\n    }\n\n    &::before,\n    &::after {\n      display: table;\n      content: '';\n    }\n\n    &::after {\n      clear: both;\n    }\n}\n</style>\n","<template>\n    <div v-if=\"content\" class=\"s-form-change\" :class=\"className\">\n        <div v-if=\"content.title\" class=\"s-form-change__title\">\n            <p v-for=\"(text, i) in content.title\" :key=\"i\" class=\"s-form-change__title-item\">\n                {{ text }}\n            </p>\n        </div>\n        <a-picture v-if=\"content.picture\" class=\"s-form-change__picture\" :link=\"content.picture\" />\n        <div v-if=\"content.description\" class=\"s-form-change__description\">\n            <p v-for=\"(text, i) in content.description\" :key=\"i\" class=\"s-form-change__description-item\">\n                {{ text }}\n            </p>\n        </div>\n        <el-form ref=\"form\" :model=\"form\" :rules=\"rules\">\n            <a-row>\n                <a-col>\n                    <el-form-item prop=\"businessEmail\">\n                        <el-input\n                            ref=\"businessEmail\"\n                            v-model=\"form.businessEmail\"\n                            autofocus\n                            name=\"businessEmail\"\n                            :label=\"content.form.label\"\n                        />\n                    </el-form-item>\n                </a-col>\n            </a-row>\n            <a-row>\n                <a-col>\n                    <a-button\n                        class=\"s-form-change__button\"\n                        :type=\"content.form.buttonType || 'action'\"\n                        v-bind=\"content.form\"\n                        :text=\"content.form.button\"\n                        :event=\"{ doNotSendGA: true }\"\n                        @click=\"submit\"\n                    />\n                </a-col>\n            </a-row>\n        </el-form>\n        <p class=\"s-form-change__skip\">\n            <a-link :text=\"content.form.link\" @click=\"$emit('submit', email)\" />\n        </p>\n    </div>\n</template>\n\n<script>\nimport AButton from '@core/components/button/button.vue';\nimport ACol from '@core/components/col/col.vue';\nimport ElFormItem from '@core/components/form/form-item.vue';\nimport ElForm from '@core/components/form/form.vue';\nimport ElInput from '@core/components/input/input.vue';\nimport ALink from '@core/components/link/link.vue';\nimport APicture from '@core/components/picture/picture.vue';\nimport ARow from '@core/components/row/row.vue';\nimport form from '@core/mixins/form';\n\nexport default {\n    name: 'TrialFormChangeEmail',\n\n    components: {\n        AButton,\n        ALink,\n        APicture,\n        ElForm,\n        ElFormItem,\n        ElInput,\n        ACol,\n        ARow,\n    },\n\n    mixins: [form],\n\n    props: {\n        content: {\n            type: Object,\n            default: null,\n        },\n\n        email: {\n            type: String,\n            default: '',\n        },\n    },\n\n    emits: ['submit'],\n\n    data: () => ({\n        firstClick: true,\n        form: {\n            businessEmail: '',\n        },\n    }),\n\n    computed: {\n        rules() {\n            return {\n                businessEmail: [\n                    {\n                        trigger: 'submit',\n                        isBusinessOnlyEmail: true,\n                        validator: this.validateEmail,\n                        errorMessageBusiness: this.setErrorMessage('emailFree'),\n                    },\n                ],\n            };\n        },\n\n        className() {\n            return `s-form-change-lang-${this.language}`;\n        },\n    },\n\n    mounted() {\n        this.form.businessEmail = this.email;\n    },\n\n    methods: {\n        async submit() {\n            try {\n                this.prepareFormToValidate();\n                await this.$nextTick();\n                await this.$refs.form?.validate();\n                this.$emit('submit', this.form.businessEmail);\n            } catch (error) {\n                this.setFocusErrorField();\n            }\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-form-change {\n    width: 100%;\n    display: flex;\n    margin: 0 0 auto;\n    text-align: center;\n    align-items: center;\n    flex-direction: column;\n    padding: 72px 16px 44px;\n    justify-content: center;\n    background: var(--av-inversed-primary);\n\n    @media (--viewport-mobile-wide) {\n        border-radius: 4px;\n        padding: 48px 48px 42px;\n        box-shadow: var(--av-shadow-small);\n        border: 1px solid var(--av-brand-light);\n    }\n\n    @media (--viewport-tablet) {\n        margin: 56px auto 0;\n    }\n\n    @media (--viewport-desktop) {\n        margin: 0 auto;\n    }\n\n    &__title {\n        @mixin title-accent;\n        color: var(--av-nav-primary);\n    }\n\n    &__description {\n        @mixin paragraph;\n        margin: 16px 0 0;\n        color: var(--av-nav-primary);\n    }\n\n    &__title-item,\n    &__description-item {\n        &:not(:first-child) {\n            margin: 8px 0 0;\n        }\n    }\n\n    &-lang-en {\n        .s-form-change {\n            &__title,\n            &__description {\n                max-width: 448px;\n            }\n        }\n    }\n\n    .el-form {\n        width: 100%;\n        margin: 32px 0 0;\n        text-align: start;\n    }\n\n    &__button {\n        width: 100%;\n        margin: 16px 0 0;\n    }\n\n    &__skip {\n        margin: 24px 0 0;\n        text-align: center;\n\n        :deep(.a-link) {\n            cursor: pointer;\n        }\n    }\n}\n</style>\n","<template>\n    <div class=\"business_address\" autocomplete=\"new-password\">\n        <label :for=\"id\">\n            {{ label }}\n        </label>\n        <input\n            :id=\"id\"\n            v-model=\"business_address\"\n            type=\"text\"\n            :placeholder=\"placeholder\"\n            class=\"required\"\n            data-required=\"true\"\n            autocomplete=\"new\"\n            role=\"presentation\"\n        />\n    </div>\n</template>\n\n<script>\nexport default {\n    data: () => ({\n        business_address: '',\n        id: 'business_address',\n        label: 'Business address',\n        placeholder: 'Enter business address',\n    }),\n    methods: {\n        getValue() {\n            return this.business_address;\n        },\n        isCaptured() {\n            if (import.meta.env.SSR) return false;\n            return Boolean(this.getValue());\n        },\n        sendGAEvent() {\n            window.dataLayer = window.dataLayer || [];\n            window.dataLayer.push({\n                event: 'Capture',\n                honeypotCapture: 'true',\n            });\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.business_address {\n    transform: scale(0);\n    margin-top: -24px;\n}\n</style>\n","const lib = {\n    isLoaded: false,\n    AsYouType: null,\n    getCountryCallingCode: null,\n    getExampleNumber: null,\n    isSupportedCountry: null,\n    parsePhoneNumber: null,\n    examples: null,\n};\n\nexport async function getLibPhoneNumber() {\n    if (lib.isLoaded) {\n        return lib;\n    }\n\n    /* eslint-disable object-curly-newline */\n    const {\n        AsYouType,\n        getCountryCallingCode,\n        getExampleNumber,\n        isSupportedCountry,\n        parsePhoneNumber,\n    } = await import('libphonenumber-js/max');\n    /* eslint-enable object-curly-newline */\n\n    const examplesModule = await import('libphonenumber-js/mobile/examples');\n\n    lib.AsYouType = AsYouType;\n    lib.getCountryCallingCode = getCountryCallingCode;\n    lib.getExampleNumber = getExampleNumber;\n    lib.isSupportedCountry = isSupportedCountry;\n    lib.parsePhoneNumber = parsePhoneNumber;\n    lib.examples = examplesModule.default;\n    lib.isLoaded = true;\n\n    return lib;\n}\n","<template>\n    <el-form-item\n        class=\"phone-number-input\"\n        :prop=\"prop\"\n        :hint=\"formattedExampleNumber\"\n        :rules=\"rules\"\n    >\n        <el-select\n            v-bind=\"labelSelect\"\n            ref=\"countrySelect\"\n            v-model=\"computedCountry\"\n            class=\"country-input\"\n            dynamic-width\n            filterable\n            :change-on-options-removal=\"false\"\n            :validate-event=\"false\"\n            :filter-method=\"onCodeFilter\"\n            :label=\"countryLabel\"\n            :popper-class=\"popperClass || 'phone-input-dropdown'\"\n            popper-max-height=\"210px\"\n            @change=\"onCodeChange\"\n        >\n            <el-option\n                v-for=\"item in countriesList\"\n                :key=\"item.iso_code\"\n                :label=\"getCountryMetaData(item.iso_code)?.parsed_code\"\n                :value=\"item.iso_code\"\n            >\n                {{ getCountryMetaData(item.iso_code)?.parsed }}\n            </el-option>\n        </el-select>\n        <el-input\n            v-model=\"phone\"\n            :label=\"labels.phoneLabel\"\n            :placeholder=\"placeholder\"\n            :name=\"prop\"\n            type=\"tel\"\n            class=\"phone-input\"\n            :maxlength=\"20\"\n            :minlength=\"3\"\n            :required=\"required\"\n            @change=\"onChange\"\n            @blur=\"setPhone\"\n            @input=\"onInput\"\n            @paste=\"onInput\"\n        >\n            <template v-if=\"$slots.suffix\" #suffix>\n                <slot name=\"suffix\" />\n            </template>\n        </el-input>\n    </el-form-item>\n</template>\n\n<script>\nimport { mapState } from 'vuex';\nimport ElFormItem from '@core/components/form/form-item.vue';\nimport ElInput from '@core/components/input/input.vue';\nimport ElOption from '@core/components/select/option.vue';\nimport ElSelect from '@core/components/select/select.vue';\nimport breakpoints from '@core/mixins/breakpoint.js';\nimport form from '@core/mixins/form.js';\nimport { LOCALE_DEFAULT } from '@model/const/locales.ts';\nimport { getLibPhoneNumber } from './libphonenumber.js';\n\nexport default {\n    name: 'APhoneInput',\n    components: {\n        ElFormItem,\n        ElInput,\n        ElOption,\n        ElSelect,\n    },\n    mixins: [form, breakpoints],\n    props: {\n        prop: {\n            type: String,\n            default: 'phone-number-input',\n        },\n        defaultPhone: {\n            type: String,\n            default: '',\n        },\n        defaultCountry: {\n            type: String,\n            default: null,\n        },\n        settings: {\n            type: Object,\n            default: null,\n        },\n        popperClass: {\n            type: String,\n            default: null,\n        },\n        required: {\n            type: Boolean,\n            default: false,\n        },\n        placeholder: {\n            type: String,\n            default: null,\n        },\n    },\n    emits: ['change', 'update', 'update:modelValue'],\n    data() {\n        // NB: the component can't work properly until libphonenumber-js is loaded,\n        // but the win of dynamic load is too big (approx 400KB unzipped).\n        // The tradeoff is a small delay on poor networks (starts to be noticeable on \"Slow 4G\").\n        // To make it more subtle, we start loading ASAP (in `created`),\n        // but waiting in the `mounted` for the import promise.\n        return {\n            libphonenumber: null,\n            libphonenumberPromise: null,\n            supportedCountries: null,\n            filteredCountries: null,\n            country: null,\n            code: null,\n            phone: '',\n        };\n    },\n    computed: {\n        ...mapState({\n            countries: (state) => state.countries?.items || [],\n        }),\n        rules() {\n            return {\n                required: true,\n                errorMessage: this.setErrorMessage('notFilledPhone'),\n                trigger: 'blur',\n                validator: this.validatePhone.bind(this),\n            };\n        },\n        locale() {\n            return this.$store.state.geolocation.finalLocale || LOCALE_DEFAULT;\n        },\n        labels() {\n            return {\n                example: 'Example:',\n                countryLabel: 'Country code',\n                phoneLabel: 'Phone',\n                ...this.settings?.labels,\n            };\n        },\n        countriesList() {\n            return this.filteredCountries || this.supportedCountries;\n        },\n        countryLabel() {\n            const countryName = this.getCountryMetaData(this.computedCountry)?.name;\n            return countryName || this.labels?.countryLabel || null;\n        },\n        formattedExampleNumber() {\n            const exampleNumber = this.exampleNumber ? this.exampleNumber.formatNational() : null;\n            return `${this.labels?.example} ${exampleNumber || ''}`;\n        },\n        parsedPhone() {\n            try {\n                return this.libphonenumber.parsePhoneNumber(this.phone, {\n                    defaultCountry: this.computedCountry,\n                    defaultCallingCode: this.computedCode,\n                    extract: false,\n                });\n            } catch {\n                return this.phone;\n            }\n        },\n        exampleNumber() {\n            return this.libphonenumber && this.computedCountry\n                ? this.libphonenumber.getExampleNumber(this.computedCountry, this.libphonenumber.examples)\n                : false;\n        },\n        computedCode: {\n            get() {\n                return this.computedCountry\n                    ? this.libphonenumber.getCountryCallingCode(this.computedCountry)\n                    : this.code;\n            },\n            set(newValue) {\n                this.code = newValue;\n            },\n        },\n        computedCountry: {\n            get() {\n                const country = this.country || this.defaultCountry;\n                this.changeCallingCode(country);\n                return country;\n            },\n            set(newValue) {\n                this.country = newValue;\n                this.changeCallingCode(newValue);\n            },\n        },\n    },\n    watch: {\n        defaultCountry() {\n            if (!this.libphonenumber.isSupportedCountry(this.defaultCountry)) return;\n            if (this.phone?.length) return;\n            this.computedCountry = this.defaultCountry;\n        },\n        defaultPhone() {\n            if (this.phone?.length) return;\n            this.initPhone();\n        },\n    },\n    async created() {\n        this.libphonenumberPromise = getLibPhoneNumber();\n        this.libphonenumber = await this.libphonenumberPromise;\n    },\n    async mounted() {\n        await this.libphonenumberPromise;\n        this.initCountries();\n        this.initPhone();\n    },\n    updated() {\n        this.$emit('update:modelValue', this.parsedPhone);\n        this.$emit('update');\n    },\n    methods: {\n        initCountries() {\n            this.supportedCountries = this.countries.filter(\n                (el) => this.libphonenumber.isSupportedCountry(el.iso_code),\n            );\n        },\n        changeCallingCode(country) {\n            if (!country) return;\n            this.computedCode = this.libphonenumber?.getCountryCallingCode(country);\n        },\n        getCountryMetaData(country) {\n            if (!country) return null;\n\n            const name = this.countries.find((el) => el.iso_code === country)?.name;\n            const code = this.libphonenumber?.getCountryCallingCode(country);\n\n            return {\n                code,\n                name,\n                parsed_code: `+${code} `,\n                parsed: `${name} +${code} `,\n            };\n        },\n        validatePhone(rule, value, callback) {\n            if (!this.computedCode) callback(new Error(this.setErrorMessage('notFilledCallingCode')));\n            if (!this.phone) callback(new Error(this.setErrorMessage('notFilledPhone')));\n\n            try {\n                const phoneNumber = this.libphonenumber.parsePhoneNumber(this.phone, {\n                    defaultCountry: this.computedCountry,\n                    defaultCallingCode: this.computedCode,\n                    extract: false,\n                });\n                const countrySupported = this.countries.find((el) => el.iso_code === phoneNumber.country);\n                if (!countrySupported) {\n                    callback(new Error(this.setErrorMessage('invalidPhone')));\n                }\n                if (!phoneNumber.isValid() || !phoneNumber.isPossible()) {\n                    callback(new Error(this.setErrorMessage('invalidPhone')));\n                } else {\n                    callback();\n                }\n            } catch {\n                callback(new Error(this.setErrorMessage('invalidPhone')));\n            }\n        },\n        onInput() {\n            try {\n                const phoneNumber = this.libphonenumber.parsePhoneNumber(this.phone);\n                const countrySupported = this.countries.find((el) => el.iso_code === phoneNumber.country);\n\n                if (phoneNumber.country === undefined) {\n                    this.computedCountry = 'US';\n                    return;\n                }\n\n                if (!countrySupported) {\n                    this.phone = '';\n                    this.computedCountry = 'US';\n                    return;\n                }\n\n                if (this.computedCountry === phoneNumber.country) return;\n                this.computedCountry = phoneNumber?.country;\n            } catch {\n                /* Should be called to avoid console errors from parsePhoneNumber */\n            }\n        },\n        setPhone() {\n            this.phone = this.computedCountry\n                ? new this.libphonenumber.AsYouType(this.computedCountry).input(this.phone)\n                : this.phone;\n        },\n        initPhone() {\n            if (!this.defaultPhone) return;\n            this.phone = this.defaultPhone;\n            const phoneNumber = this.parsedPhone;\n            this.computedCountry = phoneNumber?.country || '';\n            this.computedCode = phoneNumber?.countryCallingCode || '';\n            this.phone = phoneNumber?.nationalNumber || '';\n            this.setPhone();\n        },\n        onChange() {\n            this.$emit('update:modelValue', this.parsedPhone);\n            this.$emit('change', this.parsedPhone);\n        },\n        onCodeChange(value) {\n            if (value?.length) this.phone = '';\n            this.changeCallingCode(this.computedCountry);\n        },\n        onCodeFilter(searchQuery) {\n            const query = searchQuery.toLowerCase();\n            this.filteredCountries = this.supportedCountries.filter((country) => {\n                const meta = this.getCountryMetaData(country.iso_code)?.parsed;\n                return meta?.toLowerCase().includes(query);\n            });\n\n            if (!query) {\n                this.filteredCountries = null;\n                return;\n            }\n\n\n            // Trigger dropdown update manually\n            this.$nextTick(() => {\n                this.$refs.countrySelect?.handleQueryChange?.(searchQuery, true);\n            });\n\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.phone-number-input {\n    .country-input {\n        position: absolute;\n        width: 108px;\n        top: 1px;\n        bottom: 1px;\n        left: 1px;\n        :deep(.el-input__container) {\n            height: 45px;\n            border: none;\n        }\n        @media (--viewport-mobile-wide) {\n            width: 150px;\n            height: 48px;\n        }\n        :deep(.el-input) {\n            margin: 1px;\n        }\n        :deep(.el-select-dropdown-search-form) {\n            margin: 0;\n        }\n    }\n    .phone-input {\n        width: 100%;\n        :deep(.el-input__container) {\n            padding-left: 110px;\n            @media (--viewport-mobile-wide) {\n                padding-left: 156px;\n            }\n        }\n        :deep(.el-input__wrapper) {\n            flex-shrink: 0;\n            width: 100%;\n            padding-left: 16px;\n            border-left: 1px solid var(--av-brand-light);\n            .el-input__label {\n                padding-left: 16px;\n            }\n            &:has(+ .el-input__suffix) {\n                width: calc(100% - 40px);\n            }\n        }\n    }\n    :deep(.el-form-item__hint) {\n        @mixin caption-accent;\n        margin: 0 0 16px;\n        color: var(--av-fixed-light);\n    }\n    :deep(.el-select-dropdown__wrap) {\n        margin-inline: 0 !important;\n    }\n    &.is-error {\n        .phone-input {\n            :deep(.el-input__wrapper) {\n                border-left: 1px solid var(--av-fixed-danger);\n            }\n        }\n    }\n    &.is-focus {\n        .phone-input {\n            :deep(.el-input__container) {\n                border: 1px solid var(--av-brand-primary);\n            }\n            :deep(.el-input__wrapper) {\n                border-left: 1px solid var(--av-brand-primary);\n            }\n        }\n    }\n}\n\n[dir=\"rtl\"] {\n    .phone-number-input {\n        :deep(.el-input__editor) {\n            direction: ltr;\n            text-align: end;\n        }\n    }\n}\n</style>\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <label\n        class=\"el-radio qa-radio\"\n        :class=\"{\n            'is-disabled': isDisabled,\n            'is-checked': isChecked,\n            'is-focus': isFocused,\n            'is-active': isActive\n        }\"\n        :title=\"computedTitle\"\n        @keydown.enter.stop.prevent=\"handleKeyDown\"\n        @keyup.enter.stop.prevent=\"handleKeyUp\"\n    >\n        <span class=\"el-radio__content qa-radio-content\">\n            <span class=\"el-radio__control qa-radio-control\">\n                <input\n                    ref=\"input\"\n                    class=\"el-radio__original qa-radio-original\"\n                    type=\"radio\"\n                    role=\"radio\"\n                    :name=\"name\"\n                    :value=\"label\"\n                    :disabled=\"isDisabled\"\n                    :checked=\"isChecked\"\n                    :tabindex=\"tabIndex\"\n                    :aria-checked=\"isChecked\"\n                    :aria-disabled=\"isDisabled\"\n                    @change=\"handleChange\"\n                    @click=\"handleClick\"\n                    @focus=\"handleFocus\"\n                    @blur=\"handleBlur\"\n                />\n            </span>\n            <span v-if=\"$slots.default\" class=\"el-radio__label qa-radio-label\">\n                <slot />\n            </span>\n        </span>\n        <span v-if=\"$slots.description\" class=\"el-radio__description\">\n            <slot name=\"description\" />\n        </span>\n    </label>\n</template>\n\n<script setup>\nimport { computed, inject, ref } from 'vue';\n\nconst emit = defineEmits(['update:modelValue', 'change']);\nconst props = defineProps({\n    label: { type: [String, Number, Boolean], default: '' },\n    name: { type: String, default: '' },\n    modelValue: { type: [String, Number, Boolean], default: false },\n    disabled: Boolean,\n    showHoverHint: Boolean,\n});\n\nconst input = ref(null);\nconst isFocused = ref(false);\nconst isActive = ref(false);\n\nconst radioGroup = inject('radioGroup', null);\nconst elFormItem = inject('elFormItem', null);\n\nconst isGroup = computed(() => Boolean(radioGroup));\nconst isDisabled = computed(() => props.disabled || radioGroup?.disabled);\nconst isChecked = computed(() => {\n    return isGroup.value\n        ? radioGroup?.modelValue?.value === props.label\n        : props.modelValue === props.label;\n});\nconst computedTitle = computed(() => props.showHoverHint ? String(props.label || '') : null);\nconst tabIndex = computed(() => isDisabled.value ? -1 : 0);\n\nfunction handleChange(e) {\n    if (isGroup.value) {\n        radioGroup?.updateModelValue?.(props.label);\n        radioGroup?.emitChange?.(props.label);\n    } else {\n        emit('update:modelValue', props.label);\n        emit('change', props.label, e);\n    }\n\n    elFormItem?.markAsTouched?.();\n    elFormItem?.validate?.('change');\n\n}\n\nfunction handleFocus() {\n    isFocused.value = true;\n}\nfunction handleBlur() {\n    isFocused.value = false;\n    isActive.value = false;\n    elFormItem?.validate?.('blur');\n}\nfunction handleKeyDown() {\n    isActive.value = true;\n}\nfunction handleKeyUp() {\n    isActive.value = false;\n}\nfunction handleClick() {\n    if (!input.value?.contains(document.activeElement)) {\n        input.value?.focus();\n    }\n}\n</script>\n\n<style scoped lang=\"postcss\">\n.el-radio {\n    display: inline-block;\n    vertical-align: middle;\n    max-width: 100%;\n    outline: none;\n    position: relative;\n    cursor: pointer;\n    user-select: none;\n    &__content {\n        display: flex;\n        gap: 8px;\n        align-items: center;\n        height: inherit;\n    }\n    &__original {\n        width: 0;\n        height: 0;\n        margin: 0;\n        outline: none;\n        position: absolute;\n        opacity: 0;\n    }\n    &__description {\n        color: var(--av-fixed-light);\n        display: block;\n        padding-left: 24px\n    }\n    &__control {\n        box-sizing: border-box;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        min-width: 16px;\n        width: 16px;\n        height: 16px;\n        border: 1px solid var(--av-brand-light);\n        border-radius: 50%;\n        background-color: var(--av-inversed-primary);\n        background-clip: content-box\n    }\n    &__label {\n        @mixin body;\n        color: var(--av-fixed-secondary);\n        overflow: hidden;\n        text-overflow: ellipsis;\n        white-space: nowrap;\n        max-width: 100%;\n        vertical-align: middle;\n    }\n    &.is-disabled {\n        color: var(--av-fixed-lighter);\n        cursor: default;\n        .el-radio__control {\n            background-color: var(--av-brand-accent)\n        }\n        .el-radio__description, .el-radio__label {\n            color: var(--av-fixed-lighter)\n        }\n    }\n    &.is-focus {\n        &:not(.is-disabled) {\n            .el-radio__control {\n                box-shadow: 0 0 0 3px var(--av-fixed-focus);\n            }\n        }\n    }\n    &.is-checked {\n        .el-radio__control {\n            border: 5px solid var(--av-brand-primary)\n        }\n    }\n    &.is-checked.is-disabled {\n        .el-radio__control {\n            border: 4px solid var(--av-brand-accent);\n            background-color: var(--av-brand-light);\n            min-width: 14px;\n            width: 16px;\n            height: 16px;\n            &:before {\n                content: \"\";\n                display: block;\n                min-width: 14px;\n                width: 14px;\n                height: 14px;\n                border-radius: 50%;\n                border: 1px solid var(--av-brand-light);\n            }\n        }\n    }\n}\n</style>\n","<template>\n    <ul\n        v-show=\"visible\"\n        :class=\"{ 'is-visible': visible }\"\n        class=\"el-select-group__wrap\"\n    >\n        <li class=\"el-select-group__title\">\n            {{ label }}\n        </li>\n        <li>\n            <ul class=\"el-select-group\">\n                <slot />\n            </ul>\n        </li>\n    </ul>\n</template>\n\n<script setup>\nimport { ref, watch, inject, provide, onMounted } from 'vue';\n\nconst props = defineProps({\n    label: { type: String, default: '' },\n    disabled: { type: Boolean, default: false },\n});\n\nconst select = inject('select', null);\nconst optionRefs = ref([]);\nconst option = inject('option', null);\n\nconst visible = ref(true);\n\nfunction registerGroupOption(payload) {\n    optionRefs.value.push(payload);\n}\n\nfunction unregisterGroupOption(payload) {\n    const idx = optionRefs.value.indexOf(payload);\n    if (idx !== -1) optionRefs.value.splice(idx, 1);\n}\n\nfunction queryChange() {\n    visible.value = optionRefs.value.some(opt => opt.visible !== false);\n}\n\n\nwatch(() => props.disabled, (val) => {\n    option?.handleGroupDisabled?.(val);\n});\n\nwatch(() => select.query?.value, (val) => {\n    queryChange(val);\n});\n\nonMounted(() => {\n    if (props.disabled) {\n        option?.handleGroupDisabled?.(props.disabled);\n    }\n});\n\nprovide('optionGroup', {\n    registerGroupOption,\n    unregisterGroupOption,\n});\n</script>\n\n<style scoped lang=\"postcss\">\n.el-select-group {\n    &__wrap {\n        position: relative;\n        list-style: none;\n        margin: 0;\n        &.is-visible {\n            &:has(+ .el-select-group__wrap.is-visible) {\n                border-bottom: 1px solid var(--av-brand-light);\n                padding-bottom: 16px;\n                margin-bottom: 16px;\n            }\n        }\n    }\n    &__title {\n        padding-inline-start: 20px;\n        font-size: 14px;\n        color: var(--av-fixed-light);\n        line-height: 30px;\n    }\n    :deep(.el-select-dropdown__item) {\n        padding-inline-start: 20px;\n    }\n}\n</style>\n","import { LOCALE_DEFAULT } from '@model/const/locales.ts';\n\nexport default {\n    computed: {\n        phoneInputSettings() {\n            return this.$store.state.slices.items?.['s-list-form-elements']?.phoneInput || null;\n        },\n    },\n    methods: {\n        onPhoneInputChange(event) {\n            const field = ('phone_number' in this.form) ? 'phone_number' : 'phone';\n            this.form[field] = event.number;\n            this.form.phoneCountryCode = event.country;\n        },\n    },\n    async serverPrefetch() {\n        const locale = this.$store.state.geolocation.finalLocale || LOCALE_DEFAULT;\n        await this.$store.dispatch('slices/getSyncedData', { slice: 's-list-form-elements', locale });\n    },\n};\n","export default [\n    {\n        name: 'Alabama',\n        code: 'AL',\n    },\n    {\n        name: 'Alaska',\n        code: 'AK',\n    },\n    {\n        name: 'Arizona',\n        code: 'AZ',\n    },\n    {\n        name: 'Arkansas',\n        code: 'AR',\n    },\n    {\n        name: 'California',\n        code: 'CA',\n    },\n    {\n        name: 'Colorado',\n        code: 'CO',\n    },\n    {\n        name: 'Connecticut',\n        code: 'CT',\n    },\n    {\n        name: 'Delaware',\n        code: 'DE',\n    },\n    {\n        name: 'District of Columbia',\n        code: 'DC',\n    },\n    {\n        name: 'Florida',\n        code: 'FL',\n    },\n    {\n        name: 'Georgia',\n        code: 'GA',\n    },\n    {\n        name: 'Hawaii',\n        code: 'HI',\n    },\n    {\n        name: 'Idaho',\n        code: 'ID',\n    },\n    {\n        name: 'Illinois',\n        code: 'IL',\n    },\n    {\n        name: 'Indiana',\n        code: 'IN',\n    },\n    {\n        name: 'Iowa',\n        code: 'IA',\n    },\n    {\n        name: 'Kansas',\n        code: 'KS',\n    },\n    {\n        name: 'Kentucky',\n        code: 'KY',\n    },\n    {\n        name: 'Louisiana',\n        code: 'LA',\n    },\n    {\n        name: 'Maine',\n        code: 'ME',\n    },\n    {\n        name: 'Maryland',\n        code: 'MD',\n    },\n    {\n        name: 'Massachusetts',\n        code: 'MA',\n    },\n    {\n        name: 'Michigan',\n        code: 'MI',\n    },\n    {\n        name: 'Minnesota',\n        code: 'MN',\n    },\n    {\n        name: 'Mississippi',\n        code: 'MS',\n    },\n    {\n        name: 'Missouri',\n        code: 'MO',\n    },\n    {\n        name: 'Montana',\n        code: 'MT',\n    },\n    {\n        name: 'Nebraska',\n        code: 'NE',\n    },\n    {\n        name: 'Nevada',\n        code: 'NV',\n    },\n    {\n        name: 'New Hampshire',\n        code: 'NH',\n    },\n    {\n        name: 'New Jersey',\n        code: 'NJ',\n    },\n    {\n        name: 'New Mexico',\n        code: 'NM',\n    },\n    {\n        name: 'New York',\n        code: 'NY',\n    },\n    {\n        name: 'North Carolina',\n        code: 'NC',\n    },\n    {\n        name: 'North Dakota',\n        code: 'ND',\n    },\n    {\n        name: 'Ohio',\n        code: 'OH',\n    },\n    {\n        name: 'Oklahoma',\n        code: 'OK',\n    },\n    {\n        name: 'Oregon',\n        code: 'OR',\n    },\n    {\n        name: 'Pennsylvania',\n        code: 'PA',\n    },\n    {\n        name: 'Rhode Island',\n        code: 'RI',\n    },\n    {\n        name: 'South Carolina',\n        code: 'SC',\n    },\n    {\n        name: 'South Dakota',\n        code: 'SD',\n    },\n    {\n        name: 'Tennessee',\n        code: 'TN',\n    },\n    {\n        name: 'Texas',\n        code: 'TX',\n    },\n    {\n        name: 'Utah',\n        code: 'UT',\n    },\n    {\n        name: 'Vermont',\n        code: 'VT',\n    },\n    {\n        name: 'Virginia',\n        code: 'VA',\n    },\n    {\n        name: 'Washington',\n        code: 'WA',\n    },\n    {\n        name: 'West Virginia',\n        code: 'WV',\n    },\n    {\n        name: 'Wisconsin',\n        code: 'WI',\n    },\n    {\n        name: 'Wyoming',\n        code: 'WY',\n    },\n];\n","<template>\n    <div v-if=\"content && isFormFieldsReady\" ref=\"wrapper\" class=\"wrapper\">\n        <div\n            v-loading=\"isLoading\"\n            class=\"s-form-registration\"\n            :class=\"{ ...className }\"\n            el-loading-size=\"48\"\n            el-loading-background=\"inversed-secondary\"\n            :el-loading-text=\"content.loading || ''\"\n        >\n            <div v-if=\"content.title\" class=\"s-form-registration__title\" v-html=\"content.title\" />\n\n            <div v-if=\"content.tooltip?.title\" class=\"form-tooltip\">\n                {{ content.tooltip.title }}\n                <a-tooltip v-if=\"content.tooltip.text\" :content=\"content.tooltip.text\" />\n            </div>\n\n            <div v-if=\"content.subtitles\" class=\"s-form-registration__subtitle\">\n                <p\n                    v-for=\"(item, i) in content.subtitles\"\n                    :key=\"`subtitle-${i}`\"\n                    class=\"s-form-registration__subtitle-item\"\n                    v-html=\"item\"\n                />\n            </div>\n            <ul v-if=\"content.checklist\" class=\"s-form-registration__checklist\">\n                <li\n                    v-for=\"(item, i) in content.checklist\"\n                    :key=\"`check-${i}`\"\n                    class=\"s-form-registration__checklist-item\"\n                >\n                    <a-glyph name=\"check-square\" />\n                    <span v-html=\"item\" />\n                </li>\n            </ul>\n\n            <div v-if=\"content.link\" class=\"s-form-registration__link\" v-html=\"content.link\" />\n\n            <div v-if=\"content.info\" class=\"info\">\n                <p v-if=\"content.info.title\" class=\"info-list-title\">\n                    <span v-html=\"content.info.title\" />\n                    <a-link v-if=\"content.info.titleLink\" v-bind=\"{...content.info.titleLink, 'target': '_blank'}\" />\n                </p>\n                <a-label v-if=\"content.info.label\" v-bind=\"content.info.label\">\n                    {{ content.info.label.text }}\n                </a-label>\n                <ul v-if=\"isVisibleInfoList\" class=\"info-list\">\n                    <li\n                        v-for=\"(item, itemIndex) in content.info.list\"\n                        :key=\"`info-${itemIndex}`\"\n                        :class=\"['info-list-item', item.className]\"\n                    >\n                        <a-link v-if=\"item.link\" v-bind=\"item.link\" />\n                        <template v-else>\n                            <a-glyph v-if=\"item.glyph\" v-bind=\"item.glyph\" />\n                            <span v-html=\"item.text\" />\n                        </template>\n                    </li>\n                </ul>\n                <p v-if=\"content.info.lead\" class=\"info-lead\" v-html=\"content.info.lead\" />\n                <p v-if=\"content.info.description\" class=\"info-description\" v-html=\"content.info.description\" />\n            </div>\n\n            <el-form ref=\"form\" :rules=\"rules\" :model=\"form\">\n                <a-row v-for=\"(elRowItem, count) in listFieldSpliced\" :key=\"`a-row-${count}`\" :gutter=\"16\">\n                    <template v-for=\"(item, i) in elRowItem\">\n                        <div\n                            v-if=\"item.section\"\n                            :key=\"item.section\"\n                            class=\"s-form-registration__section\"\n                        >\n                            {{ item.section }}\n                        </div>\n                        <a-col\n                            v-if=\"isVisibleField(item, ['select', 'select-searchable'])\"\n                            :key=\"`select-${i}`\"\n                            :sm=\"getInputSize(item, 'sm')\"\n                            :lg=\"getInputSize(item, 'lg')\"\n                        >\n                            <el-form-item :prop=\"item.name\" :hint=\"item.hint\">\n                                <el-select\n                                    :key=\"form.country\"\n                                    v-bind=\"labelSelect\"\n                                    :ref=\"`${item.name}`\"\n                                    v-model=\"form[item.name]\"\n                                    :filterable=\"item.type === 'select-searchable'\"\n                                    :label=\"formLabelText(item)\"\n                                    :placeholder=\"formPlaceholderText(item)\"\n                                    :multiple-show-items-limit=\"item.multipleLimit || 1\"\n                                    :multiple=\"item.isMultiple\"\n                                    :name=\"item.name\"\n                                    :required=\"isRequiredSelect(item)\"\n                                    :popper-class=\"`el-select-dropdown__form-registration ${item.dropdownClass || ''}`\"\n                                    :popper-placement=\"item['popper-placement']\"\n                                    :popper-max-width=\"item['popper-max-width']\"\n                                    @change=\"onChangeSelect(item)\"\n                                >\n                                    <template v-if=\"item.required && formElementsDefault?.required\" #suffix>\n                                        <div class=\"input-required-label\">\n                                            {{ formElementsDefault.required }}\n                                        </div>\n                                    </template>\n                                    <template v-if=\"item?.options?.[0]?.group\">\n                                        <el-option-group\n                                            v-for=\"(option, optionIndex) in item.options\"\n                                            :key=\"`option-group-${optionIndex}`\"\n                                            :label=\"option.label\"\n                                        >\n                                            <el-option\n                                                v-for=\"(group, groupIndex) in option.group\"\n                                                :key=\"`option-group-item-${groupIndex}`\"\n                                                :label=\"group.label\"\n                                                :sub-label=\"group['sub-label']\"\n                                                :value=\"group.value\"\n                                            />\n                                        </el-option-group>\n                                    </template>\n                                    <template v-else>\n                                        <el-option\n                                            v-for=\"(option, optionIndex) in listOptions(item)\"\n                                            :key=\"`option-item-${optionIndex}`\"\n                                            :label=\"option.label || option.name\"\n                                            :sub-label=\"option['sub-label']\"\n                                            :value=\"option.iso_code || option.value || option.code\"\n                                        />\n                                    </template>\n                                </el-select>\n                            </el-form-item>\n                        </a-col>\n                        <a-col\n                            v-if=\"isVisibleField(item, ['input', 'textarea'])\"\n                            :key=\"`input-${i}`\"\n                            :sm=\"getInputSize(item, 'sm')\"\n                            :lg=\"getInputSize(item, 'lg')\"\n                        >\n                            <template v-if=\"item.name === 'phone' && usePhoneInput\">\n                                <a-phone-input\n                                    :prop=\"item.name\"\n                                    :settings=\"phoneInputSettings\"\n                                    :default-phone=\"form.phone\"\n                                    :default-country=\"form.phoneCountryCode || form.country\"\n                                    :required=\"isRequired(item)\"\n                                    :placeholder=\"formPlaceholderText(item)\"\n                                    @change=\"onPhoneInputChange\"\n                                >\n                                    <template v-if=\"item.required && formElementsDefault?.required\" #suffix>\n                                        <div class=\"input-required-label\">\n                                            {{ formElementsDefault.required }}\n                                        </div>\n                                    </template>\n                                </a-phone-input>\n                            </template>\n                            <template v-else>\n                                <el-form-item\n                                    :prop=\"item.name\"\n                                    :hint=\"inputHint(item)\"\n                                    :class=\"formItemClass(item)\"\n                                >\n                                    <el-input\n                                        :ref=\"`${item.name}`\"\n                                        v-model=\"form[item.name]\"\n                                        :autosize=\"item.autosize\"\n                                        :disabled=\"isLoading\"\n                                        :label=\"formLabelText(item)\"\n                                        :placeholder=\"formPlaceholderText(item)\"\n                                        :maxlength=\"item.maxlength\"\n                                        :name=\"item.name\"\n                                        :prefix-value=\"setPrefixValue(item)\"\n                                        :required=\"isRequired(item)\"\n                                        :type=\"item.type || 'input'\"\n                                        @blur=\"checkEmailOptIn(item.name)\"\n                                        @mouseleave=\"checkEmailOptIn(item.name)\"\n                                    >\n                                        <template v-if=\"item.required && formElementsDefault?.required\" #suffix>\n                                            <div class=\"input-required-label\">\n                                                {{ formElementsDefault.required }}\n                                            </div>\n                                        </template>\n                                    </el-input>\n                                    <div v-if=\"item.tooltip\" class=\"el-form-item__tooltip\" v-html=\"item.tooltip\" />\n                                    <div\n                                        v-if=\"item.name === 'email' && errorMessageAPI\"\n                                        :class=\"classErrorMessage(item)\"\n                                        v-html=\"errorMessageAPI\"\n                                    />\n                                </el-form-item>\n                            </template>\n                        </a-col>\n                        <a-col\n                            v-if=\"isVisibleField(item, 'password')\"\n                            :key=\"`password-${i}`\"\n                            :sm=\"getInputSize(item, 'sm')\"\n                            :lg=\"getInputSize(item, 'lg')\"\n                        >\n                            <el-form-item :prop=\"item.name\" :hint=\"item.hint\">\n                                <el-input\n                                    :ref=\"`${item.name}`\"\n                                    v-model=\"form[item.name]\"\n                                    show-password-icon\n                                    type=\"password\"\n                                    :name=\"item.name\"\n                                    :required=\"isRequired(item)\"\n                                    :label=\"formLabelText(item)\"\n                                    :placeholder=\"formPlaceholderText(item)\"\n                                >\n                                    <template v-if=\"item.required && formElementsDefault?.required\" #suffix>\n                                        <div class=\"input-required-label\">\n                                            {{ formElementsDefault.required }}\n                                        </div>\n                                    </template>\n                                </el-input>\n                                <div v-if=\"item.tooltip\" class=\"el-form-item__tooltip\">\n                                    {{ item.tooltip }}\n                                </div>\n                            </el-form-item>\n                        </a-col>\n                        <a-col v-if=\"isVisibleField(item, 'radio') && item.list\" :key=\"`radio-${i}`\">\n                            <el-form-error v-if=\"isSubmitted && item.required && !userData[item.name]\" class=\"el-radio-error-message\">\n                                {{ item.error }}\n                            </el-form-error>\n                            <el-radio\n                                v-for=\"(radio, radioCount) in item.list\"\n                                :key=\"`radio-item-${radioCount}`\"\n                                v-model=\"form[item.name]\"\n                                :label=\"radio.value\"\n                                :class=\"radio.class\"\n                                @change=\"isSubmitted = false\"\n                            >\n                                {{ radio.title }}\n                                <template #description>\n                                    {{ radio.description }}\n                                </template>\n                            </el-radio>\n                        </a-col>\n\n                        <a-col\n                            v-if=\"isVisibleField(item, 'date-picker')\"\n                            :key=\"`date-picker-${i}`\"\n                            :sm=\"getInputSize(item, 'sm')\"\n                            :lg=\"getInputSize(item, 'lg')\"\n                        >\n                            <el-form-item :prop=\"item.name\">\n                                <el-date-picker\n                                    v-model=\"form[item.name]\"\n                                    :model-value=\"null\"\n                                    v-bind=\"item\"\n                                />\n                            </el-form-item>\n                        </a-col>\n                    </template>\n                </a-row>\n\n                <a-row v-if=\"hasCheckboxesWEB46049\" class=\"s-form-checkboxes\">\n                    <p class=\"s-form-checkboxes-description\">\n                        {{ content.checkboxes.description }}\n                    </p>\n                    <div class=\"s-form-checkboxes-wrapper\">\n                        <div\n                            v-for=\"(group, groupIndex) in content.checkboxes.groups\"\n                            :key=\"`s-form-checkboxes-group-${groupIndex}`\"\n                            class=\"s-form-checkboxes-group\"\n                        >\n                            <p class=\"s-form-checkboxes-title\">\n                                {{ group.title }}\n                            </p>\n                            <div class=\"s-form-checkboxes-list\">\n                                <el-checkbox\n                                    v-for=\"(item, itemIndex) in group.list\"\n                                    :key=\"`s-form-checkboxe-${itemIndex}`\"\n                                    ref=\"checkboxesWEB46049\"\n                                    v-model=\"group.list[item]\"\n                                    :name=\"item.value\"\n                                >\n                                    {{ item.text }}\n                                </el-checkbox>\n                            </div>\n                        </div>\n                    </div>\n                </a-row>\n                <div v-if=\"content.links\" class=\"s-form-registration__links\">\n                    <div v-for=\"(item, i) in content.links\" :key=\"`link-${i}`\" class=\"s-form-registration__links-item\">\n                        <a-link class=\"s-form-registration__footer-item\" v-bind=\"item\" />\n                    </div>\n                </div>\n                <div v-for=\"(item, i) in content.notifications\" :key=\"`notification-${i}`\">\n                    <div v-if=\"isVisibleNotification(item)\" class=\"s-form-notification-item\">\n                        <a-glyph v-if=\"item.glyph\" :name=\"item.glyph\" />\n                        <span v-html=\"item.text\" />\n                    </div>\n                </div>\n                <div v-if=\"hasCheckboxes\" class=\"s-form-registration__checkboxes\">\n                    <template v-for=\"item in listCheckboxes\">\n                        <el-checkbox\n                            v-if=\"isVisibleCheckbox(item)\"\n                            :key=\"item.name\"\n                            v-model=\"form[item.name]\"\n                            :name=\"item.name\"\n                            :multiline-label=\"item.multilineLabel\"\n                            :multiline-label-limit=\"item.multilineLabelLimit\"\n                            @change=\"isSubmitted = false\"\n                        >\n                            <a-dangerous-html :content=\"formCheckboxText(item)\" />\n                            <el-form-error v-if=\"isVisibleErrorCheckbox(item)\" class=\"checkbox-error-message\">\n                                <span v-html=\"item.error || formElementsDefault?.errors?.[item.name] || 'Error'\" />\n                            </el-form-error>\n                        </el-checkbox>\n                    </template>\n                </div>\n                <div v-if=\"hasAgreement\" class=\"agreement\">\n                    <a-dangerous-html\n                        v-for=\"(item, i) in listCheckboxesLightGDPR\"\n                        :key=\"`light-gdpr-notification-${i}`\"\n                        :content=\"formCheckboxText(item)\"\n                    />\n                </div>\n\n                <p v-if=\"content.information\" class=\"information\" v-html=\"content.information\" />\n\n                <a-form-honeypot v-if=\"content.hasHoneypot\" ref=\"honeypot\" />\n\n                <a-button\n                    v-if=\"content.button\"\n                    class=\"s-form-registration__button\"\n                    v-bind=\"content.button\"\n                    :event=\"{ doNotSendGA: true }\"\n                    :disabled=\"isButtonDisable\"\n                    @mousedown.prevent\n                    @click=\"submit\"\n                />\n                <div v-if=\"content.notes\" class=\"s-form-registration__note\">\n                    <p\n                        v-for=\"(item, i) in content.notes\"\n                        :key=\"i\"\n                        class=\"s-form-registration__note-item\"\n                        :class=\"item.class || null\"\n                        v-html=\"item.title || item\"\n                    />\n                </div>\n            </el-form>\n            <template v-if=\"content.extraButtons?.length\">\n                <a-button\n                    v-for=\"(button, i) in content.extraButtons\"\n                    :key=\"`form-reg-extra-button-${i}`\"\n                    class=\"s-form-registration__extra-button\"\n                    v-bind=\"button\"\n                    :event=\"button.event || { doNotSendGA: true }\"\n                    @click=\"clickExtraButton(button)\"\n                />\n            </template>\n            <p v-if=\"content.changeAccount\" class=\"change\">\n                <a-link :text=\"content.changeAccount\" @click=\"changeAccount()\" />\n            </p>\n            <template v-if=\"hasRecaptchaInvisible\">\n                <div class=\"recaptcha-notification\" v-html=\"formRecaptchaText\" />\n            </template>\n        </div>\n    </div>\n</template>\n\n<script>\nimport { get, size, filter, isEmpty, fromPairs, isString } from 'lodash-es';\nimport { mapState, mapActions } from 'vuex';\nimport AButton from '@core/components/button/button.vue';\nimport ElCheckbox from '@core/components/checkbox/checkbox.vue';\nimport ACol from '@core/components/col/col.vue';\nimport ADangerousHtml from '@core/components/dangerous-html/dangerous-html.vue';\nimport ElDatePicker from '@core/components/date-picker/date-picker.vue';\nimport ElFormError from '@core/components/form/form-error.vue';\nimport ElFormItem from '@core/components/form/form-item.vue';\nimport ElForm from '@core/components/form/form.vue';\nimport AFormHoneypot from '@core/components/form-honeypot/form-honeypot.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport ElInput from '@core/components/input/input.vue';\nimport ALabel from '@core/components/label/label.vue';\nimport ALink from '@core/components/link/link.vue';\nimport { Loading } from '@core/components/loading';\nimport APhoneInput from '@core/components/phone-input/phone-input.vue';\nimport ElRadio from '@core/components/radio/radio.vue';\nimport ARow from '@core/components/row/row.vue';\nimport ElOptionGroup from '@core/components/select/option-group.vue';\nimport ElOption from '@core/components/select/option.vue';\nimport ElSelect from '@core/components/select/select.vue';\nimport ATooltip from '@core/components/tooltip/tooltip.vue';\nimport breakpoint from '@core/mixins/breakpoint.js';\nimport form from '@core/mixins/form.js';\nimport phoneInput from '@core/mixins/phone-input.js';\nimport recaptcha from '@core/mixins/recaptcha.js';\nimport states from '@model/const/states.ts';\nimport utils from '@utils/form.js';\n\nconst IDLE_EVENTS = ['mousemove', 'mousedown', 'keydown', 'scroll', 'touchstart', 'pointerdown'];\n\nexport default {\n    name: 'FormRegistration',\n\n    components: {\n        AButton,\n        ADangerousHtml,\n        AFormHoneypot,\n        APhoneInput,\n        AGlyph,\n        ATooltip,\n        ALabel,\n        ALink,\n        ARow,\n        ACol,\n        ElForm,\n        ElDatePicker,\n        ElFormError,\n        ElFormItem,\n        ElInput,\n        ElCheckbox,\n        ElOption,\n        ElOptionGroup,\n        ElSelect,\n        ElRadio,\n    },\n\n    directives: {\n        loading: Loading.directive,\n    },\n\n    mixins: [form, utils, recaptcha, phoneInput, breakpoint],\n\n    props: {\n        usePhoneInput: {\n            type: Boolean,\n            default: false,\n        },\n        content: {\n            type: Object,\n            default: () => ({}),\n        },\n        userData: {\n            type: Object,\n            default: null,\n        },\n\n        settingsForm: {\n            type: Object,\n            default: null,\n        },\n\n        mailgunError: {\n            type: Object,\n            default: null,\n        },\n\n        errorMessageAPI: {\n            type: String,\n            default: '',\n        },\n\n        hasAnimate: {\n            type: Boolean,\n            default: false,\n        },\n    },\n\n    emits: ['submit', 'submit-error', 'resize', 'change-step', 'hideLogin'],\n\n    data: () => ({\n        hash: '',\n        wrapperHeight: 0,\n        form: {\n            state: '',\n            country: 'US',\n        },\n        isFormFieldsReady: false,\n        resellerList: [],\n        distributorList: [],\n        isButtonDisable: false,\n        isSubmitted: false,\n        isIdle: false,\n        idleTimer: null,\n    }),\n\n    computed: {\n        ...mapState({\n            countriesData: (state) => state.countries?.items || [],\n            points: (state) => get(state, 'slices.items.s-data-centers.points', []),\n            queryStringData: (state) => state.trial?.queryStringData || {},\n            locationMapping: (state) => get(state, 'slices.items.s-data-centers.locationMapping', []),\n        }),\n\n        countries() {\n            const countriesLocalized = this.formElementsDefault.countriesLocalized || {};\n            const codes = new Set(Object.keys(countriesLocalized));\n            if (!codes.size) return this.countriesData;\n\n            return this.countriesData.map((item) => {\n                if (codes.has(item.iso_code)) {\n                    return { ...item, name: countriesLocalized[item.iso_code] };\n                }\n                return item;\n            });\n        },\n\n        dataCenters() {\n            return utils.getUniqueDataCentersForPlatform(this.points).map((item) => ({\n                ...item,\n                name: item.country,\n                code: item.marketoCode,\n            }));\n        },\n\n        rules() {\n            const result = {};\n            this.listField.forEach((item) => {\n                const trigger = item.type?.startsWith('select') ? 'change submit blur' : 'blur';\n                result[item.name] = {\n                    fieldType: item.type,\n                    required: this.isItemRequired(item),\n                    validator: this.validateFieldValue,\n                    errorMessage: this.formErrorText(item),\n                    trigger: item.trigger || trigger,\n                    isNumber: item.isNumber,\n                    minLength: item.minLength,\n                    maxLength: item.maxLength,\n                };\n\n                if (item.name === 'email') {\n                    result[item.name] = {\n                        isBusinessOnlyEmail: item.isBusinessOnlyEmail,\n                        isBusinessEmailByCountry: item.isBusinessEmailByCountry,\n                        errorMessageBusiness: item.errorBusinessEmail || this.setErrorMessage('invalidEmailBusiness'),\n                        errorMessage: item.error || this.setErrorMessage('notFilledField'),\n                        errorMessageMailgun: this.mailgunError,\n                        validator: this.validateEmail.bind(this),\n                        trigger: item.trigger || 'blur',\n                    };\n                }\n\n                if (!this.usePhoneInput && item.name === 'phone') {\n                    result[item.name] = {\n                        validator: this.validatePhone,\n                        errorMessage: this.formErrorText(item),\n                        trigger: item.trigger || 'blur',\n                    };\n                }\n\n                if (item.name === 'password') {\n                    result[item.name] = {\n                        validator: this.validatePassword,\n                        errorMessage: this.formErrorText(item),\n                        trigger: item.trigger || 'blur',\n                    };\n                }\n\n                if (item.name === 'login' && this.content.isCloudConsoleLoginFlowEnabled) {\n                    result[item.name] = {\n                        validator: this.validateLogin,\n                        errorMessage: item.error,\n                        errorMessageLogin: this.settingsForm.errorMessageLogin,\n                    };\n                }\n\n                if (this.fitsWeb46734(item)) {\n                    result[item.name] = {\n                        validator: this.validateNameFieldExtended,\n                        errorMessage: this.formErrorText(item),\n                    };\n                }\n            });\n            return result;\n        },\n\n        className() {\n            return {\n                [`s-form-registration-version-${this.content.version}`]: this.content.version,\n            };\n        },\n\n        listField() {\n            return this.content?.fields || [];\n        },\n\n        listFieldSpliced() {\n            const result = [];\n            const list = [...this.listField];\n            while (list.length > 0) {\n                const count = list[0].name === 'country' ? 3 : 2;\n                result.push(list.splice(0, count));\n            }\n            return result;\n        },\n\n        listAgreements() {\n            return get(this, 'content.agreements', []);\n        },\n\n        listCheckboxes() {\n            return filter(this.listAgreements, ['type', 'checkbox']);\n        },\n\n        listCheckboxesGDPR() {\n            return filter(this.listAgreements, ['isGDPR', true]);\n        },\n\n        listCheckboxesLightGDPR() {\n            return filter(this.listAgreements, ['isLightGDPR', true]);\n        },\n\n        hasAgreement() {\n            const comparison = (item) => item.name === 'country';\n            return this.listField.find(comparison) && this.form.country && !this.isCountryGDPR;\n        },\n\n        hasCheckboxes() {\n            const listGDPR = this.listCheckboxesGDPR;\n            const list = this.listCheckboxes.filter((item) => !item.isGDPR);\n            return size(list) || (size(listGDPR) && this.isCountryGDPR);\n        },\n\n        hasCheckboxesWEB46049() {\n            return this.content?.checkboxes?.groups?.length;\n        },\n        isVisibleInfoList() {\n            if (!this.isDesktop && this.content.info.list?.length > 3) return false;\n            return this.content.info.list;\n        },\n        formEventContext() {\n            if (!this.hasCheckboxesWEB46049) return '';\n            return this.$refs.checkboxesWEB46049\n                .filter((item) => item.isChecked)\n                .map((item) => item.name)\n                .join(',');\n        },\n    },\n\n    watch: {\n        $route(to) {\n            const hash = to.hash.replace('#', '');\n            if (this.hash === hash) return;\n            this.hash = hash;\n        },\n        mailgunError: {\n            async handler(value) {\n                if (!value) return;\n                if (!this.$refs.form) return;\n                await this.$nextTick();\n                this.$refs.form.validateField('email');\n            },\n            immediate: true,\n        },\n        'form.country': {\n            handler(newVal) {\n                if (!newVal) return;\n                if (newVal === 'US') {\n                    this.form.state = states[0]?.code || '';\n                } else {\n                    this.form.state = '';\n                }\n                this.getResellerList();\n                this.getDistributorList();\n            },\n            immediate: true,\n        },\n        'form.email': {\n            handler() {\n                if (this.isBusinessOnlyEmail()) {\n                    this.isButtonDisable = this.isFreeEmail(this.form.email.trimEnd());\n                }\n                this.$emit('hideLogin', this.form.email);\n                if (this.form.login) return;\n                if (!this.errorMessageAPI) return;\n                if (this.content?.steps?.length) return;\n                this.isButtonDisable = this.form.email === this.userData.email;\n            },\n        },\n    },\n\n    updated() {\n        const height = this.$refs.wrapper?.clientHeight || 0;\n        if (this.wrapperHeight !== height) {\n            this.wrapperHeight = height;\n            this.$emit('resize');\n        }\n\n        if (this.content.clearValidateOnUpdate) {\n            this.$nextTick(() => {\n                this.$refs.form.clearValidate();\n            });\n        }\n\n        if (this.hash && this.$refs.form) {\n            if (this.hash === this.content.sliceID) {\n                this.setFocus();\n            }\n            this.hash = '';\n            this.$nextTick(() => {\n                this.$refs.form.clearValidate();\n            });\n        }\n    },\n\n    beforeUnmount() {\n        window.removeEventListener('keydown', this.onKeyDown);\n        if (this.hasAnimate) {\n            IDLE_EVENTS.forEach((e) => window.removeEventListener(e, this.resetIdleTimer));\n            clearTimeout(this.idleTimer);\n        }\n    },\n\n    async mounted() {\n        document.addEventListener('keydown', this.onKeyDown);\n\n        if (this.hasAnimate) {\n            IDLE_EVENTS.forEach((e) => window.addEventListener(e, this.resetIdleTimer, { passive: true }));\n            this.idleTimer = setTimeout(() => { this.isIdle = true; }, 6000);\n        }\n\n        this.initFields(this.userData || {});\n\n        if (isEmpty(this.userData)) {\n            this.init();\n            return;\n        }\n\n        if (!this.form.email) return;\n        if (!('gdpr_opt_in' in this.form)) return;\n        await this.checkEmailOptIn('isAuthorized');\n\n        if (this.content.focusNotSet) return;\n        this.setFocus();\n    },\n\n    methods: {\n        ...mapActions({\n            getCompanyList: 'partnersLocator/getCompanyList',\n        }),\n\n        resetIdleTimer() {\n            this.isIdle = false;\n            clearTimeout(this.idleTimer);\n            this.idleTimer = setTimeout(() => { this.isIdle = true; }, 6000);\n        },\n\n        fitsWeb46734(item) {\n            if (!this.$route.path.includes('/products/cyber-protect/trial/')) return false;\n            if (!this.locale.startsWith('en')) return false;\n            return ['first_name', 'last_name'].includes(item.name);\n        },\n\n        hasHintForFreeEmail(item) {\n            return item.hintForFreeEmail && this.isFreeEmail(this.form.email);\n        },\n\n        inputHint(item) {\n            if (this.hasHintForFreeEmail(item)) return item.hintForFreeEmail;\n            return item.hint || item.description || '';\n        },\n\n        classInputHint(item) {\n            return { 'el-form-item-hint-critical': this.hasHintForFreeEmail(item) };\n        },\n\n        formItemClass(item) {\n            return {\n                ...this.classInputHint(item),\n                'idle-glow': this.isIdle && item.name === this.firstEmptyInputFieldName,\n            };\n        },\n\n        classErrorMessage(item) {\n            return {\n                'el-form-error-api': item,\n                [`el-form-error-api-${item.name}`]: item.name,\n            };\n        },\n\n        clickExtraButton(button) {\n            if (!button.resetFields) return;\n\n            this.isSubmitted = false;\n\n            this.listCheckboxes.forEach((checkbox) => {\n                this.form[checkbox.name] = checkbox.isChecked || false;\n            });\n\n            this.$nextTick(() => {\n                this.$refs.form.resetFields();\n                this.$refs.form.clearValidate();\n            });\n        },\n\n        async changeAccount() {\n            this.$refs.form.clearValidate();\n            await this.$store.dispatch('user/logout');\n        },\n\n        async getResellerList() {\n            const comparison = (f) => f.name === 'reseller' && f.getReseller;\n            const field = this.listField.find(comparison);\n            if (!field) return;\n            try {\n                this.isLoading = true;\n                this.form.reseller = '';\n                this.form.reseller_id = '';\n                const country = this.form.country;\n                const response = await this.getCompanyList({ country, type: 'partners' });\n                const list = response.data || [];\n                const type = field.typeReseller;\n                this.resellerList = list\n                    .filter((item) => (type ? item[type] : item))\n                    .map((item) => ({ code: item.id, name: item.name }));\n            } catch (e) {\n                this.resellerList = [];\n            } finally {\n                this.isLoading = false;\n            }\n        },\n\n        async getDistributorList() {\n            const comparison = (f) => f.name === 'distributor' && f.getDistributor;\n            const field = this.listField.find(comparison);\n            if (!field) return;\n            try {\n                this.isLoading = true;\n                this.form.distributor = '';\n                this.form.distributor_id = '';\n                const country = this.form.country;\n                const response = await this.getCompanyList({ country, type: 'distributors' });\n                const list = response.data || [];\n                const type = field.typeDistributor;\n                this.distributorList = list\n                    .filter((item) => (type ? item[type] : item))\n                    .map((item) => ({ code: item.id, name: item.name }));\n            } catch (e) {\n                this.distributorList = [];\n            } finally {\n                this.isLoading = false;\n            }\n        },\n\n        initFields(userData) {\n            this.form = {\n                ...fromPairs(this.listField.map((el) => [el.name, ''])),\n                ...fromPairs(this.listCheckboxes.map((el) => [el.name, el.isChecked || false])),\n                ...userData,\n            };\n\n            if (this.content.isFormExpressSignup) {\n                this.setSearchParamsData();\n            }\n\n            this.isFormFieldsReady = true;\n        },\n\n        prefillData(key) {\n            if (!Object.keys(this.queryStringData)?.length && !localStorage.getItem(`trial_es_${key}`)) return;\n            const query = this.queryStringData;\n            const unexpectedKeys = {\n                first_name: 'firstname',\n                last_name: 'lastname',\n                tenantId: 'uid',\n            };\n\n            const val = query[key] || query[unexpectedKeys[key]] || localStorage.getItem(`trial_es_${key}`);\n            if (!val || val === 'undefined') return;\n\n            const normalizedValue = key === 'email' && isString(val) ? val?.replaceAll(' ', '+') : val;\n            this.form[key] = normalizedValue;\n            localStorage.setItem(`trial_es_${key}`, normalizedValue);\n        },\n\n        setSearchParamsData() {\n            this.searchParams = new URLSearchParams(this.queryStringData);\n            const expectedKeys = new Set([\n                'aan',\n                'company',\n                'email',\n                'first_name',\n                'last_name',\n                'phone',\n                'currency',\n                'price',\n                'opportunity_id',\n                'tenantId',\n            ]);\n            Object.keys(this.form)\n                .filter((x) => expectedKeys.has(x))\n                .forEach(this.prefillData);\n            if (Object.keys(this.$route?.query || {}).length) {\n                const SFDCCampaignID = this.searchParams.get('SFDCCampaignID');\n                this.$router.replace({ query: SFDCCampaignID ? { SFDCCampaignID } : null });\n            }\n        },\n\n        isValidGDPR(item) {\n            return !item.isGDPR || this.isCountryGDPR;\n        },\n\n        hasCheckboxRequired(item) {\n            return item.isRequired && !this.form[item.name] && this.isValidGDPR(item);\n        },\n\n        init() {\n            this.setCountry();\n            this.setState();\n            this.setDataCenterLocation();\n            this.setAccountData();\n\n            if (this.content.focusNotSet) return;\n            this.setFocus();\n        },\n\n        async submit() {\n            this.isSubmitted = true;\n\n            if (this.hasAnimate) {\n                const isValid = await this.$refs.form.validate().then(() => true).catch(() => false);\n                if (!isValid) {\n                    this.isSubmitted = false;\n                    this.$emit('submit-error');\n                    const fieldName = this.setFocusErrorField();\n                    this.$refs.form.fields\n                        .filter((f) => f.prop !== fieldName)\n                        .forEach((f) => f.clearValidate());\n                    return;\n                }\n            }\n\n            if (this.hasCheckboxes) {\n                const required = this.listCheckboxes.find((item) => this.hasCheckboxRequired(item)) || {};\n                if (required.error || this.formElementsDefault.errors?.[required.name]) return;\n            }\n\n            try {\n                this.isButtonDisable = true;\n\n                this.prepareFormToValidate();\n                await this.$refs.form.validate();\n\n                const payload = this.form;\n                const initialPayloadToLog = { ...this.form };\n\n                const distributor = this.distributorList.find((item) => item.code === this.form.distributor);\n                if (distributor) {\n                    payload.distributor = distributor.name;\n                    payload.distributor_id = distributor.code;\n                }\n\n                const reseller = this.resellerList.find((item) => item.code === this.form.reseller);\n                if (reseller) {\n                    payload.reseller = reseller.name;\n                    payload.reseller_id = reseller.code;\n                }\n\n                // WEB-42323\n                if (this.content.hasHoneypot) {\n                    payload.business_address = this.$refs.honeypot.getValue() || false;\n                    if (this.$refs.honeypot.isCaptured()) {\n                        this.$refs.honeypot.sendGAEvent();\n                    }\n                }\n\n                // WEB-43432\n                if (this.content.isFormEvents) {\n                    const sendNotSpEvent = await this.checkIfSuitableForNotSpEvent();\n                    if (sendNotSpEvent) {\n                        this.sendNotSpEvent();\n                    }\n\n                    const term = this.$route.query?.utm_term;\n                    if (['form', 'ccform'].includes(term) || window.sessionStorage?.getItem('utm_term')) {\n                        payload.SP_validation = !sendNotSpEvent;\n                    } else {\n                        payload.SP_validation = null;\n                    }\n\n                    if (!payload.meeting_requested) {\n                        payload.meeting_requested = null;\n                    }\n                }\n\n                console.log('on submit', { initialPayloadToLog, payload }); // eslint-disable-line\n\n                this.$emit('submit', payload, this.$refs?.form?.$el, this.formEventContext);\n            } catch (e) {\n                this.setFocusErrorField();\n            } finally {\n                this.isButtonDisable = false;\n            }\n        },\n\n        setListPartners(item) {\n            if (item.name === 'reseller' && !item.getReseller) return item.options;\n            if (item.name === 'distributor' && !item.getDistributor) return item.options;\n            const options = item.name === 'reseller' ? this.resellerList : this.distributorList;\n            return [item.options[0], ...options || [], item.options[1]].filter(Boolean);\n        },\n\n        listOptions(item) {\n            const list = {\n                state: states,\n                country: this.countries,\n                dc_location: this.dataCenters,\n            };\n\n            const field = this.listField.find((el) => el.name === item.name);\n            let options = list[item.name] || field.options || this.formListOption(item.name);\n\n            if (field.affix) {\n                options = options.map((el) => ({\n                    ...el,\n                    code: `${el.code} ${field.affix}`,\n                }));\n            }\n\n            if (item.name === 'dc_location') {\n                options = options.map((el) => {\n                    if (!el.city) return el;\n                    return el.name.includes(',') ? el : { ...el, name: `${el.country}, ${el.city}` };\n                });\n            }\n\n            if (['distributor', 'reseller'].includes(item.name)) return this.setListPartners(item);\n\n            const selectedOption = options.find((el) => el.selected);\n            if (selectedOption && !this.form[item.name]) this.form[item.name] = selectedOption.code;\n\n            // WEB-49345\n            const value = new URL(window.location.href).searchParams.get(item.name);\n            if (value && options.find((el) => el.code === value || el.value === value)) {\n                this.form[item.name] = value;\n                return options;\n            }\n\n            return options;\n        },\n\n        setPrefixValue(item) {\n            if (item.placeholder) return '';\n            return item.name === 'phone' ? '+' : '';\n        },\n\n        setCountry() {\n            const isoCode = this.location?.data?.country?.code;\n            const hasCountry = this.countries.find((item) => item.iso_code === isoCode);\n            this.form.country = hasCountry ? isoCode : 'US';\n        },\n\n        findField(name) {\n            const fields = this.content.steps?.flatMap((item) => item.fields || item.form?.registration?.fields);\n            const list = fields || this.listField || [];\n            return list.find((item) => item.name === name);\n        },\n\n        setState() {\n            const field = this.findField('state');\n            if (!field || this.form.country !== 'US') return;\n            if (!this.form.state || !states.find((s) => s.code === this.form.state)) {\n                this.form.state = this.location?.data?.region?.code || states[0]?.code || '';\n            }\n        },\n\n        setDataCenterLocation() {\n            const field = this.findField('dc_location');\n            if (!field) return;\n\n            let location = '';\n            if (this.form.country === 'US' && this.form.state) {\n                const list = this.locationMapping || [];\n                const comparison = (item) => item.states?.includes(this.form.state);\n                location = list.find(comparison)?.location || '';\n            }\n\n            const code = location || utils.setDataCenter(this.dataCenters, this.form.country);\n            if (!code) return;\n\n            this.form.dc_location = field.affix ? `${code} ${field.affix}` : code;\n        },\n\n        isVisibleNotification(item) {\n            if (item.visible) {\n                if (!item.visible.list || !item.visible.field) {\n                    return false;\n                }\n                return item.visible.list.includes(this.form[item.visible.field]);\n            }\n            return false;\n        },\n\n        isVisibleCheckbox(item) {\n            return item.isOptIn ? this.isVisibleOptIn : this.isValidGDPR(item);\n        },\n\n        isVisibleErrorCheckbox(item) {\n            return this.isSubmitted && item.isRequired && !this.form[item.name];\n        },\n\n        getInputSize(item, sizeID) {\n            if (item.sizes && item.sizes[sizeID]) {\n                return item.sizes[sizeID];\n            }\n\n            if ((item.isDynamic && this.showStatesField) || this.showPostalCodeField) {\n                return 12;\n            }\n            return item.size || 12;\n        },\n\n        isItemRequired(item) {\n            if (item.name === 'message' && this.content.is46514VariantB) {\n                return this.form.company_type === 'Corporate End-Customer';\n            }\n            return item.required;\n        },\n\n        onChangeSelect(item) {\n            this.setState();\n            this.checkEmailOptIn(item.name);\n            if (this.hasBusinessEmailSelectOption) {\n                this.$refs.form?.clearValidate?.('email');\n                this.$refs.form?.validateField?.('email');\n            }\n        },\n\n        onKeyDown(event) {\n            if (event.key === 'Enter') {\n                const fields = this.content?.fields || [];\n                const field = fields.find((item) => item.name === event.target.name);\n                if (field?.type.includes('select')) {\n                    event.target.click();\n                }\n            }\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-form-registration {\n    display: flex;\n    position: relative;\n    flex-direction: column;\n    padding: 40px 16px 56px;\n    justify-content: center;\n    background: var(--av-inversed-primary);\n\n    @media (--viewport-mobile-wide) {\n        border-radius: 4px;\n        box-shadow: var(--av-shadow-small);\n        border: 1px solid var(--av-brand-light);\n    }\n\n    @media (--viewport-tablet) {\n        padding: 32px;\n    }\n\n    &__button {\n        width: 100%;\n    }\n\n    &__title {\n        @mixin title-accent;\n        margin: 0 -2px;\n        text-align: center;\n        color: var(--av-nav-primary);\n    }\n\n    .form-tooltip {\n        @mixin paragraph;\n        display: flex;\n        margin: 8px 0 0;\n        text-align: center;\n        align-items: center;\n        justify-content: center;\n        color: var(--av-fixed-primary);\n\n        .a-tooltip {\n            top: 2px;\n            position: relative;\n            background: transparent;\n            margin-inline-start: 8px;\n        }\n    }\n\n    &__subtitle {\n        @mixin lead;\n        margin: 8px 0 0;\n        text-align: center;\n\n        :deep(a) {\n            cursor: pointer;\n            text-decoration: none;\n            color: var(--av-brand-secondary);\n\n            &:hover {\n                color: var(--av-brand-secondary);\n            }\n        }\n    }\n\n    &__checklist {\n        margin-top: 16px;\n    }\n\n    &__checklist-item {\n        @mixin body;\n        display: flex;\n        align-items: center;\n\n        .a-glyph {\n            margin-inline-end: 8px;\n            position: relative;\n            top: 1px;\n            fill: var(--av-fixed-success);\n        }\n    }\n\n    &__link {\n        @mixin paragraph;\n        margin-top: 16px;\n        text-align: center;\n        color: var(--av-fixed-secondary);\n\n        :deep(a) {\n            cursor: pointer;\n            text-decoration: none;\n            color: var(--av-brand-primary);\n\n            &:hover {\n                color: var(--av-brand-secondary);\n            }\n        }\n    }\n\n    .info {\n        text-align: center;\n        margin-top: 24px;\n        @media (--viewport-tablet) {\n            margin-top: 16px;\n        }\n        @media (--viewport-desktop) {\n            margin-top: 24px;\n        }\n        .a-label {\n            display: flex;\n            margin: 0 auto;\n            width: max-content;\n        }\n        .info-list-title {\n            margin-bottom: 24px;\n            color: var(--av-nav-primary);\n\n            :deep(.a-link) {\n                margin-inline-start: 8px;\n\n                .a-link__content {\n                    display: flex;\n                    align-items: center;\n\n                    & * {\n                        margin: 0;\n                    }\n\n                    .a-glyph {\n                        margin-bottom: -2px;\n                    }\n                }\n            }\n        }\n        .info-list {\n            gap: 8px;\n            display: flex;\n            overflow: hidden;\n            padding: 8px 0;\n            justify-content: space-between;\n        }\n        .info-list-item {\n            @mixin note;\n            gap: 16px;\n            flex: 1 1 0;\n            display: flex;\n            font-weight: 400;\n            align-items: center;\n            flex-direction: column;\n            color: var(--av-nav-primary);\n            @media (--viewport-desktop) {\n                gap: 4px;\n                white-space: nowrap;\n            }\n            .a-glyph {\n                min-width: 16px;\n                fill: var(--av-solid-brand-secondary-light);\n            }\n            &.active {\n                font-weight: 700;\n                color: var(--av-fixed-primary);\n                .a-glyph {\n                    fill: var(--av-brand-primary);\n                }\n            }\n            &.has-background {\n                position: relative;\n                &:before {\n                    top: 7px;\n                    content: '';\n                    height: 2px;\n                    width: 181.63%;\n                    position: absolute;\n                    border-radius: 2px;\n                    background: var(--av-solid-brand-secondary-light);\n                }\n\n            }\n        }\n        .info-lead {\n            @mixin lead-accent;\n            margin-top: 24px;\n            color: var(--av-nav-primary);\n        }\n        .info-description {\n            @mixin paragraph;\n            margin-top: 8px;\n            color: var(--av-fixed-secondary);\n            @media (--viewport-desktop-wide) {\n                padding: 0 60px;\n            }\n        }\n    }\n\n    .s-form-checkboxes {\n        border-radius: 4px;\n        margin-bottom: 16px;\n        padding: 8px 16px 24px;\n        color: var(--av-fixed-primary);\n        background: var(--av-fixed-info-accent);\n\n        .s-form-checkboxes-description {\n            @mixin paragraph-accent;\n            text-align: center;\n        }\n\n        .s-form-checkboxes-wrapper {\n            display: flex;\n            flex-wrap: wrap;\n            margin: 0 -8px;\n\n            .s-form-checkboxes-group {\n                width: 50%;\n                padding: 0 8px;\n                margin-top: 8px;\n\n                &:last-child {\n                    width: 100%;\n\n                    .s-form-checkboxes-list {\n                        display: flex;\n\n                        .el-checkbox {\n                            width: 50%;\n                        }\n                    }\n                }\n\n                :deep(.el-checkbox) {\n                    @mixin caption;\n                    padding: 4px 0;\n\n                    &:not(:first-child) {\n                        margin: 0;\n                    }\n\n                    .el-checkbox__content {\n                        align-items: flex-start;\n                    }\n                }\n            }\n\n            .s-form-checkboxes-title {\n                @mixin caption-accent;\n            }\n\n            .s-form-checkboxes-list {\n                margin-top: 8px;\n            }\n        }\n    }\n\n    &__section {\n        @mixin paragraph;\n        padding: 0 8px 16px;\n        text-align: center;\n\n        @media (--viewport-tablet) {\n            text-align: start;\n        }\n    }\n\n    .s-form-notification-item {\n        @mixin descriptor;\n        display: flex;\n        padding: 16px;\n        position: relative;\n        padding-inline-start: 48px;\n        padding-inline-end: 24px;\n        margin: 0 0 16px;\n        background-color: var(--av-solid-brand-secondary-accent);\n\n        &:not(:first-child) {\n            margin: 8px 0 16px;\n        }\n\n        :deep(a) {\n            text-decoration: none;\n            color: var(--av-brand-secondary);\n        }\n\n        :deep(.a-glyph) {\n            min-width: 16px;\n            margin-top: 4px;\n            margin-inline-start: -24px;\n            margin-inline-end: 8px;\n        }\n    }\n\n    :deep(.el-form) {\n        margin: 32px 0 0;\n\n        @media (--viewport-tablet) {\n            margin-top: 24px;\n        }\n\n        .el-input__label {\n            &.is-active {\n                font-weight: 700;\n            }\n        }\n\n        .el-input__container {\n            .el-input__wrapper {\n                order: 1;\n            }\n\n            .el-input__suffix {\n                width: auto;\n                order: 3;\n                gap: 8px;\n                flex-shrink: 0;\n            }\n\n            .el-input__required {\n                order: 2;\n                display: flex;\n                padding: 0 8px;\n            }\n        }\n\n        .el-radio-error-message {\n            @mixin body;\n            justify-content: center;\n            color: var(--av-fixed-danger);\n        }\n\n        .el-radio {\n            width: 100%;\n            border-radius: 4px;\n            padding: 16px 24px;\n            border: 1px solid var(--av-brand-primary);\n            &:not(:first-child) {\n                margin-top: 16px;\n            }\n            &:last-child {\n                margin-bottom: 16px;\n            }\n            .el-radio__label {\n                @mixin lead-accent;\n                color: var(--av-fixed-primary);\n            }\n            .el-radio__description {\n                @mixin paragraph;\n                margin-top: 4px;\n                color: var(--av-fixed-primary);\n            }\n            &.el-radio-label-400 {\n                .el-radio__label {\n                    font-weight: 400;\n                }\n            }\n        }\n\n        .el-form-item__tooltip {\n            /* inset-inline-start/end is not needed for this tooltip */\n            @mixin caption-accent;\n            z-index: 1;\n            width: 100%;\n            bottom: 100%;\n            display: none;\n            padding: 16px;\n            margin-bottom: 8px;\n            border-radius: 4px;\n            position: absolute;\n            inset-inline-start: 50%;\n            transform: translateX(-50%);\n            color: var(--av-inversed-primary);\n            background: var(--av-fixed-primary);\n            box-shadow: var(--av-shadow-regular);\n\n            &::after {\n                width: 0;\n                height: 0;\n                inset-inline-start: 50%;\n                transform: translateX(-50%);\n                top: 100%;\n                content: '';\n                display: block;\n                position: absolute;\n                border-style: solid;\n                border-width: 4px 4px 0;\n                border-color: var(--av-fixed-primary) rgba(255, 255, 255, 0)\n                    rgba(255, 255, 255, 0) rgba(255, 255, 255, 0);\n            }\n        }\n\n        .el-form-item__error {\n            @mixin caption;\n            padding-bottom: 16px;\n        }\n\n        .el-form-item__hint {\n            @mixin caption;\n            margin-bottom: 16px;\n            color: var(--av-fixed-light);\n        }\n\n        .el-form-item {\n            &.is-error {\n                .el-input__icon {\n                    .svg {\n                        fill: var(--av-fixed-danger);\n                    }\n                }\n            }\n            &.is-focus {\n                .el-input__icon {\n                    .svg {\n                        fill: var(--av-brand-primary);\n                    }\n                }\n                .el-form-item__tooltip {\n                    display: block;\n                }\n            }\n        }\n\n        .el-form-error-api {\n            @mixin caption-accent;\n            position: relative;\n            padding-bottom: 16px;\n            color: var(--av-fixed-danger);\n\n            a {\n                text-decoration: underline;\n            }\n\n            & ~ .el-form-item__error-holder {\n                display: none;\n            }\n        }\n\n        .el-form-error-api-login {\n            @media (--viewport-tablet) {\n                width: 200%;\n            }\n\n            .el-form-item__hint {\n                @mixin caption;\n                color: var(--av-fixed-light);\n            }\n\n            .el-textarea__editor {\n                @mixin paragraph;\n                color: var(--av-fixed-primary);\n                font-family: var(--font-family-default);\n            }\n        }\n\n        .el-textarea {\n            &__label {\n                @mixin paragraph;\n            }\n            &.is-active {\n                .el-textarea__label {\n                    @mixin caption-accent;\n                }\n            }\n        }\n    }\n\n    &__error {\n        @mixin descriptor;\n        display: flex;\n        text-align: start;\n        align-items: flex-start;\n        margin-bottom: 16px;\n\n        :deep(a) {\n            text-decoration: underline;\n            color: var(--av-fixed-danger);\n        }\n    }\n\n    &__checkboxes {\n        :deep(.el-checkbox) {\n            &:last-child {\n                margin-bottom: 16px;\n            }\n\n            .el-checkbox__label {\n                @mixin body;\n                padding: 0;\n            }\n\n            .el-checkbox__content {\n                align-items: flex-start;\n            }\n\n            .el-checkbox__control {\n                margin: 4px 0 0;\n            }\n        }\n\n        .checkbox-error-message {\n            @mixin body;\n            gap: 8px;\n            display: flex;\n            align-items: flex-start;\n            margin-inline-start: -24px;\n\n            :deep(.a-glyph) {\n                min-width: 16px;\n                margin-top: 4px;\n                fill: var(--av-fixed-danger);\n            }\n        }\n    }\n\n    .input-required-label {\n        @mixin caption-accent;\n        padding: 4px 8px;\n        color: var(--av-fixed-critical);\n        background: var(--av-fixed-critical-accent);\n        border-radius: 4px;\n    }\n\n    .agreement {\n        @mixin body;\n        text-align: center;\n        margin-bottom: 16px;\n    }\n\n    .information {\n        @mixin body;\n        text-align: center;\n        margin-bottom: 16px;\n        color: var(--av-fixed-secondary);\n    }\n\n    .change {\n        margin: 16px 0 0;\n        text-align: center;\n    }\n\n    .recaptcha-notification {\n        @mixin body;\n        margin-top: 16px;\n        text-align: center;\n        color: var(--av-fixed-secondary);\n    }\n\n    &__note {\n        margin: 8px 0 0;\n\n        &-item {\n            @mixin caption;\n            color: var(--av-fixed-light);\n            text-align: center;\n\n            &.large {\n                margin: 16px 0 0;\n                @mixin body;\n                color: var(--av-fixed-secondary);\n            }\n\n            &.paragraph {\n                margin: 16px 0 0;\n                @mixin paragraph;\n                color: var(--av-fixed-secondary);\n            }\n        }\n        :deep(a) {\n            cursor: pointer;\n            color: var(--av-brand-primary);\n            text-decoration: none;\n\n            &:hover {\n                color: var(--av-brand-secondary);\n            }\n            &:focus {\n                background: var(--av-brand-secondary-light);\n                color: var(--av-brand-primary);\n            }\n            &:active {\n                background: none;\n                color: var(--av-brand-primary);\n            }\n        }\n    }\n\n    &__extra-button {\n        margin: 16px 0 0;\n\n        &.a-button_type_inverse {\n            border-radius: 4px;\n            border: 1px solid var(--av-brand-primary);\n\n            &:hover {\n                background: var(--av-brand-accent);\n            }\n\n            &:active {\n                background: var(--el-secondary-active);\n            }\n\n            :deep(.a-button__content) {\n                color: var(--av-brand-primary);\n                @mixin paragraph-accent;\n            }\n        }\n    }\n}\n\n.s-form-registration.s-form-registration-version-42019 {\n    overflow: hidden;\n    border-radius: 4px;\n    padding: 32px 16px 40px;\n    border: 1px solid var(--av-brand-light);\n    box-shadow: var(--av-shadow-small);\n\n    @media (--viewport-mobile-wide) {\n        padding-inline-end: 24px;\n        padding-inline-start: 24px;\n    }\n\n    @media (--viewport-desktop-wide) {\n        padding-inline-end: 48px;\n        padding-inline-start: 48px;\n    }\n\n    .s-form-registration__subtitle {\n        @mixin body;\n        margin-top: 16px;\n        color: var(--av-fixed-secondary);\n    }\n}\n\n[dir=\"rtl\"] {\n    .s-form-registration {\n        :deep(.el-form) {\n            margin: 32px 0 0;\n        }\n        .el-form-item__tooltip {\n            inset-inline-start: auto;\n            inset-inline-end: 50%;\n        }\n    }\n}\n\n@keyframes idle-pulse {\n    0% {\n        border-color: rgba(38, 104, 197, 0.3);\n        box-shadow: 0 0 0 0 rgba(38, 104, 197, 0);\n    }\n\n    10% {\n        border-color: #2668c5;\n        box-shadow: 0 0 8px 2px rgba(38, 104, 197, 0.15);\n    }\n\n    20% {\n        border-color: rgba(38, 104, 197, 0.3);\n        box-shadow: 0 0 0 0 rgba(38, 104, 197, 0);\n    }\n\n    30% {\n        border-color: #2668c5;\n        box-shadow: 0 0 8px 2px rgba(38, 104, 197, 0.15);\n    }\n\n    40% {\n        border-color: rgba(38, 104, 197, 0.3);\n        box-shadow: 0 0 0 0 rgba(38, 104, 197, 0);\n    }\n\n    50% {\n        border-color: #2668c5;\n        box-shadow: 0 0 8px 2px rgba(38, 104, 197, 0.15);\n    }\n\n    60%, 100% {\n        border-color: rgba(38, 104, 197, 0.3);\n        box-shadow: 0 0 0 0 rgba(38, 104, 197, 0);\n    }\n}\n\n@keyframes idle-pulse-error {\n    0% {\n        border-color: rgba(234, 57, 57, 0.3);\n        box-shadow: 0 0 0 0 rgba(234, 57, 57, 0);\n    }\n\n    10% {\n        border-color: rgb(234, 57, 57);\n        box-shadow: 0 0 8px 2px rgba(234, 57, 57, 0.15);\n    }\n\n    20% {\n        border-color: rgba(234, 57, 57, 0.3);\n        box-shadow: 0 0 0 0 rgba(234, 57, 57, 0);\n    }\n\n    30% {\n        border-color: rgb(234, 57, 57);\n        box-shadow: 0 0 8px 2px rgba(234, 57, 57, 0.15);\n    }\n\n    40% {\n        border-color: rgba(234, 57, 57, 0.3);\n        box-shadow: 0 0 0 0 rgba(234, 57, 57, 0);\n    }\n\n    50% {\n        border-color: rgb(234, 57, 57);\n        box-shadow: 0 0 8px 2px rgba(234, 57, 57, 0.15);\n    }\n\n    60%, 100% {\n        border-color: rgba(234, 57, 57, 0.3);\n        box-shadow: 0 0 0 0 rgba(234, 57, 57, 0);\n    }\n}\n\n.idle-glow {\n    :deep(.el-input__container) {\n        animation: idle-pulse 5s ease-in-out infinite;\n    }\n\n    &.is-error {\n        :deep(.el-input__container) {\n            animation: idle-pulse-error 5s ease-in-out infinite;\n        }\n    }\n}\n</style>\n","<template>\n    <div class=\"s-form-error\">\n        <a-glyph\n            v-if=\"content.glyph\"\n            :name=\"content.glyph || 'attention'\"\n            :fill=\"content.glyphFill || 'orange-bright'\"\n            :size=\"content.glyphSize || 'l'\"\n        />\n        <div v-if=\"content.title\" class=\"title\" v-html=\"content.title\" />\n        <div v-if=\"content.description\" class=\"description\" v-html=\"content.description\" />\n        <div v-if=\"content.code\" class=\"code\">\n            [{{ content.code }}]\n        </div>\n        <a-button\n            v-if=\"content.button\"\n            v-bind=\"content.button\"\n            :event=\"{ doNotSendGA: true }\"\n            @click=\"$emit('submit')\"\n        />\n    </div>\n</template>\n\n<script>\nimport AButton from '@core/components/button/button.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\n\nexport default {\n    name: 'TrialFormError',\n\n    components: {\n        AButton,\n        AGlyph,\n    },\n\n    props: {\n        content: {\n            type: Object,\n            default: () => ({\n                title: 'Something went wrong',\n                description: 'Try reloading the page',\n                button: {\n                    text: 'Try again',\n                    type: 'main',\n                },\n                code: null,\n            }),\n        },\n    },\n\n    emits: ['submit'],\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-form-error {\n    width: 100%;\n    display: flex;\n    min-height: 352px;\n    align-items: center;\n    flex-direction: column;\n    justify-content: center;\n    padding: 48px 16px 40px;\n    background: var(--av-inversed-primary);\n\n    @media (--viewport-mobile-wide) {\n        border-radius: 4px;\n        padding: 48px 48px 42px;\n        box-shadow: var(--av-shadow-small);\n        border: 1px solid var(--av-brand-light);\n    }\n\n    .title {\n        @mixin title-accent;\n        text-align: center;\n        color: var(--av-nav-primary);\n    }\n\n    .description {\n        @mixin paragraph;\n        margin: 16px 0 0;\n        text-align: center;\n    }\n\n    .code {\n        @mixin paragraph;\n        margin: 16px 0 0;\n        text-align: center;\n        color: var(--av-fixed-light);\n    }\n\n    .a-button {\n        margin: 40px auto 0;\n        padding: 8px 16px;\n        min-width: 200px;\n    }\n\n    .a-glyph {\n        margin: 0 0 16px;\n    }\n}\n</style>\n","<template>\n    <div class=\"s-form-login\">\n        <div v-if=\"content.title\" class=\"title\" v-html=\"content.title\" />\n        <div v-if=\"content.subtitles\" class=\"subtitle\">\n            <p v-for=\"(item, i) in content.subtitles\" :key=\"`subtitles-${i}`\" v-html=\"item\" />\n        </div>\n        <el-form ref=\"form\" :model=\"form\" :rules=\"rules\">\n            <a-row>\n                <el-form-item prop=\"email\">\n                    <el-input\n                        ref=\"email\"\n                        v-model=\"form.email\"\n                        autofocus\n                        name=\"email\"\n                        type=\"input\"\n                        :label=\"formLabelText({ name: 'email' })\"\n                        @input=\"onInputField\"\n                    />\n                </el-form-item>\n            </a-row>\n            <a-row>\n                <el-form-item prop=\"password\">\n                    <el-input\n                        ref=\"password\"\n                        v-model=\"form.password\"\n                        type=\"password\"\n                        name=\"password\"\n                        :label=\"formLabelText({ name: 'password' })\"\n                        show-password-icon\n                        @input=\"onInputField\"\n                    />\n                </el-form-item>\n            </a-row>\n            <el-form-error v-if=\"errorMessage\" size=\"large\" show-icon>\n                <span v-html=\"errorMessage\" />\n            </el-form-error>\n            <p v-if=\"content.note\" class=\"note\" v-html=\"content.note\" />\n            <a-button\n                v-if=\"content.button\"\n                v-bind=\"content.button\"\n                :event=\"{ doNotSendGA: true }\"\n                @click=\"onSubmitForm\"\n            />\n        </el-form>\n        <div v-if=\"content.info\" class=\"info\">\n            <p v-for=\"(item, i) in content.info\" :key=\"`info-${i}`\" v-html=\"item\" />\n        </div>\n    </div>\n</template>\n\n<script>\nimport { mapActions } from 'vuex';\nimport AButton from '@core/components/button/button.vue';\nimport ElFormError from '@core/components/form/form-error.vue';\nimport ElFormItem from '@core/components/form/form-item.vue';\nimport ElForm from '@core/components/form/form.vue';\nimport ElInput from '@core/components/input/input.vue';\nimport ARow from '@core/components/row/row.vue';\nimport form from '@core/mixins/form';\n\nexport default {\n    name: 'TrialFormLogin',\n\n    components: {\n        AButton,\n        ElForm,\n        ElFormError,\n        ElFormItem,\n        ElInput,\n        ARow,\n    },\n\n    mixins: [form],\n\n    props: {\n        content: {\n            type: Object,\n            default: null,\n        },\n    },\n\n    emits: ['error', 'loading', 'submit'],\n\n    data: () => ({\n        form: {\n            email: '',\n            password: '',\n        },\n        errorMessage: '',\n    }),\n\n    computed: {\n        rules() {\n            return {\n                email: [\n                    {\n                        trigger: 'submit',\n                        validator: this.validateEmail,\n                        message: this.formErrorText({ name: 'email' }),\n                    },\n                ],\n                password: [\n                    {\n                        trigger: 'submit',\n                        validator: this.validatePassword,\n                        message: this.formErrorText({ name: 'password' }),\n                    },\n                ],\n            };\n        },\n    },\n\n    methods: {\n        ...mapActions({\n            accountLogin: 'trial/accountLogin',\n        }),\n\n        onInputField() {\n            this.errorMessage = '';\n            this.$nextTick(() => this.$refs.form?.clearValidate?.());\n        },\n\n        async onSubmitForm() {\n            try {\n                this.prepareFormToValidate();\n                await this.$refs.form.validate();\n            } catch (e) {\n                this.setFocusErrorField();\n                return;\n            }\n\n            try {\n                this.$emit('loading', true);\n\n                const response = await this.accountLogin({\n                    email: this.form.email,\n                    password: this.form.password,\n                });\n\n                if (response.status !== 200) {\n                    const msg = 'Wrong email or password';\n                    this.errorMessage = this.content?.messages?.error || msg;\n                    this.setFocus('password');\n                    this.$emit('loading', false);\n                    return;\n                }\n\n                this.$emit('submit');\n            } catch (e) {\n                this.$emit('error');\n            }\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-form-login {\n    display: flex;\n    position: relative;\n    flex-direction: column;\n    padding: 40px 16px 56px;\n    justify-content: center;\n    background: var(--av-inversed-primary);\n\n    @media (--viewport-mobile-wide) {\n        border-radius: 4px;\n        box-shadow: var(--av-shadow-small);\n        border: 1px solid var(--av-brand-light);\n    }\n\n    @media (--viewport-tablet) {\n        padding: 40px 48px;\n    }\n\n    @media (--viewport-desktop) {\n        width: 100%;\n        margin: 0 auto;\n    }\n\n    .title {\n        @mixin title-accent;\n        text-align: center;\n        color: var(--av-nav-primary);\n    }\n\n    .subtitle {\n        @mixin paragraph;\n        margin: 8px 0 0;\n        text-align: center;\n\n        :deep(a) {\n            cursor: pointer;\n            text-decoration: none;\n            color: var(--av-brand-secondary);\n\n            &:hover {\n                color: var(--av-brand-secondary);\n            }\n        }\n    }\n\n    .note {\n        text-align: end;\n        margin-bottom: 16px;\n\n        :deep(.a-link__content) {\n            @mixin descriptor;\n            color: var(--av-brand-secondary);\n        }\n    }\n\n    .info {\n        @mixin body;\n        margin-top: 24px;\n        text-align: center;\n        color: var(--av-fixed-secondary);\n\n        a {\n            color: var(--av-brand-primary);\n        }\n    }\n\n    :deep(.el-form) {\n        width: 100%;\n        margin: 32px 0 0;\n        text-align: start;\n\n        @media (--viewport-tablet) {\n            margin: 24px 0 0;\n        }\n\n        .el-input__label {\n            &.is-active {\n                font-weight: 700;\n            }\n        }\n\n        .el-form-item__error {\n            @mixin caption;\n            padding-bottom: 16px;\n        }\n    }\n\n    :deep(.a-button) {\n        width: 100%;\n    }\n}\n</style>\n","<template>\n    <div v-if=\"content\" class=\"notification\" :class=\"className\">\n        <a-glyph v-if=\"content.glyph\" class=\"icon\" :name=\"content.glyph\" />\n        <div v-if=\"content.title\" class=\"title\" v-html=\"content.title\" />\n        <div v-if=\"content.description\" class=\"description\">\n            <p\n                v-for=\"(item, i) in content.description\"\n                :key=\"i\"\n                class=\"description-item\"\n                v-html=\"item\"\n            />\n        </div>\n        <div v-if=\"content.list\" class=\"list\">\n            <div v-for=\"(item, itemIndex) in content.list\" :key=\"`list-item-${itemIndex}`\">\n                <a-glyph name=\"checkmark-success\" />\n                <span>{{ item }}</span>\n            </div>\n        </div>\n        <a-picture v-if=\"content.image\" class=\"image\" :link=\"content.image\" />\n        <template v-if=\"content.buttons?.length\">\n            <a-button\n                v-for=\"(item, itemIndex) in content.buttons\"\n                v-bind=\"item\"\n                :key=\"`button-${itemIndex}`\"\n                :event=\"item.event || { doNotSendGA: true }\"\n                @click=\"handleClick(item)\"\n            />\n        </template>\n    </div>\n</template>\n\n<script>\nimport AButton from '@core/components/button/button.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport APicture from '@core/components/picture/picture.vue';\nimport form from '@core/mixins/form';\n\nexport default {\n    name: 'TrialFormNotification',\n\n    components: {\n        AButton,\n        AGlyph,\n        APicture,\n    },\n\n    mixins: [form],\n\n    props: {\n        content: {\n            type: Object,\n            default: null,\n        },\n    },\n\n    emits: ['backToForm'],\n\n    computed: {\n        className() {\n            return {\n                [`${this.content.className}`]: this.content.className,\n            };\n        },\n    },\n    mounted() {\n        if (this.content.eventTracking) {\n            this.sendDataLayer({\n                eventAction: window.location.href,\n                ...this.content.eventTracking,\n            });\n        }\n    },\n    methods: {\n        handleClick(item) {\n            if (item.isHistoryBack) window.history.back();\n            if (item.backToForm) this.$emit('backToForm', item.backToForm);\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.notification {\n    width: 100%;\n    display: flex;\n    padding: 40px;\n    text-align: center;\n    align-items: center;\n    flex-direction: column;\n    justify-content: center;\n    background: var(--av-inversed-primary);\n    @media (--viewport-mobile-wide) {\n        border: 1px solid #e3ecf9;\n        box-shadow: var(--av-shadow-small);\n    }\n    :deep(.a-picture) {\n        margin-top: 24px;\n        +.a-button {\n            margin-top: 24px;\n        }\n    }\n    :deep(.a-button) {\n        margin-top: 8px;\n        min-width: 200px;\n    }\n}\n\n.title {\n    @mixin title-accent;\n    margin: 16px 0 0;\n    color: var(--av-nav-primary);\n}\n\n.icon {\n    width: 32px;\n    height: 32px;\n    fill: var(--av-fixed-success);\n}\n\n.description {\n    margin-top: 16px;\n}\n\n.description-item {\n    @mixin paragraph;\n    color: var(--av-fixed-secondary);\n\n    &:not(:first-child) {\n        margin-top: 16px;\n    }\n\n    :deep(a) {\n        text-decoration: none;\n        color: var(--av-brand-primary);\n    }\n}\n\n.list {\n    gap: 16px;\n    display: flex;\n    width: 100%;\n    margin-top: 24px;\n    text-align: start;\n    flex-direction: column;\n    padding-inline-start: 16px;\n\n    :deep(.a-glyph) {\n        margin: 0 4px 2px 0;\n        vertical-align: middle;\n    }\n}\n\n.version-48244 {\n    .title,\n    .a-button {\n        margin: 0;\n    }\n\n    .description {\n        margin-top: 8px;\n    }\n\n     :deep(.a-button) {\n        width: 100%;\n        margin-top: 24px;\n\n        ~ .a-button {\n            margin-top: 16px;\n        }\n    }\n}\n</style>\n","<template>\n    <div class=\"s-form-schedule\">\n        <div class=\"s-form-schedule__title\">\n            {{ content.title }}\n        </div>\n        <div class=\"s-form-schedule__lead\">\n            {{ content.lead }}\n        </div>\n\n        <a-picture\n            v-if=\"content.image\"\n            class=\"s-form-schedule__image\"\n            :link=\"content.image\"\n        />\n\n        <div class=\"s-form-schedule__subtitle\">\n            {{ content.subtitle }}\n        </div>\n        <div class=\"s-form-schedule__body\">\n            {{ content.body }}\n        </div>\n\n        <a-button\n            v-if=\"content.button\"\n            class=\"s-form-schedule__button\"\n            v-bind=\"content.button\"\n            :to=\"content.link\"\n        />\n    </div>\n</template>\n\n<script>\n\nimport AButton from '@core/components/button/button.vue';\nimport APicture from '@core/components/picture/picture.vue';\n\nexport default {\n    name: 'FormSchedule',\n    components: {\n        AButton,\n        APicture,\n    },\n    props: {\n        content: {\n            type: Object,\n            required: true,\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-form-schedule {\n    padding: 40px;\n    background-color: var(--av-inversed-primary);\n    box-shadow: var(--av-shadow-small);\n\n    &__title {\n        @mixin hero-accent;\n        color: var(--av-nav-primary);\n        margin-bottom: 16px;\n        text-align: center;\n    }\n\n    &__lead {\n        @mixin paragraph;\n        text-align: center;\n        color: var(--av-fixed-secondary);\n        max-width: 440px;\n        margin: 0 auto;\n    }\n\n    &__image {\n        margin: 0 auto;\n        height: 316px;\n        width: auto;\n    }\n\n    &__subtitle {\n        @mixin title;\n        font-weight: 500;\n        text-align: center;\n        color: var(--av-nav-primary);\n        margin-bottom: 8px;\n    }\n\n    &__body {\n        @mixin body;\n        text-align: center;\n        color: var(--av-fixed-secondary);\n        max-width: 290px;\n        margin: 0 auto 24px;\n    }\n\n    &__button {\n        width: 100%;\n    }\n}\n\n@media (--viewport-mobile-wide) {\n    .s-form-schedule {\n        border-radius: 4px;\n        box-shadow: var(--av-shadow-small);\n        border: 1px solid var(--av-solid-brand-accent);\n    }\n}\n</style>\n","<template>\n    <div v-if=\"content\" class=\"s-form-success\" :class=\"className\">\n        <a-glyph v-if=\"content.glyph\" fill=\"fixed-success\" :name=\"content.glyph\" />\n        <p v-if=\"content.header\" class=\"header\" v-html=\"content.header\" />\n        <p v-if=\"content.paragraph\" class=\"paragraph\" v-html=\"content.paragraph\" />\n        <a-picture v-if=\"content.image\" class=\"image\" :link=\"content.image\" />\n\n        <template v-if=\"content.info\">\n            <a-dangerous-html class=\"info\" :content=\"info\" />\n        </template>\n\n        <p v-if=\"content.title && !content.header\" class=\"title\">\n            {{ content.title }}\n        </p>\n\n        <template v-if=\"content.description\">\n            <a-dangerous-html class=\"description\" :content=\"description\" />\n        </template>\n\n        <a-link\n            v-if=\"content.backToLink\"\n            v-bind=\"content.backToLink\"\n            :class=\"content.backToLink.className\"\n            @click=\"$emit('backToForm', content.backToLink.backTo)\"\n        />\n\n        <template v-if=\"content.button\">\n            <a-button\n                v-if=\"content.button.to\"\n                class=\"cta-button\"\n                :class=\"content.button.className\"\n                v-bind=\"omitClassName(content.button)\"\n                :type=\"content.button.type || 'action'\"\n                :text=\"content.button.text || 'Download'\"\n                :event=\"content.button.event || { doNotSendGA: true }\"\n            />\n            <a-button\n                v-else\n                class=\"cta-button\"\n                :class=\"content.button.className\"\n                v-bind=\"omitClassName(content.button)\"\n                :type=\"content.button.type || 'action'\"\n                :text=\"content.button.text || 'Download'\"\n                :event=\"content.button.event || { doNotSendGA: true }\"\n                @click=\"$emit('onClickButtonSuccess')\"\n            />\n        </template>\n\n        <div v-if=\"content.links?.length\" class=\"links\">\n            <dynamic-link\n                v-for=\"(link, i) in content.links\"\n                :key=\"i\"\n                class=\"link\"\n                v-bind=\"link\"\n            >\n                {{ link.text }}\n            </dynamic-link>\n        </div>\n\n        <div v-if=\"content.downloadButtons?.length\" ref=\"downloadButtons\" class=\"download-buttons\">\n            <a-button\n                v-for=\"button in content.downloadButtons\"\n                :key=\"button.to\"\n                class=\"button\"\n                :class=\"button.className\"\n                v-bind=\"omitClassName(button)\"\n                :type=\"button.type || 'action'\"\n                :event=\"button.event || { doNotSendGA: true }\"\n                :data-platform=\"button.platform\"\n            />\n        </div>\n    </div>\n</template>\n\n<script>\nimport AButton from '@core/components/button/button.vue';\nimport ADangerousHtml from '@core/components/dangerous-html/dangerous-html.vue';\nimport DynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport ALink from '@core/components/link/link.vue';\nimport APicture from '@core/components/picture/picture.vue';\nimport form from '@core/mixins/form';\nimport commonUtils from '@utils/common';\nimport formHelper from '@utils/form.js';\n\nexport default {\n    name: 'FormSuccess',\n\n    components: {\n        ADangerousHtml,\n        DynamicLink,\n        AButton,\n        AGlyph,\n        ALink,\n        APicture,\n    },\n\n    mixins: [form],\n\n    props: {\n        userData: {\n            type: Object,\n            default: null,\n        },\n        form: {\n            type: Object,\n            default: () => ({\n                image: '/images/partner-form/success',\n                description: 'Your submission has been sent',\n                title: 'Thank you',\n            }),\n        },\n    },\n\n    emits: ['onClickButtonSuccess', 'backToForm'],\n\n    data: () => ({\n        content: {},\n    }),\n\n    computed: {\n        className() {\n            return {\n                'with-downloads': Boolean(this.content.downloadButtons?.length),\n                'small-paddings': Boolean(this.content.header && this.content.links),\n            };\n        },\n        info() {\n            const text = this.content.info || '';\n            return this.replaceText(text, 'first_name');\n        },\n        description() {\n            const text = this.content.description || '';\n            return this.replaceText(text, 'email');\n        },\n    },\n    beforeMount() {\n        const variation = this.form?.variation?.field;\n        const value = this.userData?.[variation];\n        const hasVariation = Boolean(value && this.form?.variation?.value?.[value]);\n        this.content = hasVariation ? this.form.variation.value[value] : this.form;\n        this.content.eventTracking = this.form.eventTracking || false;\n    },\n    async mounted() {\n        if (this.content.isPromoSubscription) {\n            const companyType = this.userData.company_type || '';\n            const product = {\n                'Corporate End-Customer': 'Business news and products',\n                'Prosumer End-Customer': 'Home and Office news and products',\n                'Service Provider': 'Service Provider news and products',\n            };\n\n            this.sendDataLayer({\n                eventLabel: `news letter subscription: ${product[companyType] || ''}`,\n                eventAction: 'submit_form_success',\n                eventCategory: 'form',\n                formTimer: formHelper.getSecondsOnPage(), // WEB-44946\n                emailAddress: await commonUtils.toSHA256String(this.userData.email), // WEB-45304\n            });\n            return;\n        }\n\n        if (this.content.eventTracking) {\n            this.sendDataLayer({\n                eventAction: window.location.href,\n                ...this.content.eventTracking,\n                formTimer: formHelper.getSecondsOnPage(), // WEB-44946\n                emailAddress: await commonUtils.toSHA256String(this.userData.email), // WEB-45304\n            });\n        }\n\n        if (this.content.downloadButtons) {\n            const selectedOS = /mac|iphone|ipad|ipod/i.test(navigator.userAgent) ? 'MAC' : 'PC';\n            this.$refs.downloadButtons.querySelector(`[data-platform=\"${selectedOS}\"]`)?.click();\n        }\n    },\n\n    methods: {\n        omitClassName(obj) {\n            const props = { ...obj };\n            delete props.className;\n            return props;\n        },\n        replaceText(text, key) {\n            const value = this.userData?.[key] || '';\n            return text.replace(`@${key}`, value);\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-form-success {\n    width: 100%;\n    display: flex;\n    text-align: center;\n    align-items: center;\n    flex-direction: column;\n    justify-content: center;\n    border-radius: 4px;\n    padding: 89px 24px 90px;\n    color: var(--av-nav-primary);\n    background: var(--av-inversed-primary);\n    border: 1px solid var(--av-fixed-lightest);\n    box-shadow: 0 4px 8px rgba(36, 49, 67, 0.2);\n\n    @media (--viewport-desktop-large) {\n        padding: 113px 24px 114px;\n    }\n    @media (--viewport-desktop-wide) {\n        padding: 105px 24px 106px;\n    }\n\n    .info {\n        @mixin body-accent;\n        margin-top: 8px;\n    }\n\n    .title {\n        @mixin title;\n        font-weight: 500;\n        margin: 32px 0 0;\n        color: var(--av-nav-primary);\n    }\n\n    .image {\n        height: 250px;\n        margin: 24px 0 auto;\n\n        @media (--viewport-desktop) {\n            height: 252px;\n        }\n        @media (--viewport-desktop-wide) {\n            height: 250px;\n        }\n\n        :deep(.a-picture__img) {\n            height: 100%;\n        }\n    }\n\n    .link,\n    .paragraph,\n    .description {\n        @mixin paragraph;\n        margin: 24px 0 0;\n        max-width: 472px;\n    }\n\n    .header {\n        @mixin title-accent;\n        max-width: 472px;\n    }\n\n    :deep(a) {\n        text-decoration: none;\n        color: var(--av-brand-secondary);\n    }\n\n    .a-button.cta-button {\n        color: var(--av-inversed-primary);\n    }\n\n    .links {\n        display: flex;\n        flex-direction: column;\n    }\n\n    .cta-button {\n        margin-top: 24px;\n    }\n\n    &.small-paddings {\n        padding: 16px 40px 40px;\n\n        .header {\n            margin-bottom: 24px;\n        }\n\n        .cta-button.full-width {\n            width: 100%;\n        }\n    }\n\n    &.with-downloads {\n        padding: 24px 32px 32px;\n\n        .header {\n            @mixin lead-accent;\n            margin-top: 8px;\n        }\n    }\n\n    .extra-button {\n        margin: 16px 0 0;\n\n        &.a-button_type_inverse {\n            border-radius: 4px;\n            border: 1px solid var(--av-brand-primary);\n\n            &:hover {\n                background: var(--av-brand-accent);\n            }\n\n            &:active {\n                background: var(--el-secondary-active);\n            }\n\n            :deep(.a-button__content) {\n                color: var(--av-brand-primary);\n                @mixin paragraph-accent;\n            }\n        }\n    }\n\n    .download-buttons {\n        margin: 16px 0 0;\n        display: flex;\n        flex-wrap: wrap;\n        flex-direction: row;\n        gap: 16px;\n\n        .a-button {\n            width: 100%;\n            border-color: var(--av-brand-primary);\n            color: var(--av-brand-primary);\n\n            @media (--viewport-tablet) {\n                flex: 1;\n                width: 50%;\n            }\n\n            :deep(.a-glyph) {\n                width: 16px;\n                height: 16px;\n                fill: var(--av-brand-primary);\n            }\n        }\n    }\n\n    .back-to-form-link {\n        margin-top: 16px;\n\n        :deep(.a-link__content) {\n            @mixin paragraph;\n            color: var(--av-brand-primary);\n        }\n    }\n}\n</style>\n","<template>\n    <div class=\"s-form-support-confirmation\">\n        <div class=\"s-form-support-confirmation__title\">\n            {{ content.title }}\n        </div>\n\n        <a-picture\n            v-if=\"content.image\"\n            class=\"s-form-support-confirmation__image\"\n            :link=\"content.image\"\n        />\n\n        <div class=\"s-form-support-confirmation__subtitle\">\n            {{ content.subtitle }}\n        </div>\n\n        <a-button\n            v-if=\"content.button\"\n            class=\"s-form-support-confirmation__button\"\n            v-bind=\"content.button\"\n            :to=\"content.redirectLink\"\n        />\n\n        <div v-if=\"message\" class=\"s-form-support-confirmation__message\">\n            <a-dangerous-html class=\"a-feature-card__text\" :content=\"message\" />\n        </div>\n    </div>\n</template>\n\n<script>\n\nimport AButton from '@core/components/button/button.vue';\nimport ADangerousHtml from '@core/components/dangerous-html/dangerous-html.vue';\nimport APicture from '@core/components/picture/picture.vue';\n\nexport default {\n    name: 'FormSupportConfirmation',\n    components: {\n        AButton,\n        ADangerousHtml,\n        APicture,\n    },\n    props: {\n        content: {\n            type: Object,\n            required: true,\n        },\n        form: {\n            type: Object,\n            default: null,\n        },\n    },\n    computed: {\n        message() {\n            return this.content.audienceMessage?.[this.form?.company_type];\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-form-support-confirmation {\n    padding: 40px;\n    background-color: var(--av-inversed-primary);\n\n    &__title {\n        @mixin lead-accent;\n        color: var(--av-nav-primary);\n        text-align: center;\n    }\n\n    &__image {\n        margin: 24px auto;\n        height: 243px;\n        width: auto;\n    }\n\n    &__subtitle {\n        @mixin paragraph;\n        text-align: center;\n        color: var(--av-fixed-primary);\n        margin-bottom: 22px;\n    }\n\n    &__message {\n        margin-top: 15px;\n        text-align: center;\n    }\n\n    &__button {\n        width: 100%;\n    }\n}\n\n@media (--viewport-mobile-wide) {\n    .s-form-support-confirmation {\n        border-radius: 4px;\n        box-shadow: var(--av-shadow-small);\n    }\n}\n</style>\n","<template>\n    <div v-if=\"content\" class=\"s-form-upsell-container\">\n        <div v-if=\"!content.table\" class=\"s-form-upsell\">\n            <div v-if=\"content.flag\" class=\"s-form-upsell-flag\">\n                {{ content.flag }}\n            </div>\n            <div v-if=\"content.title\" class=\"s-form-upsell-title\">\n                {{ content.title }}\n            </div>\n            <a-picture v-if=\"content.image\" class=\"s-form-upsell-image\" :link=\"content.image\" />\n            <div v-if=\"content.description\" class=\"s-form-upsell-description\">\n                {{ content.description }}\n            </div>\n            <a-button\n                v-if=\"content.button\"\n                class=\"s-form-upsell-button\"\n                :text=\"content.button\"\n                :event=\"content.buttonEventGA || { doNotSendGA: true }\"\n                @click=\"onClick()\"\n            />\n            <a-button\n                v-if=\"content.link\"\n                class=\"s-form-upsell-link\"\n                :text=\"content.link\"\n                :event=\"content.linkEventGA || { doNotSendGA: true }\"\n                @click=\"onSubmit()\"\n            />\n        </div>\n        <div v-else class=\"s-form-upsell-table\">\n            <div v-if=\"content.table?.length\" class=\"table\">\n                <div v-for=\"(row, rowIndex) in content.table\" :key=\"`row-${rowIndex}`\" class=\"row\">\n                    <div\n                        v-for=\"(cell, cellIndex) in row\"\n                        :key=\"`cell-${cellIndex}`\"\n                        class=\"cell\"\n                        v-html=\"cell\"\n                    />\n                </div>\n            </div>\n            <div v-if=\"content.buttons?.length\" class=\"buttons\">\n                <a-button\n                    v-for=\"(button, buttonIndex) in content.buttons\"\n                    :key=\"`button-${buttonIndex}`\"\n                    :event=\"button.event || { doNotSendGA: true }\"\n                    v-bind=\"button\"\n                    @click=\"button.hasRedirect ? onClick(): onSubmit()\"\n                />\n            </div>\n        </div>\n    </div>\n</template>\n\n<script>\nimport { get, isEmpty } from 'lodash-es';\nimport AButton from '@core/components/button/button.vue';\nimport APicture from '@core/components/picture/picture.vue';\nimport form from '@core/mixins/form.js';\nimport language from '@core/mixins/language';\n\nexport default {\n    name: 'TrialFormUpsell',\n\n    components: {\n        AButton,\n        APicture,\n    },\n\n    mixins: [form, language],\n\n    props: {\n        content: {\n            type: Object,\n            default: null,\n        },\n    },\n\n    emits: ['submit', 'showNotification'],\n\n    mounted() {\n        this.sendDataLayer({\n            eventCategory: 'Upsell',\n            eventAction: 'show',\n            eventLabel: 'dnl_typage_promo',\n            formFieldA: 'Prosumer End-Customer',\n        });\n    },\n\n    methods: {\n        onSubmit() {\n            this.sendDataLayer({\n                eventCategory: 'Upsell',\n                eventAction: 'click',\n                eventLabel: 'Acronis Backup',\n            });\n            this.$emit('submit');\n        },\n\n        onClick() {\n            const notification = get(this, 'content.notification', null);\n            const targetURL = `https://www.acronis.com/${this.pageLocaleMarker}/homecomputing/thanks/home-office/`;\n            const url = this.content?.buttonTargetURL || targetURL;\n\n            this.sendDataLayer({\n                eventCategory: 'Upsell',\n                eventAction: 'click',\n                eventLabel: 'Acronis True Image',\n            });\n\n            if (isEmpty(notification)) {\n                window.location.assign(url);\n                return;\n            }\n\n            if (notification.openLink) {\n                window.open(url);\n            }\n\n            this.$emit('showNotification', notification);\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-form-upsell {\n    @mixin body;\n    text-align: center;\n    padding: 40px 16px 56px;\n    background: var(--av-inversed-primary);\n    @media (--viewport-mobile-wide) {\n        border-radius: 4px;\n        box-shadow: var(--av-shadow-small);\n        border: 1px solid var(--av-brand-light);\n    }\n    @media (--viewport-tablet) {\n        padding: 40px 48px;\n    }\n    &-flag {\n        @mixin note;\n        color: #83ad00;\n        min-width: 110px;\n        padding: 4px 12px;\n        border-radius: 12px;\n        display: inline-block;\n        background-color: rgba(141, 183, 14, 0.15);\n    }\n\n    &-title {\n        @mixin title-accent;\n        margin-top: 16px;\n        color: var(--av-fixed-secondary);\n    }\n\n    &-image {\n        margin: 24px auto 0;\n        width: 248px;\n        height: 168px;\n    }\n\n    &-description {\n        margin-top: 24px;\n        color: var(--av-fixed-secondary);\n    }\n\n    &-button {\n        @mixin body;\n        color: var(--av-inversed-primary);\n        display: block;\n        margin-top: 24px;\n        padding: 4px 16px;\n        background-color: #4875b3;\n        width: 100%;\n        text-align: center;\n\n        &:hover {\n            color: var(--av-inversed-primary);\n            background-color: #4875b3;\n        }\n    }\n\n    &-link {\n        padding: 0;\n        color: #0275d8;\n        font-size: 14px;\n        font-weight: 400;\n        background: none;\n        margin-top: 16px;\n        line-height: 20px;\n        white-space: unset;\n\n        &:hover {\n            background: none;\n            color: #014c8c;\n        }\n    }\n\n    &-link,\n    &-button {\n        border: none;\n        box-shadow: none;\n    }\n}\n.s-form-upsell-table {\n    z-index: 1;\n    margin: 0 16px;\n    text-align: center;\n    border-radius: 16px;\n    box-shadow: var(--av-shadow-small);\n    border: 1px solid var(--av-brand-light);\n    background: var(--av-inversed-primary);\n    @media (--viewport-tablet) {\n        margin: 0;\n        text-align: left;\n        width: calc(100% - 64px);\n    }\n    @media (--viewport-desktop) {\n        max-width: 984px;\n    }\n    .table {\n        @mixin paragraph;\n        color: var(--av-fixed-secondary);\n        .row {\n            gap: 8px 0;\n            display: flex;\n            padding: 16px;\n            flex-wrap: wrap;\n            flex-direction: row;\n            align-items: center;\n            background: var(--av-brand-lightest);\n            border-bottom: 1px solid var(--av-brand-accent);\n            @media (--viewport-tablet) {\n                gap: 32px;\n                padding: 16px 32px;\n            }\n            @media (--viewport-desktop) {\n                padding: 16px 48px;\n            }\n            &:first-child {\n                gap: 24px 0;\n                padding: 24px 16px;\n                align-items: flex-start;\n                background: transparent;\n                box-shadow: 0 4px 8px 0 rgba(36, 49, 67, 0.10);\n                border-bottom: 1px solid var(--av-brand-accent);\n                @media (--viewport-tablet) {\n                    gap: 32px;\n                    padding: 24px 32px;\n                }\n                @media (--viewport-desktop) {\n                    padding: 24px 48px;\n                }\n                .cell {\n                    padding: 0 16px;\n                    @media (--viewport-tablet) {\n                        padding: 0;\n                    }\n                }\n            }\n        }\n        .cell {\n            width: 50%;\n            @media (--viewport-tablet) {\n                flex: 1;\n                width: auto;\n            }\n            &:first-child {\n                width: 100%;\n                font-weight: 700;\n                @media (--viewport-tablet) {\n                    width: auto;\n                    min-width: 237px;\n                    font-weight: 400;\n                }\n            }\n        }\n        :deep(.title) {\n            font-weight: 400;\n            b {\n                @mixin lead-accent;\n                display: block;\n                color: var(--av-nav-primary);\n                @media (--viewport-tablet) {\n                    @mixin title-accent;\n                }\n            }\n\n        }\n         :deep(.product) {\n            font-weight: 700;\n            color: var(--av-nav-primary);\n        }\n        :deep(.note) {\n            @mixin body;\n            padding: 0 16px;\n            font-weight: 400;\n            text-align: start;\n            color: var(--av-fixed-light);\n            @media (--viewport-tablet) {\n                padding: 0;\n            }\n        }\n    }\n    .buttons {\n        gap: 16px;\n        display: flex;\n        padding: 24px 16px;\n        flex-direction: row;\n        @media (--viewport-tablet) {\n            gap: 56px;\n            padding: 24px 104px;\n            justify-content: center;\n        }\n        .a-button {\n            white-space: unset;\n            text-align: center;\n            @media (--viewport-tablet) {\n                flex: 1;\n                align-items: center;\n            }\n        }\n    }\n}\n</style>\n","<template>\n    <div ref=\"container\" :class=\"{ ...className }\">\n        <p v-if=\"form.productTitle\" class=\"s-form-title\">\n            <a-link\n                v-if=\"form.productLink\"\n                :to=\"form.productLink\"\n                :text=\"form.productTitle\"\n            />\n            <span v-else v-html=\"form.productTitle\" />\n        </p>\n\n        <div class=\"s-form-content\">\n            <div v-if=\"isLoading\" class=\"s-form-container__loading\">\n                <el-spinner :size=\"48\" color=\"brand-secondary\" />\n                <p v-html=\"loadingMessage\" />\n            </div>\n            <form-support-confirmation\n                v-if=\"isActive('support')\"\n                :content=\"form.support\"\n                :form=\"userData\"\n            />\n            <form-schedule\n                v-if=\"isActive('schedule')\"\n                :content=\"formScheduleContent\"\n            />\n            <form-constructor\n                v-if=\"isActive('registration') || Boolean(isActive('upsell') && [47424, 47425].includes(form.version))\"\n                :user-data=\"userData\"\n                :settings-form=\"settingsForm\"\n                :content=\"formRegistrationContent\"\n                :use-phone-input=\"form.registration.usePhoneInput\"\n                :mailgun-error=\"mailgunError\"\n                :error-message-a-p-i=\"errorMessageAPI\"\n                :has-animate=\"hasAnimate\"\n                @loading=\"isLoading = $event\"\n                @submit=\"isSubmittedRegistration\"\n                @submit-error=\"onSubmitError\"\n                @change-step=\"changeStep($event)\"\n                @resize=\"$emit('resize')\"\n                @hideLogin=\"hideLogin\"\n            />\n            <form-login\n                v-if=\"isActive('login')\"\n                :content=\"form.login\"\n                @error=\"showForm('error')\"\n                @loading=\"isLoading = $event\"\n                @submit=\"getUserData()\"\n            />\n            <form-constructor\n                v-if=\"isActive('update')\"\n                :content=\"formUpdateContent\"\n                :settings-form=\"settingsForm\"\n                :use-phone-input=\"formUpdateContent.usePhoneInput\"\n                @showForm=\"showForm\"\n                @submit=\"isSubmittedUpdate\"\n                @resize=\"$emit('resize')\"\n            />\n            <form-change\n                v-if=\"isActive('change')\"\n                :content=\"form.change\"\n                :email=\"userData.email\"\n                @submit=\"isSubmittedChangeEmail($event)\"\n            />\n            <form-upsell\n                v-if=\"isActive('upsell')\"\n                :content=\"form.upsell\"\n                @showNotification=\"showNotification($event)\"\n                @submit=\"isSubmittedUpsell()\"\n            />\n            <form-error v-if=\"isActive('error')\" :content=\"errorContent\" @submit=\"showForm(errorContent.activeForm)\" />\n            <form-success\n                v-if=\"isActive('success')\"\n                :form=\"form.success\"\n                :user-data=\"userData\"\n                @onClickButtonSuccess=\"onClickButtonSuccess\"\n                @backToForm=\"showForm\"\n            />\n            <form-notification v-if=\"isActive('notification')\" :content=\"notification\" @backToForm=\"showForm\" />\n            <label v-if=\"hasRecaptchaInvisible\" class=\"sr-only\" for=\"g-recaptcha-response\">Google Recaptcha</label>\n            <div v-if=\"hasRecaptchaInvisible\" ref=\"recaptcha\" class=\"g-recaptcha\" />\n        </div>\n    </div>\n</template>\n\n<script>\nimport { get, mapValues, isString } from 'lodash-es';\nimport { mapState, mapActions } from 'vuex';\nimport ALink from '@core/components/link/link.vue';\nimport { Loading } from '@core/components/loading';\nimport ElSpinner from '@core/components/spinner/spinner.vue';\nimport cleverbridge from '@core/mixins/cleverbridge.js';\nimport currency from '@core/mixins/currency.js';\nimport form from '@core/mixins/form';\nimport recaptcha from '@core/mixins/recaptcha.js';\nimport { LOCALE_DEFAULT } from '@model/const/locales.ts';\nimport commonUtils from '@utils/common';\nimport utils from '@utils/form.js';\nimport { sleep } from '@utils/promise.ts';\n\nimport { getDB } from '../../db.js';\n\nimport formChange from './form-change.vue';\nimport formConstructor from './form-constructor.vue';\nimport formError from './form-error.vue';\nimport formLogin from './form-login.vue';\nimport formNotification from './form-notification.vue';\nimport formSchedule from './form-schedule.vue';\nimport formSuccess from './form-success.vue';\nimport formSupportConfirmation from './form-support-confirmation.vue';\nimport formUpsell from './form-upsell.vue';\n\nconst EVENT_FORM_SUCCESS = 'form-submit-success';\nconst EVENT_FORM_ERROR = 'form-submit-error';\n\nexport default {\n    name: 'SFormContainer',\n\n    components: {\n        ALink,\n        formChange,\n        formConstructor,\n        formError,\n        formLogin,\n        formNotification,\n        formSchedule,\n        formSupportConfirmation,\n        formSuccess,\n        formUpsell,\n        ElSpinner,\n    },\n\n    directives: {\n        loading: Loading.directive,\n    },\n\n    mixins: [form, recaptcha, currency, cleverbridge],\n\n    props: {\n        form: {\n            type: Object,\n            default: null,\n        },\n\n        isActiveSuccess: {\n            type: Boolean,\n            default: false,\n        },\n\n        hasAnimate: {\n            type: Boolean,\n            default: false,\n        },\n    },\n\n    emits: ['onClickButtonSuccess', 'submit', 'resize', 'changeStep', 'activeFormName'],\n\n    data: () => ({\n        ck: '',\n        activeForm: '',\n        userData: {},\n        settingsForm: {},\n        isLoading: true,\n        serverErrors: [],\n        notification: {},\n        backTo: 'registration',\n        FORMS: ['registration', 'login', 'update', 'previous', 'start'],\n        content: null,\n        errorContent: null,\n        mailgunError: {},\n        redirectLink: '',\n        redirectSegmented: '',\n        segmentRules: null,\n        response: {},\n        sendLeadTo: '',\n        formInstance: null,\n        formEventContext: '',\n        errorMessageAPI: '',\n        formStep: null,\n        loadingMessage: '',\n        formRegistrationFields: [],\n        isShaking: false,\n    }),\n\n    computed: {\n        ...mapState({\n            location: (state) => state.geolocation?.location || null,\n            copyright: (state) => get(state.slices.items, 's-global-footer.copyright', ''),\n            legalLinks: (state) => get(state.slices.items, 's-global-footer.legalLinks', []),\n            countriesData: (state) => state.countries?.items || [],\n        }),\n\n        className() {\n            return {\n                's-form-container': this.form,\n                [`s-form-container-version-${this.form.version}`]: this.form.version,\n                's-form-container--shake': this.isShaking,\n            };\n        },\n\n        hasFormID() {\n            return Boolean(this.form?.flow?.marketo?.form_id);\n        },\n\n        formScheduleContent() {\n            const conditions = this.form.schedule?.conditions || [];\n            if (!conditions.length) return null;\n\n            const userLocation = this.userData?.country || this.location?.data?.country?.code;\n            const userCompanyType = this.userData?.company_type;\n\n            for (const condition of conditions) {\n                const matchedItem = condition.list?.find((item) => {\n                    const countryMatch = !item.countries || item.countries.includes(userLocation);\n                    const companyTypeMatch = !item.company_type || item.company_type === userCompanyType;\n                    return countryMatch && companyTypeMatch;\n                });\n\n                if (matchedItem) {\n                    return {\n                        ...condition.content,\n                        link: matchedItem.link,\n                    };\n                }\n            }\n\n            return null;\n        },\n\n        hasSuccessPage() {\n            return get(this, 'form.flow.successPage', false);\n        },\n\n        submitDelay() {\n            return get(this, 'form.settings.submitDelay', 0);\n        },\n\n        isContactsRenewals() {\n            return Boolean(this.form?.flow?.sendContactsRenewals);\n        },\n\n        hasNotification() {\n            return get(this, 'form.flow.notification', false);\n        },\n\n        formRegistrationContent() {\n            return {\n                ...this.form.registration,\n                sliceID: this.form.sliceID,\n                version: this.form.version,\n                isFormExpressSignup: Boolean(this.form?.flow?.isFormExpressSignup),\n                isFormEvents: Boolean(this.form?.settings?.isFormEvents),\n                hasHoneypot: Boolean(this.form?.settings?.hasHoneypot),\n                hasAsterisks: this.form?.settings?.hasAsterisks,\n                is46514VariantB: this.form?.settings?.is46514VariantB,\n                isCloudConsoleLoginFlowEnabled: this.isCloudConsoleLoginFlowEnabled,\n                fields: this.formRegistrationFields,\n                ...this.formVariation,\n            };\n        },\n\n        formHasSteps() {\n            return this.form?.registration?.steps?.length;\n        },\n        formVariation() {\n            const currentStep = this.form.registration?.steps?.[this.formStep] || {};\n            return this.formHasSteps ? currentStep : {};\n        },\n\n        formUpdateContent() {\n            return {\n                ...this.settingsFormUpdate,\n                subtitles: [this.accountData?.email],\n                hasAsterisks: this.form?.settings?.hasAsterisks,\n                ...this.form.update,\n            };\n        },\n\n        needToRegisterAccount() {\n            return this.form?.flow?.registerAccount || false;\n        },\n\n        isResourceCenter() {\n            return Boolean(this.form?.flow?.isResourceCenter);\n        },\n\n        listProductID() {\n            return this.form?.flow?.registerProducts || [762];\n        },\n\n        formFields() {\n            const steps = this.form?.registration?.steps || [];\n            return this.form?.registration?.fields || steps.flatMap((item) => item.fields || []) || [];\n        },\n    },\n\n    watch: {\n        form() {\n            this.formRegistrationFields = this.form.registration?.fields || [];\n        },\n        accountData(data) {\n            if (this.activeForm === 'update' && !data) {\n                this.showForm('login');\n            }\n        },\n    },\n\n    beforeUnmount() {\n        this.$refs.container.removeEventListener('click', this.handleClick);\n    },\n\n    beforeMount() {\n        if (this.formHasSteps) this.formStep = 0;\n        this.activeForm = this.isActiveSuccess ? 'success' : '';\n        this.loadingMessage = this.form?.registration?.loading || 'Loading';\n        this.formRegistrationFields = this.form?.registration?.fields || [];\n    },\n\n    mounted() {\n        this.sendLeadTo = this.form?.flow?.sendLeadTo || '';\n        this.redirectLink = this.form?.flow?.redirectLink || '';\n        this.redirectSegmented = this.form?.flow?.redirectSegmented || '';\n        this.segmentRules = this.form?.flow?.segmentRules || null;\n        this.$refs.container.addEventListener('click', this.handleClick);\n\n        this.ck = utils.getCookies(utils.MRKTO_COOKIE_NAME) || utils.createMarketoToken();\n\n        this.init();\n    },\n\n    async serverPrefetch() {\n        if (!import.meta.env.SSR) return;\n\n        if (this.form?.registration) {\n            const locale = this.$store.state.geolocation.finalLocale || LOCALE_DEFAULT;\n            await this.$store.dispatch('slices/getSyncedData', { slice: 's-data-centers', locale });\n        }\n    },\n\n    methods: {\n        ...mapActions({\n            accountUpdate: 'trial/accountUpdate',\n            accountAgreement: 'trial/accountAgreement',\n            accountLogin: 'trial/accountLogin',\n            accountRegister: 'trial/accountRegister',\n            accountTrial: 'trial/accountTrial',\n            sendLead: 'trial/sendLead',\n            isEmailValid: 'trial/isEmailValid',\n            generateSessionURL: 'cleverbridge/get',\n            getGeoLocation: 'geolocation/getGeoLocation',\n        }),\n\n        handleClick(e) {\n            const str = e.target?.hash || e.target?.parentElement?.hash || e.target?.closest('a')?.hash || '';\n            const hash = str.replace('#', '');\n            if (hash && this.FORMS.includes(hash)) {\n                e.preventDefault();\n                if (hash === 'start') {\n                    this.changeStep(0);\n                    return;\n                }\n                if (hash === 'previous') {\n                    this.changeStep(this.formStep - 1);\n                    return;\n                }\n                if (hash === 'registration') {\n                    this.userData = {};\n                    this.changeStep(this.form.registration?.step || 0);\n                    this.settingsForm = {};\n                    this.errorMessageAPI = '';\n                }\n                this.showForm(hash);\n                this.$router?.replace({path: this.$route.path});\n            }\n            if (e.target.dataset?.login) {\n                this.errorMessageAPI = '';\n                this.changeLoginFieldType('input');\n            }\n        },\n\n        isActive(name) {\n            const hasContent = this.form[name] || name === 'notification';\n            return hasContent && this.activeForm === name;\n        },\n\n        showNotification(data) {\n            this.notification = data;\n            this.showForm('notification');\n        },\n\n        isProsumer() {\n            return this.userData?.company_type === 'Prosumer End-Customer';\n        },\n\n        isSegmented() {\n            if (!this.segmentRules) return false;\n            return Object.entries(this.segmentRules).every(([key, value]) => this.userData[key] === value);\n        },\n\n        showForm(name) {\n            this.isLoading = false;\n            this.activeForm = name;\n            this.$emit('activeFormName', name);\n        },\n\n        hideLogin(email) {\n            if (!this.isCloudConsoleLoginFlowEnabled) return;\n            if (this.userData.email === email) return;\n            this.errorMessageAPI = '';\n            if (this.userData.login) {\n                this.userData.email = email;\n                this.changeLoginFieldType('hidden');\n            }\n        },\n\n        async changeLoginFieldType(type) {\n            if (!this.isCloudConsoleLoginFlowEnabled) return;\n            const comparison = (item) => (item.name === 'login' ? { ...item, type } : item);\n            this.formRegistrationFields = this.formRegistrationFields.map(comparison);\n            this.showForm('');\n            this.settingsForm = { validate: false, focus: 'login' };\n            this.userData.login = type === 'input' ? this.setLogin() : null;\n            await this.$nextTick();\n            this.showForm('registration');\n        },\n\n        setLoadingMessage() {\n            let count = 0;\n            const messages = this.form?.registration?.loadingMessages;\n            if (!messages) return;\n\n            const myInterval = setInterval(() => {\n                ++count;\n\n                const hasMessage = messages.find((item) => item.time > count);\n                if (!hasMessage) clearInterval(myInterval);\n\n                const message = messages.find((item) => item.time === count) || {};\n                if (message.text) this.loadingMessage = message.text;\n            }, 1000);\n        },\n\n        setLogin() {\n            if (!this.userData.first_name) return '';\n            if (!this.userData.last_name) return '';\n            return `${this.userData.first_name}.${this.userData.last_name}`.toLowerCase();\n        },\n\n        setErrorContent(error) {\n            const defaultError = this.formElementsDefault?.errors?.apiErrorCodes?.default || 'Error';\n            let title = this.formElementsDefault?.errors?.apiErrorCodes?.[error.code] || defaultError;\n            let code = error.code;\n\n            const isAborted = this.isCloudConsoleLoginFlowEnabled && ['ERR_NETWORK', 'ECONNABORTED'].includes(code);\n            if (error.code === 'third_party_api_exception' || isAborted) {\n                const text = this.formElementsDefault?.errors?.third_party_api_exception?.timeout || {};\n                this.errorContent = { ...this.form.error, ...text };\n                return;\n            }\n\n            if (error.ex && ['invalid_email', 'mailbox_is_disposable_address'].includes(error.code)) {\n                this.settingsForm = {\n                    focus: 'email',\n                };\n                const isTypo = error.ex.reason === 'failed custom grammar check' || error.ex.didYouMean;\n                const errorKey = isTypo ? 'invalidMailTypo' : 'invalidMailGeneral';\n                title = this.formElementsDefault.errors?.eventsMailGunErrors?.[errorKey] || title;\n                code = null;\n                this.mailgunError = {\n                    message: title,\n                    email: this.userData.email,\n                };\n\n                if (this.isActive('update')) {\n                    window.dataLayer = window.dataLayer || [];\n                    window.dataLayer.push({\n                        event: 'Acronis',\n                        eventAction: 'Error',\n                        eventCategory: 'Form',\n                        eventLabel: error.code,\n                    });\n                }\n            } else {\n                this.handleError(error);\n            }\n\n            this.errorContent = {\n                ...this.form.error,\n                title,\n                code,\n                activeForm: this.isActive('update') ? 'update' : 'registration',\n            };\n        },\n\n        async isSubmittedUpdate(data, formInstance) {\n            this.formInstance = formInstance;\n\n            this.userData = {\n                ...data,\n                ck: this.ck,\n                email: this.accountData?.email || '',\n                first_name: this.accountData?.first || '',\n                last_name: this.accountData?.last || '',\n                country: this.accountData?.country || '',\n                state: this.accountData?.state_province || '',\n                postal_code: this.accountData?.zip || '',\n            };\n\n            if (this.form?.upsell && this.isProsumer()) {\n                this.backTo = 'update';\n                this.showForm('upsell');\n                return;\n            }\n\n            if (this.hasRecaptchaInvisible && data.form_id !== 'TRIAL_FORMS_ALL_NO_CAPTCHA') {\n                await this.recaptchaActive().execute(this.recaptchaWidgetId);\n            }\n\n            try {\n                this.isLoading = true;\n                if (this.userData.phone !== 'NULL') {\n                    await this.accountUpdate({ phone: this.userData.phone });\n                }\n                await this.accountTrial({ product_id: this.listProductID });\n                await this.trySendLead();\n            } catch (e) {\n                this.sendVwoEvent(EVENT_FORM_ERROR);\n                if (e) {\n                    this.setErrorContent(e);\n                    this.showForm('error');\n                }\n                return;\n            }\n\n            this.isLoading = true;\n            const events = this.form?.update?.sendEventsGA || this.settingsFormUpdate?.sendEventsGA || [];\n            this.trySendEventsGA(events);\n            this.sendVwoEvent(EVENT_FORM_SUCCESS);\n\n            const redirectLink = this.settingsFormUpdate?.redirectLink;\n            const redirectSegmented = this.settingsFormUpdate?.redirectSegmented;\n            if (this.isSegmented() && redirectSegmented) {\n                window.location.assign(this.replaceLocale(redirectSegmented));\n                return;\n            }\n            if (redirectLink) window.location.assign(this.replaceLocale(redirectLink));\n        },\n\n        async getUserDataDB() {\n            if (this.accountData) return {};\n            const db = await getDB();\n            const last = await db.fields.orderBy('id').last();\n            const result = await db.fields.get(last?.id || '');\n            const fields = Object.assign({}, ...(result || [{}]));\n            delete fields.event_time;\n            return fields;\n        },\n\n        async getUserData() {\n            if (this.$store.state.user) {\n                // Not all Sites have `user` module included in the Store.\n                await this.$store.dispatch('user/get');\n            }\n\n            if (this.accountData && this.form.login && this.settingsFormUpdate) {\n                if (this.form.flow.doNotShowFormUpdate) {\n                    await this.isSubmittedUpdate({\n                        phone: 'NULL',\n                        industry: 'NULL',\n                        of_Employees__c: 'NULL',\n                        form_id: 'TRIAL_FORMS_ALL_NO_CAPTCHA',\n                    });\n                    return;\n                }\n                if (this.activeForm === 'login') {\n                    this.showForm('update');\n                    return;\n                }\n            }\n\n            if (this.accountData?.country) {\n                const hasIsoCode = this.countriesData.find((item) => item.iso_code === this.accountData.country);\n                if (!hasIsoCode) this.accountData.country = '';\n            }\n\n            this.userData = await this.getUserDataDB();\n            this.sanitizeUserDataOptions();\n            this.showForm(this.activeForm || 'registration');\n        },\n\n        sanitizeUserDataOptions() {\n            this.formFields.forEach((field) => {\n                if (!field.options?.length) return;\n\n                const value = this.userData[field.name];\n                if (!value) return;\n\n                if (Array.isArray(value)) {\n                    const validCodes = new Set(field.options.map((item) => item.code ?? item.value));\n                    const validValues = value.filter((v) => validCodes.has(v));\n                    if (validValues.length) {\n                        this.userData[field.name] = validValues;\n                    } else {\n                        delete this.userData[field.name];\n                    }\n                    return;\n                }\n\n                const isValid = field.options.some((item) => item.code === value || item.value === value);\n                if (isValid) return;\n\n                delete this.userData[field.name];\n            });\n        },\n\n        async setUserData() {\n            const fields = this.formFields;\n            if (!fields.length) return;\n            const userData = fields\n                .filter((item) => !['password', 'textarea'].includes(item.type) && item.name !== 'event_time')\n                .map((item) => {\n                    const raw = this.userData?.[item.name];\n                    // Check handles multi-select fields (isMultiple: true)\n                    const value = Array.isArray(raw) ? [...raw] : (raw || '');\n                    return value && value.length ? { [item.name]: value } : '';\n                })\n                .filter(Boolean);\n\n            const db = await getDB();\n\n            const last = await db.fields.orderBy('id').last();\n            if (last?.id) {\n                const userDataSaved = await db.fields.get(last.id);\n                const userDataMerged = {\n                    ...Object.assign({}, ...userDataSaved),\n                    ...Object.assign({}, ...userData),\n                };\n                const userDataUpdated = Object.keys(userDataMerged).map((key) => ({ [key]: userDataMerged[key] }));\n                await db.fields.update(last.id, userDataUpdated);\n                return;\n            }\n            await db.fields.add(userData);\n        },\n\n        async init() {\n            await this.getGeoLocation();\n            const country = this.location?.data?.country?.code || '';\n\n            // WEB-51974\n            const notifications = this.formElementsDefault?.notification;\n            if (Array.isArray(notifications)) {\n                const currentUrl = window.location.href;\n                const siteID = this.$store.state.context?.public?.siteID || '';\n                const matchedGroup = notifications.find((group) =>\n                    group.forms?.some((item) => currentUrl.includes(item.path) || siteID === item.path),\n                );\n                const matchedCountry = matchedGroup?.countries?.find((item) => item.iso === country);\n                if (matchedCountry) {\n                    this.notification = matchedCountry;\n                    this.showForm('notification');\n                    return;\n                }\n            }\n\n            if (this.hasRecaptchaInvisible) {\n                this.recaptchaInject(country);\n            }\n\n            await this.getUserData();\n        },\n\n        isSubmittedRegistration(data, formInstance, formEventContext) {\n            this.formEventContext = formEventContext;\n            this.formInstance = formInstance;\n\n            this.userData = {\n                ...data,\n                ck: this.ck,\n            };\n\n            if (this.isBusinessEmail() && this.isFreeEmail(data.email) && !data.login) {\n                this.showForm('change');\n                return;\n            }\n\n            if (this.formScheduleContent) {\n                this.showForm('schedule');\n                this.submit();\n                return;\n            }\n\n            if (this.isProsumer()) {\n                if (this.form?.upsell) {\n                    this.backTo = 'registration';\n                    if (this.form?.upsell?.sendEventsGA) {\n                        this.trySendEventsGA(this.form.upsell.sendEventsGA);\n                    }\n                    this.showForm('upsell');\n                    return;\n                }\n                if (this.form?.support) {\n                    this.showForm('support');\n                    return;\n                }\n            }\n\n            if (this.userData?.company_type) {\n                const fields = this.form?.registration?.fields || [];\n                const options = fields.find((item) => item.name === 'company_type')?.options || [];\n                const value = this.userData.company_type;\n                const option = utils.findOptionByValue(options, value) || {};\n                this.redirectLink = option?.redirectLink || this.form?.flow?.redirectLink || '';\n                this.redirectSegmented = option?.redirectSegmented || this.form?.flow?.redirectSegmented || '';\n            }\n\n            if (this.isResourceCenter) {\n                this.userData.terms = true;\n            }\n\n            this.submit();\n        },\n\n        isSubmittedChangeEmail(email) {\n            this.userData.email = email;\n            this.submit();\n        },\n\n        isSubmittedUpsell() {\n            this.userData = {\n                ...this.userData,\n                company: '',\n                industry: '',\n                company_type: 'Corporate End-Customer',\n            };\n            if (this.isContactsRenewals) {\n                this.userData.company_type = 'Home Products';\n            }\n            if ([47424, 47425].includes(this.form.version)) {\n                this.userData.company_type = 'Corporate End-Customer';\n                this.changeStep(1);\n                return;\n            }\n\n            this.settingsForm = {\n                validate: true,\n                focus: 'company',\n            };\n\n            this.showForm(this.backTo);\n        },\n\n        trySendEventsGA(events) {\n            events.forEach(async (item) => {\n                // WEB-44753, WEB-45411\n                const event = mapValues(item, (value) => {\n                    if (value === 'setCountry') {\n                        return this.userData?.country || '';\n                    }\n                    if (value === 'setState') {\n                        return this.userData?.state || '';\n                    }\n                    if (value === 'setDataCenter') {\n                        return this.userData?.dc_location || '';\n                    }\n                    if (value === 'setCompanyType') {\n                        return this.userData?.company_type || '';\n                    }\n                    if (value === 'setServiceSelector') {\n                        const conf = this.formRegistrationContent?.fields?.find((f) => f.name === 'service-selector');\n                        const options = conf?.options;\n                        const selectorValue = this.userData?.['service-selector'];\n                        const opt = utils.findOptionByValue(options, selectorValue);\n                        return opt?.name || '';\n                    }\n                    if (value === 'hasLoginField') {\n                        return this.userData?.login ? 'user login' : 'no user login';\n                    }\n                    if (value === 'setDeveloperPreference') {\n                        return this.userData?.[\"I'd like\"] || '';\n                    }\n                    if (value === 'setNumOfEmployees') {\n                        return this.userData?.['of_Employees__c'] || '';\n                    }\n                    return value;\n                });\n\n                if (event.eventAction === 'submit_form_success') {\n                    if (!event.emailAddress) {\n                        event.emailAddress = await commonUtils.toSHA256String(this.userData?.email || ''); // WEB-45304\n                    }\n                    event.formTime = utils.getSecondsOnPage(); // WEB-44946\n                }\n\n                this.sendDataLayer({\n                    eventContext: this.formEventContext || '',\n                    eventContent: this.isFreeEmail(this.userData?.email || '') ? 'FreeEmail' : 'BusinessEmail',\n                    ...event,\n                });\n            });\n        },\n\n        async tryRegisterBeta() {\n            if (!get(this, 'form.isBeta', false)) {\n                return true;\n            }\n\n            try {\n                this.isLoading = true;\n                this.$store.dispatch('user/logout');\n                const response = await this.accountLogin({\n                    email: this.userData.email,\n                    password: this.userData.password,\n                });\n\n                if (response.status === 200) {\n                    return true;\n                }\n\n                const message = this?.form?.registration?.messages?.error || '';\n                this.errorMessageAPI = message || 'Wrong email or password';\n                return Promise.reject();\n            } catch (e) {\n                this.setErrorContent(e);\n                this.showForm('error');\n                return Promise.reject();\n            } finally {\n                this.isLoading = false;\n            }\n        },\n\n        async tryRegisterAccount() {\n            if (!this.needToRegisterAccount) return true;\n\n            try {\n                this.isLoading = true;\n\n                const response = await this.accountRegister(this.payloadAccount);\n\n                if (response.data?.errors?.email) {\n                    const message = this.form?.registration?.messages?.accountExist || '';\n                    this.errorMessageAPI = message || 'This email address is already in use';\n                    const step = this.form.registration?.steps?.findIndex((item) => item?.fields?.find((field) => field?.name === 'email'));\n                    this.changeStep(this.form.registration?.step || step || 0);\n                    return Promise.reject();\n                }\n\n                if (response.status !== 204) {\n                    throw new Error('Unsuccessful');\n                }\n            } catch (e) {\n                this.setErrorContent(e);\n                this.showForm('error');\n                return Promise.reject();\n            }\n\n            await this.accountLogin({\n                email: this.userData.email,\n                password: this.userData.password,\n            });\n\n            await this.accountAgreement({ accept: true });\n\n            await this.accountTrial({ product_id: this.listProductID });\n\n            this.isLoading = false;\n            return true;\n        },\n\n        async mailgunValidation() {\n            if (!this.needToRegisterAccount) return true;\n            if (this.formVariation.skipMailgunValidation) return true;\n\n            if (this.hasRecaptchaInvisible) {\n                await this.recaptchaActive().execute(this.recaptchaWidgetId);\n            }\n\n            try {\n                this.isLoading = true;\n                const payload = this.payloadMarketo();\n                const isEmailValid = await this.isEmailValid({\n                    email: payload.email,\n                    form_id: payload.form_id,\n                    // eslint-disable-next-line no-underscore-dangle\n                    recaptchaResponse: payload._recaptchaResponse,\n                });\n                return isEmailValid;\n            } catch (error) {\n                this.setErrorContent(error);\n                this.showForm('error');\n                return Promise.reject();\n            } finally {\n                this.isLoading = false;\n            }\n        },\n\n        async trySendLead() {\n            if (!this.hasFormID) return true;\n            try {\n                this.isLoading = true;\n                this.setLoadingMessage();\n\n                const payload = {\n                    ...this.payloadMarketo(),\n                    actionURL: this.sendLeadTo || '/svc/v1/marketing/forms/leads',\n                };\n\n                if (this.isCloudConsoleLoginFlowEnabled) {\n                    payload.login = payload.login || null;\n                }\n\n                if (this.formRegistrationContent.isFormEvents) {\n                    // WEB-46729\n                    payload.attend_training = payload.attend_training === 'true';\n                }\n\n                if (this.form.flow?.sendDowntimeCalculatorLink) {\n                    const downtimeLink = localStorage.getItem('downtimeCalculatorLink');\n                    if (downtimeLink) {\n                        payload.downtime_calculator_link = downtimeLink;\n                    }\n                }\n\n                const start = new Date();\n                this.response = await this.sendLead(payload);\n\n                if (this.form.flow?.personalizationLocalStorage) {\n                    localStorage.setItem(this.form.flow.personalizationLocalStorage, 'true');\n                }\n\n                if (this.form.flow?.sendDowntimeCalculatorLink) {\n                    localStorage.removeItem('downtimeCalculatorLink');\n                }\n\n                if (this.isCloudConsoleLoginFlowEnabled) {\n                    const end = new Date();\n                    const seconds = (end.getTime() - start.getTime()) / 1000;\n                    const consoleURL = this.response?.data?.gatewayBody?.console_url;\n                    if (consoleURL && seconds <= 30) this.redirectLink = consoleURL;\n                }\n\n                return true;\n            } catch (error) {\n                if (error.code === 'third_party_api_exception') {\n                    const gatewayStatus = error.ex?.gatewayStatus;\n                    const exception = this.formElementsDefault?.errors?.third_party_api_exception || {};\n\n                    if (gatewayStatus === 409 && this.userData.login) {\n                        this.settingsForm = {\n                            focus: 'login',\n                            validate: true,\n                            errorMessageLogin: exception.login || 'Login is already in use. Specify another login different from email',\n                        };\n                        this.changeStep(this.form.registration?.step || 0);\n                        return Promise.reject();\n                    }\n\n                    const message = exception[gatewayStatus] || exception?.unknown || 'Error';\n                    if (isString(message)) {\n                        this.errorMessageAPI = message.replace('@userEmail', this.userData.email);\n                        this.settingsForm = { validate: true, focus: 'email' };\n                        this.changeStep(this.form.registration?.step || 0);\n                        return Promise.reject();\n                    }\n\n                    this.errorContent = { ...this.form.error, ...message };\n                    this.showForm('error');\n                    return Promise.reject();\n                }\n                this.setErrorContent(error);\n                this.showForm('error');\n                return Promise.reject();\n            } finally {\n                this.isLoading = false;\n            }\n        },\n\n        async trySendContactsRenewals() {\n            if (!this.isContactsRenewals) return true;\n            try {\n                this.isLoading = true;\n                const payload = this.payloadMarketo();\n                const isHomeProducts = payload.company_type === 'Home Products';\n                const companyName = isHomeProducts ? 'Home' : payload.companyName;\n                await this.sendLead({\n                    ...payload,\n                    Origin: 'web',\n                    termsAgreement: true,\n                    countryCode: payload.country,\n                    contactEmail: payload.email,\n                    contactPhone: payload.phone,\n                    Subject: `${companyName} - Renewal Request`,\n                    companyName,\n                    licenseInvoice: isHomeProducts ? 'Home' : payload.licenseInvoice,\n                    productRegistrationEmail: isHomeProducts ? payload.email : payload.productRegistrationEmail,\n                    actionURL: isHomeProducts\n                        ? '/svc/v1/acronis-contacts/renewals-home-office/case'\n                        : '/svc/v1/acronis-contacts/renewals/case',\n                });\n                return true;\n            } catch (e) {\n                this.setErrorContent(e);\n                this.showForm('error');\n                return Promise.reject();\n            } finally {\n                this.isLoading = false;\n            }\n        },\n\n        async trySendContactUsForm() {\n            if (!this.form.flow.isContactUsForm) {\n                return true;\n            }\n            try {\n                this.isLoading = true;\n                const payload = this.payloadMarketo();\n                await this.sendContactUsForm(payload);\n                return true;\n            } catch (e) {\n                this.setErrorContent(e);\n                this.showForm('error');\n                return Promise.reject();\n            } finally {\n                this.isLoading = false;\n            }\n        },\n\n        async trySendEventSubscription() {\n            try {\n                this.isLoading = true;\n\n                const payload = {\n                    ...this.payloadMarketo(),\n                    form_id: this.form.success.leadOnSuccessCTA.form_id,\n                    actionURL: this.sendLeadTo || '/svc/v1/marketing/forms/leads',\n                    opt_in_status: true,\n                };\n                payload.attend_training = payload.attend_training === 'true';\n\n                await this.sendLead(payload);\n                this.showForm('');\n                this.$emit('onClickButtonSuccess');\n                await this.$nextTick();\n                this.showForm('success');\n            } catch (e) {\n                this.setErrorContent(e);\n                this.showForm('error');\n                return Promise.reject();\n            } finally {\n                this.isLoading = false;\n            }\n        },\n\n        onSubmitError() {\n            if (this.hasAnimate) {\n                this.isShaking = true;\n                setTimeout(() => { this.isShaking = false; }, 333);\n            }\n            this.sendVwoEvent(EVENT_FORM_ERROR);\n        },\n\n        async changeStep(step) {\n            this.formStep = step;\n            this.showForm('');\n            await this.$nextTick();\n            this.showForm('registration');\n            this.$refs.container.closest('.s-form').scrollIntoView({ behavior: 'smooth' });\n            this.$emit('changeStep', step);\n        },\n        async submit() {\n            this.guid = utils.getGUID();\n\n            try {\n                await this.mailgunValidation();\n\n                if (this.hasRecaptchaInvisible) {\n                    this.isLoading = true;\n                    await this.recaptchaActive().execute(this.recaptchaWidgetId);\n                    this.isLoading = false;\n                }\n                if (this.formHasSteps) {\n                    if (this.formStep < this.form.registration.steps.length - 1) {\n                        const field = this.formVariation?.checkField || '';\n                        const value = this.userData[field];\n                        if (field && !value) return;\n                        const list = this.formVariation?.fields?.find(((i) => i.name === field))?.list || [];\n                        const item = list.find((i) => i.value === value) || {};\n                        const eventsGA = item.sendEventsGA || this.formVariation.sendEventsGA || [];\n                        this.trySendEventsGA(eventsGA);\n                        if (item.notification) {\n                            this.showNotification(item.notification);\n                            return;\n                        }\n                        if (item.redirectLink) {\n                            this.isLoading = true;\n                            window.location.assign(item.redirectLink);\n                            return;\n                        }\n                        if (!this.formVariation.lastStep) {\n                            this.changeStep(item.nextStep || this.formStep + 1);\n                            return;\n                        }\n                    }\n                }\n                await this.trySendContactUsForm();\n                await this.tryRegisterAccount();\n                await this.trySendLead();\n                await this.trySendContactsRenewals();\n                await this.tryRegisterBeta();\n            } catch (e) {\n                this.sendVwoEvent(EVENT_FORM_ERROR);\n                return;\n            }\n\n            try {\n                await this.setUserData();\n            } catch (e) {\n                // eslint-disable-next-line no-console\n                console.warn('setUserData failed:', e);\n            }\n\n            this.isLoading = true;\n            this.sendEventMarketingSubscription(this.userData.gdpr_opt_in || this.userData.opt_in);\n            this.trySendEventsGA(this.form?.flow?.sendEventsGA || []);\n            this.sendVwoEvent(EVENT_FORM_SUCCESS);\n\n            if (this.formScheduleContent) {\n                this.isLoading = false;\n                return;\n            }\n\n            if (this.submitDelay) {\n                await sleep(this.submitDelay);\n            }\n\n            if (this.isSegmented() && this.redirectSegmented) {\n                window.location.assign(this.replaceLocale(this.redirectSegmented));\n                return;\n            }\n\n            if (this.redirectLink) {\n                window.location.assign(this.replaceLocale(this.redirectLink));\n                return;\n            }\n\n            if (this.form?.flow?.redirectToCleverbridge) {\n                this.redirectToCleverbridge(this.payloadPartnerSignupCloud);\n                return;\n            }\n\n            if (this.form?.flow?.getExpressSignupFormSURL) {\n                this.redirectToCleverbridge(this.payloadExpressSignup);\n                return;\n            }\n\n            if (this.hasSuccessPage) {\n                this.showForm('success');\n            }\n\n            if (this.hasNotification) {\n                this.notification = this.form?.flow.notification;\n                this.showForm('notification');\n            }\n\n            this.$emit('submit', {\n                userData: this.userData,\n                response: this.response,\n            });\n        },\n\n        sendVwoEvent(type) {\n            if (typeof window === 'undefined') return;\n            if (!this.formInstance) return;\n            const eventValue = type === EVENT_FORM_SUCCESS ? 1 : 0;\n            window.VWO = window.VWO || [];\n            window.VWO.push(['nls.formAnalysis.markSuccess', this.formInstance, eventValue]);\n            delete this.formInstance;\n        },\n\n        async onClickButtonSuccess() {\n            if (this.form?.success?.leadOnSuccessCTA) {\n                await this.trySendEventSubscription();\n                return;\n            }\n            this.$emit('onClickButtonSuccess');\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-form-container {\n    position: relative;\n    margin: 40px -16px auto;\n    color: var(--av-fixed-secondary);\n\n    @media (--viewport-mobile-wide) {\n        width: 100%;\n        margin: 56px auto auto;\n    }\n\n    @media (--viewport-tablet) {\n        width: 648px;\n    }\n\n    @media (--viewport-desktop) {\n        margin: 0 auto auto;\n        width: 552px;\n    }\n\n    @media (--viewport-desktop-wide) {\n        width: 648px;\n    }\n\n    .s-form-title {\n        @mixin display;\n        text-align: center;\n        margin-bottom: 32px;\n        color: var(--av-nav-primary);\n        :deep(.a-link) {\n            .a-link__content {\n                @mixin display;\n                color: var(--av-nav-primary);\n            }\n        }\n    }\n\n    .s-form-content {\n        position: relative;\n    }\n\n    &__loading {\n        top: 2px;\n        inset-inline-start: 2px;\n        gap: 16px;\n        z-index: 10;\n        display: flex;\n        padding: 0 48px;\n        min-height: 128px;\n        text-align: center;\n        position: absolute;\n        border-radius: 4px;\n        align-items: center;\n        flex-direction: column;\n        justify-content: center;\n        width: calc(100% - 4px);\n        height: calc(100% - 4px);\n        color: var(--av-fixed-primary);\n        background: var(--av-inversed-secondary);\n\n        &.with-logo {\n            @media (--viewport-desktop) {\n                top: 58px;\n                height: calc(100% - 60px);\n            }\n        }\n    }\n\n    :deep(.el-form) {\n        &-item {\n            padding: 0;\n        }\n    }\n\n    :deep(.el-input) {\n        &__container {\n            text-align: start;\n        }\n\n        &__placeholder {\n            @mixin paragraph;\n        }\n\n        &__label {\n            @mixin paragraph;\n\n            &.is-active {\n                @mixin caption;\n                padding-top: 4px;\n            }\n        }\n    }\n\n    :deep(.el-textarea) {\n        &__editor {\n            @mixin body;\n            max-height: 134px;\n        }\n    }\n\n    :deep(.el-checkbox) {\n        @mixin body;\n        display: block;\n        text-align: start;\n        color: var(--av-fixed-secondary);\n\n        @media (--viewport-tablet) {\n            @mixin paragraph;\n        }\n\n        &:not(:first-child) {\n            margin-top: 8px;\n        }\n    }\n\n    :deep(input),\n    :deep(select),\n    :deep(textarea) {\n        @mixin paragraph;\n    }\n\n    .g-recaptcha {\n        :deep(> div) {\n            margin: 0 auto;\n        }\n\n        :deep(.grecaptcha-badge) {\n            display: none;\n        }\n    }\n}\n\n.s-form-container.s-form-container-version-42019 {\n    margin: 40px 0 auto;\n\n    @media (--viewport-tablet) {\n        width: 50%;\n        margin-top: 0;\n    }\n\n    @media (--viewport-desktop) {\n        max-width: 472px;\n    }\n\n    @media (--viewport-desktop-wide) {\n        max-width: 568px;\n    }\n\n    @media (--viewport-desktop-large) {\n        max-width: 648px;\n    }\n}\n.s-form-container.s-form-container-version-47424,\n.s-form-container.s-form-container-version-47425 {\n    :deep(.s-form-upsell-container) {\n        top: 0;\n        left: 0;\n        width: 100%;\n        height: 100%;\n        z-index: 10;\n        display: flex;\n        position: fixed;\n        align-items: center;\n        justify-content: center;\n        &:before {\n            top: 0;\n            left: 0;\n            content: '';\n            width: 100%;\n            height: 100%;\n            position: fixed;\n            background: rgba(0, 32, 77, 0.65);\n        }\n        .s-form-upsell {\n            padding: 40px;\n            max-width: 568px;\n            border-radius: 4px;\n            border: 1px solid #e3ecf9;\n            background: var(--av-inversed-primary);\n            box-shadow: 0 4px 8px 0 rgba(36, 49, 67, 0.10);\n            .s-form-upsell-title {\n                @mixin nav-title-accent;\n                margin: 0 auto;\n                max-width: 424px;\n                color: var(--av-nav-primary);\n            }\n            .s-form-upsell-image {\n                width: auto;\n                height: 194px;\n            }\n            .s-form-upsell-description {\n                @mixin paragraph;\n            }\n            .s-form-upsell-button {\n                @mixin paragraph-accent;\n                padding: 12px 16px;\n                color: var(--av-inversed-primary);\n                background: var(--av-button-main);\n                &:hover {\n                    background: var(--av-button-main-hover);\n                }\n            }\n            .s-form-upsell-link {\n                @mixin paragraph;\n                margin-top: 24px;\n                color: var(--av-link-primary);\n                &:hover {\n                    color: var(--av-link-primary-hover);\n                }\n            }\n        }\n    }\n}\n\n.s-form-container.s-form-container-version-47424 {\n    :deep(.s-form-upsell-container) {\n        top: 16px;\n        display: flex;\n        overflow: scroll;\n        align-items: flex-start;\n        max-height: calc(100% - 32px);\n        @media (--viewport-tablet) {\n            align-items: center;\n        }\n    }\n}\n</style>\n\n<style lang=\"postcss\">\n.el-select-dropdown {\n    &.el-select-dropdown__form-registration {\n        .el-text--strong {\n            font-weight: 500;\n        }\n        .sublabel {\n            font-size: 12px;\n            line-height: 16px !important;\n        }\n        .el-select-group {\n            .el-select-dropdown__item {\n                height: auto;\n                padding: 0 16px;\n\n                &.is-multi-line {\n                    padding: 8px 16px;\n                }\n            }\n        }\n        .el-select-group__title {\n            @mixin note-heading;\n            padding: 8px 16px;\n            color: var(--av-fixed-light);\n        }\n        .el-select-group__wrap:not(:last-of-type) {\n            padding-bottom: 16px;\n\n            &::after {\n                bottom: 8px;\n                background: var(--av-brand-accent);\n            }\n        }\n    }\n}\n\n@keyframes s-form-shake {\n    0%, 100% { transform: translateX(0); }\n    20%, 60% { transform: translateX(-6px); }\n    40%, 80% { transform: translateX(6px); }\n}\n\n.s-form-container--shake {\n    animation: s-form-shake 0.333s ease-in-out;\n}\n</style>\n","<template>\n    <a-modal\n        :id=\"modal.id\"\n        is-overlay-close\n        type=\"screenshot\"\n        class=\"a-modal-acronis-demo\"\n    >\n        <div v-if=\"hasRibbon\" class=\"ribbon\">\n            <span v-if=\"ribbonTitle\">{{ ribbonTitle }}</span>\n            <a-link v-if=\"ribbonLink\" v-bind=\"ribbonLink\" />\n            <a-button v-if=\"ribbonButton\" v-bind=\"ribbonButton\" />\n        </div>\n        <div class=\"iframe-container\">\n            <iframe\n                :src=\"modal.src\"\n                :style=\"{ opacity: iframeReady ? 1 : 0, transition: 'opacity 0.3s ease' }\"\n                @load=\"iframeReady = true\"\n            />\n        </div>\n    </a-modal>\n</template>\n\n<script>\nimport AButton from '@core/components/button/button.vue';\nimport ALink from '@core/components/link/link.vue';\nimport AModal from '@core/components/modal/modal.vue';\nimport Modal from '@core/directives/modal.js';\n\nexport default {\n    name: 'ADemoModal',\n\n    components: {\n        AButton,\n        ALink,\n        AModal,\n    },\n    directives: {\n        Modal,\n    },\n    props: {\n        modal: {\n            type: Object,\n            default: null,\n        },\n    },\n    data() {\n        return {\n            iframeReady: false,\n        };\n    },\n    computed: {\n        ribbon() {\n            return this.modal.ribbon || {};\n        },\n        ribbonTitle() {\n            return this.ribbon.title;\n        },\n        ribbonLink() {\n            return this.ribbon.link;\n        },\n        ribbonButton() {\n            return this.ribbon.button;\n        },\n        hasRibbon() {\n            return this.ribbonTitle || this.ribbonLink || this.ribbonButton;\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-modal-acronis-demo {\n    .a-modal__wrapper {\n        padding: 64px 0 8px !important;\n\n        .overlay,\n        .a-button {\n            z-index: 1;\n            min-width: unset!important;\n        }\n\n        .loader {\n            .el-loading__content {\n                .el-spinner {\n                    border-color: #fff;\n                }\n                .mt-16 {\n                    margin: 0;\n                }\n                .el-text {\n                    display: none;\n                }\n            }\n        }\n\n        .a-modal__content {\n            width: 98vw;\n            max-width: 1440px;\n            border-radius: 4px;\n            overflow: auto;\n        }\n\n        .a-modal__inner {\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n        }\n    }\n}\n</style>\n\n<style lang=\"postcss\" scoped>\n.ribbon {\n    @mixin body-accent;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 16px;\n    background: var(--av-solid-brand-secondary-accent);\n    color: var(--av-nav-primary);\n    box-shadow: var(--av-shadow-small);\n    border-bottom: 1px solid var(--av-brand-accent);\n    text-align: center;\n    position: sticky;\n    top: 0;\n    z-index: 90;\n    padding: 12px 0;\n}\n.ribbon :deep(.a-button) .a-button__content {\n    @mixin body-accent;\n}\n.iframe-container {\n    z-index: 1;\n    position: relative;\n    width: 100%;\n    height: calc(100vh - 117px); /* Deduct ribbon height and some padding */\n    max-height: 750px;\n    overflow: auto; /* Allow scrolling inside the container */\n    display: flex;\n    justify-content: center;\n    align-items: flex-start; /* Align iframe to the top */\n}\niframe {\n    width: auto; /* Allow iframe content to determine its width */\n    height: auto; /* Allow iframe content to determine its height */\n    min-width: 100%;\n    min-height: 100%;\n    border: none;\n}\n</style>\n","<template>\n    <div class=\"a-modal-gallery\" :class=\"{'no-caption': !caption, 'no-nav': !isNav}\">\n        <div v-if=\"isNav\" class=\"nav\" :class=\"{'no-caption': !caption}\">\n            <button\n                v-if=\"prevId\"\n                ref=\"prevBtn\"\n                v-modal=\"prevId\"\n                class=\"button prev\"\n                type=\"button\"\n            >\n                <span class=\"sr-only\">Previous image</span>\n                <a-glyph class=\"glyph\" name=\"chevron-big-left\" />\n            </button>\n            <button\n                v-if=\"nextId\"\n                ref=\"nextBtn\"\n                v-modal=\"nextId\"\n                class=\"button next\"\n                type=\"button\"\n            >\n                <span class=\"sr-only\">Next image</span>\n                <a-glyph class=\"glyph\" name=\"chevron-big-right\" />\n            </button>\n        </div>\n        <p v-if=\"caption\" :class=\"{'no-nav': !isNav}\" class=\"caption\">\n            {{ truncateCaption(caption) }}\n        </p>\n    </div>\n</template>\n\n<script setup>\nimport { truncate } from 'lodash-es';\nimport { computed } from 'vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport Modal from '@core/directives/modal.js';\n\ndefineOptions({\n    name: 'AModalGallery',\n    directives: { Modal },\n});\n\nconst props = defineProps({\n    caption: { type: String, default: undefined },\n    prevId: { type: String, default: undefined },\n    nextId: { type: String, default: undefined },\n});\n\nconst isNav = computed(() => Boolean(props.prevId || props.nextId));\n\nfunction truncateCaption(caption) {\n    return truncate(caption, { length: 243 });\n}\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-modal-gallery {\n    @mixin colls 12;\n    position:fixed;\n    inset-inline-end: 0;\n    inset-inline-start: 0;\n    bottom: 0;\n    display: flex;\n    flex-flow: row wrap;\n    background: var(--av-fixed-secondary);\n    padding: 16px;\n    color: var(--av-inversed-primary);\n    user-select: none;\n    @media (--viewport-mobile-wide) {\n        align-items: center;\n        justify-content: center;\n        flex-flow: row nowrap;\n        gap: 32px;\n    }\n    @media (--viewport-tablet) {\n        @mixin colls 10;\n        position: absolute;\n        bottom: 24px;\n        padding: 0;\n        margin: 0 auto;\n        min-height: 96px;\n        background: none;\n    }\n    @media (--viewport-desktop-wide) {\n        max-width: 960px;\n        margin: 24px auto 0;\n    }\n    .nav {\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        gap: 16px;\n        order: 2;\n        margin: 16px auto 0;\n        @media (--viewport-mobile-wide) {\n            order: 1;\n            margin: 0;\n        }\n        &.no-caption {\n            margin: 0 auto;\n        }\n        .button {\n            display: flex;\n            border: 1px solid;\n            border-radius: 24px;\n            align-items: center;\n            justify-content: center;\n            width: 32px;\n            height: 32px;\n            cursor: pointer;\n            transition: all 0.3s;\n            @media (--viewport-tablet) {\n                width: 48px;\n                height: 48px;\n            }\n            &:hover {\n                background: var(--av-fixed-secondary);\n            }\n            :deep(.a-glyph) {\n                fill: var(--av-inversed-primary);\n            }\n        }\n    }\n    .caption {\n        @mixin paragraph;\n        flex-grow: 1;\n        order: 1;\n        @media (--viewport-mobile-wide) {\n            order: 2;\n        }\n        &.no-nav {\n            @media (--viewport-tablet) {\n                width:100%;\n                text-align:center;\n            }\n        }\n    }\n}\n</style>\n","export const SIZES = [null, 'large', 'small'];\n\nexport default {};\n","<template>\n    <div class=\"a-video-card\" :class=\"className\">\n        <template v-if=\"oneTrustConsentWasGiven\">\n            <a-youtube v-if=\"isEmbeded\" :yt-id=\"ytId\" />\n            <div v-else v-modal=\"modalId\" class=\"a-video-card__wrapper\">\n                <a-picture\n                    class=\"a-video-card__img\"\n                    :link=\"image\"\n                    :alt=\"imageAlt\"\n                    :fit=\"imageFit\"\n                    is-background\n                />\n                <div v-if=\"cta\" class=\"a-video-card__cta\">\n                    <a-button\n                        class=\"a-video-card__cta-button\"\n                        v-bind=\"resolvedCta\"\n                        @click.stop.prevent=\"onCtaClick\"\n                    />\n                </div>\n                <div v-else :class=\"classNameGlyph\">\n                    <a-glyph :name=\"glyph\" />\n                </div>\n                <div class=\"a-video-card__content\">\n                    <v-clamp class=\"a-video-card__text\" autoresize :max-lines=\"1\">\n                        {{ text }}\n                    </v-clamp>\n                    <span v-if=\"time\" class=\"a-video-card__time\">\n                        {{ time }}\n                    </span>\n                </div>\n            </div>\n            <a-modal\n                :id=\"modalId\"\n                type=\"youtube\"\n                is-youtube\n            >\n                <a-youtube\n                    :yt-id=\"ytId\"\n                    :params=\"ytParams\"\n                    :title=\"text\"\n                    @progressChanged=\"$emit('progressChanged', $event)\"\n                />\n            </a-modal>\n        </template>\n        <template v-else>\n            <div class=\"a-video-card__wrapper\" @click=\"openYouTubePage\">\n                <a-picture\n                    class=\"a-video-card__img\"\n                    :link=\"image\"\n                    :alt=\"imageAlt\"\n                    :fit=\"imageFit\"\n                    is-background\n                />\n                <div v-if=\"cta\" class=\"a-video-card__cta\">\n                    <a-button\n                        class=\"a-video-card__cta-button\"\n                        v-bind=\"resolvedCta\"\n                        @click.stop.prevent=\"onCtaClick\"\n                    />\n                </div>\n                <div v-else :class=\"classNameGlyph\">\n                    <a-glyph :name=\"glyph\" />\n                </div>\n                <div class=\"a-video-card__content\">\n                    <v-clamp class=\"a-video-card__text\" autoresize :max-lines=\"1\">\n                        {{ text }}\n                    </v-clamp>\n                    <span v-if=\"time\" class=\"a-video-card__time\">\n                        {{ time }}\n                    </span>\n                </div>\n            </div>\n        </template>\n    </div>\n</template>\n\n<script>\nimport VClamp from 'vue3-clamp';\nimport AButton from '@core/components/button/button.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport AModal from '@core/components/modal/modal.vue';\nimport APicture from '@core/components/picture/picture.vue';\nimport AYoutube from '@core/components/youtube/youtube.vue';\nimport Modal from '@core/directives/modal.js';\nimport breakpoint from '@core/mixins/breakpoint.js';\nimport { SIZES } from './constants.js';\n\nconst ONETRUST_CONSENT_CHANGED = 'consent.onetrust';\nconst ONETRUST_NATIVE_CONSENT_CHANGED = 'OneTrust.OnConsentChanged';\nconst YOUTUBE_CONSENT_GROUP = 'C0004';\n\nexport default {\n    name: 'AVideoCard',\n\n    components: {\n        AYoutube,\n        VClamp,\n        AButton,\n        AGlyph,\n        AModal,\n        APicture,\n    },\n\n    directives: {\n        Modal,\n    },\n\n    mixins: [breakpoint],\n\n    props: {\n        /**\n         * Youtube id\n         */\n        ytId: {\n            type: String,\n            required: true,\n        },\n\n        ytParams: {\n            type: Object,\n            default: () => ({ autoplay: 1 }),\n        },\n\n        /**\n         * Text\n         */\n        text: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * Video time\n         */\n        time: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * Image URL\n         */\n        image: {\n            type: String,\n            required: true,\n        },\n\n        /**\n         * Image alt\n         */\n        imageAlt: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * Size\n         */\n        size: {\n            type: String,\n            default: undefined,\n            validator: (value) => value === undefined || SIZES.includes(value),\n        },\n\n        glyph: {\n            type: String,\n            default: 'play',\n        },\n        isEmbeded: {\n            type: Boolean,\n            default: false,\n        },\n        cta: {\n            type: Object,\n            default: undefined,\n        },\n        imageFit: {\n            type: String,\n            default: 'fill',\n        },\n    },\n\n    emits: ['progressChanged'],\n\n    data: () => ({\n        oneTrustConsentWasGiven: false,\n    }),\n\n    computed: {\n        modalId() {\n            return `yt_id-${this.ytId}`;\n        },\n        computedSize() {\n            if (this.size) return this.size;\n            return this.isMobile ? 'small' : 'large';\n        },\n        className() {\n            const { computedSize } = this;\n            return {\n                [`a-video-card_size_${computedSize}`]: computedSize,\n                'a-video-card--no-overlay': !this.text,\n            };\n        },\n        classNameGlyph() {\n            return [\n                'a-video-card__glyph',\n                [`a-video-card__glyph-${this.glyph}`],\n            ];\n        },\n        youtubeUrl() {\n            return `https://www.youtube.com/watch?v=${this.ytId}`;\n        },\n        resolvedCta() {\n            if (!this.cta) return null;\n\n            // CTA in video-card replaces only visual play control.\n            // Navigation/open behavior must stay the same as video click/play.\n            return {\n                ...this.cta,\n                to: null,\n                target: undefined,\n                nativeType: 'button',\n            };\n        },\n    },\n\n    mounted() {\n        this.checkOneTrustConsent();\n        window.addEventListener(ONETRUST_CONSENT_CHANGED, this.checkOneTrustConsent);\n        window.addEventListener(ONETRUST_NATIVE_CONSENT_CHANGED, this.checkOneTrustConsent);\n    },\n\n    beforeUnmount() {\n        window.removeEventListener(ONETRUST_CONSENT_CHANGED, this.checkOneTrustConsent);\n        window.removeEventListener(ONETRUST_NATIVE_CONSENT_CHANGED, this.checkOneTrustConsent);\n    },\n\n    methods: {\n        checkOneTrustConsent() {\n            if (typeof window.OptanonActiveGroups === 'undefined') return;\n            this.oneTrustConsentWasGiven = window.OptanonActiveGroups.includes(YOUTUBE_CONSENT_GROUP);\n        },\n\n        openYouTubePage() {\n            window.open(this.youtubeUrl, '_blank');\n        },\n        onCtaClick() {\n            if (!this.oneTrustConsentWasGiven) {\n                this.openYouTubePage();\n                return;\n            }\n\n            const trigger = this.$el?.querySelector('.a-video-card__wrapper');\n            trigger?.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true }));\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-video-card {\n    width: 100%;\n    aspect-ratio: 16 / 9;\n    cursor: pointer;\n    position: relative;\n    overflow: hidden;\n    border-radius: 4px;\n    border: 1px solid var(--av-brand-secondary-light, rgba(64, 139, 234, 0.3));\n    box-shadow: 0 10px 20px 0 var(--av-fixed-lightest);\n    transition: all 0.2s ease-in-out;\n\n    &_size {\n        &_small {\n            .a-video-card__glyph {\n                padding: 16px;\n                width: 56px;\n                height: 56px;\n\n                .a-glyph {\n                    width: 24px;\n                    height: 24px;\n                }\n            }\n            .a-video-card__text {\n                @mixin caption;\n            }\n        }\n\n        &_large {\n            .a-video-card__glyph {\n                padding: 20px;\n                width: 72px;\n                height: 72px;\n\n                .a-glyph {\n                    width: 32px;\n                    height: 32px;\n                }\n            }\n            .a-video-card__text {\n                @mixin paragraph;\n            }\n        }\n    }\n\n    &__wrapper {\n        position: absolute;\n        top: 0;\n        inset-inline-start: 0;\n        height: 100%;\n        width: 100%;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n\n        &::before {\n            content: '';\n            position: absolute;\n            border: var(--av-border);\n            border-radius: 4px;\n            top: 0;\n            inset-inline-start: 0;\n            bottom: 0;\n            inset-inline-end: 0;\n            z-index: 6;\n        }\n    }\n\n    &__img {\n        position: absolute;\n        top: 0;\n        inset-inline-start: 0;\n        width: 100%;\n        height: 100%;\n        object-fit: cover;\n        object-position: center;\n        transition: transform 0.2s ease-in-out;\n\n        &:before {\n            content: '';\n            position: absolute;\n            inset: 0;\n            background: linear-gradient(192deg, rgba(0, 49, 127, 0) 48.94%, rgba(0, 49, 127, 0.8) 100%);\n            z-index: 1;\n            opacity: 1;\n            pointer-events: none;\n            will-change: opacity;\n            transition: opacity 0.2s ease-in-out;\n        }\n\n        &:after {\n            content: '';\n            position: absolute;\n            inset: 0;\n            background: linear-gradient(192deg, rgba(0, 91, 204, 0) 48.94%, #005BCC 100%);\n            z-index: 2;\n            opacity: 0;\n            pointer-events: none;\n            will-change: opacity;\n            transition: opacity 0.2s ease-in-out;\n        }\n    }\n\n    &:hover,\n    &:active {\n        box-shadow: none;\n        transition: box-shadow 0.2s ease-in-out;\n\n        .a-video-card {\n            &__img {\n                transform: scale(1.02);\n\n                &:before {\n                    opacity: 0;\n                }\n\n                &:after {\n                    opacity: 1;\n                }\n            }\n\n            &__glyph-play {\n                background-color: #0065e3;\n                box-shadow: 0 10px 20px 0 var(--av-fixed-lightest);\n\n                &:hover {\n                    background-color: #005bcc;\n                }\n            }\n\n            &__glyph-play-gradient {\n                background-color: var(--av-inversed-primary);\n\n                &:hover {\n                    background-color: var(--av-inversed-primary);\n                }\n            }\n        }\n    }\n\n    &:active {\n        .a-video-card__glyph-play {\n            background-color: #0051b6;\n\n            &:active {\n                background-color: #0051b6;\n            }\n        }\n    }\n\n    &__content {\n        position: absolute;\n        z-index: 1;\n        bottom: 0;\n        inset-inline-start: 0;\n        inset-inline-end: 0;\n        width: 100%;\n        padding: 0 8px 8px 16px;\n        height: 80%;\n        display: flex;\n        align-items: flex-end;\n    }\n\n    &__glyph {\n        position: absolute;\n        width: 56px;\n        height: 56px;\n        border-radius: 50px;\n        display: flex;\n        transition: all ease-in-out 0.2s;\n        flex-shrink: 0;\n        z-index: 5;\n\n        .a-glyph {\n            fill: var(--av-inversed-primary);\n            margin: auto;\n            width: 24px;\n            height: 24px;\n        }\n    }\n\n    &__glyph-play {\n        background: #0065e3;\n    }\n\n    &__glyph-play-gradient {\n        background: var(--av-inversed-primary);\n    }\n\n    &__cta {\n        position: absolute;\n        z-index: 5;\n    }\n\n    &__cta-button {\n        transition: box-shadow ease-in-out 0.2s;\n    }\n\n    &__text {\n        @mixin caption;\n        color: var(--av-inversed-primary);\n        font-weight: 600;\n        padding-inline-end: 24px;\n        margin-bottom: 8px;\n        flex: 1;\n    }\n\n    &__time {\n        @mixin caption;\n        color: var(--av-inversed-primary);\n        background: var(--av-fixed-lighter);\n        border-radius: 4px;\n        padding: 0 2px;\n    }\n\n    &--no-overlay {\n        .a-video-card__img {\n            &:before,\n            &:after {\n                display: none;\n            }\n        }\n    }\n}\n</style>\n","/* eslint-disable n/no-unsupported-features/node-builtins */\nimport { ref, type Ref } from 'vue';\n\ninterface InteractionDemoModal {\n    id?: string;\n    src?: string;\n    breakpoint?: string[];\n    abbr?: string;\n}\n\ninterface InteractionDemoItem {\n    modal?: InteractionDemoModal;\n    [key: string]: any;\n}\n\nexport function useInteractionDemo(currentBreakpointRef: Ref<string>) {\n    const isVisibleDemoModal = ref(false);\n\n    function hasInteractionDemo(item: InteractionDemoItem): boolean {\n        if (!item?.modal) return false;\n        if (!item.modal.id || !item.modal.src) return false;\n        if (!item.modal.breakpoint?.length) return true;\n\n        const bp = currentBreakpointRef?.value;\n        return item.modal.breakpoint.includes(bp);\n    }\n\n    function logInteraction(item: InteractionDemoItem): void {\n        isVisibleDemoModal.value = true;\n\n        const abbr = item.modal?.abbr || 'ACPC';\n        const hops = `demoButtonClickHops-${abbr}`;\n        const name = `demoButtonClickDate-${abbr}`;\n\n        if (!localStorage.getItem(hops)) localStorage.setItem(hops, String(0));\n        if (!localStorage.getItem(name)) localStorage.setItem(name, String(new Date()));\n    }\n\n    return {\n        isVisibleDemoModal,\n        hasInteractionDemo,\n        logInteraction,\n    };\n}\n","/**\n * Media types\n *\n * @type {string[]}\n */\nexport const BORDER_RADIUS = [0, 2, 4, 8, 12, 16, 20, 24, 28];\n\nexport const TYPES = ['image', 'screenshot', 'video'];\n\nexport default {};\n","<template>\n    <div class=\"media-wrapper\" :class=\"wrapperClasses\" :style=\"mediaStyle\">\n        <template v-if=\"computedType === 'screenshot' || computedType === 'image'\">\n            <div\n                v-if=\"computedType === 'screenshot'\"\n                :class=\"{ 'no-shadow': !isShadow }\"\n                class=\"media screenshot-wrapper\"\n            >\n                <div\n                    v-if=\"enlargedImage\"\n                    ref=\"enlargedTriggerRef\"\n                    v-modal=\"computedModalId\"\n                    tabindex=\"0\"\n                    role=\"button\"\n                    :aria-label=\"computedEnlargeLabel\"\n                    @click=\"onClickMedia\"\n                    @keydown.enter=\"onClickMedia\"\n                >\n                    <div class=\"enlarged-image screenshot-image\">\n                        <a-picture\n                            v-bind=\"$props\"\n                            :class=\"className\"\n                            class=\"full-width\"\n                            :is-shadow=\"false\"\n                        />\n                    </div>\n                    <div v-if=\"enlargedImage\" class=\"zoom-in\">\n                        <a-glyph name=\"zoom-in\" class=\"icon\" :aria-hidden=\"true\" />\n                    </div>\n                </div>\n\n                <template v-if=\"!disableModal\">\n                    <a-modal\n                        v-if=\"enlargedImage\"\n                        :id=\"computedModalId\"\n                        :is-overlay-close=\"isOverlayClose\"\n                        :caption=\"caption\"\n                        :type=\"isGallery ? 'gallery' : 'screenshot'\"\n                    >\n                        <template #default>\n                            <a-picture\n                                :link=\"enlargedImage\"\n                                position=\"center\"\n                                :is-shadow=\"false\"\n                                persist-original\n                            />\n                        </template>\n                        <template v-if=\"isGallery\" #gallery>\n                            <a-modal-gallery\n                                :caption=\"caption\"\n                                :next-id=\"nextId\"\n                                :prev-id=\"prevId\"\n                            />\n                        </template>\n                    </a-modal>\n\n                    <a-picture\n                        v-else\n                        v-bind=\"$props\"\n                        :class=\"className\"\n                        :is-shadow=\"false\"\n                        class=\"full-width screenshot-image\"\n                    />\n                </template>\n            </div>\n\n            <a-picture\n                v-else-if=\"computedType === 'image'\"\n                v-bind=\"$props\"\n                :class=\"className\"\n                :is-shadow=\"false\"\n                class=\"media full-width\"\n            />\n\n            <template v-if=\"ctaSettings\">\n                <template v-if=\"hasInteractionDemo(ctaSettings)\">\n                    <div ref=\"ctaBlockRef\" class=\"cta-block\">\n                        <a-button\n                            ref=\"ctaButtonRef\"\n                            v-modal=\"`${ctaSettings.modal.id}-media`\"\n                            tabindex=\"0\"\n                            class=\"cta-button\"\n                            v-bind=\"ctaSettings\"\n                            @click=\"logInteraction(ctaSettings)\"\n                        />\n                    </div>\n                    <a-demo-modal\n                        v-if=\"isVisibleDemoModal\"\n                        :modal=\"{...ctaSettings.modal, id: `${ctaSettings.modal.id}-media`}\"\n                    />\n                </template>\n\n                <div\n                    v-else\n                    ref=\"ctaBlockRef\"\n                    class=\"cta-block\"\n                    @click=\"onCtaBlockClick\"\n                >\n                    <a-button\n                        ref=\"ctaButtonRef\"\n                        tabindex=\"0\"\n                        class=\"cta-button\"\n                        v-bind=\"ctaSettings\"\n                        @click=\"onCtaButtonClick\"\n                    />\n                </div>\n            </template>\n        </template>\n\n        <a-video-card\n            v-else-if=\"computedType === 'video'\"\n            v-bind=\"$props\"\n            :cta=\"videoCtaSettings\"\n            :class=\"className\"\n            class=\"media\"\n            @progressChanged=\"$emit('progressChanged', $event)\"\n        />\n\n        <span v-else>ERR: Unsupported media type!</span>\n\n        <template v-if=\"badge && (computedType === 'screenshot' || computedType === 'video')\">\n            <div\n                class=\"badge\"\n                :style=\"{\n                    top: `${badge?.offsetTop || -12}px`,\n                    insetInlineEnd: `${badge?.offsetRight || 48}px`\n                }\"\n            >\n                <dynamic-link\n                    v-if=\"badge?.to\"\n                    :to=\"badge.to\"\n                    :target=\"badge.target || '_blank'\"\n                >\n                    <a-picture :link=\"badge.image\" />\n                </dynamic-link>\n                <a-picture\n                    v-else\n                    :link=\"badge\"\n                />\n            </div>\n        </template>\n    </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed, onBeforeUnmount, onMounted, ref } from 'vue';\n\nimport AButton from '@core/components/button/button.vue';\nimport ADemoModal from '@core/components/demo-modal/demo-modal.vue';\nimport DynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport AModalGallery from '@core/components/modal/modal-gallery.vue';\nimport AModal from '@core/components/modal/modal.vue';\nimport APicture from '@core/components/picture/picture.vue';\nimport AVideoCard from '@core/components/video-card/video-card.vue';\n\nimport { useBreakpoint } from '@core/composables/useBreakpoint';\nimport { useInteractionDemo } from '@core/composables/useInteractionDemo';\n\nimport Modal from '@core/directives/modal.js';\nimport { getElementPath } from '@utils/analytics';\nimport { TYPES, BORDER_RADIUS } from './constants.js';\n\ndefineOptions({\n    name: 'AMedia',\n    directives: { Modal },\n});\n\ntype BadgeObject = {\n    image?: string;\n    to?: any;\n    target?: string;\n    offsetTop?: number;\n    offsetRight?: number;\n};\n\ntype Badge = string | BadgeObject;\n\ntype CtaModal = {\n    id?: string;\n    src?: string;\n    breakpoint?: string[];\n    abbr?: string;\n};\n\ntype CtaSettings = {\n    text?: string;\n    type?: string;\n    size?: string;\n    glyph?: string;\n    to?: any;\n    modal?: CtaModal;\n    [key: string]: any;\n};\n\ntype DomRef = Element | { $el?: Element } | null | undefined;\n\nconst props = defineProps({\n    type: {\n        type: String,\n        validator: (type: string) => TYPES.includes(type),\n        default: 'image',\n    },\n    link: { type: String, default: '' },\n    alt: { type: String, default: 'Acronis' },\n    fit: { type: [String, Object], default: undefined },\n    position: { type: String, default: 'center' },\n    enlargedImage: { type: String, default: null },\n    persistOriginal: { type: Boolean, default: false },\n    disableModal: { type: Boolean, default: false },\n    modalId: { type: String, default: null },\n    caption: { type: String, default: null },\n    nextId: { type: String, default: null },\n    prevId: { type: String, default: null },\n    isOverlayClose: { type: Boolean, default: true },\n    isShadow: { type: Boolean, default: true },\n    isBackground: { type: Boolean, default: false },\n    background: { type: Object, default: undefined },\n    size: { type: String, default: undefined },\n    ytId: { type: String, default: undefined },\n    text: { type: String, default: undefined },\n    time: { type: String, default: undefined },\n    image: { type: String, default: undefined },\n    badge: { type: [String, Object] as unknown as () => Badge, default: undefined },\n    imageAlt: { type: String, default: undefined },\n    isEager: { type: Boolean, default: false },\n    cta: { type: Object as unknown as () => CtaSettings | undefined, default: undefined },\n    events: { type: Object as unknown as () => any, default: undefined },\n    borderRadius: {\n        type: Number,\n        default: 4,\n        validator: (value) => !value || BORDER_RADIUS.includes(value),\n    },\n});\n\nconst emit = defineEmits<{\n    (e: 'click', event: Event): void;\n    (e: 'progressChanged', payload: any): void;\n}>();\n\nconst enlargedTriggerRef = ref<HTMLElement | null>(null);\nconst ctaBlockRef = ref<HTMLElement | null>(null);\nconst ctaButtonRef = ref<any>(null); // AButton instance\n\nconst { currentBreakpoint } = useBreakpoint();\nconst { isVisibleDemoModal, hasInteractionDemo, logInteraction } = useInteractionDemo(currentBreakpoint);\n\nconst computedType = computed(() => (props.type ? props.type : 'image'));\n\nconst ctaSettings = computed<CtaSettings | null>(() => {\n    if (!props.cta || props.enlargedImage) return null;\n    if (!['screenshot', 'image'].includes(computedType.value)) return null;\n\n    const fallback: CtaSettings = {\n        text: 'Button',\n        type: 'main',\n        size: 'small',\n        glyph: 'arrow',\n    };\n\n    return { ...fallback, ...props.cta };\n});\n\nconst videoCtaSettings = computed<CtaSettings | null>(() => {\n    if (!props.cta) return null;\n    if (computedType.value !== 'video') return null;\n\n    const fallback: CtaSettings = {\n        text: 'Play video',\n        type: 'main',\n        size: 'small',\n        glyph: 'i-play-round--16',\n    };\n\n    return { ...fallback, ...props.cta };\n});\n\nconst wrapperClasses = computed(() => ({\n    [`media-wrapper--${computedType.value}`]: true,\n    'media-with-cta': Boolean(ctaSettings.value || videoCtaSettings.value),\n    'media-with-enlarge': Boolean(props.enlargedImage),\n    'has-outline': Boolean(props.enlargedImage) || Boolean(ctaSettings.value || videoCtaSettings.value),\n}));\n\nconst className = computed(() => ({\n    [`a-media__type__${props.type}`]: props.type,\n}));\n\nconst mediaStyle = computed(() => ({\n    '--a-media-border-radius': `${props.borderRadius}px`,\n}));\n\nconst computedModalId = computed(() => (props.modalId ? props.modalId : `${props.link}-${props.enlargedImage}`));\n\nconst isGallery = computed(() => Boolean(props.caption || (props.prevId && props.nextId)));\n\nconst computedEnlargeLabel = computed(() => {\n    if (props.caption) return props.caption;\n    if (props.alt) return props.alt;\n    if (props.imageAlt) return props.imageAlt;\n    return 'View larger image';\n});\n\nfunction eventsGA(event: any) {\n    if (props.events) return props.events;\n    return {\n        open: eventGA(event, 'expand'),\n        close: eventGA(event, 'close'),\n    };\n}\n\nfunction eventGA(event: any, status: string) {\n    return {\n        event: 'Acronis',\n        eventCategory: 'Interactions',\n        eventAction: 'Screenshots',\n        eventLabel: props.link.replace('@', ''),\n        eventLocation: getElementPath(event.target),\n        eventContext: status,\n        eventButton: event.target?.dataset?.id || '0',\n    };\n}\n\nfunction onClickMedia(event: any) {\n    const modalEvents = eventsGA(event);\n    localStorage.setItem('modalEvents', JSON.stringify(modalEvents));\n}\n\n\nfunction toEl(target: DomRef): Element | null {\n    if (!target) return null;\n    if (target instanceof Element) return target;\n    if (typeof target === 'object' && target.$el instanceof Element) return target.$el;\n    return null;\n}\n\nfunction tagEnlargedImagesWithIndex() {\n    const root = toEl(enlargedTriggerRef.value);\n    if (!root) return;\n\n    root.querySelectorAll<HTMLElement>('.a-picture__img').forEach((img, index) => {\n        img.setAttribute('data-id', String(index + 1));\n    });\n}\n\nfunction setCtaButtonState(state: 'hover' | 'active', enabled: boolean) {\n    const btn = toEl(ctaButtonRef.value);\n    if (!btn) return;\n\n    btn.classList.toggle(state, enabled);\n}\n\nfunction addCtaListeners() {\n    if (!ctaSettings.value) return;\n\n    const block = toEl(ctaBlockRef.value);\n    if (!block) return;\n\n    block.addEventListener('mouseenter', onCtaMouseEnter);\n    block.addEventListener('mouseleave', onCtaMouseLeave);\n    block.addEventListener('mousedown', onCtaMouseDown);\n    block.addEventListener('mouseup', onCtaMouseUp);\n}\n\nfunction removeCtaListeners() {\n    const block = toEl(ctaBlockRef.value);\n    if (!block) return;\n\n    block.removeEventListener('mouseenter', onCtaMouseEnter);\n    block.removeEventListener('mouseleave', onCtaMouseLeave);\n    block.removeEventListener('mousedown', onCtaMouseDown);\n    block.removeEventListener('mouseup', onCtaMouseUp);\n}\n\nfunction onCtaMouseEnter() {\n    setCtaButtonState('hover', true);\n}\nfunction onCtaMouseLeave() {\n    setCtaButtonState('hover', false);\n}\nfunction onCtaMouseDown() {\n    setCtaButtonState('active', true);\n}\nfunction onCtaMouseUp() {\n    setCtaButtonState('active', false);\n}\n\nfunction onCtaBlockClick(event: Event) {\n    if (props.cta?.to) {\n        const btn = toEl(ctaButtonRef.value) as HTMLElement | null;\n        btn?.click();\n        return;\n    }\n\n    emit('click', event);\n}\n\nfunction onCtaButtonClick(event: Event) {\n    event.stopPropagation();\n}\n\nonMounted(() => {\n    tagEnlargedImagesWithIndex();\n    addCtaListeners();\n});\n\nonBeforeUnmount(() => {\n    removeCtaListeners();\n});\n</script>\n\n<style lang=\"postcss\" scoped>\n.full-width :deep(.a-picture__img) {\n    width: 100%;\n}\n\n.enlarged-image {\n    position: relative;\n    cursor: pointer;\n    border-radius: var(--a-media-border-radius);\n    &:hover {\n        .a-media__type__screenshot {\n            box-shadow: none;\n        }\n    }\n}\n\n.badge {\n    position: absolute;\n    top: -8px;\n    inset-inline-end: 32px;\n    width: auto !important;\n    height: auto !important;\n    filter: drop-shadow(0px 4px 8px rgba(36, 49, 67, .3));\n    @media (--viewport-desktop) {\n        top: -12px;\n        inset-inline-end: 48px;\n    }\n    &:deep(.a-picture__img) {\n        max-height: 64px;\n        max-width: 64px;\n        @media (--viewport-desktop) {\n            max-height: 72px;\n            max-width: 72px;\n        }\n    }\n}\n\n.zoom-in {\n    display: flex;\n    position: absolute;\n    bottom: 8px;\n    right: 8px;\n    background: var(--av-fixed-lighter);\n    border-radius: var(--a-media-border-radius);\n    padding: 8px;\n    transition: 0.2s all;\n\n    .icon {\n        fill: var(--av-inversed-primary);\n    }\n}\n\n.a-media {\n    &_radius {\n        &_0 { --a-media-border-radius: 0px }\n        &_2 { --a-media-border-radius: 2px }\n        &_4 { --a-media-border-radius: 4px; }\n        &_8 { --a-media-border-radius: 8px; }\n        &_12 { --a-media-border-radius: 12px; }\n        &_16 { --a-media-border-radius: 16px; }\n        &_20 { --a-media-border-radius: 20px; }\n        &_24 { --a-media-border-radius: 24px; }\n        &_28 { --a-media-border-radius: 28px; }\n    }\n    &__type {\n        &__screenshot {\n            border-radius: var(--a-media-border-radius);\n            overflow: hidden;\n            transition: box-shadow 0.2s ease-in-out;\n        }\n    }\n}\n.a-media__type__video {\n    border-radius: var(--a-media-border-radius);\n    :deep(.a-video-card__wrapper) {\n        border-radius: var(--a-media-border-radius);\n        overflow: hidden;\n    }\n}\n.a-media__type__video :deep(.a-video-card__wrapper:before) {\n    content: none;\n}\n\n.no-shadow {\n    .a-media__type__screenshot {\n        box-shadow: none;\n    }\n}\n\n.cta-block {\n    position: absolute;\n    inset: 0;\n    display: flex;\n    user-select: none;\n    align-items: center;\n    justify-content: center;\n}\n\n.cta-block :deep(.a-button__content) {\n    user-select: none;\n}\n\n.cta-button {\n    transition: box-shadow ease-in-out 0.2s;\n}\n\n.media-wrapper {\n    user-select: none;\n    position: relative;\n\n    .a-picture {\n        width: 100%;\n        height: 100%;\n    }\n\n    &.has-outline {\n        &:focus-within,\n        &:focus-visible {\n            .media {\n                outline: 3px solid var(--av-brand-secondary);\n                outline-offset: -1px;\n                border-radius: var(--a-media-border-radius);\n            }\n        }\n    }\n\n    &--image.media-with-cta {\n        .a-picture {\n            transition: opacity 0.2s ease-in-out;\n            will-change: opacity;\n        }\n\n        &:hover {\n            cursor: pointer;\n\n            .a-picture {\n                opacity: .6;\n            }\n        }\n    }\n\n    &--screenshot.media-with-cta {\n        .screenshot-wrapper {\n            overflow: hidden;\n            border-radius: var(--a-media-border-radius);\n            border: 1px solid var(--av-brand-secondary-light, rgba(64, 139, 234, 0.3));\n            box-shadow: 0 10px 20px 0 var(--av-fixed-lightest);\n            transition: opacity .2s ease-in-out, box-shadow .2s ease-in-out;\n            will-change: opacity;\n        }\n\n        .a-picture {\n            transition: transform 0.2s ease-in-out;\n            will-change: transform;\n        }\n\n        .cta-block {\n            background: radial-gradient(50.09% 77.73% at 50.09% 50%, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0) 100%);\n        }\n\n        &:hover {\n            cursor: pointer;\n\n            .screenshot-wrapper {\n                box-shadow: none;\n                opacity: 0.6;\n                .a-picture {\n                    transform: scale(1.02);\n                }\n            }\n\n        }\n    }\n\n    &--screenshot.media-with-enlarge {\n        .screenshot-image {\n            overflow: hidden;\n            border-radius: var(--a-media-border-radius);\n            border: 1px solid var(--av-brand-secondary-light, rgba(64, 139, 234, 0.3));\n            box-shadow: 0 10px 20px 0 var(--av-fixed-lightest);\n            transition: opacity 0.2s ease-in-out;\n            will-change: opacity;\n        }\n\n        .a-picture {\n            transition: transform 0.2s ease-in-out;\n            will-change: transform;\n        }\n\n        .zoom-in {\n            background: var(--av-fixed-lighter);\n            &:hover {\n                background: var(--av-button-main-hover);\n                box-shadow: 0 10px 20px 0 var(--av-fixed-lightest);\n            }\n            &:active {\n                background: var(--av-button-main-active);\n                box-shadow: 0 10px 20px 0 var(--av-fixed-lightest);\n            }\n        }\n\n        &:hover {\n            cursor: pointer;\n\n            .screenshot-image {\n                box-shadow: none;\n                opacity: 0.6;\n            }\n\n            .a-picture {\n                transform: scale(1.02);\n            }\n        }\n    }\n\n    &--screenshot:not(.media-with-enlarge, .media-with-cta) {\n        .screenshot-image {\n            overflow: hidden;\n            border-radius: var(--a-media-border-radius);\n            border: 1px solid var(--av-brand-secondary-light, rgba(64, 139, 234, 0.3));\n            box-shadow: 0 10px 20px 0 var(--av-fixed-lightest);\n            transition: opacity 0.2s ease-in-out;\n            will-change: opacity;\n        }\n    }\n\n    &:hover {\n        .zoom-in {\n            fill: var(--av-button-main);\n            background: var(--av-button-main);\n            box-shadow: 0 10px 20px 0 var(--av-fixed-lightest);\n        }\n\n        .cta-button {\n            box-shadow: 0 10px 20px 0 var(--av-fixed-lightest);\n        }\n    }\n    &:active {\n        .zoom-in {\n            background: var(--av-button-main-active);\n            box-shadow: 0 10px 20px 0 var(--av-fixed-lightest);\n        }\n        .a-button {\n            box-shadow: 0 10px 20px 0 var(--av-fixed-lightest);\n        }\n    }\n}\n</style>\n","import { GOOGLE_MAP_API_KEY } from '@model/const/api-keys.ts';\nimport { LOCALE_DEFAULT } from '@model/const/locales';\n\nexport default {\n    data() {\n        return {\n            map: null,\n            isLoadedGoogleMaps: false,\n        };\n    },\n\n    computed: {\n        locale() {\n            return this.$store.state.geolocation.finalLocale || LOCALE_DEFAULT;\n        },\n        language() {\n            // TODO: should this use getLanguageCodeFromLocale?\n            return this.locale.split('-').shift();\n        },\n    },\n\n    async mounted() {\n        await this.$nextTick();\n\n        if (typeof window === 'undefined') return;\n\n        await this.waitForBody();\n\n        try {\n            await this.loadGoogleMapsScript();\n            this.isLoadedGoogleMaps = true;\n            this.addMap?.();\n            this.addMarkers?.();\n        } catch (err) {\n            // eslint-disable-next-line no-console\n            console.error('❌ Failed to load Google Maps:', err);\n        }\n    },\n\n    methods: {\n        waitForBody() {\n            return new Promise((resolve) => {\n                if (document.body) {\n                    resolve(undefined); // explicit resolve to avoid lint\n                    return;\n                }\n\n                const id = setInterval(() => {\n                    if (document.body) {\n                        clearInterval(id);\n                        resolve(undefined); // again, resolve with undefined\n                    }\n                }, 50);\n            });\n        },\n\n        loadGoogleMapsScript() {\n            return new Promise((resolve, reject) => {\n                if (window.google?.maps) {\n                    resolve(undefined);\n                    return;\n                }\n\n                if (window.GoogleMapsInit) {\n                    const checkInterval = setInterval(() => {\n                        if (window.google?.maps) {\n                            clearInterval(checkInterval);\n                            resolve(undefined);\n                        }\n                    }, 100);\n                    return;\n                }\n\n                const params = 'loading=async&callback=GoogleMapsInit&libraries=marker';\n                const src = `https://maps.googleapis.com/maps/api/js?key=${GOOGLE_MAP_API_KEY}&${params}&language=${this.language}`;\n                const script = document.createElement('script');\n                script.setAttribute('src', src);\n                script.setAttribute('async', '');\n                script.setAttribute('defer', '');\n\n                window.GoogleMapsInit = () => resolve(undefined);\n                script.onerror = reject;\n\n                document.body.appendChild(script);\n            });\n        },\n    },\n};\n","export default {\n    links: [\n        {\n            link: 'https://www.facebook.com/acronis',\n            name: 'facebook',\n            title: 'Facebook',\n        },\n        {\n            link: 'https://x.com/Acronis',\n            name: 'twitter',\n            title: 'X',\n        },\n        {\n            link: 'https://www.youtube.com/user/Acronis',\n            name: 'yt',\n            title: 'YouTube',\n        },\n        {\n            link: 'https://www.linkedin.com/company/acronis',\n            name: 'linkedin',\n            title: 'LinkedIn',\n        },\n        {\n            link: 'https://www.reddit.com/r/acronis',\n            name: 'reddit',\n            title: 'Reddit',\n        },\n    ],\n    share: [\n        {\n            link: (url, title) => `https://x.com/share?text=${title}&url=${url}`,\n            name: 'twitter',\n        },\n        {\n            link: (url) => `https://www.facebook.com/sharer.php?u=${url}`,\n            name: 'facebook',\n        },\n        {\n            link: (url, title) => `http://www.linkedin.com/shareArticle?mini=true&url=${url}&title=${title}`,\n            name: 'linkedin',\n        },\n        {\n            link: (url, title) => `https://www.reddit.com/submit?url=${url}&title=${title}`,\n            name: 'reddit',\n        },\n    ],\n};\n","<template>\n    <div\n        class=\"a-breadcrumbs\"\n        :class=\"className\"\n        role=\"navigation\"\n        aria-label=\"Breadcrumb\"\n    >\n        <div class=\"a-container\">\n            <div class=\"a-breadcrumbs__desktop\">\n                <ul ref=\"listItem\" class=\"a-breadcrumbs__list\">\n                    <li v-for=\"(item, index) in links\" :key=\"index\" class=\"a-breadcrumbs__item\">\n                        <a-link\n                            v-if=\"bigWidth === true && item.to && index < links.length - 1\"\n                            v-bind=\"item\"\n                            class=\"a-breadcrumbs__link\"\n                            :to=\"item.to\"\n                            :text=\"item.text\"\n                            :size=\"item.size || 'caption'\"\n                            accent\n                            :type=\"theme === 'dark' ? 'light' : 'regular'\"\n                        />\n                        <span\n                            v-if=\"item.to && index === links.length - 1\"\n                            class=\"a-breadcrumbs__current\"\n                            :class=\"item.size || 'caption'\"\n                            aria-current=\"page\"\n                        >\n                            {{ item.text }}\n                        </span>\n                        <a-glyph\n                            v-if=\"bigWidth === true && glyphDesktop && item.to && index < links.length - 1\"\n                            class=\"a-breadcrumbs__glyph\"\n                            :name=\"glyphDesktop\"\n                            :aria-hidden=\"true\"\n                        />\n                        <a-link\n                            v-if=\"bigWidth === false && item.to && (index === 0 || index === links.length - 2)\"\n                            v-bind=\"item\"\n                            class=\"a-breadcrumbs__link\"\n                            :to=\"item.to\"\n                            :text=\"item.text\"\n                            :size=\"item.size || 'caption'\"\n                            accent\n                            :type=\"theme === 'dark' ? 'light' : 'regular'\"\n                        />\n                        <a-glyph\n                            v-if=\"bigWidth === false && glyphDesktop && item.to && (index === 0 || index === links.length - 2)\"\n                            class=\"a-breadcrumbs__glyph\"\n                            :name=\"glyphDesktop\"\n                            :aria-hidden=\"true\"\n                        />\n                        <div v-if=\"bigWidth === false && item.sublinks\" class=\"a-breadcrumbs__sublist-container\">\n                            <button\n                                class=\"a-breadcrumbs__sublist-toggler\"\n                                :class=\"{ 'a-breadcrumbs__sublist-toggler--active': sublinkActive }\"\n                                type=\"button\"\n                                @click=\"showSublist\"\n                            >\n                                <a-glyph class=\"a-breadcrumbs__glyph\" name=\"ellipsis\" :aria-hidden=\"true\" />\n                            </button>\n                            <ul ref=\"links\" class=\"a-breadcrumbs__sublist\" @mouseleave=\"hideSublist\">\n                                <li v-for=\"(sublink, subIndex) in links\" :key=\"subIndex\" class=\"a-breadcrumbs__subitem\">\n                                    <a-link\n                                        v-if=\"sublink.to && subIndex > 1 && subIndex < links.length - 2\"\n                                        class=\"a-breadcrumbs__sublink\"\n                                        v-bind=\"sublink\"\n                                        :to=\"sublink.to\"\n                                        :text=\"sublink.text\"\n                                        :size=\"sublink.size || 'caption'\"\n                                        accent\n                                        :type=\"theme === 'dark' ? 'light' : 'regular'\"\n                                    />\n                                </li>\n                            </ul>\n                            <a-glyph class=\"a-breadcrumbs__glyph\" :name=\"glyphDesktop\" :aria-hidden=\"true\" />\n                        </div>\n                    </li>\n                </ul>\n            </div>\n            <div class=\"a-breadcrumbs__mobile\">\n                <div v-for=\"(item, index) in links\" :key=\"index\" class=\"a-breadcrumbs__item\">\n                    <a-link\n                        v-if=\"item.to && item.text && index === links.length - 2\"\n                        v-bind=\"item\"\n                        class=\"a-breadcrumbs__link\"\n                        :to=\"item.to\"\n                        :text=\"item.text\"\n                        :glyph=\"glyphMobile\"\n                        glyph-position=\"left\"\n                        :size=\"item.size || 'caption'\"\n                        accent\n                        :type=\"theme === 'dark' ? 'light' : 'regular'\"\n                    />\n                </div>\n            </div>\n        </div>\n    </div>\n</template>\n\n<script>\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport ALink from '@core/components/link/link.vue';\n\nconst sublistClassContainer = 'a-breadcrumbs__sublist-container';\nconst sublistClass = 'a-breadcrumbs__sublist-toggler';\nconst sublistClassActive = `${sublistClass}_active`;\n\nexport default {\n    name: 'ABreadcrumbs',\n\n    components: {\n        ALink,\n        AGlyph,\n    },\n\n    props: {\n        /**\n         * Links\n         */\n        links: {\n            type: Array,\n            default: () => [],\n        },\n\n        glyphDesktop: {\n            type: String,\n            required: false,\n            default: 'breadcrumb-chevron-right',\n        },\n\n        glyphMobile: {\n            type: String,\n            required: false,\n            default: 'long-arrow-left',\n        },\n\n        sublinks: {\n            type: Boolean,\n        },\n\n        theme: {\n            type: String,\n            validator: (prop) => ['light', 'dark'].includes(prop),\n            default: 'light',\n        },\n    },\n\n    data() {\n        return {\n            sublinkActive: false,\n            bigWidth: true,\n            listWidth: null,\n        };\n    },\n\n    computed: {\n        className() {\n            return {\n                'a-breadcrumbs_dark': this.theme === 'dark',\n            };\n        },\n    },\n    mounted() {\n        this.listWidth = this.$refs.listItem.clientWidth;\n        this.calcWidth();\n        window.addEventListener('resize', this.calcWidth);\n    },\n\n    beforeUnmount() {\n        window.removeEventListener('resize', this.calcWidth);\n    },\n\n    methods: {\n        showSublist(event) {\n            if (event.target.classList.contains(sublistClassActive)) {\n                event.target.classList.remove(sublistClassActive);\n            } else {\n                event.target.classList.add(sublistClassActive);\n            }\n        },\n\n        hideSublist(event) {\n            if (event.relatedTarget && event.relatedTarget.className !== sublistClassContainer) {\n                event.target\n                    .closest(`.${sublistClassContainer}`)\n                    .querySelector(`.${sublistClass}`)\n                    .classList.remove(sublistClassActive);\n            }\n        },\n\n        calcWidth() {\n            if (!this.$refs.listItem) {\n                return false;\n            }\n            if (window.innerWidth - this.listWidth >= 50) {\n                this.bigWidth = true;\n            } else {\n                this.bigWidth = false;\n            }\n            return true;\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-breadcrumbs {\n    width: 100%;\n    position: relative;\n\n    /* WEB-43924 why do we use 120 here ? */\n    z-index: 120;\n    &__desktop {\n        display: none;\n        @media (--viewport-tablet) {\n            display: block;\n        }\n    }\n\n    &__mobile {\n        display: block;\n        @media (--viewport-tablet) {\n            display: none;\n        }\n    }\n    &__current {\n        color: var(--av-nav-primary);\n        padding: 4px 8px;\n\n        &.caption {\n            @mixin caption-accent;\n        }\n        &.title {\n            @mixin title-accent;\n        }\n    }\n    &__list {\n        display: flex;\n        flex-shrink: 0;\n        white-space: nowrap;\n        flex-wrap: wrap;\n    }\n\n    &__item {\n        @mixin caption-accent;\n        font-weight: 600;\n        display: flex;\n        align-items: center;\n        justify-content: flex-start;\n        color: var(--av-brand-secondary);\n        .a-breadcrumbs__glyph {\n            margin-inline-end: 4px;\n        }\n    }\n\n    &__link {\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n        gap: 8px;\n        padding: 4px 8px;\n        border-radius: 4px;\n        @mixin caption-accent;\n        color: var(--av-brand-primary) !important;\n        &:hover {\n            background-color: var(--el-secondary-hover);\n        }\n        &:active {\n            background-color: var(--el-secondary-active);\n        }\n\n        :deep(.a-glyph) {\n            fill: var(--av-brand-primary) !important;\n            margin: 0 !important;\n        }\n        :deep(.hasGlyph) {\n            display: flex;\n        }\n    }\n\n    &__glyph {\n        fill: var(--av-brand-primary);\n        height: 16px;\n        width: 16px;\n    }\n\n    &__sublist-container {\n        position: relative;\n        display: flex;\n        align-items: center;\n    }\n\n    &__sublist-toggler {\n        display: flex;\n        align-items: center;\n        padding: 4px 8px;\n        color: var(--av-brand-secondary);\n        background: transparent;\n        margin-inline-end: 4px;\n        border-radius: 4px;\n        border: 1px solid var(--av-brand-secondary-light);\n        cursor: pointer;\n\n        .a-breadcrumbs__glyph {\n            fill: var(--av-brand-primary) !important;\n            margin: 0;\n        }\n\n        & > * {\n            pointer-events: none;\n        }\n\n        &:hover {\n            background-color: var(--el-secondary-hover);\n        }\n\n        &_active {\n            background-color: var(--el-secondary-active);\n            & + .a-breadcrumbs {\n                &__sublist {\n                    display: block;\n                }\n            }\n        }\n\n        :deep(.a-link.nuxt-link-exact-active) {\n            color: var(--av-nav-primary);\n        }\n\n        &--active {\n            color: var(--av-inversed-primary);\n        }\n    }\n\n    &__sublist-glyph {\n        margin-inline-start: 8px;\n        fill: currentcolor;\n        transition: transform 0.15s ease-out;\n    }\n\n    &__sublist {\n        display: none;\n        position: absolute;\n        top: calc(100% + 10px);\n        inset-inline-start: 0;\n        padding: 8px 0;\n        background-color: var(--av-inversed-primary);\n        box-shadow: 0 10px 20px rgba(36, 49, 67, 0.2);\n        border-radius: 4px;\n        border: 1px solid var(--av-brand-secondary);\n    }\n\n    &__subitem {\n        margin: 0;\n        padding: 0;\n    }\n\n    &__sublink {\n        color: var(--av-brand-primary) !important;\n        cursor: pointer;\n        display: block;\n        padding: 8px 16px;\n        :deep(.a-glyph) {\n            fill: var(--av-brand-primary) !important;\n        }\n        &:hover {\n            background-color: var(--el-secondary-hover);\n        }\n\n        &:active {\n            background-color: var(--el-secondary-active);\n        }\n\n        &.a-link.nuxt-link-exact-active {\n            pointer-events: auto;\n        }\n    }\n    &_dark {\n        background: var(--av-nav-primary);\n    }\n    &_dark & {\n        &__current {\n            color: var(--av-inversed-primary);\n        }\n        &__sublist-toggler {\n            color: var(--av-link-inversed);\n            .a-breadcrumbs__glyph {\n                fill: var(--av-link-inversed) !important;\n            }\n        }\n        &__link {\n            color: var(--av-link-inversed) !important;\n            :deep(.a-glyph) {\n                fill: var(--av-link-inversed) !important;\n            }\n        }\n        &__glyph {\n            fill: var(--av-link-inversed);\n        }\n    }\n}\n[dir='rtl'] {\n    .a-breadcrumbs__item .a-breadcrumbs__glyph {\n        transform: rotate(180deg);\n    }\n}\n</style>\n","export default {\n    async serverPrefetch() {\n        if (!this.listAwards?.length) return;\n        const promises = this.listAwards.map((id) => this.$store.dispatch('awards/getAward', id));\n        await Promise.all(promises);\n    },\n};\n","<template>\n    <!-- eslint-disable max-len -->\n    <svg\n        width=\"257\"\n        height=\"32\"\n        viewBox=\"0 0 257 32\"\n        fill=\"none\"\n        xmlns=\"http://www.w3.org/2000/svg\"\n    >\n        <path d=\"M131.446 2.326h-2.444L128.245 0l-.754 2.326h-2.445l1.977 1.436-.755 2.326 1.977-1.436 1.979 1.436-.754-2.326 1.976-1.436ZM21.275 18.707H9.668l-1.102 2.75h13.808l-1.099-2.75ZM24.142 25.874l-.815-2.04H7.613l-1.103 2.75h17.92l-.28-.71h-.008ZM19.223 13.577h-7.499l-1.103 2.75h9.703l-1.1-2.75Z\" fill=\"#B31942\" /><path d=\"M43.792 27.884c-4.846 0-7.863-3.427-7.863-8.41 0-4.985 2.835-8.412 7.817-8.412 3.565 0 6.08 1.644 7.13 5.348h4.708c-1.053-5.988-5.668-9.464-11.746-9.464-7.087 0-12.57 5.076-12.57 12.525 0 7.222 4.753 12.527 12.342 12.527 5.896 0 10.56-3.245 12.023-9.098h-4.708c-1.006 3.2-3.611 4.982-7.13 4.982l-.003.002ZM63.542 10.468l-.182-3.063h-4.206v24.137h4.572V19.06c0-4.296 1.327-7.039 6.127-7.039h.683V6.946h-.412c-2.835 0-5.074 1.373-6.582 3.522ZM83.929 6.946c-7.13 0-12.663 5.12-12.663 12.525 0 7.222 5.348 12.527 12.663 12.527s12.663-5.305 12.663-12.527c0-7.13-5.259-12.525-12.663-12.525Zm.043 20.938c-4.661 0-7.998-3.427-7.998-8.457 0-4.708 2.97-8.365 7.955-8.365 4.984 0 7.999 3.611 7.999 8.365s-3.245 8.457-7.956 8.457ZM112.087 6.946c-3.291 0-5.852 1.007-7.724 2.971l-.321-2.515h-4.067V31.54h4.572V17.642c0-3.931 2.513-6.536 6.582-6.536 3.747 0 5.302 2.149 5.302 6.078v14.355h4.572V16.318c0-5.989-3.199-9.372-8.916-9.372ZM130.508 7.405h-4.526v24.137h4.526V7.405ZM152.36 19.06c-1.508-.821-3.155-1.142-4.938-1.416-1.875-.274-4.067-.502-5.258-.96-1.188-.456-1.829-1.142-1.829-2.467 0-2.059 1.783-3.565 4.8-3.565 2.835 0 5.028 1.373 5.302 4.16h4.344c-.277-5.259-4.024-7.863-9.646-7.863-5.164 0-9.187 2.699-9.187 7.819 0 2.195.868 4.16 3.063 5.212 1.416.684 3.061 1.053 5.44 1.416 2.285.367 3.427.549 4.523.96 1.143.413 1.875 1.053 1.875 2.606 0 2.24-2.149 3.337-4.982 3.337-3.427 0-5.76-1.28-6.216-4.206h-4.436c.459 5.717 4.756 7.91 10.65 7.91 2.925 0 5.212-.549 6.949-1.968 1.644-1.324 2.512-3.337 2.512-5.622 0-2.148-.958-4.251-2.971-5.347l.005-.005ZM191.583 17.05c-2.011-1.327-4.846-1.92-8.731-2.561-4.482-.732-8.412-1.598-8.412-5.896 0-3.885 3.2-6.447 8.091-6.447 4.754 0 8.412 2.15 9.052 6.767h2.559C193.412 2.743 188.52 0 182.667 0c-6.124 0-10.603 3.337-10.603 8.821 0 3.11 1.462 5.076 3.747 6.219 2.056 1.004 4.021 1.372 6.856 1.874 2.423.413 4.572.733 6.401 1.645 1.921.868 3.291 2.149 3.291 5.027 0 4.206-3.75 6.263-8.777 6.263-5.668 0-9.738-2.147-10.378-7.177h-2.516c.595 6.354 5.622 9.326 12.799 9.326 6.539 0 11.338-3.018 11.338-8.686 0-3.245-1.324-5.027-3.245-6.262h.003ZM214.59 29.849c-7.543 0-12.525-5.804-12.525-13.987 0-7.955 5.028-13.716 12.161-13.716 5.852 0 10.194 3.246 11.702 8.962h2.559C226.797 4.206 221.541 0 214.318 0c-8.685 0-14.858 6.675-14.858 15.954 0 9.28 5.989 16.046 15.04 16.046 7.131 0 12.435-4.344 14.079-11.382h-2.469c-1.555 6.078-5.898 9.233-11.52 9.233v-.002ZM252.871 17.05c-2.01-1.327-4.845-1.92-8.731-2.561-4.482-.732-8.411-1.598-8.411-5.896 0-3.885 3.199-6.447 8.091-6.447 4.754 0 8.411 2.15 9.051 6.767h2.559C254.7 2.743 249.808 0 243.956 0c-5.853 0-10.604 3.337-10.604 8.821 0 3.11 1.463 5.076 3.747 6.219 2.057 1.004 4.022 1.372 6.857 1.874 2.423.413 4.572.733 6.4 1.645 1.921.868 3.292 2.149 3.292 5.027 0 4.206-3.75 6.263-8.778 6.263-5.668 0-9.738-2.147-10.378-7.177h-2.515c.594 6.354 5.622 9.326 12.799 9.326 6.538 0 11.338-3.018 11.338-8.686 0-3.245-1.324-5.027-3.245-6.262h.002ZM12.983.456 0 31.542h4.756l1.89-4.689 5.65-14.098c1.327-3.291 2.47-6.034 3.156-8.091.732 2.06 1.875 4.8 3.201 8.09l5.246 13.12h.01l.735 1.86 1.506 3.808h4.754L17.92.456h-4.938Z\" fill=\"#0A3161\" />\n    </svg>\n</template>\n\n<script>\nexport default {\n    name: 'AScsLogo',\n};\n</script>\n","export function parseDynamicPagePath(path: string | string[] = ''): { slug: string, draftKey: string | undefined } {\n    const str = Array.isArray(path) ? path.join('/') : path;\n    const segments = str?.split('/').filter(Boolean);\n\n    if (!segments.length) {\n        return {\n            slug: '',\n            draftKey: undefined,\n        };\n    }\n\n    if (segments[segments.length - 1].startsWith('draft-')) {\n        const draftKeySegment = segments.pop();\n\n        return {\n            slug: segments.join('/'),\n            draftKey: draftKeySegment.replace('draft-', ''),\n        };\n    }\n\n    return {\n        slug: segments.join('/'),\n        draftKey: undefined,\n    };\n}\n","import { defineAsyncComponent, markRaw } from 'vue';\n\nexport function getNestedSlices(node: any): any[] {\n    if (!node || !node.data) return [];\n    // TODO: this is more complicated than it should be.\n    // make s-all-products use the same format as wrapper, tabs, side-menu\n    const nested = node.name === 's-all-products'\n        ? (node.data.slicesData || []).flatMap((x: any) => x?.slices || [])\n        : (node.data.slices || []);\n\n    return Array.isArray(nested) ? nested.filter(Boolean) : [];\n}\n\n// Recursive routine for dynamic slices resolution (including `.data.slices[*].name`).\n// Used for dynamic slices resolution in pages view components.\nexport function resolvePageBodySlices(pageBody: any[] = []): string[] {\n    const names = new Set<string>();\n\n    if (!Array.isArray(pageBody) || !pageBody.length) {\n        return [];\n    }\n\n    // Only interested in dynamic slices, starting with `s-`\n    const maybeAdd = (name: any) => {\n        if (typeof name === 'string' && name.startsWith('s-')) {\n            names.add(name);\n        }\n    };\n\n    const resolveRecursive = (node: any) => {\n        maybeAdd(node.name);\n        getNestedSlices(node).forEach(resolveRecursive);\n    };\n\n    pageBody.forEach(resolveRecursive);\n\n    return Array.from(names);\n}\n\nexport function defaultSectionResolver(name: string): string {\n    if (name.startsWith('s-developer')) return 'developer';\n    if (name.startsWith('s-trueimage')) return 'trueimage';\n    if (name.startsWith('s-acronis-scs')) return 'scs';\n    return 'pages';\n}\n\nexport interface RegisterSlicesRequest {\n    pageBody: any[];\n    componentRegistrar: (name: string, component: any) => void;\n    sectionResolver?: (fullname: string) => string;\n}\n\n/**\n * Register slice components dynamically.\n *\n * @param req.pageBody The `page.body` data\n * @param req.componentRegistrar A function called for each name/component\n * @param req.sectionResolver A function to resolve the section for a given name (defaults to 'pages')\n */\nexport function registerSlices(req: RegisterSlicesRequest) {\n    if (!req || typeof req.componentRegistrar !== 'function') return;\n\n    const { pageBody = [], componentRegistrar, sectionResolver = defaultSectionResolver } = req;\n\n    const names = resolvePageBodySlices(pageBody);\n\n    names.forEach((fullname) => {\n        const sliceName = fullname.replace(/^s-/, '');\n        const section = sectionResolver(fullname);\n\n        const loader = () => import(`@core/slices/${section}/${sliceName}/${sliceName}.vue`);\n\n        try {\n            const asyncComponent = markRaw(defineAsyncComponent(loader));\n            componentRegistrar(fullname, asyncComponent);\n        } catch (err) {\n            // eslint-disable-next-line no-console\n            console.error(`[registerSlices] Failed to register slice: \"${fullname}\"`, err);\n        }\n    });\n}\n","export const countries = ['GB', 'UK', 'US', 'CA', 'AU', 'NZ', 'DE', 'FR'];\n\nexport function getEnableAfter(url) {\n    if (url.includes('/products/cloud/express-signup/')) {\n        return 1000;\n    }\n\n    return 10 * 1000;\n}\n\nexport const pageRegex = ['/products/', '/partners/', '/solutions/'].map(\n    (reg) => new RegExp(reg, 'ig'),\n);\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <iframe\n        v-if=\"enabled\"\n        id=\"sfchat-iframe\"\n        :style=\"style\"\n        :src=\"iframeSource\"\n    />\n</template>\n\n<script>\nimport { mapGetters, mapState } from 'vuex';\nimport { LOCALE_DEFAULT } from '@model/const/locales.ts';\nimport { countries, pageRegex, getEnableAfter } from './constants.js';\n\nexport default {\n    data() {\n        return {\n            style: '',\n            enabled: false,\n            country: null,\n            iframeSource: '',\n        };\n    },\n    computed: {\n        ...mapState({\n            location: (state) => state.geolocation?.location || null,\n        }),\n        ...mapGetters('config', ['$config']),\n        locale() {\n            return this.$store.state.geolocation.finalLocale || LOCALE_DEFAULT;\n        },\n        enabledAfter() {\n            if (typeof window === 'undefined') return 0;\n\n            if (localStorage.getItem('acronis_sfchat_maximized') === '1') {\n                return 0;\n            }\n\n            return getEnableAfter(window.location.pathname);\n        },\n    },\n    async mounted() {\n        await this.setGeolocation();\n\n        if (!this.checkEligibility()) return;\n\n        setTimeout(() => {\n            this.enabled = true;\n            this.iframeSource = `/public/integrations/sfchat?lang=${this.locale.slice(0, 2)}`;\n        }, this.enabledAfter);\n        window.addEventListener('message', this.onMessageReceive);\n    },\n    beforeUnmount() {\n        window.removeEventListener('message', this.onMessageReceive);\n    },\n    methods: {\n        async setGeolocation() {\n            if (this.location) return;\n            await this.$store.dispatch('geolocation/getGeoLocation');\n            this.country = (this.location?.data?.country?.code || '').toUpperCase();\n        },\n        isAllowedOrigin(origin) {\n            try {\n                const url = new URL(origin);\n                const hostname = url.hostname;\n\n                const ALLOWED_HOSTS = [\n                    'service.force.com',\n                    'acronis.com',\n                    'my.salesforce.com',\n                    'salesforce.com',\n                ];\n\n                return (\n                    ALLOWED_HOSTS.some(allowed =>\n                        hostname === allowed || hostname.endsWith(`.${allowed}`),\n                    )\n                );\n            } catch (err) {\n                return false;\n            }\n        },\n\n        onMessageReceive(e) {\n            if (!e.data.sender || e.data.sender !== 'sf_iframe') return;\n            if (!this.isAllowedOrigin(e.origin)) return;\n\n\n            if (e.data.message === 'onHelpButtonClick' || e.data.message === 'afterMaximize') {\n                localStorage.setItem('acronis_sfchat_maximized', 1);\n                this.style = 'height: 570px; width: 400px;';\n            } else if (e.data.message === 'afterMinimize' || e.data.message === 'afterDestroy') {\n                localStorage.setItem('acronis_sfchat_maximized', 0);\n                this.style = 'height: 90px; width: 110px';\n            } else if (e.data.message === 'onLoad') {\n                const safeSliceData = JSON.parse(JSON.stringify(this.$store.state.slices.items?.['s-chat-settings'] || {}));\n                try {\n                    e?.source?.postMessage?.(\n                        {\n                            message: 'callback',\n                            sender: 'sf_chat_interpreter',\n                            sliceData: safeSliceData,\n                        },\n                        e.origin,\n                    );\n                } catch {\n                    // Avoid sentry errors\n                }\n            } else {\n                this.style = '';\n            }\n        },\n        checkEligibility() {\n            const routeEligible = pageRegex.some((reg) => reg.test(window.location.pathname));\n            const countryEligible = this.country && !countries.includes(this.country);\n\n            return countryEligible && routeEligible;\n        },\n    },\n    async serverPrefetch() {\n        if (!import.meta.env.SSR) return;\n\n        await this.$store.dispatch('slices/getSyncedData', { slice: 's-chat-settings', locale: this.locale });\n    },\n};\n</script>\n<style scoped>\n#sfchat-iframe {\n    border: none;\n    bottom: 0;\n    inset-inline-end: 0;\n    position: fixed;\n    height: 90px;\n    width: 110px;\n    z-index: 500;\n    overflow: hidden;\n}\n</style>\n","<template>\n    <div v-if=\"isReady\" class=\"fullscreen-popup\">\n        <a-button ref=\"openButton\" v-modal=\"popupId\" class=\"open-button\" />\n        <a-modal :id=\"popupId\" :is-overlay-close=\"false\">\n            <s-form-container :form=\"form\" @submit=\"isSubmitted = true; $emit('submitted')\" />\n            <a-button\n                class=\"close-button\"\n                data-micromodal-close\n                glyph=\"close\"\n                type=\"inverse\"\n                aria-label=\"Close modal\"\n                sr-only=\"Close modal\"\n                @click=\"$emit('close', isSubmitted)\"\n            />\n        </a-modal>\n    </div>\n</template>\n\n<script lang=\"ts\">\nimport { mapState } from 'vuex';\nimport AButton from '@core/components/button/button.vue';\nimport AModal from '@core/components/modal/modal.vue';\nimport Modal from '@core/directives/modal.js';\nimport form from '@core/mixins/form.js';\nimport SFormContainer from '@core/slices/pages/trial-form/components/form/form.vue';\n\nexport default {\n    name: 'FullscreenPopup',\n\n    components: {\n        AButton,\n        AModal,\n        SFormContainer,\n    },\n\n    directives: {\n        Modal,\n    },\n\n    mixins: [form],\n\n    props: {\n        data: {\n            type: Object as any,\n            required: true,\n        },\n\n        enabled: {\n            type: Boolean,\n            default: false,\n        },\n    },\n\n    emits: ['close', 'submitted'],\n\n    data: () => ({\n        form: null,\n        isReady: false,\n        isSubmitted: false,\n        popupId: 'fullscreen-popup',\n    }),\n    computed: {\n        ...mapState({\n            formSpecialOffer: (state: any) => state.slices.items?.['s-preset-form-special-offer'] || {},\n        }),\n        isCorporate() {\n            return this.data.pageAudienceId === 3 || this.data.pageAudienceId === 'corporate';\n        },\n        isConsumer() {\n            return this.data.pageAudienceId === 2 || this.data.pageAudienceId === 'consumer';\n        },\n    },\n\n    watch: {\n        enabled: {\n            handler(newValue) {\n                if (newValue) this.$refs?.openButton?.$el.click();\n            },\n            immediate: true,\n        },\n    },\n\n    mounted() {\n        if (!this.formSpecialOffer?.form) return;\n\n        this.form = this.formSpecialOffer.form;\n\n        if (this.data.title) {\n            this.form.registration.title = this.data.title;\n        }\n\n        if (this.data.ctaPrimaryText) {\n            this.form.registration.button.text = this.data.ctaPrimaryText;\n        }\n\n        if (this.data.description) {\n            this.form.registration.subtitles = [this.data.description];\n        }\n\n        if (this.data.formSubmitSuccessMessage) {\n            this.form.flow.notification.title = '';\n            this.form.flow.notification.description = [this.data.formSubmitSuccessMessage];\n        }\n\n        if (this.data.salesforceCampaignId) {\n            this.form.flow.marketo.sfdc_campaign_id = this.data.salesforceCampaignId;\n        }\n\n        if (this.isCorporate) {\n            this.form.flow.marketo.company_type = 'Corporate End-Customer';\n            this.form.flow.marketo.product_title = 'Acronis Cyber Protect';\n        }\n\n        if (this.isConsumer) {\n            this.form.flow.marketo.company_type = 'Prosumer End-Customer';\n            this.form.flow.marketo.product_title = 'Acronis True Image';\n        }\n\n        this.form.registration.fields = this.form.registration.fields.filter((item: any) => {\n            if (this.isCorporate && item.isConsumer) return false;\n            if (this.isConsumer && item.isCorporate) return false;\n            return true;\n        });\n\n        this.form.flow.marketo.utm_term = this.data.id;\n\n        this.isReady = true;\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.fullscreen-popup {\n    .open-button {\n        display: none;\n    }\n}\n\n#fullscreen-popup {\n    .close-button {\n        padding: 0;\n        inset-inline-end: 0;\n        top: -40px;\n        position: absolute;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        width: 32px;\n        height: 32px;\n        border: 1px solid white;\n        border-radius: 50%;\n        cursor: pointer;\n\n        @media (--viewport-tablet) {\n            top: 0;\n            inset-inline-end: -48px;\n        }\n\n        :deep(.a-button__glyph) {\n            fill: white;\n            margin: 0;\n        }\n    }\n    &.a-modal {\n        :deep(.close),\n        :deep(.close-mobile) {\n            display: none;\n        }\n        :deep(.a-modal__content) {\n            width: auto;\n        }\n    }\n\n    :deep(.s-form-container) {\n        margin: 0;\n\n        @media (--viewport-desktop) {\n            width: 648px;\n        }\n    }\n\n    :deep(.notification) {\n        padding: 96px 90px;\n        border-radius: 4px;\n\n        b {\n            @mixin title-accent;\n            display: block;\n            margin: 16px 0 0;\n            color: var(--av-nav-primary);\n        }\n\n        .a-glyph {\n            width: 85px;\n            height: 76px;\n        }\n    }\n}\n</style>\n","<template>\n    <div class=\"acr-pb-wrapper\" :class=\"{ shown: enabled }\">\n        <div class=\"wrapper\">\n            <header class=\"header\">\n                <a-picture :link=\"imageId\" is-background />\n                <div class=\"title\" v-html=\"title\" />\n            </header>\n            <main>\n                <div class=\"description\" v-html=\"description\" />\n                <div class=\"buttons\">\n                    <a-button\n                        v-if=\"ctaPrimaryText && ctaPrimaryUrl\"\n                        :to=\"ctaPrimaryUrl\"\n                        :text=\"ctaPrimaryText\"\n                        type=\"action\"\n                        :event=\"getGAEvent(ctaPrimaryUrl)\"\n                        @click=\"$emit('ctaButtonClick')\"\n                    />\n                    <a-button\n                        v-if=\"ctaAuxiliaryText && ctaAuxiliaryUrl\"\n                        :to=\"ctaAuxiliaryUrl\"\n                        :text=\"ctaAuxiliaryText\"\n                        type=\"main\"\n                        :event=\"getGAEvent(ctaAuxiliaryUrl)\"\n                        @click=\"$emit('ctaButtonClick')\"\n                    />\n                </div>\n            </main>\n        </div>\n        <div class=\"close\" @click=\"$emit('closeButtonClick')\">\n            <a-glyph class=\"close-icon\" name=\"times-24\" />\n        </div>\n    </div>\n</template>\n\n<script>\nimport AButton from '@core/components/button/button.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport APicture from '@core/components/picture/picture.vue';\nimport breakpoint from '@core/mixins/breakpoint.js';\n\nexport default {\n    name: 'SPopup',\n    components: {\n        APicture,\n        AButton,\n        AGlyph,\n    },\n    mixins: [breakpoint],\n    props: {\n        enabled: {\n            type: Boolean,\n            required: true,\n        },\n        title: {\n            type: String,\n            required: true,\n        },\n        description: {\n            type: String,\n            required: true,\n        },\n        imageId: {\n            type: String,\n            required: true,\n        },\n        ctaPrimaryUrl: {\n            type: String,\n            required: true,\n        },\n        ctaPrimaryText: {\n            type: String,\n            required: true,\n        },\n        ctaAuxiliaryUrl: {\n            type: String,\n            default: undefined,\n        },\n        ctaAuxiliaryText: {\n            type: String,\n            default: undefined,\n        },\n    },\n    emits: ['closeButtonClick', 'ctaButtonClick'],\n    methods: {\n        getGAEvent(link) {\n            return {\n                event: 'Acronis',\n                category: 'Popup',\n                action: 'Clicked',\n                label: link || '[no label]',\n                context: 'click',\n                content: this.title,\n                location: 'bottom popup',\n            };\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.acr-pb-wrapper {\n    position: fixed;\n    inset-inline-start: 24px;\n    bottom: -480px;\n    max-width: 300px;\n\n    /* WEB-43924 why do we use 499 here? */\n    z-index: 499;\n    opacity: 0;\n    transition: all 0.5s;\n    animation: pb-slide-bottom 0.5s ease-in-out alternate both;\n    &.shown {\n        bottom: 16px;\n        opacity: 1;\n        animation: pb-slide-top 0.5s ease-in-out alternate both;\n    }\n    .wrapper {\n        border-radius: 4px;\n        border: 1px solid var(--av-nav-secondary);\n        box-shadow: var(--av-shadow-regular);\n        overflow: hidden;\n        .header {\n            position: relative;\n            display: flex;\n            align-items: center;\n            height: 125px;\n            width: 300px;\n            background: var(--av-nav-primary);\n            border-bottom: 1px solid var(--av-nav-secondary);\n            :deep(img) {\n                object-fit: cover;\n            }\n\n            .title {\n                position: relative;\n                margin-inline-start: 16px;\n                max-width: 160px;\n                @mixin lead;\n                font-weight: 700;\n                color: var(--av-inversed-primary);\n                span {\n                    @mixin body;\n                    display: block;\n                    line-height: 20px;\n                    font-weight: 400;\n                }\n            }\n        }\n        main {\n            background: var(--av-nav-primary);\n            padding: 16px;\n            .description {\n                @mixin body;\n                line-height: 20px;\n                margin-bottom: 16px;\n                color: var(--av-inversed-primary);\n            }\n            .buttons {\n                display: flex;\n                align-items: center;\n                flex-flow: row wrap;\n                gap: 16px;\n                :deep(.a-button) {\n                    padding: 8px 16px;\n                    font-weight: 700;\n                }\n            }\n        }\n    }\n    .close {\n        position: absolute;\n        width: 26px;\n        height: 26px;\n        top: 0;\n        inset-inline-end: -32px;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        cursor: pointer;\n        background: var(--av-inversed-primary);\n        border-radius: 50%;\n        padding: 3px;\n\n        :deep(.a-glyph) {\n            width: 24px;\n            height: 24px;\n        }\n    }\n    @keyframes pb-slide-top {\n        0% {\n            transform: translateY(150%);\n        }\n        40% {\n            scale: 1.4;\n        }\n        80% {\n            scale: 1.2;\n        }\n        100% {\n            scale: 1;\n            transform: translateY(0%);\n        }\n    }\n    @keyframes pb-slide-bottom {\n        0% {\n            scale: 1;\n            transform: translateY(0%);\n        }\n        80% {\n            scale: 0.6;\n        }\n        40% {\n            scale: 0.4;\n        }\n        100% {\n            transform: translateY(150%);\n            scale: 0;\n        }\n    }\n}\n</style>\n","<template>\n    <div v-if=\"!isMobile && isReady && hasPopup\">\n        <fullscreen-popup\n            v-if=\"isFullscreen\"\n            :data=\"popup\"\n            :enabled=\"enabled\"\n            @close=\"onFullscreenClose\"\n            @submitted=\"onFullscreenSubmitted\"\n        />\n        <popup\n            v-else-if=\"hasEnoughSpace && enabled && !temporarilyHidden\"\n            v-bind=\"popup\"\n            :enabled=\"enabled\"\n            @closeButtonClick=\"onClose\"\n            @ctaButtonClick=\"closePopup\"\n        />\n    </div>\n</template>\n\n<script lang=\"ts\">\nimport { throttle } from 'lodash-es';\nimport { mapState } from 'vuex';\nimport breakpoint from '@core/mixins/breakpoint.js';\nimport { LOCALE_DEFAULT } from '@model/const/locales';\nimport FullscreenPopup from './fullscreen-popup.vue';\nimport Popup from './popup.vue';\n\nconst FULLSCREEN_DISPLAY_DELAY_MS = 1000 * 20; // 20 seconds\nconst FULLSCREEN_COOLDOWN_MS = 1000 * 60 * 60 * 24 * 15; // 15 days\n\nexport default {\n    components: { Popup, FullscreenPopup },\n    mixins: [breakpoint],\n    props: {\n        delay: {\n            type: Number,\n            default: 10000,\n        },\n    },\n    data: () => ({\n        session: {\n            shown: 'acronis_pb_shown',\n        },\n        local: {\n            visible: 'acronis_pb_visible',\n            closed: 'acronis_pb_banners',\n            fsReEnable: 'acronis_pb_fs_re_enable',\n            fsSubmitted: 'acronis_pb_fs_submitted',\n        },\n        viewedBannerIds: [],\n        temporarilyHidden: false,\n        enabled: false,\n        hasEnoughSpace: true,\n        timerId: null,\n        selectedBannerIndex: -1,\n        isReady: false,\n    }),\n    computed: {\n        ...mapState({\n            productID: (state) => state.pages?.page.product_id,\n            promotions: (state: any) => state.promotions?.data || [],\n        }),\n        popups() {\n            return this.$store.state.popup.data;\n        },\n        hasPopup() {\n            return Boolean(this.popups.length);\n        },\n        popup() {\n            return this.popups[this.selectedBannerIndex];\n        },\n        isFullscreen() {\n            const compare = (item: any) => !item.is_for_emails_only && item.product_id === this.productID;\n            const promotionItem = this.promotions.find(compare) || {};\n\n            if (promotionItem.discount) {\n                return false;\n            }\n\n            return this.popup.hasForm;\n        },\n        isHomePage() {\n            return this.$route?.path === `/${this.$store.state.geolocation.finalLocale}/`;\n        },\n        hasViewedBanner() {\n            return this.viewedBannerIds.includes(this.popup.id);\n        },\n    },\n    mounted() {\n        if (!this.popups.length) return;\n\n        if (typeof localStorage !== 'object') return;\n\n        this.selectedBannerIndex = Math.floor(Math.random() * this.popups.length);\n\n        this.viewedBannerIds = JSON.parse(localStorage.getItem(this.local.closed)) || [];\n\n        this.scrollHandler = throttle(() => {\n            this.onLayoutChange();\n            this.handleTemporaryHideOnScroll();\n        }, 150);\n\n\n        this.resizeHandler = throttle(this.onLayoutChange, 200);\n\n        window.addEventListener('load', this.onLayoutChange, { passive: true });\n        window.addEventListener('scroll', this.scrollHandler, { passive: true });\n        window.addEventListener('resize', this.resizeHandler, { passive: true });\n\n        if (this.isFullscreen) {\n            const isSubmitted = localStorage.getItem(`${this.local.fsSubmitted}_${this.popup.id}`) || false;\n            const allowedTime = Number(localStorage.getItem(`${this.local.fsReEnable}_${this.popup.id}`) || 0);\n\n            if (!isSubmitted && Date.now() >= allowedTime) {\n                localStorage.removeItem(`${this.local.fsReEnable}_${this.popup.id}`);\n                clearTimeout(this.timerId);\n                this.timerId = setTimeout(this.displayPopup, FULLSCREEN_DISPLAY_DELAY_MS);\n            }\n        } else if (!this.hasViewedBanner) {\n            if (this.isHomePage) {\n                window.addEventListener('scroll', this.displayPopupAfterScroll, { passive: true });\n            } else {\n                clearTimeout(this.timerId);\n                this.timerId = setTimeout(this.displayPopup, this.delay);\n            }\n        }\n\n        this.isReady = true;   \n    },\n    beforeUnmount() {\n        clearTimeout(this.timerId);\n\n        window.removeEventListener('load', this.onLayoutChange);\n        window.removeEventListener('resize', this.resizeHandler);\n        window.removeEventListener('scroll', this.scrollHandler);\n        window.removeEventListener('scroll', this.displayPopupAfterScroll);\n\n        this.scrollHandler.cancel?.();\n        this.resizeHandler.cancel?.();\n    },\n    methods: {\n        handleTemporaryHideOnScroll() {\n            if (this.isFullscreen || !this.enabled) return;\n\n            const scrollY = window.scrollY || window.pageYOffset;\n            const threshold = 600;\n\n            /*\n                We can shorten here to this.temporarilyHidden = scrollY < threshold\n                But I think this will set the value on each scroll and that's why I tried to avoid that.\n            */\n\n            if (scrollY < threshold && !this.temporarilyHidden) {\n                this.temporarilyHidden = true;\n            } else if (scrollY >= threshold && this.temporarilyHidden) {\n                this.temporarilyHidden = false;\n            }\n        },\n        onLayoutChange() {\n            const pageYOffset = window.pageYOffset;\n            const scrollHeight = document.body.scrollHeight;\n            const clientHeight = document.body.clientHeight;\n\n            this.hasEnoughSpace = clientHeight > 480;\n            if (!this.isFullscreen && pageYOffset > scrollHeight / 2) this.displayPopup();\n        },\n        closePopup() {\n            this.disable();\n        },\n        onFullscreenSubmitted() {\n            this.sendEventsToGA({ action: 'Submitted', label: 'Discount' });\n            localStorage.setItem(`${this.local.fsSubmitted}_${this.popup.id}`, '1');\n        },\n        onFullscreenClose(isSubmitted) {\n            if (isSubmitted) {\n                localStorage.setItem(`${this.local.fsSubmitted}_${this.popup.id}`, '1');\n            } else {\n                localStorage.setItem(\n                    `${this.local.fsReEnable}_${this.popup.id}`,\n                    `${Date.now() + FULLSCREEN_COOLDOWN_MS}`,\n                );\n                this.sendEventsToGA({ action: 'Closed' });\n            }\n            this.closePopup();\n        },\n        onClose() {\n            this.sendEventsToGA({ action: 'Closed' });\n            this.closePopup();\n        },\n        disable() {\n            this.enabled = false;\n            this.viewedBannerIds.push(this.popup.id);\n\n            localStorage.removeItem(this.local.visible);\n            localStorage.setItem(this.local.closed, JSON.stringify(this.viewedBannerIds));\n\n            clearTimeout(this.timerId);\n        },\n        enable() {\n            if (this.hasViewedBanner) return;\n            this.enabled = true;\n            localStorage.setItem(this.local.visible, '1');\n            clearTimeout(this.timerId);\n        },\n        displayPopupAfterScroll() {\n            if (this.isFullscreen) {\n                return;\n            }\n\n            const pageHeight = document.body.getBoundingClientRect().height;\n            const halfPage = pageHeight / 2;\n\n            if (window.scrollY >= halfPage) {\n                this.displayPopup();\n                window.removeEventListener('scroll', this.displayPopupAfterScroll);\n            }\n        },\n        displayPopup() {\n            if (this.enabled || this.hasViewedBanner) return;\n\n            sessionStorage.setItem(this.session.shown, '1');\n            this.sendEventsToGA({ action: 'Shown' });\n            this.enable();\n        },\n\n        sendEventsToGA(incomingGA) {\n            const event = {\n                event: 'Acronis',\n                eventCategory: incomingGA.category || 'Popup',\n                eventAction: incomingGA.action || '',\n                eventLabel: incomingGA.label || this.popup?.ctaPrimaryUrl || window.location.href,\n                eventContext: incomingGA.context || '',\n                eventContent: incomingGA.content || this.popup.title,\n                eventLocation: incomingGA.location || `${this.isFullscreen ? 'fullscreen' : 'bottom'} popup`,\n                eventButton: incomingGA.button || '',\n            };\n\n            window.dataLayer = window.dataLayer || [];\n            window.dataLayer.push(event);\n        },\n    },\n\n    async serverPrefetch() {\n        if (!import.meta.env.SSR) return;\n\n        const locale = this.$store.state.geolocation.finalLocale || LOCALE_DEFAULT;\n        await Promise.all([\n            this.$store.dispatch('slices/getSyncedData', { slice: 's-list-form-elements', locale }),\n            this.$store.dispatch('slices/getSyncedData', { slice: 's-preset-form-special-offer', locale }),\n        ]);\n    },\n};\n</script>\n","import { ref, computed, onMounted, onBeforeUnmount } from 'vue';\n\ninterface CountdownOptions {\n    startDate: string;\n    labels: {\n        days: string;\n        hours: string;\n        minutes: string;\n        seconds: string;\n    };\n}\n\nexport function useCountdown(options: CountdownOptions) {\n    const eventStarted = ref(false);\n    const timerData = ref([]);\n    const timerId = ref<number | null>(null);\n\n    const startTs = computed(() => {\n        const normalizedStartDate = options.startDate.replace(' ', 'T'); // For old iOS Safari\n\n        const utcOffset = new Date().getTimezoneOffset() / 60;\n        const utcOffsetDate = new Date(normalizedStartDate);\n\n        utcOffsetDate.setHours(\n            utcOffsetDate.getHours() - utcOffset,\n        );\n\n        return utcOffsetDate.getTime();\n    });\n\n    function toDhmsFormat(ms: number) {\n        const days = Math.floor(ms / (24 * 60 * 60 * 1000));\n        const daysms = ms % (24 * 60 * 60 * 1000);\n\n        const hours = Math.floor(daysms / (60 * 60 * 1000));\n        const hoursms = ms % (60 * 60 * 1000);\n\n        const minutes = Math.floor(hoursms / (60 * 1000));\n        const minutesms = ms % (60 * 1000);\n\n        const sec = Math.floor(minutesms / 1000);\n\n        const pad = (v: number) => (v >= 10 ? v : `0${v}`);\n\n        return [\n            { value: pad(days), unit: options.labels.days, class: 'timer-value' },\n            { separator: true, class: 'timer-separator' },\n\n            { value: pad(hours), unit: options.labels.hours, class: 'timer-value' },\n            { separator: true, class: 'timer-separator' },\n\n            { value: pad(minutes), unit: options.labels.minutes, class: 'timer-value' },\n            { separator: true, class: 'timer-separator' },\n\n            { value: pad(sec), unit: options.labels.seconds, class: 'timer-value' },\n        ];\n    }\n\n    function tick() {\n        if (eventStarted.value) return;\n\n        const msLeft = startTs.value - Date.now();\n\n        timerData.value = toDhmsFormat(msLeft);\n\n        if (msLeft > 0) {\n            timerId.value = window.setTimeout(tick, 1000);\n        } else {\n            eventStarted.value = true;\n        }\n    }\n\n    onMounted(() => {\n        timerData.value = toDhmsFormat(\n            startTs.value - Date.now(),\n        );\n\n        tick();\n    });\n\n    onBeforeUnmount(() => {\n        if (timerId.value) clearTimeout(timerId.value);\n    });\n\n    return {\n        timerData,\n        eventStarted,\n    };\n}\n","export function normalizeRibbonBackgroundImage(options = {}) {\n    const backgroundImage = options.backgroundImage;\n    const backgroundImageMobileId = options.backgroundImageMobileId;\n    const backgroundImageDesktopId = options.backgroundImageDesktopId;\n\n    const image = backgroundImage && typeof backgroundImage === 'object' ? backgroundImage : {};\n\n    const mobile = backgroundImageMobileId || image.mobile || null;\n    const desktop = backgroundImageDesktopId || image.desktop || null;\n    const tablet = backgroundImageDesktopId || image.tablet || desktop || mobile || null;\n\n    const normalized = {\n        mobile: mobile || tablet || desktop || null,\n        tablet: tablet || desktop || mobile || null,\n        desktop: desktop || tablet || mobile || null,\n    };\n\n    return Object.values(normalized).some(Boolean) ? normalized : null;\n}\n\nexport function getRibbonTarget(linkUrl) {\n    if (!linkUrl) return undefined;\n\n    return linkUrl.includes('#launch') ? '_self' : '_blank';\n}\n\nexport function getRibbonStartDate(props = {}) {\n    return props.countdownTargetDate || props.startDate || null;\n}\n\nexport function hasRibbonCountdown(props = {}) {\n    return Boolean(getRibbonStartDate(props));\n}\n","<template>\n    <component\n        :is=\"wrapperTag\"\n        class=\"s-ribbon s-ribbon-countdown\"\n        :class=\"className\"\n        v-bind=\"wrapperProps\"\n    >\n        <a-picture\n            v-if=\"normalizedBackgroundImage\"\n            class=\"background\"\n            :background=\"normalizedBackgroundImage\"\n            fit=\"cover\"\n            is-eager\n            is-background\n        />\n        <div class=\"a-container content\">\n            <div class=\"text-wrapper\" :class=\"{ 'promo-ended': eventStarted }\">\n                <v-clamp\n                    v-if=\"primaryLabel\"\n                    class=\"label primary\"\n                    tag=\"div\"\n                    :max-lines=\"2\"\n                    :autoresize=\"true\"\n                >\n                    {{ primaryLabel }}\n                </v-clamp>\n                <v-clamp\n                    v-if=\"secondaryLabel\"\n                    class=\"label secondary\"\n                    tag=\"div\"\n                    :max-lines=\"2\"\n                    :autoresize=\"true\"\n                >\n                    {{ secondaryLabel }}\n                </v-clamp>\n            </div>\n            <div v-if=\"!eventStarted\" class=\"countdown-wrapper\">\n                <div class=\"timer-values\">\n                    <div\n                        v-for=\"(item, index) in timerData\"\n                        :key=\"index\"\n                        :class=\"['timer-item', item.class]\"\n                    >\n                        <template v-if=\"item.separator\">\n                            <span class=\"timer-separator\">:</span>\n                        </template>\n                        <template v-else>\n                            <div class=\"timer-digit\">\n                                {{ item.value }}\n                            </div>\n                            <div class=\"timer-unit\">\n                                {{ item.unit }}\n                            </div>\n                        </template>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </component>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed } from 'vue';\nimport VClamp from 'vue3-clamp';\nimport DynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport APicture from '@core/components/picture/picture.vue';\nimport { useCountdown } from '@core/composables/useCountdown';\nimport {\n    getRibbonStartDate,\n    getRibbonTarget,\n    normalizeRibbonBackgroundImage,\n} from './utils.js';\n\nconst props = defineProps({\n    labelPrimary: {\n        type: String,\n        default: '',\n    },\n    labelAuxiliary: {\n        type: String,\n        default: null,\n    },\n    labelCta: {\n        type: String,\n        default: null,\n    },\n    linkUrl: {\n        type: String,\n        default: null,\n    },\n    styleName: {\n        type: String,\n        default: 'yellow',\n    },\n    backgroundImage: {\n        type: Object,\n        default: undefined,\n    },\n    backgroundImageMobileId: {\n        type: String,\n        default: '',\n    },\n    backgroundImageDesktopId: {\n        type: String,\n        default: '',\n    },\n    startDate: {\n        type: String,\n        default: null,\n    },\n    countdownTargetDate: {\n        type: String,\n        default: null,\n    },\n    promoEndedTitle: {\n        type: String,\n        default: null,\n    },\n    promoEndedLead: {\n        type: String,\n        default: null,\n    },\n    days: {\n        type: String,\n        default: 'days',\n    },\n    hours: {\n        type: String,\n        default: 'hours',\n    },\n    minutes: {\n        type: String,\n        default: 'minutes',\n    },\n    seconds: {\n        type: String,\n        default: 'seconds',\n    },\n});\n\nconst resolvedStartDate = computed(() => getRibbonStartDate(props) || new Date().toISOString());\nconst normalizedBackgroundImage = computed(() => normalizeRibbonBackgroundImage(props));\nconst hasCtaLink = computed(() => Boolean(props.labelCta && props.linkUrl));\nconst isWrappedWithLink = computed(() => Boolean(props.linkUrl) && !hasCtaLink.value);\nconst wrapperTag = computed(() => (isWrappedWithLink.value ? DynamicLink : 'div'));\nconst linkTarget = computed(() => getRibbonTarget(props.linkUrl));\n\nconst wrapperProps = computed(() => {\n    if (!isWrappedWithLink.value) return {};\n\n    return {\n        to: props.linkUrl,\n        target: linkTarget.value,\n        event: {\n            location: 'top ribbon',\n            content: props.labelPrimary,\n        },\n    };\n});\n\nconst { timerData, eventStarted } = useCountdown({\n    get startDate() {\n        return resolvedStartDate.value;\n    },\n    labels: {\n        get days() {\n            return props.days;\n        },\n        get hours() {\n            return props.hours;\n        },\n        get minutes() {\n            return props.minutes;\n        },\n        get seconds() {\n            return props.seconds;\n        },\n    },\n});\n\nconst primaryLabel = computed(() => (\n    eventStarted.value\n        ? props.promoEndedTitle || props.labelPrimary\n        : props.labelPrimary\n));\nconst secondaryLabel = computed(() => (\n    eventStarted.value\n        ? props.promoEndedLead || props.labelAuxiliary\n        : props.labelAuxiliary\n));\n\nconst className = computed(() => ({\n    [props.styleName]: true,\n    'is-link': isWrappedWithLink.value,\n    'has-background-image': Boolean(normalizedBackgroundImage.value),\n}));\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-ribbon-countdown {\n    position: relative;\n    z-index: 401;\n    display: block;\n    width: 100%;\n    flex-shrink: 0;\n    overflow: hidden;\n    transition: background-color linear 0.2s;\n\n    .background {\n        position: absolute;\n        inset: 0;\n        z-index: 0;\n    }\n\n    &::after {\n        content: '';\n        position: absolute;\n        inset: 0;\n        z-index: 1;\n        pointer-events: none;\n        background: transparent;\n        transition: background-color linear 0.2s;\n    }\n\n    .content {\n        position: relative;\n        z-index: 2;\n        display: flex;\n        box-sizing: border-box;\n        flex-direction: column;\n        justify-content: center;\n        width: 100%;\n        padding: 12px 16px;\n        color: var(--av-nav-primary);\n\n        @media (--viewport-mobile-wide) {\n            align-items: center;\n            padding: 12px 32px;\n        }\n\n        @media (--viewport-tablet) {\n            flex-direction: row;\n        }\n\n        @media (--viewport-desktop) {\n            padding: 6px 32px;\n        }\n\n        @media (--viewport-desktop-wide) {\n            padding: 6px 64px;\n        }\n\n        @media (--viewport-desktop-large) {\n            padding: 6px 0;\n        }\n\n    }\n\n    .text-wrapper {\n        display: flex;\n        flex-direction: column;\n        min-width: 0;\n        @media (--viewport-tablet) {\n            flex: 1 1 auto;\n        }\n    }\n\n    .label {\n        min-width: 0;\n        text-align: center;\n        margin-bottom: 16px;\n        @media (--viewport-tablet) {\n            text-align: start;\n            margin: 0;\n        }\n        &.primary {\n            @mixin lead;\n            margin-bottom: 8px;\n            @media (--viewport-mobile-wide) {\n                margin: 0;\n            }\n            @media (--viewport-desktop) {\n                @mixin title;\n            }\n        }\n\n        &.secondary {\n            @mixin descriptor;\n            font-weight: 300;\n\n            @media (--viewport-desktop) {\n                @mixin paragraph;\n                line-height: 20px;\n            }\n        }\n    }\n\n    .countdown-wrapper {\n        display: flex;\n        justify-content: center;\n        width: 100%;\n        align-items: center;\n        margin: 5px 0;\n\n        @media (--viewport-mobile-wide) {\n            margin: 0;\n        }\n\n        @media (--viewport-tablet) {\n            width: auto;\n            margin-inline-start: auto;\n        }\n    }\n\n    .timer-values {\n        display: flex;\n        align-items: flex-start;\n        text-align: center;\n        gap: 0 12px;\n        margin-bottom: 8px;\n    }\n\n    .timer-digit,\n    .timer-separator {\n        @mixin title;\n        @media (--viewport-desktop) {\n            @mixin display;\n        }\n    }\n\n    .timer-unit {\n        font-size: 8px;\n        line-height: 10px;\n        font-weight: 800;\n        text-transform: uppercase;\n        @media (--viewport-desktop) {\n            font-size: 10px;\n            line-height: 12px;\n        }\n    }\n\n    &.blue,\n    &.dark-blue,\n    &.navy,\n    &.red,\n    &.mid-blue,\n    &.gradient,\n    &.ai-gradient {\n        .content,\n        .cta {\n            color: var(--av-inversed-primary);\n            fill: var(--av-inversed-primary);\n        }\n    }\n\n    &.is-link {\n        cursor: pointer;\n\n        &:hover::after {\n            background: rgba(17, 24, 39, 0.08);\n        }\n\n        &:focus-visible {\n            outline: 3px solid var(--av-fixed-focus);\n            outline-offset: -3px;\n        }\n    }\n\n    .cta:hover {\n        :deep(.a-link__content) {\n            color: var(--av-link-primary-hover);\n        }\n    }\n\n    .cta:active {\n        :deep(.a-link__content) {\n            color: var(--av-link-primary-active);\n        }\n    }\n\n    &.blue,\n    &.ai-purple,\n    &.dark-blue,\n    &.navy,\n    &.red,\n    &.mid-blue,\n    &.gradient,\n    &.ai-gradient {\n        &.is-link:hover::after {\n            background: rgba(255, 255, 255, 0.12);\n        }\n\n        .cta:hover {\n            :deep(.a-link__content) {\n                color: var(--av-link-inversed-hover);\n            }\n        }\n\n        .cta:active {\n            :deep(.a-link__content) {\n                color: var(--av-link-inversed-active);\n            }\n        }\n\n        .cta:focus-visible {\n            :deep(.a-link__content) {\n                color: var(--av-link-inversed);\n            }\n        }\n    }\n\n    &.yellow {\n        background: var(--av-fixed-warning-light);\n    }\n\n    &.blue {\n        background: var(--av-nav-secondary);\n    }\n\n    &.ai-purple {\n        background: linear-gradient(75deg, #1F379C 0%, #3849E0 50%, #FC2DF1 100%);\n    }\n\n    &.gradient {\n        background: linear-gradient(90.05deg, #05245A 3.92%, #2C40C0 44.27%, #EC0004 99.99%);\n    }\n\n    &.dark-blue,\n    &.navy {\n        background: var(--av-nav-primary);\n    }\n\n    &.green,\n    &.light-green {\n        background: var(--av-fixed-success-light);\n    }\n\n    &.light-blue {\n        background: var(--av-fixed-info-accent);\n    }\n\n    &.red {\n        background: rgba(193, 43, 34, 1);\n    }\n\n    &.mid-blue {\n        background: rgba(33, 89, 209, 1);\n    }\n\n    &.ai-gradient {\n        background: linear-gradient(75deg, #1F379C 0%, #3849E0 50%, #FC2DF1 100%);\n    }\n}\n</style>\n","<template>\n    <component\n        :is=\"wrapperTag\"\n        class=\"s-ribbon\"\n        :class=\"className\"\n        v-bind=\"wrapperProps\"\n    >\n        <a-picture\n            v-if=\"normalizedBackgroundImage\"\n            class=\"background\"\n            :background=\"normalizedBackgroundImage\"\n            fit=\"cover\"\n            is-eager\n            is-background\n        />\n        <div class=\"a-container content\">\n            <v-clamp\n                v-if=\"labelPrimary\"\n                class=\"label primary\"\n                tag=\"div\"\n                :max-lines=\"2\"\n                :autoresize=\"true\"\n                @clampchange=\"onClampChange($event, 'first')\"\n            >\n                {{ labelPrimary }}\n            </v-clamp>\n            <v-clamp\n                v-if=\"labelAuxiliary\"\n                class=\"label secondary\"\n                tag=\"div\"\n                :max-lines=\"2\"\n                :autoresize=\"true\"\n                @clampchange=\"onClampChange($event, 'second')\"\n            >\n                {{ labelAuxiliary }}\n            </v-clamp>\n            <a-glyph\n                v-if=\"showStandaloneIcon\"\n                :class=\"iconPosition\"\n                :name=\"iconName\"\n                size=\"m\"\n                class=\"icon\"\n            />\n        </div>\n    </component>\n</template>\n\n<script>\nimport VClamp from 'vue3-clamp';\nimport DynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport APicture from '@core/components/picture/picture.vue';\nimport {\n    getRibbonTarget,\n    normalizeRibbonBackgroundImage,\n} from './utils.js';\n\nexport default {\n    name: 'SRibbon',\n    components: {\n        APicture,\n        AGlyph,\n        VClamp,\n        DynamicLink,\n    },\n    props: {\n        labelPrimary: {\n            type: String,\n            default: '',\n        },\n        labelAuxiliary: {\n            type: String,\n            default: null,\n        },\n        linkUrl: {\n            type: String,\n            default: null,\n        },\n        iconPosition: {\n            type: String,\n            default: 'start',\n        },\n        iconName: {\n            type: String,\n            default: null,\n        },\n        styleName: {\n            type: String,\n            default: 'blue',\n        },\n        backgroundImage: {\n            type: Object,\n            default: undefined,\n        },\n        backgroundImageMobileId: {\n            type: String,\n            default: null,\n        },\n        backgroundImageDesktopId: {\n            type: String,\n            default: null,\n        },\n    },\n    data: () => ({\n        isLabelClamped: {\n            first: true,\n            second: true,\n        },\n    }),\n    computed: {\n        className() {\n            const firstLabelClamped = this.labelPrimary && this.isLabelClamped.first;\n            const secondLabelClamped = this.labelAuxiliary && this.isLabelClamped.second;\n\n            return {\n                [this.styleName]: true,\n                'is-link': this.isWrappedWithLink,\n                'is-clamped': firstLabelClamped || secondLabelClamped,\n                'has-background-image': Boolean(this.normalizedBackgroundImage),\n            };\n        },\n        isClickable() {\n            return Boolean(this.linkUrl);\n        },\n        isWrappedWithLink() {\n            return this.isClickable;\n        },\n        wrapperTag() {\n            return this.isWrappedWithLink ? DynamicLink : 'div';\n        },\n        wrapperProps() {\n            if (!this.isWrappedWithLink) return {};\n\n            return {\n                to: this.linkUrl,\n                target: this.linkTarget,\n                event: {\n                    location: 'top ribbon',\n                    content: this.labelPrimary,\n                },\n            };\n        },\n        linkTarget() {\n            return getRibbonTarget(this.linkUrl);\n        },\n        showStandaloneIcon() {\n            return Boolean(this.iconName);\n        },\n        normalizedBackgroundImage() {\n            return normalizeRibbonBackgroundImage(this);\n        },\n    },\n    methods: {\n        onClampChange(clamped, label) {\n            this.isLabelClamped[label] = clamped;\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-ribbon {\n    position: relative;\n    z-index: 401; /* to be above s-main-header */\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    width: 100%;\n    background-size: cover;\n    background-position: center;\n    background-repeat: no-repeat;\n    transition: background-color linear 0.2s;\n    min-height: 48px;\n    flex-shrink: 0;\n    overflow: hidden;\n\n    @media (--viewport-tablet) {\n        min-height: 56px;\n    }\n\n    .background {\n        position: absolute;\n        inset: 0;\n        z-index: 0;\n    }\n\n    &:focus {\n            outline: 3px solid var(--av-inversed-lighter);\n            outline-offset: -3px;\n        }\n\n    .content {\n        @mixin caption-accent;\n        position: relative;\n        z-index: 2;\n        width: 100%;\n        color: var(--av-nav-primary);\n        transition: background linear 0.2s;\n        column-gap: 16px;\n        padding-block: 8px;\n\n        @media (--viewport-tablet) {\n            padding-block: 12px;\n            flex-direction: row;\n            align-items: center;\n            display: flex;\n            justify-content: center;\n        }\n\n        @media (--viewport-desktop) {\n            @mixin body-accent;\n        }\n\n        @media (--viewport-desktop-large) {\n            padding-inline: 0;\n        }\n    }\n\n    .label {\n        margin-inline-end: 2px;\n\n        &.primary {\n            order: 2;\n            margin-inline-start: 0;\n        }\n\n        &.secondary {\n            order: 4;\n        }\n    }\n\n    .icon {\n        fill: var(--av-nav-primary);\n        display: none;\n        flex-shrink: 0;\n        margin: 0;\n        max-width: 24px;\n        max-height: 24px;\n\n        @media (--viewport-tablet) {\n            display: block;\n        }\n\n        &.start {\n            order: 1;\n        }\n\n        &.divider {\n            order: 3;\n        }\n\n        &.end {\n            margin-inline-end: 0;\n            order: 5;\n        }\n    }\n\n    &.yellow {\n        background: var(--av-fixed-warning-light);\n        &:hover {\n            background: var(--av-fixed-warning);\n        }\n    }\n\n    &.blue {\n        background: var(--av-nav-secondary);\n        &:hover {\n            background: var(--av-fixed-info-dark);\n        }\n    }\n\n    &.ai-purple {\n        background: linear-gradient(75deg, #1F379C 0%, #3849E0 50%, #FC2DF1 100%);\n    }\n\n    &.gradient {\n        background: linear-gradient(90.05deg, #05245A 3.92%, #2C40C0 44.27%, #EC0004 99.99%);\n        &:hover {\n            background: linear-gradient(90.05deg, #05245A 26.02%, #2C40C0 67.81%, #B2133D 99.99%);\n        }\n    }\n\n    &.dark-blue,\n    &.navy {\n        background: var(--av-nav-primary);\n        &:hover {\n            background: var(--av-primary-hover);\n        }\n    }\n\n    &.green,\n    &.light-green {\n        background: var(--av-fixed-success-light);\n        &:hover {\n            background: var(--av-fixed-success);\n        }\n    }\n\n    &.light-blue {\n        background: var(--av-fixed-info-accent);\n        &:hover {\n            background: var(--av-fixed-info-light);\n        }\n        &:focus {\n            outline: 3px solid var(--av-brand-secondary-light);\n            outline-offset: -3px;\n        }\n    }\n\n    &.red {\n        background: rgba(193, 43, 34, 1);\n        &:hover {\n            background: var(--av-fixed-danger);\n        }\n    }\n\n    &.mid-blue {\n        background: rgba(33, 89, 209, 1);\n        &:hover {\n            background: var(--av-fixed-info-dark);\n        }\n    }\n\n    &.ai-gradient {\n        background: linear-gradient(75deg, #1F379C 0%, #3849E0 50%, #FC2DF1 100%);\n        &:hover {\n            background: linear-gradient(75deg, #142FA0 20%, #E90DDD 100%);\n        }\n    }\n\n    &.blue,\n    &.ai-purple,\n    &.dark-blue,\n    &.navy,\n    &.red,\n    &.mid-blue,\n    &.gradient,\n    &.ai-gradient {\n        .content,\n        .icon {\n            color: var(--av-inversed-primary);\n            fill: var(--av-inversed-primary);\n        }\n    }\n\n    &.is-clamped {\n        .label {\n            flex: 1 0 0;\n        }\n    }\n\n    &.is-link {\n        cursor: pointer;\n    }\n}\n</style>\n","<template>\n    <component :is=\"componentName\" v-if=\"ribbon\" v-bind=\"{ ...ribbon }\" />\n</template>\n\n<script>\nimport SRibbonCountdown from './ribbon-countdown.vue';\nimport SRibbon from './ribbon.vue';\nimport { hasRibbonCountdown } from './utils.js';\n\nexport default {\n    name: 'SRibbonContainer',\n    components: {\n        SRibbon,\n        SRibbonCountdown,\n    },\n    props: {\n        ribbons: {\n            type: Array,\n            required: true,\n        },\n    },\n    data() {\n        return {\n            ribbon: null,\n        };\n    },\n    computed: {\n        componentName() {\n            return hasRibbonCountdown(this.ribbon) ? 's-ribbon-countdown' : 's-ribbon';\n        },\n    },\n    mounted() {\n        if (!this.ribbons.length) return;\n        this.ribbon = this.ribbons[Math.floor(Math.random() * this.ribbons.length)];\n    },\n};\n</script>\n","export const SOLUTIONS_RESOURCE_URL = 'https://eu8-cloud.acronis.com/api/platform-web-assets/public/s3';\n","import { mapState } from 'vuex';\nimport { SOLUTIONS_RESOURCE_URL } from '@model/const/solutions';\n\nexport default {\n    data() {\n        return {\n            AVAILABLE_TAGS: {\n                NEW: {\n                    text: 'New',\n                    variant: 'success',\n                    weight: 30,\n                },\n                COMING_SOON: {\n                    text: 'Coming soon',\n                    variant: 'info',\n                    weight: 20,\n                },\n                LIGHTHOUSE: {\n                    text: 'Lighthouse',\n                    variant: 'success',\n                    weight: 10,\n                },\n                FEATURED: {\n                    text: 'Featured',\n                    variant: 'info',\n                    theme: 'dark',\n                    weight: 40,\n                },\n            },\n        };\n    },\n\n    computed: {\n        ...mapState({\n            pageSettings: (state) => state.slices.items['solutions-acronis-com-home'],\n            integrations: (state) => state.solutions.integrations,\n            currentIntegration: (state) => state.solutions.integration,\n            categories: (state) => state.solutions.categories,\n        }),\n    },\n\n    methods: {\n        prepareIntegrationFields(integration) {\n            if (!integration) return {};\n\n            return {\n                ...integration,\n                logo: `${SOLUTIONS_RESOURCE_URL}${integration.logo}`,\n                tag: this.AVAILABLE_TAGS[integration.publishing_tag] || null,\n            };\n        },\n\n        sortByTags(a, b) {\n            const aWeight = this.AVAILABLE_TAGS[a.publishing_tag]?.weight || 0;\n            const bWeight = this.AVAILABLE_TAGS[b.publishing_tag]?.weight || 0;\n            return bWeight - aWeight;\n        },\n    },\n};\n","<template>\n    <component\n        :is=\"to ? DynamicLink : 'div'\"\n        class=\"a-value-card\"\n        :to=\"to ? to : null\"\n        :class=\"className\"\n    >\n        <div\n            v-if=\"image || media\"\n            class=\"image-wrapper\"\n            :class=\"pictureClassName\"\n        >\n            <a-picture\n                v-if=\"image\"\n                class=\"image-container\"\n                :link=\"image\"\n                :alt=\"imageAlt\"\n                :fit=\"imageFit\"\n            />\n            <a-media\n                v-if=\"media\"\n                class=\"media\"\n                v-bind=\"media\"\n            />\n        </div>\n        <div class=\"content\">\n            <a-label v-if=\"label\" v-bind=\"label\">\n                {{ label?.text }}\n            </a-label>\n            <div class=\"header\">\n                <component :is=\"titleTagName\" v-if=\"title\" class=\"title\">\n                    {{ title }}\n                </component>\n                <a-icon\n                    v-if=\"icon\"\n                    class=\"icon\"\n                    :number=\"icon\"\n                    :alt=\"iconAlt || title\"\n                />\n            </div>\n            <div\n                v-if=\"text\"\n                class=\"description\"\n                :class=\"{'has-button': ctaButtons?.length}\"\n            >\n                <a-dangerous-html :content=\"text\" />\n            </div>\n\n            <div v-if=\"ctaButtons\" class=\"buttons\">\n                <a-button\n                    v-for=\"(button, index) in ctaButtons\"\n                    :key=\"index\"\n                    v-bind=\"button\"\n                />\n            </div>\n        </div>\n    </component>\n</template>\n\n<script setup>\nimport { computed } from 'vue';\nimport AButton from '@core/components/button/button.vue';\nimport { BORDER_RADIUS } from '@core/components/button/constants.js';\nimport ADangerousHtml from '@core/components/dangerous-html/dangerous-html.vue';\nimport DynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport AIcon from '@core/components/icon/icon.vue';\nimport ALabel from '@core/components/label/label.vue';\nimport AMedia from '@core/components/media/media.vue';\nimport { FIT_TYPES } from '@core/components/picture/constants.js';\nimport APicture from '@core/components/picture/picture.vue';\n\ndefineOptions({\n    name: 'AValueCard',\n    inheritAttrs: false,\n});\n\nconst props = defineProps({\n    to: {\n        type: String,\n        default: undefined,\n    },\n    media: {\n        type: Object,\n        default: undefined,\n    },\n    label: {\n        type: Object,\n        default: undefined,\n    },\n    title: {\n        type: String,\n        default: undefined,\n    },\n    text: {\n        type: String,\n        default: undefined,\n    },\n    titleTag: {\n        type: String,\n        default: 'div',\n    },\n    ctaButtons: {\n        type: Array,\n        default: null,\n    },\n    borderRadius: {\n        type: Number,\n        default: 4,\n        validator: (value) => !value || BORDER_RADIUS.includes(value),\n    },\n    centered: {\n        type: Boolean,\n        default: false,\n    },\n\n    /* Left image and icons props for backward compatibility */\n    image: {\n        type: String,\n        default: undefined,\n    },\n    imageAlt: {\n        type: String,\n        default: undefined,\n    },\n    imageFit: {\n        type: String,\n        default: 'cover',\n        validator: (val) => FIT_TYPES.includes(val),\n    },\n    icon: {\n        type: [String, Number],\n        default: '',\n    },\n    iconAlt: {\n        type: String,\n        default: '',\n    },\n});\n\nconst titleTagName = computed(() => props.titleTag);\n\nconst className = computed(() => [\n    `a-value-card_radius_${props.borderRadius}`,\n    { 'is-centered': props.centered },\n    { linked: props.to },\n    { 'with-image': Boolean(props.image) },\n]);\n\nconst pictureClassName = computed(() => [\n    { 'has-contain-fit': props.imageFit === 'contain' },\n]);\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-value-card {\n    display: flex;\n    flex-flow: column;\n    width: 100%;\n    height: 100%;\n    border: 1px solid var(--av-brand-secondary-light);\n    border-radius: var(--a-value-card-border-radius);\n    box-shadow: var(--av-shadow-small);\n    overflow: hidden;\n\n    :deep(.media-wrapper) {\n        .a-media__type__screenshot {\n            border-radius: 0;\n        }\n        .screenshot-image,\n        .a-video-card {\n            border-radius: 0;\n            border: none;\n            box-shadow: none;\n            outline: none;\n        }\n        &.has-outline {\n            &:focus-within,\n            &:focus-visible {\n                .media {\n                    outline: none;\n                    outline-offset: 0;\n                    border-radius: 0;\n                }\n            }\n        }\n    }\n\n    .image-wrapper {\n        aspect-ratio: 16 / 9;\n        background: var(--av-inversed-primary);\n        &.has-contain-fit {\n            aspect-ratio: unset;\n            height: auto;\n            max-height: 246px;\n            .image-container {\n                max-height: 246px;\n                overflow: hidden;\n            }\n            :deep(.media-wrapper) {\n                max-height: 246px;\n                overflow: hidden;\n            }\n        }\n        :deep(.a-picture__img) {\n            width: 100%;\n        }\n    }\n\n    .content {\n        display: flex;\n        flex-flow: column;\n        align-items: flex-start;\n        background: var(--av-inversed-primary);\n        padding: 24px;\n        height: 100%;\n        z-index: 2;\n        :deep(.a-label) {\n            margin-bottom: 16px;\n        }\n        .header {\n            margin-bottom: 16px;\n            display: flex;\n            align-items: flex-start;\n            justify-content: space-between;\n            .title {\n                @mixin title-accent;\n                color: var(--av-nav-primary);\n            }\n            .icon {\n                margin-inline-start: 24px;\n                width: 64px;\n                height: 64px;\n            }\n        }\n        .description {\n            @mixin paragraph;\n            color: var(--av-fixed-secondary);\n            &.has-button {\n                margin-bottom: 24px;\n            }\n        }\n        .buttons {\n            width: 100%;\n            display: flex;\n            flex-flow: column;\n            gap: 16px;\n            margin-top: auto;\n            :deep(.a-button) {\n                text-align: center;\n                justify-content: center;\n            }\n        }\n\n    }\n    &.is-centered {\n        text-align: center;\n        .content {\n            align-items: center;\n        }\n    }\n\n    &_radius {\n        &_0 { --a-value-card-border-radius: 0px }\n        &_2 { --a-value-card-border-radius: 2px }\n        &_4 { --a-value-card-border-radius: 4px; }\n        &_8 { --a-value-card-border-radius: 8px; }\n        &_12 { --a-value-card-border-radius: 12px; }\n        &_16 { --a-value-card-border-radius: 16px; }\n        &_20 { --a-value-card-border-radius: 20px; }\n        &_24 { --a-value-card-border-radius: 24px; }\n        &_28 { --a-value-card-border-radius: 28px; }\n    }\n\n    &.linked {\n        .content {\n            .header {\n                .title {\n                    color: var(--av-brand-secondary);\n                    transition: color 0.15s ease-out;\n                }\n            }\n        }\n        &:hover {\n            box-shadow: none;\n            .content {\n                .header {\n                    .title {\n                        color: var(--av-nav-secondary);\n                    }\n                }\n            }\n        }\n    }\n}\n</style>\n","export default {\n    props: {\n        /**\n         * Get data slice from product\n         */\n        typeInheritance: {\n            type: String,\n            default: 'common',\n        },\n\n        products: {\n            type: Array,\n        },\n    },\n\n    inheritAttrs: false,\n\n    computed: {\n        productId() {\n            return this.$store.state.pages?.page.product_id;\n        },\n        productCurrent() {\n            return this.$store.state.products?.items?.[this.productId] || {};\n        },\n        productParameters() {\n            return this.productCurrent?.parameters || {};\n        },\n        product() {\n            return this.productParameters?.[this.typeInheritance] || {};\n        },\n        productSystemInfo() {\n            return this.productParameters?.systemInfo || [];\n        },\n        productFAQ() {\n            return this.productParameters?.faq || {};\n        },\n        productPages() {\n            return this.productParameters?.pages || {};\n        },\n        getProducts() {\n            return Array.isArray(this.products) ? this.products : [];\n        },\n        currentLocale() {\n            return this.$store.state.geolocation.finalLocale;\n        },\n    },\n\n    methods: {\n        getData(name) {\n            const property = this.l10n?.[name] || this.$props[name];\n            const propertyByProduct = this.product[name];\n\n            if (Array.isArray(property) && property.length) {\n                return property.filter(Boolean);\n            }\n            if (Array.isArray(propertyByProduct) && propertyByProduct.length) {\n                return propertyByProduct.filter(Boolean);\n            }\n\n            return property || propertyByProduct;\n        },\n        isVisible(name) {\n            const property = this.getData(name);\n            if (Array.isArray(property) && property.length) {\n                return true;\n            }\n            return Boolean(property);\n        },\n    },\n};\n","<template>\n    <div v-if=\"isReady && isVisibleCTA\" :class=\"['cta', { 'cta-promo': hasDiscount }]\">\n        <template v-if=\"hasLabel\">\n            <template v-if=\"useNewLabelDesign\">\n                <dynamic-link\n                    v-if=\"settings.labelTo\"\n                    :to=\"settings.labelTo\"\n                    :event=\"{ ...settings.labelEvent, label: settings.labelTo, content: label }\"\n                    native-type=\"a\"\n                >\n                    <a-label\n                        class=\"cta-label-new\"\n                        :variant=\"settings.labelVariant || 'success'\"\n                        :layout=\"settings.labelLayout || 'subtle'\"\n                        :theme=\"settings.labelTheme\"\n                        :glyph=\"settings.labelGlyph\"\n                        :size=\"settings.labelSize\"\n                    >\n                        <a-glyph v-if=\"hasDiscount && glyph\" :name=\"glyph\" size=\"s\" />\n                        <span v-html=\"label\" />\n                    </a-label>\n                </dynamic-link>\n                <a-label\n                    v-else\n                    class=\"cta-label-new\"\n                    :variant=\"settings.labelVariant || 'success'\"\n                    :layout=\"settings.labelLayout || 'subtle'\"\n                    :theme=\"settings.labelTheme\"\n                    :glyph=\"settings.labelGlyph\"\n                    :size=\"settings.labelSize\"\n                >\n                    <a-glyph v-if=\"hasDiscount && glyph\" :name=\"glyph\" size=\"s\" />\n                    <span v-html=\"label\" />\n                </a-label>\n            </template>\n            <template v-else>\n                <dynamic-link\n                    v-if=\"settings.labelTo\"\n                    :to=\"settings.labelTo\"\n                    :event=\"{ ...settings.labelEvent, label: settings.labelTo, content: label }\"\n                    native-type=\"a\"\n                >\n                    <div class=\"cta-label\">\n                        <a-glyph v-if=\"hasDiscount && glyph\" :name=\"glyph\" />\n                        <span v-html=\"label\" />\n                    </div>\n                </dynamic-link>\n                <div v-else class=\"cta-label\">\n                    <a-glyph v-if=\"hasDiscount && glyph\" :name=\"glyph\" />\n                    <span v-html=\"label\" />\n                </div>\n            </template>\n        </template>\n        <div v-if=\"hasDescription\" class=\"cta-description\">\n            <dynamic-link v-if=\"settings.to\" :to=\"settings.to\" native-type=\"a\">\n                <span v-html=\"description\" />\n            </dynamic-link>\n            <p v-else v-html=\"description\" />\n        </div>\n\n        <div v-if=\"trialPage && hasDiscount\" class=\"cta-trial\">\n            <p v-if=\"trialPage.label\" class=\"cta-trial-label\">\n                <a-glyph v-if=\"trialPage.glyph\" :name=\"trialPage.glyph\" />\n                <span v-html=\"trialPage.label\" />\n            </p>\n            <p v-if=\"trialPage.description\" v-html=\"trialPage.description\" />\n        </div>\n    </div>\n</template>\n\n<script>\nimport { merge } from 'lodash-es';\n\nimport DynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport ALabel from '@core/components/label/label.vue';\nimport analytics from '@core/mixins/analytics.js';\nimport cleverbridge from '@core/mixins/cleverbridge.js';\nimport currency from '@core/mixins/currency.js';\nimport productMixin from '@core/mixins/product.js';\nimport purchasing from '@core/mixins/purchasing.js';\n\nexport default {\n    name: 'AProductCta',\n\n    components: {\n        DynamicLink,\n        AGlyph,\n        ALabel,\n    },\n\n    mixins: [productMixin, purchasing, currency, analytics, cleverbridge],\n\n    props: {\n        settings: {\n            type: Object,\n            default: null,\n        },\n        useNewLabelDesign: {\n            type: Boolean,\n            default: false,\n        },\n    },\n\n    data() {\n        return {\n            label: '',\n            glyph: '',\n            description: '',\n            hasDiscount: false,\n            isReady: false,\n        };\n    },\n\n    computed: {\n        isVisibleCTA() {\n            if (!this.isLoadedPrices) return false;\n            return this.hasLabel || this.hasDescription || (this.trialPage && this.hasDiscount);\n        },\n\n        hasLabel() {\n            return this.settings.hasLabel && this.label;\n        },\n\n        hasDescription() {\n            return this.settings.hasDescription && this.description;\n        },\n\n        trialPage() {\n            return this.settings?.trialPageCTA;\n        },\n    },\n\n    async mounted() {\n        await this.getCurrency();\n        const productId = this.settings?.productId || this.internalProductId;\n        const pageSettingsCTA = this.productItems[productId]?.parameters?.common?.productPageCTA;\n        const settingsCTA = merge({}, pageSettingsCTA, this.settings);\n        const cleverBridgeCartID = settingsCTA.cleverBridgeCartID;\n        let license = this.licenseData({ cleverBridgeCartID, settingsCTA });\n\n        let promo = license.promoSettings || {};\n\n        if (!this.settings?.cleverBridgeCartID) {\n            const comparison = (item) => item.product_id === productId;\n            const promotion = this.promotionList.find(comparison) || {};\n            if (!promo.product_page_license_id) promo = promotion.promoSettings || {};\n            const licenseIdOverride = Number(promotion.license_id_override) || promo.product_page_license_id;\n            if (licenseIdOverride && licenseIdOverride !== cleverBridgeCartID) {\n                const overrideLicense = this.licenseData({ cleverBridgeCartID: licenseIdOverride, settingsCTA });\n                if (overrideLicense.price) license = overrideLicense;\n            }\n        }\n\n        this.hasDiscount = license.discount && !settingsCTA.doNotApplyPromo;\n        this.glyph = this.hasDiscount && promo.glyph || settingsCTA.glyph || '';\n\n        const period = settingsCTA.isMonthlyPrice ? 12 : 1;\n        const price = this.setCurrency(license.price / period, { productId });\n        const pricePromo = this.hasDiscount ? this.setCurrency(license.price_promo / period, { productId }) : '';\n        const text = this.hasDiscount && promo.product_page_description || settingsCTA.description || '';\n\n        this.description = text\n            .replace(/@PricePromo/i, pricePromo)\n            .replace(/@PriceFull/i, price)\n            .replace(/@Price/i, price);\n\n        if (this.settings.hasLabel) {\n            const label = this.hasDiscount && promo.product_page_label;\n            this.label = label || settingsCTA.promo?.label || settingsCTA.label || '';\n            this.glyph = settingsCTA.promo?.glyph || settingsCTA.glyph || '';\n        }\n\n        if (this.settings.hasFullLabel) {\n            this.label = `${this.label} ${this.description.charAt(0).toLowerCase()}${this.description.slice(1)}`;\n        }\n\n        this.isReady = true;\n    },\n\n    async serverPrefetch() {\n        if (!import.meta.env.SSR) return;\n\n        if (!this.settings) return;\n        await this.getLicenses(this.settings);\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.cta {\n    @mixin title;\n    color: var(--av-nav-primary);\n}\n\n.cta-label {\n    display: flex;\n    font-weight: 400;\n    align-items: center;\n    color: var(--av-button-action);\n\n    .a-glyph {\n        width: 24px;\n        height: 24px;\n        margin-inline-end: 8px;\n        fill: var(--av-fixed-success);\n    }\n}\n\n.cta-description {\n    display: flex;\n    flex-wrap: wrap;\n    margin: 8px 0 0;\n    align-items: center;\n\n    del {\n        color: var(--av-fixed-light);\n    }\n    :deep(a) {\n        b {\n            color: var(--av-link-primary);\n            &:hover {\n                color: var(--av-link-primary-hover);\n            }\n            &:active {\n                color: var(--av-link-primary-active);\n            }\n        }\n    }\n}\n\n.cta-trial {\n    @mixin body;\n    padding-inline-start: 32px;\n    color: var(--av-fixed-secondary);\n\n    a {\n        color: var(--av-brand-secondary);\n    }\n\n    .a-glyph {\n        top: 0;\n        inset-inline-start: -32px;\n        width: 24px;\n        height: 24px;\n        position: absolute;\n        fill: var(--av-fixed-success);\n    }\n}\n\n.cta-trial-label {\n    font-weight: 600;\n    position: relative;\n}\n</style>\n","export const TYPES = ['tag', 'chip'];\n\nexport default {};\n","<template>\n    <div>\n        <a-button v-if=\"type === 'tag'\" class=\"a-tag\" v-bind=\"link\" />\n        <button\n            v-if=\"visible && type === 'chip'\"\n            class=\"a-chip\"\n            :class=\"{'closable': closable}\"\n            :disabled=\"disabled\"\n            @click=\"handleClick\"\n        >\n            <span>{{ text }}</span>\n            <a-glyph v-if=\"closable\" name=\"times\" size=\"xs\" />\n        </button>\n    </div>\n</template>\n\n<script>\nimport AButton from '@core/components/button/button.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport { TYPES } from './constants.js';\n\nexport default {\n    name: 'ATag',\n    components: {\n        AButton,\n        AGlyph,\n    },\n    props: {\n        /**\n         * General props\n         */\n        text: {\n            type: String,\n            required: false,\n            default: undefined,\n        },\n        type: {\n            type: String,\n            required: false,\n            default: 'tag',\n            validator: (value) => TYPES.includes(value),\n        },\n\n        /* Tag Props */\n        link: {\n            type: Object,\n            required: false,\n            default: undefined,\n        },\n\n        /* Chip props */\n        closable: {\n            type: Boolean,\n            required: false,\n            default: false,\n        },\n        disabled: {\n            type: Boolean,\n            required: false,\n            default: false,\n        },\n    },\n    emits: ['click'],\n    data() {\n        return {\n            visible: true,\n        };\n    },\n    methods: {\n        handleClick(event) {\n            this.$emit('click', event);\n\n            if (this.closable) {\n                this.visible = false;\n            }\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-tag,\n.a-chip {\n    @mixin note-heading;\n    padding: 0 8px;\n    border-radius: 8px;\n    text-transform: uppercase;\n    background: var(--av-brand-accent);\n    color: var(--av-brand-primary);\n    border: none;\n    outline: 3px solid transparent;\n    box-shadow: none;\n    user-select: none;\n    cursor: pointer;\n\n    &:hover {\n        background: var(--av-brand-secondary-accent);\n    }\n\n    &:focus {\n        background: var(--av-brand-accent);\n        outline: 3px solid var(--av-brand-secondary-light);\n    }\n\n    &:active {\n        background: var(--av-brand-secondary-light);\n    }\n\n    &:disabled {\n        pointer-events: none;\n        background: var(--av-brand-accent);\n        opacity: 0.3;\n    }\n}\n.a-chip {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n\n    &.closable {\n        background: var(--av-brand-secondary-light);\n\n        &:hover {\n            background: var(--av-brand-secondary-light);\n        }\n\n        &:active {\n            background: var(--av-brand-secondary-accent);\n            outline: none;\n        }\n\n        &:focus {\n            background: var(--av-brand-accent);\n        }\n\n        .a-glyph {\n            fill: var(--av-brand-secondary);\n        }\n    }\n}\n</style>\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <li\n        class=\"el-submenu\"\n        :class=\"{ 'is-opened': opened, 'is-active': active }\"\n        role=\"menuitem\"\n        :title=\"computedTitle\"\n    >\n        <div\n            ref=\"submenuTitle\"\n            class=\"el-submenu__item\"\n            :class=\"{\n                'is-root': level === 1,\n                'is-multiline': multiline,\n                'is-focus': isFocus\n            }\"\n            tabindex=\"0\"\n            @click=\"handleClick\"\n            @mousedown=\"isFocus = true\"\n            @mouseup=\"isFocus = false\"\n            @focus=\"isFocus = true\"\n            @blur=\"isFocus = false\"\n            @keyup.enter=\"handleClick\"\n            @keydown.enter.prevent=\"handleClick\"\n        >\n            <a-glyph v-if=\"showArrow\" class=\"el-submenu__arrow\" name=\"i-chevron-right--16\" />\n            <span v-if=\"$slots.icon\" class=\"el-menu__bar-icon\">\n                <slot name=\"icon\" />\n            </span>\n            <span class=\"el-text el-text--body-24 el-text--ellipsis\">\n                <slot name=\"title\" />\n            </span>\n        </div>\n\n        <ul v-show=\"opened\" class=\"el-menu__bar\" role=\"menu\">\n            <div :class=\"[`el-menu__bar--level-${level}`]\">\n                <slot />\n            </div>\n        </ul>\n    </li>\n</template>\n\n<script setup>\nimport { ref, computed, inject, provide, useSlots, onMounted, onBeforeUnmount } from 'vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\n\nconst slots = useSlots();\nconst props = defineProps({\n    index: { type: String, required: true },\n    multiline: { type: Boolean, default: false },\n    showHoverHint: { type: Boolean, default: false },\n});\n\nconst submenuTitle = ref(null);\nconst isFocus = ref(false);\n\nconst menuContext = inject('menuContext');\nconst parentMenu = inject('parentMenu', null);\nconst indexPath = computed(() => [...(parentMenu?.indexPath || []), props.index]);\nconst level = computed(() => (parentMenu?.level || 0) + 1);\nconst opened = computed(() => menuContext.openedMenus?.value.includes(props.index));\n\nconst active = computed(() => {\n    const current = menuContext.activeIndex?.value;\n    return indexPath.value.includes(current);\n});\n\nconst showArrow = computed(() => menuContext.type === 'secondary');\n\nconst computedTitle = computed(() => {\n    if (!props.showHoverHint) return null;\n    const nodes = [...(slots.title?.() || slots.default?.() || [])];\n    return nodes.map(node => node.children?.toString?.() || '').join('').trim();\n});\n\nfunction handleClick() {\n    menuContext.handleSubmenuClick({\n        index: props.index,\n        indexPath: indexPath.value,\n        $el: submenuTitle.value,\n        slots,\n    });\n}\n\nonMounted(() => {\n    menuContext.addSubmenu({ index: props.index, indexPath: indexPath.value, $el: submenuTitle.value });\n});\n\nonBeforeUnmount(() => {\n    menuContext.closeMenu?.(props.index);\n    menuContext.removeSubmenu({ index: props.index });\n});\n\nprovide('parentMenu', { name: 'Submenu', indexPath: indexPath.value, level: level.value });\n</script>\n","<template>\n    <s-basic-slice :id=\"id\" class=\"s-preferred-small-cards\" :class=\"{ ...className, ...basicClassName }\">\n        <div class=\"s-preferred-small-cards__leftside\">\n            <component\n                :is=\"titleTag\"\n                v-if=\"l10n.title\"\n                class=\"a-slice-header__title\"\n            >\n                {{ l10n.title }}\n            </component>\n            <div v-if=\"(l10n.lead && !l10n.title) || leadIsVisible\" class=\"a-slice-header__lead\">\n                {{ l10n.lead }}\n            </div>\n            <a-link\n                v-if=\"downloadLink\"\n                class=\"s-preferred-small-cards__download-file\"\n                :to=\"downloadLink.link\"\n                :type=\"downloadLink.type || 'download-file'\"\n                :glyph=\"downloadLink.glyph || 'download-arrow'\"\n                :glyph-position=\"downloadLink.glyphPosition || 'left'\"\n                :text=\"downloadLink.title\"\n                v-bind=\"downloadLink\"\n            />\n            <div\n                v-if=\"l10n.link\"\n                class=\"s-preferred-small-cards__link-container\"\n                :class=\"{ hasLead: l10n.lead }\"\n            >\n                <a-link\n                    class=\"s-preferred-small-cards__link\"\n                    v-bind=\"l10n.link\"\n                    :type=\"l10n.link.type || 'direct'\"\n                    :glyph=\"l10n.link.glyph || 'arrow'\"\n                />\n            </div>\n        </div>\n        <div class=\"s-preferred-small-cards__content\">\n            <div class=\"s-preferred-small-cards__list\">\n                <div\n                    v-for=\"(card, index) in cardsTrimmed\"\n                    v-show=\"!visibleCards || visibleCards > index\"\n                    :key=\"`preferred-small-cards-${index}`\"\n                    class=\"s-preferred-small-cards__list-item\"\n                >\n                    <a-small-card v-bind=\"{ ...card, theme }\" />\n                </div>\n            </div>\n        </div>\n    </s-basic-slice>\n</template>\n\n<script>\nimport ALink from '@core/components/link/link.vue';\nimport ASmallCard from '@core/components/small-card/small-card.vue';\nimport contentMixin from '@core/mixins/content.js';\nimport l10n from '@core/mixins/l10n.js';\nimport styleMixin from '@core/mixins/style.js';\nimport SBasicSlice from '@core/slices/pages/basic-slice/basic-slice.vue';\n\nconst CARDS_LIMIT = 12;\n\nexport default {\n    name: 'SCardsSmall',\n\n    components: {\n        ALink,\n        ASmallCard,\n        SBasicSlice,\n    },\n\n    mixins: [l10n, contentMixin, styleMixin],\n\n    props: {\n        link: {\n            type: Object,\n            default: undefined,\n        },\n        cards: {\n            type: Array,\n            required: true,\n        },\n        downloadFileArr: {\n            type: Array,\n            default: undefined,\n        },\n        sliderOptions: {\n            type: Object,\n            default: () => ({}),\n        },\n        isRowLayout: {\n            type: Boolean,\n            default: false,\n        },\n        leadIsVisible: {\n            type: Boolean,\n            default: false,\n        },\n        isRateLayout: {\n            type: Boolean,\n            default: false,\n        },\n        isCompanyLayout: {\n            type: Boolean,\n            default: false,\n        },\n        theme: {\n            type: String,\n            validator: (prop) => ['light', 'dark'].includes(prop),\n            default: 'light',\n        },\n    },\n\n    data() {\n        return {\n            step: 0,\n            visibleCards: 0,\n            initialVisibleCards: 0,\n            sliceSliderOptions: {\n                slidesPerView: 'auto',\n                ...this.sliderOptions,\n            },\n        };\n    },\n\n    computed: {\n        cardsTrimmed() {\n            return this.l10n.cards?.slice(0, CARDS_LIMIT);\n        },\n\n        className() {\n            return {\n                's-preferred-small-cards_layout': true,\n                's-preferred-small-cards_layout_company': this.isCompanyLayout,\n                's-preferred-small-cards_layout_row': this.isRowLayout,\n                's-preferred-small-cards_layout_default': (!this.isCompanyLayout && !this.isRowLayout),\n                [`layout-${this.l10n.cards.length}-cards`]: this.l10n.cards?.length,\n                's-preferred-small-cards_layout_rate': this.isRateLayout,\n            };\n        },\n        downloadLink() {\n            return this.l10n.downloadFileArr?.[0] || false;\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-preferred-small-cards {\n    :deep(h1.a-slice-header__title),\n    :deep(h2.a-slice-header__title) {\n        @media (--viewport-mobile-wide) {\n            @mixin hero-accent;\n        }\n    }\n    :deep(.a-slice-header) {\n        &__title {\n            @mixin display-accent;\n            color: var(--av-nav-primary);\n            margin-bottom: 24px;\n        }\n\n        &__lead {\n            margin-top: 0;\n            margin-bottom: 24px;\n\n            @media (--viewport-tablet) {\n                margin-bottom: 16px;\n            }\n\n            @media (--viewport-desktop) {\n                margin-bottom: 40px;\n            }\n        }\n    }\n\n    &__link-container {\n        margin-bottom: 48px;\n        @media (--viewport-desktop) {\n            position: absolute;\n            top: 0px;\n            inset-inline-end: 32px;\n            margin: 0;\n        }\n        @media (--viewport-desktop-wide) {\n            inset-inline-end: 64px;\n        }\n\n        @media (--viewport-desktop-large) {\n            inset-inline-end: 0;\n        }\n        &.hasLead {\n            @media (--viewport-desktop) {\n                top: 82px;\n            }\n            @media (--viewport-desktop-wide) {\n                top: 66px;\n            }\n            @media (--viewport-desktop-large) {\n                top: 50px;\n            }\n        }\n    }\n\n    &__download-file {\n        margin-bottom: 16px;\n\n        @media (--viewport-desktop) {\n            position: absolute;\n            top: 138px;\n            inset-inline-end: 32px;\n            margin: 0;\n        }\n\n        @media (--viewport-desktop-wide) {\n            top: 122px;\n            inset-inline-end: 64px;\n        }\n\n        @media (--viewport-desktop-large) {\n            top: 106px;\n            inset-inline-end: 0;\n        }\n\n        :deep(.a-link__content) {\n            @mixin paragraph;\n        }\n\n        :deep(.a-link__desc) {\n            margin-top: 4px;\n            font-weight: 700;\n\n            @media (--viewport-desktop) {\n                text-align: end;\n            }\n        }\n    }\n\n    &__slide {\n        width: 66%;\n        padding-inline-end: 16px;\n    }\n\n    &__list {\n        display: flex;\n        gap: 16px;\n        flex-direction: column;\n    }\n\n    &_layout {\n        &.layout-1-cards {\n            @media (--viewport-desktop) {\n                .s-preferred-small-cards__list-item {\n                    max-width: 50%;\n\n                    &:last-child {\n                        flex-grow: 0;\n                    }\n                }\n            }\n        }\n\n        &_rate {\n            :deep(.rate-list) {\n                margin-top: auto;\n            }\n        }\n\n        @media (--viewport-mobile-wide) {\n            &_row {\n                :deep(.a-slice-header__title) {\n                    margin-bottom: 24px;\n                }\n\n                .s-preferred-small-cards__leftside {\n                    max-width: initial;\n\n                    @media (--viewport-desktop) {\n                         min-width: 228px;\n                    }\n\n                    @media (--viewport-desktop-wide) {\n                        min-width: 276px;\n                    }\n\n                    @media (--viewport-desktop-large) {\n                        min-width: 316px;\n                    }\n                }\n\n                .s-preferred-small-cards__list-item:last-child {\n                    flex-grow: 1;\n                }\n\n                &.layout-1-cards {\n                    .s-preferred-small-cards__list-item {\n                        max-width: 50%;\n                    }\n                }\n            }\n        }\n\n        @media (--viewport-tablet) {\n            .s-preferred-small-cards__list {\n                flex-direction: row;\n                flex-wrap: wrap;\n            }\n\n            .s-preferred-small-cards__list-item {\n                flex-grow: 1;\n            }\n\n            &.layout-2-cards,\n            &.layout-3-cards,\n            &.layout-4-cards,\n            &.layout-5-cards,\n            &.layout-6-cards,\n            &.layout-7-cards,\n            &.layout-8-cards,\n            &.layout-9-cards,\n            &.layout-10-cards,\n            &.layout-11-cards,\n            &.layout-12-cards {\n                .s-preferred-small-cards__list-item {\n                    flex-basis: calc(50% - 8px);\n                }\n            }\n\n            &_row {\n                &.layout-1-cards {\n                    .s-preferred-small-cards__list-item {\n                        max-width: 100%;\n                    }\n                }\n            }\n        }\n\n        @media (--viewport-desktop) {\n            .s-preferred-small-cards__list-item:last-child {\n                flex-grow: 0;\n            }\n\n            &.layout-2-cards,\n            &.layout-3-cards,\n            &.layout-4-cards,\n            &.layout-5-cards,\n            &.layout-6-cards,\n            &.layout-7-cards,\n            &.layout-8-cards,\n            &.layout-10-cards,\n            &.layout-11-cards {\n                .s-preferred-small-cards__list-item {\n                    flex-basis: calc(50% - 8px);\n                }\n            }\n\n            &.layout-3-cards {\n                .s-preferred-small-cards__list-item {\n                    flex-basis: calc(33% - 8px);\n                }\n            }\n\n            &_row {\n                :deep(.a-slice-header) {\n                    &__title {\n                        max-width: 100%;\n                    }\n\n                    &__lead {\n                        max-width: 100%;\n                        margin-bottom: 16px;\n                    }\n                }\n\n                :deep(.a-container) {\n                    display: flex;\n                    justify-content: space-between;\n                    gap: 16px;\n                }\n\n                .s-preferred-small-cards__leftside {\n                    display: flex;\n                    flex-direction: column;\n                }\n\n                .s-preferred-small-cards__link-container {\n                    position: initial;\n                    order: 1;\n                    margin-bottom: 24px;\n                }\n\n                .s-preferred-small-cards__download-file {\n                    position: initial;\n                    order: 2;\n\n                    :deep(.a-link__desc) {\n                        text-align: start;\n                    }\n                }\n\n                &.layout-1-cards {\n                    .s-preferred-small-cards__list-item {\n                        max-width: 50%;\n                    }\n                }\n\n                &.layout-3-cards {\n                    .s-preferred-small-cards__list-item {\n                        flex-basis: calc(33% - 12px);\n\n                        &:last-child {\n                            flex-basis: 100%;\n                        }\n                    }\n                }\n            }\n\n            &_rate {\n                .s-preferred-small-cards__list {\n                    @mixin colls 8;\n                }\n            }\n        }\n\n        @media (--viewport-desktop-wide) {\n            &.layout-2-cards {\n                .s-preferred-small-cards__list-item {\n                    flex-basis: calc(50% - 8px);\n                }\n            }\n\n            &.layout-3-cards {\n                .s-preferred-small-cards__list-item {\n                    flex-basis: calc(33% - 8px);\n\n                    &:last-child {\n                        flex-basis: calc(33% - 8px);\n                    }\n                }\n            }\n\n            &.layout-5-cards,\n            &.layout-6-cards,\n            &.layout-9-cards,\n            &.layout-10-cards {\n                .s-preferred-small-cards__list-item {\n                    flex-basis: calc(25% - 12px);\n\n                    &:last-child {\n                        flex-basis: calc(50% - 8px);\n                    }\n                }\n            }\n\n            &.layout-7-cards,\n            &.layout-11-cards {\n                .s-preferred-small-cards__list-item {\n                    flex-basis: calc(25% - 12px);\n\n                    &:nth-last-child(-n + 3) {\n                        flex-basis: calc(33% - 8px);\n                    }\n                }\n            }\n\n            &.layout-4-cards,\n            &.layout-8-cards,\n            &.layout-12-cards {\n                .s-preferred-small-cards__list-item {\n                    flex-basis: calc(25% - 12px);\n                }\n            }\n\n            &_rate {\n                .s-preferred-small-cards__list {\n                    @mixin colls 12;\n                }\n            }\n\n            &_row {\n                &.layout-4-cards,\n                &.layout-5-cards,\n                &.layout-6-cards,\n                &.layout-7-cards,\n                &.layout-8-cards,\n                &.layout-9-cards,\n                &.layout-10-cards,\n                &.layout-11-cards,\n                &.layout-12-cards {\n                    .s-preferred-small-cards__list-item {\n                        flex-basis: calc(50% - 8px);\n\n                        &:nth-last-child(-n + 3) {\n                            flex-basis: calc(50% - 8px);\n                        }\n                    }\n                }\n            }\n        }\n    }\n\n    @media (--viewport-desktop) {\n        :deep(.a-slice-header) {\n            &__title {\n                max-width: 66.66%;\n            }\n\n            &__lead {\n                max-width: 66.66%;\n            }\n        }\n\n        &__content {\n            position: relative;\n        }\n    }\n}\n\n.s-side-menu {\n    :deep(.a-container) {\n        .s-preferred-small-cards {\n            padding-bottom: 0;\n            padding-top: 56px;\n            @media (--viewport-desktop) {\n                &:not(:first-child) {\n                    padding: 0;\n                    margin: 104px 0 0;\n                }\n            }\n            .a-slice-header {\n                &__title {\n                    display: none;\n                    @media (--viewport-desktop) {\n                        display: block;\n                    }\n                }\n            }\n            &__list {\n                width: auto;\n            }\n            &__list-item {\n                width: calc(33.33% - 16px);\n                @media (--viewport-mobile-wide) {\n                    width: calc(50% - 16px);\n                }\n                @media (--viewport-desktop-wide) {\n                    width: calc(33.33% - 16px);\n                }\n            }\n        }\n    }\n}\n\n.s-preferred-small-cards_layout_row {\n    .s-preferred-small-cards__content {\n        flex-shrink: 0;\n        width: 328px;\n\n        @media (--viewport-tablet) {\n            width: 704px;\n        }\n\n        @media (--viewport-desktop) {\n            width: 716px;\n        }\n\n        @media (--viewport-desktop-wide) {\n            width: 860px;\n        }\n\n        @media (--viewport-desktop-large) {\n            width: 980px;\n        }\n    }\n\n    :deep(.a-slice-header__title) {\n        max-width: 100%;\n    }\n\n    :deep(.a-slice-header__lead) {\n        max-width: 100%;\n    }\n}\n</style>\n","<template>\n    <div class=\"a-tab\" data-tab-panel>\n        <slot />\n    </div>\n</template>\n\n<script>\nexport default {\n    name: 'ATab',\n\n    props: {\n        /**\n         * Title\n         */\n        label: {\n            type: String,\n            required: true,\n        },\n\n        labelIcon: {\n            type: String,\n            default: undefined,\n        },\n\n        labelIconAlt: {\n            type: String,\n            default: undefined,\n        },\n\n        anchorId: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * Subtitle\n         */\n        translatedLabel: {\n            type: String,\n            default: undefined,\n        },\n        glyph: {\n            type: Object,\n            default: null,\n        },\n        aLabel: {\n            type: Object,\n            default: null,\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-tab {\n    display: none;\n    &_active {\n        display: block;\n    }\n}\n</style>\n","import GlobalPubSub from '@utils/global-pub-sub.ts';\n\nconst CLASSES = {\n    activeTabParent: 'a-tabs__item_active',\n    activeTab: 'a-tabs-item_active',\n    activePanel: 'a-tab_active',\n};\n\nexport function animate(opts, _startedAt) {\n    const startedAt = _startedAt || performance.now();\n\n    requestAnimationFrame((time) => {\n        let timeFraction = (time - startedAt) / opts.duration;\n        if (timeFraction > 1) {\n            timeFraction = 1;\n        }\n\n        const progress = opts.timing(timeFraction);\n\n        opts.draw(progress);\n\n        if (timeFraction < 1) {\n            requestAnimationFrame(() => animate(opts, startedAt));\n        }\n    });\n}\n\nexport function easeInOutQuad(t) {\n    return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;\n}\n\nclass Tabs {\n    constructor(el, options, vnode) {\n        this.el = el;\n        this.options = options;\n        this.tabsContainer = this.el.querySelector('[data-tabs-header]');\n        this.tabSwitchers = [...this.el.querySelectorAll('[data-tab-switcher]')];\n        this.tabPanels = [...this.el.querySelectorAll('[data-tab-panel]')];\n        this.vueRoot = vnode?.instance?.$root ?? null;\n\n        this.activeIndex = options && options.activeIndex ? options.activeIndex : 0;\n\n        this.underline = el.querySelector('[data-tabs-underline]');\n        this.newScrollPos = 0;\n        this.animationRightShift = 48;\n        this.animationLeftShift = 64;\n\n        this.tabsClickHandler = this.tabsClickHandler.bind(this);\n        this.setUnderline = this.setUnderline.bind(this);\n        this.moveScroll = this.moveScroll.bind(this);\n        this.init();\n    }\n\n    init() {\n        this.setTabIndexes();\n        this.switchActive(this.activeIndex);\n        this.setUnderline();\n\n        window.addEventListener('resize', this.setUnderline);\n        this.el.addEventListener('click', this.tabsClickHandler);\n        GlobalPubSub.on('tabChangeActive', this.onTabChange.bind(this));\n    }\n\n    setTabIndexes() {\n        this.tabSwitchers?.forEach((tab, index) => {\n            const parent = tab?.parentElement;\n            if (parent) {\n                parent.setAttribute(\n                    'style',\n                    `--data-index: ${this.tabSwitchers.length - index};`,\n                );\n            }\n        });\n    }\n\n    onTabChange(e) {\n        this.switchTab(e.activeTabIndex);\n    }\n\n    tabsClickHandler(event) {\n        if (event.target.closest('[data-tab-switcher]')) {\n            const newActiveIndex = this.tabSwitchers.indexOf(\n                event.target.closest('[data-tab-switcher]'),\n            );\n\n            this.switchTab(newActiveIndex);\n        }\n    }\n\n    switchTab(newActiveIndex) {\n        if (this.activeIndex !== newActiveIndex) {\n            this.switchActive(newActiveIndex);\n            this.tabMoving();\n            this.setUnderline();\n        }\n    }\n\n    switchActive(newActiveIndex) {\n        if (!this.tabSwitchers[newActiveIndex]) return;\n        if (!this.tabSwitchers[this.activeIndex]) return;\n\n        this.tabSwitchers[this.activeIndex].classList.remove(CLASSES.activeTab);\n        this.tabSwitchers[this.activeIndex].parentElement.classList.remove(CLASSES.activeTabParent);\n        this.tabPanels[this.activeIndex].classList.remove(CLASSES.activePanel);\n\n        this.activeIndex = newActiveIndex;\n\n        this.tabSwitchers[this.activeIndex].classList.add(CLASSES.activeTab);\n        this.tabSwitchers[this.activeIndex].parentElement.classList.add(CLASSES.activeTabParent);\n        this.tabPanels[this.activeIndex].classList.add(CLASSES.activePanel);\n    }\n\n    tabMoving() {\n        if (!this.tabSwitchers[this.activeIndex]) return;\n        const activeTabRect = this.tabSwitchers[this.activeIndex].getBoundingClientRect();\n        const tabsContainerRect = this.tabsContainer.getBoundingClientRect();\n\n        const tabWidth = activeTabRect.width;\n        const tabLeftXCoord = Math.floor(activeTabRect.x);\n        const tabRightXCoord = tabLeftXCoord + tabWidth;\n\n        const tabsContainerWidth = tabsContainerRect.width;\n        const tabsContainerLeftXCoord = Math.floor(tabsContainerRect.x);\n        const tabsContainerRightXCoord = tabsContainerLeftXCoord + tabsContainerWidth;\n\n        const tabsContainerScrollLeft = this.tabsContainer.scrollLeft;\n\n        if (tabLeftXCoord - 32 < tabsContainerLeftXCoord) {\n            this.newScrollPos =\n                tabsContainerScrollLeft +\n                tabLeftXCoord -\n                tabsContainerLeftXCoord -\n                this.animationLeftShift;\n            window.requestAnimationFrame(this.moveScroll);\n        }\n\n        if (tabRightXCoord + 32 > tabsContainerRightXCoord) {\n            this.newScrollPos =\n                tabsContainerScrollLeft +\n                (tabLeftXCoord + tabWidth) -\n                tabsContainerWidth +\n                this.animationRightShift;\n            window.requestAnimationFrame(this.moveScroll);\n        }\n    }\n\n    moveScroll() {\n        animate({\n            duration: 350,\n            timing: easeInOutQuad,\n            draw: (progress) => {\n                this.tabsContainer.scrollLeft +=\n                    progress * (this.newScrollPos - this.tabsContainer.scrollLeft);\n            },\n        });\n    }\n\n    setUnderline() {\n        if (!this.tabSwitchers[this.activeIndex]) return;\n        const activeTabRect = this.tabSwitchers[this.activeIndex].getBoundingClientRect();\n        const btnWidth = activeTabRect.width;\n        const btnLeftCoord = activeTabRect.left;\n        const tabsContainerLeftXCoord = this.tabsContainer.getBoundingClientRect().left;\n        const tabsContainerScrollLeft = this.tabsContainer.scrollLeft;\n\n        this.underline.style.width = `${btnWidth}px`;\n        this.underline.style.left = `${btnLeftCoord - tabsContainerLeftXCoord + tabsContainerScrollLeft}px`;\n    }\n\n    destroy() {\n        window.removeEventListener('resize', this.setUnderline);\n        GlobalPubSub.off('tabChangeActive', this.onTabChange);\n        this.el.removeEventListener('click', this.tabsClickHandler);\n    }\n}\n\nexport default {\n    mounted(el, binding) {\n        const options = binding.value?.options || {};\n        el.tabs = new Tabs(el, options, binding);\n    },\n\n    unmounted(el) {\n        if (el.tabs) {\n            el.tabs.destroy();\n            el.tabs = null;\n        }\n    },\n};\n","<template>\n    <div v-tabs=\"{ options }\" class=\"a-tabs\" :class=\"className\">\n        <div class=\"a-tabs__header\" data-tabs-header :class=\"{ noBottomSpacing, noTopSpacing }\">\n            <div class=\"a-tabs__list-wrapper\">\n                <ul class=\"a-tabs__list-wrapper__list\">\n                    <li\n                        v-for=\"(tab, i) in tabs\"\n                        :key=\"i\"\n                        class=\"a-tabs__item\"\n                        @click=\"handleClick($event, tab, i)\"\n                    >\n                        <button\n                            :id=\"tab.anchorId\"\n                            class=\"a-tabs-item\"\n                            type=\"button\"\n                            data-tab-switcher\n                        >\n                            <span v-if=\"tab.labelIcon\" class=\"a-tabs-item__icon-container\">\n                                <a-icon class=\"a-tabs-item__icon\" :number=\"tab.labelIcon\" :icon-alt=\"tab.labelIconAlt\" />\n                            </span>\n                            <span class=\"a-tabs-item__label\">{{ tab.label }} <a-glyph v-if=\"tab.glyph\" v-bind=\"tab.glyph\" /></span>\n                            <span v-if=\"tab.translatedLabel\" class=\"a-tabs-item__translated-label\">\n                                {{ tab.translatedLabel }}\n                            </span>\n                            <a-label v-if=\"tab?.aLabel?.text\" v-bind=\"tab.aLabel\">\n                                {{ tab.aLabel.text }}\n                            </a-label>\n                        </button>\n                    </li>\n                </ul>\n                <div class=\"a-tabs__underline\" data-tabs-underline />\n            </div>\n        </div>\n        <div class=\"a-tabs__content\">\n            <slot />\n        </div>\n    </div>\n</template>\n\n<script>\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport AIcon from '@core/components/icon/icon.vue';\nimport ALabel from '@core/components/label/label.vue';\nimport Tabs from '@core/directives/tabs.js';\nimport { getElementPath } from '@utils/analytics.ts';\nimport GlobalPubSub from '@utils/global-pub-sub.ts';\nimport { VSlotUnwrap } from '@utils/v-slot.ts';\n\nexport default {\n    name: 'ATabs',\n    components: {\n        AGlyph,\n        ALabel,\n        AIcon,\n    },\n    directives: {\n        Tabs,\n    },\n    props: {\n        noTopSpacing: {\n            type: Boolean,\n            default: false,\n        },\n        noBottomSpacing: {\n            type: Boolean,\n            default: false,\n        },\n        useSmallTabs: {\n            type: Boolean,\n            default: false,\n        },\n        type: {\n            type: String,\n            default: undefined,\n        },\n        activeTab: {\n            type: Number,\n            default: undefined,\n        },\n        typeWidth: {\n            type: String,\n            default: undefined,\n        },\n    },\n    emits: ['click'],\n    data() {\n        const children = VSlotUnwrap(this.$slots.default).filter((vnode) => vnode?.type?.name);\n        const tabsList = children.map((tab) => tab.props);\n\n        return {\n            tabs: tabsList,\n            options: {\n                activeIndex: Number.isInteger(this.activeTab)\n                    ? this.activeTab\n                    : this.hashIndex(tabsList, this.$route?.hash || ''),\n                speed: this.type === 'tile' ? 300 : null,\n            },\n\n        };\n    },\n    computed: {\n        className() {\n            const tabCount = this.tabs?.length || 0;\n\n            return {\n                'is-full-width': this.typeWidth === 'full',\n                'a-tabs_type_with-icons': this.type === 'with-icons',\n                'a-tabs_type_tile': this.type === 'tile',\n                'a-tabs_tile-layout_more-than-6-items': this.type === 'tile' && tabCount > 6,\n                'a-tabs_tile-layout_6-items': this.type === 'tile' && tabCount === 6,\n                'a-tabs_tile-layout_5-items': this.type === 'tile' && tabCount === 5,\n                'a-tabs_tile-layout_4-items': this.type === 'tile' && tabCount === 4,\n                'a-tabs_tile-layout_3-items': this.type === 'tile' && tabCount === 3,\n                'a-tabs_normal-layout_less-than-4-items': this.type !== 'tile' && tabCount <= 4 && !this.useSmallTabs,\n                'a-tabs_normal-layout_more-than-5-items': this.type !== 'tile' && (tabCount >= 5 || this.useSmallTabs),\n            };\n\n        },\n    },\n\n    updated() {\n        if (Number.isInteger(this.activeTab)) {\n            GlobalPubSub.emit('tabChangeActive', {\n                activeTabIndex: this.activeTab,\n                hash: 0,\n            });\n        }\n    },\n\n    mounted() {\n        window.addEventListener('hashchange', this.handleHashChange);\n    },\n\n    beforeUnmount() {\n        window.removeEventListener('hashchange', this.handleHashChange);\n    },\n\n    methods: {\n        activeIndex(tabsList) {\n            let windowHash = '';\n            if (typeof window !== 'undefined') {\n                windowHash = window.location.hash;\n            }\n            const hash = this.$route ? this.$route.hash : windowHash;\n            return this.hashIndex(tabsList, hash);\n        },\n        hashIndex(tabsList, hash) {\n            const index = tabsList.findIndex(({ anchorId }) => anchorId === hash.slice(1));\n            return index >= 0 ? index : 0;\n        },\n        handleHashChange() {\n            const tabId = this.activeIndex(this.tabs);\n            GlobalPubSub.emit('tabChangeActive', {\n                activeTabIndex: tabId,\n                hash: window.location.hash.slice(1),\n            });\n        },\n\n        handleClick(event, tab, i) {\n            window.dataLayer = window.dataLayer || [];\n            window.dataLayer.push({\n                event: 'Acronis',\n                eventCategory: 'Interactions',\n                eventAction: 'Tab Menu',\n                eventLabel: tab.label,\n                eventContent: tab.label,\n                eventLocation: getElementPath(event.target),\n                eventButton: (i + 1).toString(),\n                ...tab.event,\n            });\n\n            this.$emit('click', i);\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-tabs {\n    &__header {\n        overflow: scroll;\n        padding-bottom: 12px;\n        margin-top: 56px;\n        margin-bottom: 28px;\n        transition: transform 0.3s ease-out;\n        scrollbar-width: none;\n\n        &::-webkit-scrollbar {\n            height: 0;\n            background: rgba(255, 255, 255, 0);\n        }\n\n        &.noTopSpacing {\n            margin-top: 0;\n        }\n\n        &.noBottomSpacing {\n            margin-bottom: 0;\n        }\n    }\n\n    &__list-wrapper {\n        position: relative;\n        padding-bottom: 2px;\n        &::before {\n            content: '';\n            position: absolute;\n            inset-inline-start: 0;\n            bottom: 0;\n            z-index: 1;\n            width: 100%;\n            height: 2px;\n            background-color: var(--av-brand-secondary-accent);\n        }\n\n        &__list {\n            position: relative;\n            display: flex;\n            align-items: center;\n            border-radius: 4px;\n        }\n    }\n\n    .a-tabs__item {\n        transition: box-shadow 0.3s ease-in-out;\n        &:not(:last-of-type) {\n            margin-inline-end: 24px;\n\n            @media (--viewport-mobile-wide) {\n                margin-inline-end: 40px;\n            }\n        }\n    }\n    &__underline {\n        display: block;\n        background-color: var(--av-nav-primary);\n        position: absolute;\n        bottom: 0;\n        height: 2px;\n        transition: left ease-out 0.3s, width ease-out 0.3s;\n    }\n\n    .a-tabs-item {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        width: 100%;\n        padding: 0 0 8px;\n        background-color: rgba(255, 255, 255, 0);\n        border: none;\n        cursor: pointer;\n        position: relative;\n        text-align: center;\n        .a-tabs-item__label {\n            color: var(--av-brand-primary);\n            width: 100%;\n            white-space: nowrap;\n        }\n        &:hover {\n            .a-tabs-item__label {\n                color: var(--av-brand-secondary);\n            }\n        }\n        &:focus {\n            .a-tabs-item__label {\n                background: var(--av-brand-lightest);\n                color: var(--av-brand-primary);\n            }\n        }\n        &_active {\n            .a-tabs-item__label {\n                color: var(--av-nav-primary) !important;\n            }\n            &:focus {\n                .a-tabs-item__label {\n                    background: none;\n                }\n            }\n        }\n        &__icon-container {\n            margin-bottom: 24px;\n            width: 40px;\n            height: 40px;\n        }\n    }\n    &__link {\n        top: 0;\n        inset-inline-start: 0;\n        z-index: 1;\n        content: '';\n        width: 100%;\n        height: 100%;\n        cursor: pointer;\n        position: absolute;\n    }\n\n    &_normal-layout {\n        &_more-than-5-items {\n            .a-tabs__item {\n                &:not(:last-of-type) {\n                    margin-inline-end: 16px;\n                    @media (--viewport-desktop) {\n                        margin-inline-end: 24px;\n                    }\n                }\n            }\n            .a-tabs-item__label {\n                @mixin body;\n                font-weight: 600;\n                @media (--viewport-desktop) {\n                    @mixin lead;\n                }\n            }\n        }\n        &_less-than-4-items {\n            .a-tabs__item {\n                &:not(:last-of-type) {\n                    margin-inline-end: 24px;\n                    @media (--viewport-mobile-wide) {\n                        margin-inline-end: 40px;\n                    }\n                }\n            }\n            .a-tabs-item__label {\n                @mixin lead;\n                @media (--viewport-desktop) {\n                    @mixin title;\n                }\n            }\n        }\n    }\n    &_type {\n        &_with-icons {\n            .a-tabs {\n                &__item {\n                    cursor: pointer;\n\n                    &:not(:last-of-type) {\n                        margin-inline-end: 0;\n                    }\n                }\n            }\n\n            .a-tabs-item {\n                padding: 0 8px 40px;\n\n                @media (--viewport-desktop-large) {\n                    padding: 0 24px 40px;\n                }\n\n                .a-tabs-item__label {\n                    font-size: 16px;\n                    font-weight: 600;\n                    line-height: 24px;\n                    color: var(--av-nav-primary);\n                    white-space: normal;\n                }\n            }\n        }\n\n        &_tile {\n            .a-tabs {\n                &__content {\n                    transition-timing-function: ease-in-out;\n                }\n\n                &__underline {\n                    display: none;\n                }\n\n                &__header {\n                    margin: 0 -16px 20px;\n\n                    @media (--viewport-mobile-wide) {\n                        margin: 0 -32px 20px;\n                    }\n\n                    @media (--viewport-desktop-wide) {\n                        margin: 0 -64px 36px;\n                    }\n                }\n\n                &__list-wrapper {\n                    width: 100%;\n                    padding: 0 16px;\n\n                    @media (--viewport-mobile-wide) {\n                        padding: 0 32px;\n                    }\n\n                    @media (--viewport-desktop-wide) {\n                        padding: 0 64px;\n                    }\n\n                    &::before {\n                        display: none;\n                    }\n                }\n\n                &__item {\n                    box-shadow: var(--av-shadow-small);\n                    position: relative;\n                    padding: 0;\n                    z-index: var(--data-index, 0);\n\n                    &:not(:last-of-type) {\n                        margin-inline-end: 0;\n\n                        .a-tabs-item {\n                            border-inline-end: none;\n                        }\n                    }\n\n                    &:first-of-type {\n                        .a-tabs-item {\n                            border-top-left-radius: 4px;\n                            border-bottom-left-radius: 4px;\n                        }\n                    }\n\n                    &:last-of-type {\n                        .a-tabs-item {\n                            border-top-right-radius: 4px;\n                            border-bottom-right-radius: 4px;\n                        }\n                    }\n                }\n            }\n\n            :deep(.a-tab) {\n                .a-container {\n                    padding: 0;\n                }\n            }\n\n            .a-tabs-item {\n                display: flex;\n                justify-content: center;\n                align-items: center;\n                height: 96px;\n                padding: 24px;\n                background-color: var(--av-inversed-primary);\n                border: 1px solid var(--av-solid-brand-secondary-light);\n                color: var(--av-brand-secondary);\n\n                .a-tabs-item__label {\n                    font-size: 16px;\n                    line-height: 24px;\n                    font-weight: 600;\n                    white-space: normal;\n                    transition: color 0.3s ease-in-out;\n                }\n                &:hover {\n                    background-color: var(--av-solid-brand-accent);\n                    color: var(--av-nav-primary);\n\n                    .a-tabs-item__label {\n                        color: var(--av-nav-primary);\n                    }\n                }\n                &:focus {\n                    .a-tabs-item__label {\n                        background: none;\n                    }\n                }\n\n                &_active {\n                    background-color: var(--av-solid-brand-accent);\n\n                    &:hover {\n                        cursor: default;\n                    }\n\n                    &__label {\n                        color: var(--av-nav-primary);\n                    }\n                }\n            }\n        }\n    }\n\n    &_tile-layout {\n        &_more-than-6-items {\n            .a-tabs {\n                &__item {\n                    flex: 0 0 50%;\n\n                    @media (--viewport-mobile-wide) {\n                        flex: 0 1 100%;\n                    }\n                }\n            }\n        }\n\n        &_6-items {\n            .a-tabs {\n                &__item {\n                    flex: 0 0 50%;\n\n                    @media (--viewport-mobile-wide) {\n                        flex: 0 1 100%;\n                    }\n\n                    @media (--viewport-desktop) {\n                        flex: 0 1 100%;\n                    }\n                }\n            }\n        }\n\n        &_5-items {\n            .a-tabs {\n                &__item {\n                    flex: 0 0 50%;\n\n                    @media (--viewport-mobile-wide) {\n                        flex: 0 1 100%;\n                    }\n\n                    @media (--viewport-desktop) {\n                        flex: 0 1 100%;\n                    }\n                }\n            }\n        }\n\n        &_4-items {\n            .a-tabs {\n                &__item {\n                    flex: 0 0 50%;\n\n                    @media (--viewport-mobile-wide) {\n                        flex: 0 1 100%;\n                    }\n                }\n            }\n        }\n\n        &_3-items {\n            .a-tabs {\n                &__item {\n                    flex: 0 0 50%;\n\n                    @media (--viewport-mobile-wide) {\n                        flex: 0 0 33.33%;\n                    }\n                }\n            }\n        }\n    }\n    :deep(.a-label) {\n        white-space: nowrap;\n    }\n}\n\n.is-full-width {\n    .a-tabs__item {\n        flex: 1;\n    }\n}\n</style>\n","export const availableInBuilder: string[] = [\n    's-acp-tabs',\n    's-anchor-menu',\n    's-asset-cards',\n    's-award-compact',\n    's-award-highlight',\n    's-awards',\n    's-awards-ribbon',\n    's-cards-highlight',\n    's-cards-product',\n    's-cards-product-list',\n    's-cards-small',\n    's-cards-small-slider',\n    's-cards-support',\n    's-cards-with-icon',\n    's-compete-page',\n    's-cta',\n    's-cta-discount-code',\n    's-cta-simple',\n    's-cta-with-image',\n    's-customizable-header',\n    's-data-centers-local',\n    's-download',\n    's-event-countdown',\n    's-event-questions',\n    's-event-location',\n    's-faq',\n    's-features-large',\n    's-features-small',\n    's-g2-reviews',\n    's-header-lp-three-products',\n    's-header-lp-two-products-2026',\n    's-header-message',\n    's-header-product-new',\n    's-header-simple',\n    's-insertion',\n    's-integrations',\n    's-intro',\n    's-message-highlights',\n    's-mobile-app-highlight',\n    's-numbers',\n    's-partner-logos-carousel',\n    's-product-reviews',\n    's-promo-countdown',\n    's-requirements',\n    's-requirements-combo',\n    's-resources',\n    's-schema-switcher',\n    's-site-search',\n    's-subscription',\n    's-supported-systems',\n    's-tabs',\n    's-trial-form',\n    's-value-cards',\n    's-video-featured',\n    's-webinar',\n];\n","export const FLAG_IMG_BY_COUNTRY = new Set([\n    'au',\n    'bg',\n    'br',\n    'ca',\n    'ch',\n    'cn',\n    'cz',\n    'de',\n    'es',\n    'fr',\n    'gb',\n    'hu',\n    'il',\n    'in',\n    'it',\n    'jp',\n    'kr',\n    'nl',\n    'pl',\n    'ro',\n    'se',\n    'sg',\n    'tr',\n    'us',\n]);\n","export default {\n    data: () => ({\n        isVisibleDemoModal: false,\n    }),\n\n    methods: {\n        hasInteractionDemo(item) {\n            if (!item?.modal) return false;\n            if (!item.modal.id || !item.modal.src) return false;\n            if (!item.modal.breakpoint?.length) return true;\n            return item.modal.breakpoint.includes(this.currentBreakpoint);\n        },\n        logInteraction(item) {\n            this.isVisibleDemoModal = true;\n\n            const abbr = item.modal?.abbr || 'ACPC';\n            const hops = `demoButtonClickHops-${abbr}`;\n            const name = `demoButtonClickDate-${abbr}`;\n\n            if (!localStorage.getItem(hops)) localStorage.setItem(hops, 0);\n            if (!localStorage.getItem(name)) localStorage.setItem(name, new Date());\n        },\n    },\n};\n","import { SECTION_ID_BLOG } from '@model/const/blog.ts';\n\nexport default {\n    computed: {\n        translations() {\n            return this.$store.state.slices.items?.blog || {};\n        },\n\n        isBlog() {\n            // First check is to avoid Vue warning about missing component property\n            return 'sectionId' in this && this.sectionId === SECTION_ID_BLOG;\n        },\n\n        isOnEnLocale() {\n            return this.$store.state.geolocation.finalLocale?.startsWith('en');\n        },\n\n        enabledLocalesCPC() {\n            const toExclude = ['en-eu', 'en-gb', 'en-sg'];\n            const languages = this.translations.localeLanguageMapping || {};\n            return (this.$store.state.locales.locales || [])\n                .filter((locale) => locale.is_active_on_blog_tru && !toExclude.includes(locale.code))\n                .map((locale) => ({\n                    ...locale,\n                    language: languages[locale.code],\n                }));\n        },\n    },\n\n    methods: {\n        getSectionName(id) {\n            return id === SECTION_ID_BLOG ? 'blog' : 'tru';\n        },\n\n        getBlogPostFields(post, translations) {\n            if (!post) return null;\n\n            const sectionPath = this.getSectionName(post.section_id);\n\n            return {\n                ...post,\n                minReadTitle: translations.minRead,\n                link: `/${sectionPath}/posts/${post.slug}`,\n            };\n        },\n\n        getAuthorFields(author) {\n            if (!author) return null;\n\n            const socials = [];\n            if (author.link_linked_in) {\n                socials.push({\n                    to: author.link_linked_in,\n                    glyph: 'linkedin2',\n                });\n            }\n            if (author.link_twitter) {\n                socials.push({\n                    to: author.link_twitter,\n                    glyph: 'twitter',\n                });\n            }\n            if (author.link_website) {\n                socials.push({\n                    to: author.link_website,\n                    glyph: 'language-select',\n                });\n            }\n\n            return {\n                ...author,\n                socials,\n                link: `/blog/authors/${author.slug}`,\n            };\n        },\n\n        getNewsFields(item) {\n            if (!item) return null;\n\n            const parentSection = this.getSectionName(item.section_id);\n            const link = [parentSection, 'posts', item.slug].filter(Boolean).join('/');\n            return {\n                ...item,\n                link: `/${link}`,\n            };\n        },\n\n        getCategoryFields(category) {\n            if (!category) return null;\n\n            const parentSection = category.section_id === SECTION_ID_BLOG ? 'blog' : 'tru';\n            const link = [parentSection, 'categories', category.slug].filter(Boolean).join('/');\n            return {\n                id: category.id,\n                title: category.title,\n                link: `/${link}`,\n            };\n        },\n    },\n};\n","<template>\n    <span>\n        <teleport to=\"#teleports\">\n            <transition :name=\"transition\" @after-leave=\"doDestroy\">\n                <div\n                    v-show=\"!disabled && showPopper\"\n                    :id=\"tooltipId\"\n                    ref=\"dropdownRef\"\n                    class=\"el-popover a-popper\"\n                    :class=\"[\n                        maxWidth === 'auto-width' ? 'a-tooltip__popper--auto-width' : '',\n                        popperClass,\n                        visibleArrow ? 'a-popper--with-arrow' : ''\n                    ]\"\n                    :style=\"computedStyle\"\n                    role=\"tooltip\"\n                    :aria-hidden=\"disabled || !showPopper ? true : false\"\n                    tabindex=\"0\"\n                    @keydown.esc=\"handleEsc\"\n                    @keydown.tab=\"handleKeydown\"\n                >\n                    <div\n                        v-if=\"visibleArrow\"\n                        ref=\"arrowEl\"\n                        class=\"a-popper__arrow\"\n                        data-popper-arrow\n                    />\n                    <div v-if=\"loading && !$slots.default\" class=\"el-popover__loading\" />\n                    <div ref=\"resizableContainer\" class=\"el-popover__wrap\">\n                        <slot />\n                        <div v-if=\"$slots.actions\" class=\"el-alert__actions mx-16\">\n                            <slot name=\"actions\" />\n                        </div>\n                    </div>\n                </div>\n            </transition>\n        </teleport>\n\n        <div ref=\"triggerRef\" class=\"el-popover__reference\">\n            <slot name=\"reference\" />\n        </div>\n    </span>\n</template>\n\n<script setup>\nimport ResizeObserver from 'resize-observer-polyfill';\nimport { ref, computed, nextTick, onMounted, onBeforeUnmount, watch } from 'vue';\nimport { usePopper } from '@core/composables/usePopper';\nimport GlobalPubSub from '@utils/global-pub-sub.ts';\n\nconst props = defineProps({\n    trigger: {\n        type: String,\n        default: 'click',\n        validator: val => ['click', 'focus', 'hover', 'manual'].includes(val),\n    },\n    placement: { type: String, default: 'top' },\n    openDelay: { type: Number, default: 0 },\n    disabled: Boolean,\n    manual: Boolean,\n    popperClass: { type: String, default: '' },\n    maxWidth: { type: [String, Number], default: 'default' },\n    visibleArrow: { type: Boolean, default: true },\n    transition: { type: String, default: '' },\n});\n\nconst emit = defineEmits(['show', 'hide']);\n\nconst showPopper = ref(false);\nconst triggerRef = ref(null);\nconst dropdownRef = ref(null);\nconst resizableContainer = ref(null);\nconst tooltipId = `el-popover-${Math.floor(Math.random() * 10000)}`;\nconst timer = ref(null);\nconst arrowEl = ref(null);\nlet observer = null;\n\nconst computedStyle = computed(() => {\n    return typeof props.maxWidth === 'number'\n        ? { maxWidth: `${props.maxWidth}px` }\n        : {};\n});\n\nconst popperOptions = computed(() => ({\n    placement: props.placement,\n    modifiers: [\n        { name: 'offset', options: { offset: [0, 8] } },\n        { name: 'arrow', options: { element: arrowEl.value?.$el } },\n        { name: 'preventOverflow', options: { boundary: 'viewport' } },\n        { name: 'flip', options: { fallbackPlacements: ['top', 'right', 'left', 'bottom'] } },\n    ],\n    ...props.popperOptions,\n}));\n\nconst { initializePopper, updatePopper, destroyPopper } = usePopper(triggerRef, dropdownRef, popperOptions.value);\n\nfunction doShow() {\n    showPopper.value = true;\n    emit('show');\n}\n\nfunction doClose() {\n    showPopper.value = false;\n    emit('hide');\n}\n\nfunction doDestroy() {\n    destroyPopper();\n}\n\nfunction doToggle() {\n    showPopper.value = !showPopper.value;\n}\n\nfunction handleMouseEnter() {\n    clearTimeout(timer.value);\n    timer.value = setTimeout(doShow, props.openDelay);\n}\n\nfunction handleMouseLeave() {\n    clearTimeout(timer.value);\n    timer.value = setTimeout(doClose, 200);\n}\n\nfunction handleDocumentClick(e) {\n    const refEl = triggerRef.value;\n    const popEl = dropdownRef.value;\n    if (!refEl || !popEl || refEl.contains(e.target) || popEl.contains(e.target)) return;\n    showPopper.value = false;\n}\n\nfunction handleEsc(e) {\n    if (e.key === 'Escape' && props.trigger !== 'manual') doClose();\n}\n\nfunction handleKeydown() {\n    dropdownRef.value?.focus();\n}\n\nfunction setupListeners() {\n    const refEl = triggerRef.value;\n    const popEl = dropdownRef.value;\n    if (!refEl || !popEl) return;\n\n    refEl.setAttribute('aria-describedby', tooltipId);\n    refEl.setAttribute('tabindex', '0');\n    popEl.setAttribute('tabindex', '0');\n\n    if (props.trigger === 'click') {\n        refEl.addEventListener('click', e => {\n            if (!showPopper.value) GlobalPubSub.emit('hideAllPopovers');\n            doToggle();\n            e.stopPropagation();\n        });\n        document.addEventListener('click', handleDocumentClick, true);\n    } else if (props.trigger === 'hover') {\n        refEl.addEventListener('mouseenter', handleMouseEnter);\n        refEl.addEventListener('mouseleave', handleMouseLeave);\n        popEl.addEventListener('mouseenter', handleMouseEnter);\n        popEl.addEventListener('mouseleave', handleMouseLeave);\n    } else if (props.trigger === 'focus') {\n        if (refEl.querySelector('input, textarea')) {\n            refEl.addEventListener('focusin', doShow);\n            refEl.addEventListener('focusout', doClose);\n        } else {\n            refEl.addEventListener('mousedown', doShow);\n            refEl.addEventListener('mouseup', doClose);\n        }\n    }\n\n    refEl.addEventListener('keydown', handleKeydown);\n}\n\nonMounted(() => {\n    nextTick(() => {\n        setupListeners();\n        if (props.trigger === 'manual' && showPopper.value) {\n            nextTick(async () => {\n                await initializePopper();\n            });\n        }\n        observer = new ResizeObserver(() => updatePopper());\n        if (resizableContainer.value) observer.observe(resizableContainer.value);\n    });\n\n    GlobalPubSub.on('hideAllPopovers', doClose);\n});\n\nonBeforeUnmount(() => {\n    destroyPopper();\n    GlobalPubSub.off('hideAllPopovers', doClose);\n    document.removeEventListener('click', handleDocumentClick, true);\n    observer?.disconnect();\n});\n\nwatch(showPopper, visible => {\n    if (visible) {\n        nextTick(async () => {\n            await initializePopper();\n            requestAnimationFrame(() => {\n                updatePopper();\n            });\n        });\n    }\n});\n</script>\n\n<style scoped lang=\"postcss\">\n.el-popover {\n    @mixin caption;\n    box-shadow: 0 0 0 1px var(--av-brand-primary), var(--av-shadow-regular);\n    background: var(--av-inversed-primary);\n    color: var(--av-fixed-primary);\n    max-width: 325px;\n}\n</style>\n","import { SECTION_ID_BLOG } from '@model/const/blog.ts';\n\nexport default {\n    computed: {\n        translations() {\n            return this.$store.state.slices.items?.tru || {};\n        },\n\n        enabledLocalesCPC() {\n            const toExclude = ['en-eu', 'en-gb', 'en-sg'];\n            const languages = this.translations.common?.localeLanguageMapping || {};\n            return (this.$store.state.locales.locales || [])\n                .filter((locale) => locale.is_active_on_blog_tru && !toExclude.includes(locale.code))\n                .map((locale) => ({\n                    ...locale,\n                    language: languages[locale.code],\n                }));\n        },\n    },\n\n    methods: {\n        getSectionName(id) {\n            return id === SECTION_ID_BLOG ? 'blog' : 'tru';\n        },\n\n        getBlogPostFields(post, translations) {\n            if (!post) return null;\n\n            const sectionPath = this.getSectionName(post.section_id);\n\n            return {\n                ...post,\n                minReadTitle: translations.minRead,\n                link: `/${sectionPath}/posts/${post.slug}`,\n                categories: (post.categories || []).map((cat) => this.getCategoryFields(cat)),\n            };\n        },\n\n        getAuthorFields(author) {\n            if (!author) return null;\n\n            const socials = [];\n            if (author.link_linked_in) {\n                socials.push({\n                    to: author.link_linked_in,\n                    glyph: 'linkedin2',\n                });\n            }\n            if (author.link_twitter) {\n                socials.push({\n                    to: author.link_twitter,\n                    glyph: 'twitter',\n                });\n            }\n            if (author.link_website) {\n                socials.push({\n                    to: author.link_website,\n                    glyph: 'language-select',\n                });\n            }\n\n            return {\n                ...author,\n                socials,\n                link: `/tru/authors/${author.slug}`,\n            };\n        },\n\n        getNewsFields(item) {\n            if (!item) return null;\n\n            const parentSection = this.getSectionName(item.section_id);\n            const link = [parentSection, 'posts', item.slug].filter(Boolean).join('/');\n            return {\n                ...item,\n                link: `/${link}`,\n            };\n        },\n\n        getCategoryFields(category) {\n            if (!category) return null;\n\n            const parentSection = category.section_id === SECTION_ID_BLOG ? 'blog' : 'tru';\n            const link = [parentSection, 'categories', category.slug].filter(Boolean).join('/');\n            return {\n                id: category.id,\n                title: category.title,\n                link: `/${link}`,\n            };\n        },\n    },\n};\n","<template>\n    <div class=\"a-event-card\" :class=\"{ ...className, ...basicClassName }\">\n        <div\n            v-if=\"isLoading\"\n            v-loading=\"true\"\n            class=\"a-event-card__info-loading\"\n            el-loading-size=\"48\"\n        />\n        <template v-else>\n            <div class=\"img-wrap\">\n                <a-picture\n                    v-if=\"showImage\"\n                    class=\"img\"\n                    :link=\"image\"\n                    :alt=\"imageAlt\"\n                    :position=\"picturePosition\"\n                    fit=\"cover\"\n                />\n            </div>\n            <div class=\"info\">\n                <div class=\"date\">\n                    <template v-if=\"label && !hasEnded\">\n                        <a-glyph class=\"a-accordion__icon\" :name=\"label.glyph\" />\n                        <span>{{ label.text }}</span>\n                    </template>\n                    <template v-else-if=\"hasEnded\">\n                        <a-glyph class=\"a-accordion__icon\" name=\"i-play-round--16\" />\n                        <span>{{ webinarOnDemandText }}</span>\n                    </template>\n                    <template v-else>\n                        <a-glyph class=\"a-accordion__icon\" name=\"i-clipboard--24\" />\n                        <span>{{ date }}</span>\n                    </template>\n                </div>\n                <div v-if=\"link.text\" class=\"title\">\n                    {{ title }}\n                </div>\n                <a-link\n                    v-else\n                    v-bind=\"link\"\n                    size=\"title\"\n                    :text=\"title\"\n                    class=\"title\"\n                />\n                <div v-if=\"categories.length\" class=\"tags\">\n                    <a-label v-for=\"(tag, j) in categories\" :key=\"`${tag.text}-${j}`\" v-bind=\"getTagProps(tag)\">\n                        {{ tag.title }}\n                    </a-label>\n                </div>\n                <div class=\"desc\">\n                    {{ desc }}\n                </div>\n                <div v-if=\"!detailsAfterSpeakers\" class=\"details\">\n                    <p v-if=\"detailsText\" class=\"details-title\">\n                        {{ detailsText }}\n                    </p>\n                    <div class=\"details-items\">\n                        <div v-if=\"language\" class=\"details-item\">\n                            <a-glyph name=\"i-chat--16\" />\n                            <span>{{ language }}</span>\n                        </div>\n                        <div v-if=\"duration\" class=\"details-item\">\n                            <a-glyph name=\"i-clock--16\" />\n                            <span>{{ duration }}</span>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"bottom\" :class=\"{'with-details': detailsAfterSpeakers }\">\n                    <div v-if=\"!miniCard && speakers.length\" class=\"speakers\">\n                        <p class=\"speakers-title\">\n                            {{ speakersText }}\n                        </p>\n                        <ul class=\"first-speakers\">\n                            <li\n                                v-for=\"speaker in speakers\"\n                                :key=\"speaker.name\"\n                                class=\"first-speakers-item\"\n                            >\n                                <span class=\"first-speakers-name\">{{ speaker.name }}, </span>\n                                <span v-if=\"speaker.position\" class=\"first-speakers-position\">{{ speaker.position }}</span>\n                            </li>\n                        </ul>\n                    </div>\n                    <div v-if=\"detailsAfterSpeakers\" class=\"details\">\n                        <p v-if=\"detailsText\" class=\"details-title\">\n                            {{ detailsText }}\n                        </p>\n                        <div class=\"details-items\">\n                            <div v-if=\"language\" class=\"details-item\">\n                                <a-glyph name=\"language-select2\" />\n                                <span>{{ language }}</span>\n                            </div>\n                            <div v-if=\"duration\" class=\"details-item\">\n                                <a-glyph name=\"i-clock--16\" />\n                                <span>{{ duration }}</span>\n                            </div>\n                        </div>\n                    </div>\n                    <div v-if=\"link.text\" class=\"link-wrap\">\n                        <a-link\n                            v-if=\"miniCard\"\n                            v-bind=\"link\"\n                            :glyph=\"link.glyph || 'i-arrow-right--16'\"\n                            :size=\"link.size || 'paragraph'\"\n                            :type=\"theme === 'dark' ? 'light' : 'regular'\"\n                        />\n                        <a-button\n                            v-else\n                            class=\"link\"\n                            v-bind=\"link\"\n                            :type=\"link.type || 'main'\"\n                            :size=\"link.size || 'small'\"\n                            :glyph=\"link.glyph || 'i-arrow-right--16'\"\n                        />\n                    </div>\n                </div>\n            </div>\n        </template>\n    </div>\n</template>\n\n<script>\nimport AButton from '@core/components/button/button.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport ALabel from '@core/components/label/label.vue';\nimport ALink from '@core/components/link/link.vue';\nimport { Loading } from '@core/components/loading';\nimport APicture from '@core/components/picture/picture.vue';\nimport breakpoint from '@core/mixins/breakpoint.js';\nimport styleMixin from '@core/mixins/style.js';\n\nexport default {\n    name: 'AEventCard',\n\n    components: {\n        AGlyph,\n        AButton,\n        ALink,\n        APicture,\n        ALabel,\n    },\n\n    directives: {\n        loading: Loading.directive,\n    },\n\n    mixins: [breakpoint, styleMixin],\n\n    props: {\n        speakers: {\n            type: Array,\n            default: () => [],\n        },\n\n        webinarOnDemandText: {\n            type: String,\n            default: 'Webinar on demand',\n        },\n\n        detailsText: {\n            type: String,\n            default: undefined,\n        },\n\n        speakersText: {\n            type: String,\n            default: undefined,\n        },\n\n        hasEnded: {\n            type: Boolean,\n        },\n\n        colorScheme: {\n            type: String,\n            validator: (prop) => ['green', 'blue'].includes(prop),\n            default: 'green',\n        },\n\n        detailsAfterSpeakers: {\n            type: Boolean,\n            default: false,\n        },\n\n        categories: {\n            type: Array,\n            default: () => [],\n        },\n\n        date: {\n            type: String,\n            default: undefined,\n        },\n\n        label: {\n            type: Object,\n            default: undefined,\n        },\n\n        language: {\n            type: String,\n            default: undefined,\n        },\n\n        duration: {\n            type: String,\n            default: undefined,\n        },\n\n        title: {\n            type: String,\n            required: true,\n        },\n\n        desc: {\n            type: String,\n            required: true,\n        },\n\n        link: {\n            type: Object,\n            default: () => ({}),\n        },\n\n        miniCard: {\n            type: Boolean,\n        },\n\n        image: {\n            type: String,\n            default: undefined,\n        },\n\n        imageAlt: {\n            type: String,\n            default: undefined,\n        },\n\n        imagePosition: {\n            type: String,\n            // new cards are wide and focused off-center to the right\n            default: '67% center',\n        },\n\n        imageMobilePosition: {\n            type: String,\n            default: '74% center',\n        },\n\n        cardShadow: {\n            type: Boolean,\n        },\n\n        loading: {\n            type: Boolean,\n            default: false,\n        },\n\n        theme: {\n            type: String,\n            validator: (prop) => ['light', 'dark'].includes(prop),\n            default: 'light',\n        },\n\n        showMiniCardImage: {\n            type: Boolean,\n            default: false,\n        },\n    },\n\n    computed: {\n        isLoading() {\n            return !this.miniCard && this.loading;\n        },\n\n        className() {\n            return {\n                'shadow': this.cardShadow,\n                'mini': this.miniCard,\n                'blue': this.colorScheme === 'blue',\n                'dark': this.theme === 'dark',\n            };\n        },\n\n        picturePosition() {\n            return this.isMobile ? this.imageMobilePosition : this.imagePosition;\n        },\n\n        showImage() {\n            return (!this.miniCard || this.showMiniCardImage) && this.image;\n        },\n    },\n\n    methods: {\n        getTagProps(tag) {\n            return {\n                variant: 'neutral',\n                type: 'label',\n                layout: 'solid',\n                size: 's',\n                ...tag,\n            };\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-event-card {\n    color: var(--av-nav-primary);\n    padding: 16px;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n\n    &.shadow {\n        margin-top: 18px;\n        box-shadow: var(--av-shadow-small);\n        border-radius: 16px;\n        border: 1px solid var(--av-brand-light);\n        width: 100%;\n    }\n\n    &:not(.mini) {\n        .desc {\n            line-height: 24px;\n        }\n    }\n\n    &.mini {\n        padding: 24px 16px 8px 0;\n        flex-direction: column;\n\n        .date {\n            margin-bottom: 8px;\n        }\n        .link-wrap {\n            margin-top: 0;\n        }\n        .a-link {\n            font-weight: 700;\n        }\n        .details-title {\n            margin-bottom: 8px;\n        }\n        .img {\n            width: 100%;\n            max-width: none;\n            height: 200px;\n            max-height: none;\n            min-height: 0;\n            margin-bottom: 16px;\n        }\n    }\n\n    &.mini:not(&.shadow) {\n        .info {\n            padding-inline-start: 0;\n        }\n    }\n\n    &.blue {\n        .date {\n            color: var(--av-brand-primary);\n\n            .a-glyph {\n                fill: var(--av-brand-primary);\n            }\n        }\n\n        .details {\n            .details-item .a-glyph {\n                fill: var(--av-brand-primary);\n            }\n        }\n\n    }\n\n    &.dark {\n        color: var(--av-inversed-primary);\n\n        .date .a-glyph,\n        .details .details-item .a-glyph {\n            fill: var(--av-inversed-primary);\n        }\n\n        .date,\n        .title,\n        .desc,\n        .first-speakers-item {\n            color: var(--av-inversed-primary);\n        }\n    }\n\n    @media (--viewport-tablet) {\n        padding: 24px;\n        flex-direction: row;\n        align-items: stretch;\n    }\n\n    :deep(.a-slider__nav) {\n        margin-top: 24px;\n        margin-bottom: 16px;\n    }\n}\n\n.img-wrap {\n    display: flex;\n}\n\n.img {\n    border-radius: 8px;\n    overflow: hidden;\n    display: flex;\n    min-height: 212px;\n    max-height: 296px;\n    width: 100%;\n    height: auto;\n\n    @media (--viewport-tablet) {\n        display: block;\n        min-height: 286px;\n        max-height: none;\n        min-width: 276px;\n        max-width: 276px;\n        width: auto;\n    }\n\n    @media (--viewport-desktop) {\n        min-width: 286px;\n        max-width: 286px;\n    }\n\n    :deep(.a-picture__img) {\n        width: 100%;\n        height: 100%;\n    }\n}\n\n.info {\n    padding-top: 16px;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n\n    @media (--viewport-tablet) {\n        padding-top: 0;\n        padding-inline-start: 24px;\n    }\n}\n\n.lang {\n    @mixin body;\n\n    margin-bottom: 8px;\n    color: var(--av-brand-secondary);\n}\n\n.title {\n    @mixin title-accent;\n    margin-bottom: 8px;\n}\n\ndiv.title {\n    color: var(--av-nav-primary);\n}\n\n.desc {\n    @mixin paragraph;\n\n    margin-bottom: 8px;\n}\n\n.date {\n    @mixin body-accent;\n    color: var(--av-brand-primary);\n    display: flex;\n    align-items: center;\n\n    .a-glyph {\n        width: 16px;\n        height: 16px;\n        margin-top: 0;\n        margin-inline-end: 6px;\n        fill: var(--av-brand-primary);\n    }\n}\n\n.tags {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 8px;\n    margin-bottom: 16px;\n}\n\n.details-items {\n    @mixin descriptor;\n\n    display: flex;\n    gap: 16px;\n    align-items: center;\n}\n\n.details-item {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n\n    .a-glyph {\n        fill: var(--av-brand-primary);\n    }\n}\n\n.bottom {\n    margin-top: auto;\n    padding-top: 24px;\n\n    @media (--viewport-desktop) {\n        display: flex;\n        flex-direction: row;\n        align-items: flex-end;\n        justify-content: space-between;\n    }\n\n    .details {\n        margin-top: 8px;\n    }\n\n    &.with-details {\n        @media (--viewport-desktop) {\n            align-items: flex-start;\n            flex-wrap: wrap;\n\n            .details {\n                margin-top: 0;\n                flex-basis: 256px;\n            }\n\n            .details-items {\n                flex-direction: column;\n                align-items: flex-start;\n                gap: 0;\n            }\n\n            .link-wrap {\n                width: 100%;\n            }\n\n            .link {\n                margin-top: 24px;\n            }\n        }\n    }\n}\n\n.speakers {\n    @media (--viewport-desktop) {\n        margin-bottom: 0;\n        margin-inline-end: 24px;\n    }\n}\n\n.speakers-title,\n.details-title {\n    @mixin paragraph-accent;\n\n    color: var(--av-nav-primary);\n}\n\n\n.first-speakers-item {\n    @mixin descriptor;\n    color: var(--av-fixed-secondary);\n}\n\n.speakers-comma {\n    display: none;\n}\n\n.link-wrap {\n    margin-top: 24px;\n\n    @media (--viewport-desktop) {\n        margin-top: 0;\n    }\n}\n\n.link {\n    min-width: 240px;\n\n    svg {\n        display: none;\n    }\n\n    @media (--viewport-tablet) {\n        justify-content: space-between;\n        margin-inline-start: 0;\n\n        svg {\n            display: block;\n        }\n    }\n}\n</style>\n","import axios from 'axios';\nimport { computed, ref } from 'vue';\nimport { GOOGLE_SEARCH_CX_KEY, GOOGLE_SEARCH_API_KEY } from '@model/const/api-keys';\nimport { getLanguageCodeFromLocale } from '@utils/languages';\n\nconst localeMapping: Record<string, string> = {\n    'en-us': 'lang_en',\n    'en-en': 'lang_en',\n    'en-eu': 'lang_en',\n    'en-sg': 'lang_en',\n    'bg-bg': 'lang_bg',\n    'cs-cz': 'lang_cz',\n    'de-de': 'lang_de',\n    'es-es': 'lang_es',\n    'es-mx': 'lang_es',\n    'fr-fr': 'lang_fr',\n    'he-il': 'lang_iw',\n    'hu-hu': 'lang_hu',\n    'it-it': 'lang_it',\n    'ja-jp': 'lang_ja',\n    'ko-kr': 'lang_ko',\n    'nl-nl': 'lang_nl',\n    'pl-pl': 'lang_pl',\n    'pt-br': 'lang_pt',\n    'ro-ro': 'lang_ro',\n    'tr-tr': 'lang_tr',\n    'zh-cn': 'lang_zh-CN',\n    'zh-tw': 'lang_zh-TW',\n    'sv-se': 'lang_sv',\n};\n\nconst PAGE_SIZE = 10;\nconst MAX_PAGES = 10;\nconst MAX_RESULTS = 100;\nconst SEARCH_URL = 'https://customsearch.googleapis.com/customsearch/v1';\n\nexport function buildSiteFilterClause(links: string[], locale: string): string {\n    const language = getLanguageCodeFromLocale(locale) ?? '';\n\n    return (links || [])\n        .filter(Boolean)\n        .map((link) => link.replace(/^https?:\\/\\//, ''))\n        .map((link) => link.replace('$LOCALE', locale))\n        .map((link) => link.replace('$LANG', language))\n        .map((link) => `site:https://${link}`)\n        .join(' OR ');\n}\n\nexport interface GoogleSearchParams {\n    query: string;\n    locale: string;\n    filterClause?: string;\n    page?: number;\n}\n\nexport interface GoogleSearchResponse {\n    items?: any[];\n    searchInformation?: { totalResults?: string | number };\n    queries?: { request?: { searchTerms?: string }[] };\n    spelling?: { correctedQuery?: string };\n}\n\nexport function formattedLinkPath(path: string): string {\n    if (!path) return '';\n    return path\n        .replace(/^https?:\\/\\//gm, '')\n        .replace(/[<][/]/g, '::protected::') // protect closing html tags \"</\" from split\n        .split('/')\n        .filter(Boolean)\n        .join(' › ')\n        .replace(/::protected::/g, '</'); // restore the closing tags from protected tokens\n}\n\nexport function useGoogleSearch() {\n    const results = ref([]);\n    const totalResults = ref(0);\n    const page = ref(1);\n    const isLoading = ref(false);\n    const lastResponse = ref<GoogleSearchResponse | null>(null);\n\n    const totalPages = computed(() => {\n        const capped = Math.min(totalResults.value, MAX_RESULTS);\n        const total = Math.ceil(capped / PAGE_SIZE);\n        return total < MAX_PAGES ? total : MAX_PAGES;\n    });\n\n    async function search({ query, locale, filterClause = '', page: pageNumber = 1 }: GoogleSearchParams) {\n        page.value = pageNumber;\n        isLoading.value = true;\n\n        const start = (pageNumber - 1) * PAGE_SIZE + 1;\n        const fullQuery = filterClause ? `${query} ${filterClause}` : query;\n\n        try {\n            const response = await axios.request({\n                method: 'GET',\n                url: SEARCH_URL,\n                timeout: 10000,\n                params: {\n                    cx: GOOGLE_SEARCH_CX_KEY,\n                    key: GOOGLE_SEARCH_API_KEY,\n                    q: fullQuery,\n                    start,\n                    num: PAGE_SIZE,\n                    lr: localeMapping[locale],\n                },\n            });\n            lastResponse.value = response.data;\n            results.value = response.data?.items || [];\n            totalResults.value = Number(response.data?.searchInformation?.totalResults) || 0;\n        } catch {\n            lastResponse.value = null;\n            results.value = [];\n            totalResults.value = 0;\n        } finally {\n            isLoading.value = false;\n        }\n\n        return lastResponse.value;\n    }\n\n    function reset() {\n        results.value = [];\n        totalResults.value = 0;\n        page.value = 1;\n        lastResponse.value = null;\n    }\n\n    return {\n        results,\n        totalResults,\n        page,\n        totalPages,\n        pageSize: PAGE_SIZE,\n        isLoading,\n        lastResponse,\n        search,\n        reset,\n    };\n}\n","export default {\n    computed: {\n        translations() {\n            return this.$store.state.slices.items?.['threat-catalog'] || {};\n        },\n\n        enabledLocales() {\n            const toExclude = ['en-eu', 'en-gb', 'en-sg'];\n            const languages = this.translations.common?.localeLanguageMapping || {};\n            return (this.$store.state.locales.locales || [])\n                .filter((locale) => locale.is_active_on_blog_tru && !toExclude.includes(locale.code))\n                .map((locale) => ({\n                    ...locale,\n                    language: languages[locale.code],\n                }));\n        },\n    },\n\n    methods: {\n        getBlogPostFields(post, translations) {\n            if (!post) return null;\n\n            const slug = post.slug\n                .replace('threat-catalog-', '')\n                .replace('malware-', 'malware/');\n\n            return {\n                ...post,\n                minReadTitle: translations.minRead,\n                link: `/tru/threat-catalog/${slug}/`,\n            };\n        },\n\n        getAuthorFields(author) {\n            if (!author) return null;\n\n            const socials = [];\n            if (author.link_linked_in) {\n                socials.push({\n                    to: author.link_linked_in,\n                    glyph: 'linkedin2',\n                });\n            }\n            if (author.link_twitter) {\n                socials.push({\n                    to: author.link_twitter,\n                    glyph: 'twitter',\n                });\n            }\n            if (author.link_website) {\n                socials.push({\n                    to: author.link_website,\n                    glyph: 'language-select',\n                });\n            }\n\n            return {\n                ...author,\n                socials,\n                link: `/blog/authors/${author.slug}`,\n            };\n        },\n    },\n};\n","<template>\n    <div class=\"a-navigation-tabs\" :class=\"{ light: theme === 'light' }\">\n        <div\n            ref=\"nav\"\n            class=\"navigation\"\n            :class=\"navigationClassName\"\n            :style=\"navigationStyle\"\n        >\n            <div class=\"nav-transformer\">\n                <div ref=\"indicator\" class=\"nav-indicator\" />\n                <div ref=\"nav-items\" class=\"nav-items\">\n                    <div\n                        v-for=\"(item, i) in tabs\"\n                        :key=\"item\"\n                        class=\"nav-item\"\n                        :class=\"{ active: i === activeIndex }\"\n                        @click=\"moveTo(i)\"\n                    >\n                        <span>{{ item?.text || item }}</span>\n                        <a-glyph v-if=\"item?.glyph\" :name=\"item.glyph\" />\n                    </div>\n                </div>\n            </div>\n        </div>\n        <button\n            class=\"arrow left\"\n            :class=\"{ hidden: !leftArrowVisible }\"\n            @click=\"buttonLeftClick\"\n        >\n            <span class=\"sr-only\">Navigation arrow left</span>\n            <a-glyph name=\"i-chevron-big-left--16\" :aria-hidden=\"true\" />\n        </button>\n        <button\n            class=\"arrow right\"\n            :class=\"{ hidden: !rightArrowVisible }\"\n            @click=\"buttonRightClick\"\n        >\n            <span class=\"sr-only\">Navigation arrow right</span>\n            <a-glyph name=\"i-chevron-big-right--16\" :aria-hidden=\"true\" />\n        </button>\n    </div>\n</template>\n\n<script>\nimport throttle from 'lodash-es/throttle';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport breakpoint from '@core/mixins/breakpoint.js';\n\nexport default {\n    name: 'ANavigationTabs',\n    components: {\n        AGlyph,\n    },\n\n    mixins: [breakpoint],\n\n    props: {\n        tabs: {\n            type: Array,\n            required: true,\n        },\n        theme: {\n            type: String,\n            validator: (prop) => ['light', 'dark'].includes(prop),\n            default: 'dark',\n        },\n        activeIndex: {\n            type: Number,\n            default: 0,\n        },\n    },\n\n    emits: ['move-to'],\n\n    data: () => ({\n        leftArrowVisible: false,\n        rightArrowVisible: false,\n        navOffset: 0,\n        onResize: null,\n        onTransitionEnd: null,\n    }),\n\n    computed: {\n        navigationClassName() {\n            return {\n                'with-left-arrow': this.leftArrowVisible,\n                'with-right-arrow': this.rightArrowVisible,\n            };\n        },\n\n        navigationStyle() {\n            return {\n                '--nav-offset': `${this.navOffset}px`,\n            };\n        },\n    },\n\n    watch: {\n        activeIndex(value) {\n            if (value < 0) return;\n            this.stateChange();\n        },\n    },\n\n    mounted() {\n        this.onResize = throttle(this.stateChange, 150);\n        window.addEventListener('resize', this.onResize);\n\n        this.onTransitionEnd = () => {\n            const nav = this.$refs.nav;\n            const items = this.$refs['nav-items'];\n            if (!nav || !items) return;\n\n            this.checkArrowState(nav, items);\n        };\n\n        this.$refs.indicator.addEventListener('transitionend', this.onTransitionEnd);\n\n        this.stateChange();\n    },\n\n    beforeDestroy() {\n        window.removeEventListener('resize', this.onResize);\n        this.$refs.indicator?.removeEventListener('transitionend', this.onTransitionEnd);\n\n        this.onResize = null;\n        this.onTransitionEnd = null;\n    },\n\n    methods: {\n        stateChange() {\n            requestAnimationFrame(() => {\n                const nav = this.$refs.nav;\n                const items = this.$refs['nav-items'];\n                const indicator = this.$refs.indicator;\n\n                if (!nav || !items || !indicator) return;\n\n                this.moveIndicator(items, indicator);\n                this.moveNavigation(nav, items);\n                this.checkArrowState(nav, items);\n            });\n        },\n\n        moveIndicator(items, indicatorEl) {\n            if (!items || !indicatorEl) return;\n            const el = indicatorEl;\n            const children = items.children;\n\n            if (!children || this.activeIndex < 0 || this.activeIndex >= children.length) {\n                el.style.width = '0px';\n                el.style.left = '0px';\n                return;\n            }\n\n            const activeElement = children[this.activeIndex];\n            if (!activeElement) return;\n\n            const left = activeElement.offsetLeft;\n            const width = activeElement.offsetWidth;\n\n            el.style.left = `${left}px`;\n            el.style.width = `${width}px`;\n        },\n\n        checkArrowState(nav, items) {\n            this.leftArrowVisible = false;\n            this.rightArrowVisible = false;\n\n            const parentRect = nav.getBoundingClientRect();\n            const children = items.children;\n\n            for (let i = 0; i < children.length; i++) {\n                const rect = children[i].getBoundingClientRect();\n\n                if (rect.left < parentRect.left) {\n                    this.leftArrowVisible = true;\n                } else if (rect.right > parentRect.right) {\n                    this.rightArrowVisible = true;\n                }\n\n                if (this.leftArrowVisible && this.rightArrowVisible) break;\n            }\n        },\n\n        // moves active element to the center of navigation if possible\n        moveNavigation(nav, items) {\n            if (!nav || !items) {\n                this.navOffset = 0;\n                return;\n            }\n            const children = items.children;\n            if (!children || this.activeIndex < 0 || this.activeIndex >= children.length) {\n                this.navOffset = 0;\n                return;\n            }\n\n            const activeElement = children[this.activeIndex];\n            if (!activeElement) return;\n\n            const PADDING = this.isMobile ? 6 : 8;\n            const containerWidth = nav.offsetWidth;\n            const itemsWidth = items.offsetWidth;\n            const activeWidth = activeElement.offsetWidth;\n            const activeLeft = activeElement.offsetLeft;\n\n            const maxOffset = containerWidth - itemsWidth - PADDING * 2;\n            let offset = containerWidth / 2 - activeWidth / 2 - activeLeft - PADDING;\n\n            offset = Math.min(0, offset);\n            offset = Math.max(maxOffset, offset);\n\n            this.navOffset = offset;\n        },\n\n        buttonLeftClick() {\n            const activeIndex = Math.max(0, this.activeIndex - 1);\n            this.$emit('move-to', activeIndex);\n        },\n\n        buttonRightClick() {\n            const activeIndex = Math.min(this.tabs.length - 1, this.activeIndex + 1);\n            this.$emit('move-to', activeIndex);\n        },\n\n        moveTo(index) {\n            const activeIndex = index;\n            this.$emit('move-to', activeIndex);\n        },\n    },\n};\n</script>\n\n<style scoped lang=\"postcss\">\n.a-navigation-tabs {\n    --nav-offset: 0px;\n    --fade-offset: 30px;\n    --fade-width: 24px;\n    max-width: 100%;\n    margin-top: 42px;\n    position: relative;\n    background: rgba(64, 139, 234, 0.20);\n    backdrop-filter: blur(8px);\n    border-radius: 32px;\n    width: 100%;\n    margin-inline: auto;\n    overflow: hidden;\n\n    @media (--viewport-desktop) {\n        --fade-offset: 40px;\n        --fade-width: 24px;\n    }\n\n    &.light {\n        background: rgba(213, 226, 246, 0.50);\n        .navigation {\n            color: var(--av-brand-primary);\n        }\n    }\n}\n\n.navigation {\n    @mixin caption-accent;\n    position: relative;\n    white-space: nowrap;\n    height: 42px;\n    padding: 6px;\n    color: var(--av-nav-primary);\n\n    &.with-left-arrow {\n        mask-image: linear-gradient(\n            90deg,\n            transparent 0,\n            transparent var(--fade-offset),\n            var(--av-nav-primary) calc(var(--fade-offset) + var(--fade-width))\n        );\n    }\n\n    &.with-right-arrow {\n        mask-image: linear-gradient(\n            90deg,\n            var(--av-nav-primary) calc(100% - var(--fade-offset) - var(--fade-width)),\n            transparent calc(100% - var(--fade-offset)),\n            transparent\n        );\n    }\n\n    &.with-left-arrow.with-right-arrow {\n        mask-image: linear-gradient(\n            90deg,\n            transparent 0,\n            transparent var(--fade-offset),\n            var(--av-nav-primary) calc(var(--fade-offset) + var(--fade-width)),\n            var(--av-nav-primary) calc(100% - var(--fade-offset) - var(--fade-width)),\n            transparent calc(100% - var(--fade-offset)),\n            transparent\n        );\n    }\n\n    @media (--viewport-tablet) {\n        @mixin paragraph-accent;\n        padding: 8px;\n        height: 56px;\n    }\n}\n\n.nav-items {\n    --nav-offset: 0px;\n    --fade-offset: 30px;\n    --fade-width: 24px;\n    display: flex;\n    flex-wrap: nowrap;\n    align-items: center;\n    width: fit-content;\n    min-width: 100%;\n    height: 100%;\n}\n\n.nav-item {\n    display: flex;\n    align-items: center;\n    padding: 6px 12px;\n    gap: 8px;\n    flex-shrink: 0;\n    height: 30px;\n    cursor: pointer;\n    border-radius: 24px;\n    transition: color 100ms ease-out;\n    justify-content: center;\n    flex-grow: 1;\n    color: var(--av-nav-primary);\n\n    @media (--viewport-tablet) {\n        height: 40px;\n        text-align: center;\n    }\n\n    &:hover {\n        color: var(--av-brand-primary);\n    }\n}\n\n.nav-transformer {\n    transform: translateX(var(--nav-offset));\n    transition-property: transform;\n    transition-duration: 320ms;\n    transition-timing-function: ease-out;\n}\n\n.nav-indicator {\n    z-index: -1;\n    position: absolute;\n    top: 0;\n    bottom: 0;\n    left: 0;\n    width: 0;\n    background: var(--av-inversed-primary);\n    border-radius: 24px;\n    transition-property: left, width;\n    transition-duration: 320ms;\n    transition-timing-function: ease-out;\n}\n\n.arrow {\n    position: absolute;\n    top: 0;\n    height: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n\n    &.left {\n        inset-inline-start: 0;\n        padding-inline: 10px 8px;\n\n        @media (--viewport-desktop) {\n            padding-inline: 16px 10px;\n        }\n    }\n\n    &.right {\n        inset-inline-end: 0;\n        padding-inline: 8px 10px;\n\n        @media (--viewport-desktop) {\n            padding-inline: 10px 16px;\n        }\n    }\n\n    &.hidden {\n        display: none;\n    }\n\n    .a-glyph {\n        fill: var(--av-brand-primary);\n    }\n}\n\n.fade-in-enter-active,\n.fade-in-leave-active {\n    transition: opacity 320ms ease;\n}\n\n.fade-in-enter-active {\n    top: 0;\n    position: absolute;\n    width: 100%;\n    height: 100%;\n}\n\n.fade-in-enter,\n.fade-in-leave-to {\n    opacity: 0;\n}\n</style>\n","export const contentProps = {\n    id: { type: String },\n    title: { type: String },\n    lead: { type: String },\n    bodyText: { type: String },\n};\n","import { computed } from 'vue';\nimport { BORDERS, COLORS } from '@model/slices/basic-slice.js';\n\nexport const styleProps = {\n    margin: { type: String, default: undefined, required: false },\n    padding: { type: String, default: undefined, required: false },\n    noBottomPadding: { type: Boolean, default: false },\n    borderTop: { type: String, validator: (v) => !v || BORDERS.includes(v) },\n    borderBottom: { type: String, validator: (v) => !v || BORDERS.includes(v) },\n    background: {\n        type: String,\n        validator: (v) => v === undefined || COLORS.includes(v),\n        default: 'white',\n    },\n};\n\nexport function useStyle(props: any) {\n    const className = computed(() => ({\n        's-slice_no-bottom-padding': props.noBottomPadding,\n        's-slice_border-bottom': props.borderBottom,\n        [`s-slice_border-bottom_${props.borderBottom}`]: props.borderBottom,\n        's-slice_border-top': props.borderTop,\n        [`s-slice_border-top_${props.borderTop}`]: props.borderTop,\n        [`s-slice_background_${props.background}`]: props.background,\n        ...(props.padding ? { [props.padding]: true } : {}),\n        ...(props.margin ? { [props.margin]: true } : {}),\n    }));\n    return { className };\n}\n","<template>\n    <div class=\"s-side-menu-content\">\n        <!-- ================= TABS ================= -->\n        <template v-if=\"type === 'tabs' && activeTabSlice\">\n            <component\n                :is=\"getComponent(activeTabSlice.name)\"\n                v-bind=\"activeTabSlice.data\"\n                :key=\"activeTabId || activeTabSlice.name\"\n                :ref=\"activeTabId\"\n                :data-anchor-id=\"activeTabId\"\n            />\n        </template>\n\n        <!-- ================= LINKS ================= -->\n        <template v-else-if=\"type === 'links'\">\n            <component\n                :is=\"getComponent(slice.name)\"\n                v-for=\"slice in slices\"\n                v-bind=\"slice.data\"\n                :id=\"getSliceId(slice)\"\n                :key=\"getSliceId(slice)\"\n                :ref=\"getSliceId(slice)\"\n            />\n        </template>\n\n        <!-- ================= COMBINED ================= -->\n        <template v-else-if=\"type === 'combined'\">\n            <div\n                v-for=\"item in slices\"\n                :key=\"getSliceId(item)\"\n            >\n                <template v-if=\"activeElement === getSliceId(item)\">\n                    <component\n                        :is=\"getComponent(child.name)\"\n                        v-for=\"child in item.slices\"\n                        v-bind=\"child.data\"\n                        :id=\"getSliceId(child)\"\n                        :key=\"getSliceId(child)\"\n                        :ref=\"getSliceId(child)\"\n                    />\n                </template>\n            </div>\n        </template>\n    </div>\n</template>\n\n<script setup>\nimport { computed, watchEffect } from 'vue';\nimport { registerSlices } from '@utils/dynamic-slices-resolver';\n\ndefineOptions({\n    name: 'SSideMenuContent',\n});\n\nconst props = defineProps({\n    type: {\n        type: String,\n        default: 'tabs',\n        validator: (value) => ['tabs', 'links', 'combined'].includes(value),\n    },\n\n    slices: {\n        type: Array,\n        default: () => [],\n    },\n\n    activeElement: {\n        type: String,\n        default: '',\n    },\n});\n\nfunction normalizeId(id) {\n    return String(id || '').replace(/^#/, '').trim();\n}\n\nfunction getSliceId(slice) {\n    return normalizeId(slice?.info?.id);\n}\n\nconst activeTabSlice = computed(() =>\n    props.slices.find((x) => getSliceId(x) === props.activeElement),\n);\n\nconst activeTabId = computed(() =>\n    getSliceId(activeTabSlice.value),\n);\n\nconst componentsRegistry = {};\n\nfunction flattenSlices(items = []) {\n    return items.flatMap((item) => {\n        const current = item?.name ? [{ name: item.name, data: item.data }] : [];\n        const children = Array.isArray(item?.slices) ? flattenSlices(item.slices) : [];\n        return [...current, ...children];\n    });\n}\n\nfunction resolveSlices() {\n    const normalizedSlices = flattenSlices(props.slices);\n\n    /*\n        This code is required here, because we had occurances of incorrect JSON structure passed via admin panel\n        The example was when s-compete-page passed to s-tabs via awardsTabs object instead of slices array\n        Our dynamic resolver requires the slice to be passing \"slices\" array and having { data, name } inside\n        Not \"awardsTabs\": { \"slices\": [{ data, name }] }\n        Other example was s-documentation trough side-menu, so we should remove this code only if we resolve all such cases.\n    */\n\n    registerSlices({\n        pageBody: normalizedSlices,\n        componentRegistrar: (name, component) => {\n            componentsRegistry[name] = component;\n        },\n    });\n}\n\nfunction getComponent(name) {\n    const component = componentsRegistry[name];\n    return component;\n}\n\nwatchEffect(() => {\n    resolveSlices();\n});\n</script>\n\n<style lang=\"postcss\">\n.s-side-menu-content {\n    @media (--viewport-desktop) {\n        .s-slice:first-child {\n            padding-top: 0;\n        }\n    }\n\n    .a-container {\n        padding: 0;\n    }\n}\n</style>\n","<template>\n    <component :is=\"tag\" v-if=\"text\" class=\"s-side-menu-control__group\">\n        <a-glyph\n            v-if=\"glyph\"\n            :name=\"glyph\"\n            class=\"s-side-menu-control__group-icon\"\n        />\n        <span class=\"s-side-menu-control__group-title\">{{ text }}</span>\n    </component>\n</template>\n\n<script setup>\nimport AGlyph from '@core/components/glyph/glyph.vue';\n\ndefineProps({\n    text: {\n        type: String,\n        default: null,\n    },\n    glyph: {\n        type: String,\n        default: null,\n    },\n    tag: {\n        type: String,\n        default: 'li',\n    },\n});\n</script>\n","<template>\n    <li class=\"s-side-menu-control__item\">\n        <component\n            :is=\"tag\"\n            class=\"s-side-menu-control__element\"\n            :class=\"className\"\n            v-bind=\"bindAttrs\"\n            @click=\"onClick\"\n        >\n            {{ label }}\n\n            <span\n                v-if=\"showCounter\"\n                class=\"s-side-menu-control__element-counter\"\n            >\n                {{ counter }}\n            </span>\n        </component>\n    </li>\n</template>\n\n<script setup>\nimport { computed } from 'vue';\n\nconst props = defineProps({\n    tag: {\n        type: String,\n        default: 'button',\n    },\n    label: {\n        type: String,\n        required: true,\n    },\n    href: {\n        type: String,\n        default: undefined,\n    },\n    className: {\n        type: [String, Array, Object],\n        default: null,\n    },\n    showCounter: {\n        type: Boolean,\n        default: false,\n    },\n    counter: {\n        type: [String, Number],\n        default: null,\n    },\n});\n\nconst emit = defineEmits(['click']);\n\nconst bindAttrs = computed(() => {\n    if (props.tag === 'a') {\n        return { href: props.href };\n    }\n\n    return { type: 'button' };\n});\n\nfunction onClick(event) {\n    emit('click', event);\n}\n</script>\n","<template>\n    <div ref=\"menu\" class=\"s-side-menu-control\">\n        <!-- ================= TABS OR LINKS ================= -->\n        <template v-if=\"type === 'tabs' || type === 'links'\">\n            <ul class=\"s-side-menu-control__list\">\n                <template v-for=\"(group, gIndex) in listGroups\" :key=\"group.id || gIndex\">\n                    <side-menu-group-header\n                        :text=\"group.text\"\n                        :glyph=\"group.glyph\"\n                    />\n\n                    <side-menu-list-item\n                        v-for=\"item in group.items\"\n                        :key=\"item.id\"\n                        :tag=\"item.tag\"\n                        :label=\"item.label\"\n                        :href=\"item.href\"\n                        :class-name=\"getClassElement(item.raw)\"\n                        :show-counter=\"item.counter !== null\"\n                        :counter=\"item.counter\"\n                        @click=\"onChange(item.id)\"\n                    />\n                </template>\n            </ul>\n\n            <el-select\n                v-if=\"isMounted\"\n                class=\"s-side-menu-control__select\"\n                :model-value=\"activeElement\"\n                @change=\"onChange\"\n            >\n                <template #selectSuffix>\n                    <span class=\"s-side-menu-control__element-counter select-counter\">\n                        {{ hasCounter(activeItem) ? activeItem?.data?.cards?.length : '' }}\n                    </span>\n                </template>\n                <template v-if=\"hasGroups\">\n                    <template\n                        v-for=\"(group, gIndex) in groupedSlices\"\n                        :key=\"group.id || `g-${gIndex}`\"\n                    >\n                        <el-option-group\n                            v-if=\"group.text\"\n                            :label=\"group.text\"\n                            :disabled=\"Boolean(group.disabled)\"\n                        >\n                            <el-option\n                                v-for=\"item in group.items\"\n                                :key=\"getSliceId(item)\"\n                                :value=\"getSliceId(item)\"\n                                :label=\"item.info.caption\"\n                                :hide-on-resize=\"type === 'tabs' && isDesktop\"\n                            >\n                                <template #suffix>\n                                    <span\n                                        v-if=\"hasCounter(item)\"\n                                        class=\"s-side-menu-control__element-counter select-counter\"\n                                    >\n                                        {{ item.data.cards.length }}\n                                    </span>\n                                </template>\n                            </el-option>\n                        </el-option-group>\n\n                        <template v-else>\n                            <el-option\n                                v-for=\"item in group.items\"\n                                :key=\"getSliceId(item)\"\n                                :value=\"getSliceId(item)\"\n                                :label=\"item.info.caption\"\n                                :hide-on-resize=\"type === 'tabs' && isDesktop\"\n                            >\n                                <template #suffix>\n                                    <span\n                                        v-if=\"hasCounter(item)\"\n                                        class=\"s-side-menu-control__element-counter select-counter\"\n                                    >\n                                        {{ item.data.cards.length }}\n                                    </span>\n                                </template>\n                            </el-option>\n                        </template>\n                    </template>\n                </template>\n\n                <template v-else>\n                    <el-option\n                        v-for=\"item in flatSlices\"\n                        :key=\"getSliceId(item)\"\n                        :value=\"getSliceId(item)\"\n                        :label=\"item.info.caption\"\n                        :hide-on-resize=\"type === 'tabs' && isDesktop\"\n                    >\n                        <template #suffix>\n                            <span\n                                v-if=\"hasCounter(item)\"\n                                class=\"s-side-menu-control__element-counter select-counter\"\n                            >\n                                {{ item.data.cards.length }}\n                            </span>\n                        </template>\n                    </el-option>\n                </template>\n            </el-select>\n        </template>\n\n        <!-- ================= COMBINED ================= -->\n        <div v-else-if=\"type === 'combined'\" class=\"s-side-menu-control__combined-wrapper\">\n            <el-select\n                v-if=\"isMounted\"\n                class=\"s-side-menu-control__select\"\n                :model-value=\"combinedMobileValue\"\n                @change=\"onCombinedMobileChange\"\n            >\n                <template #selectSuffix>\n                    <span class=\"s-side-menu-control__element-counter select-counter\">\n                        {{ hasCounter(activeItem) ? activeItem?.data?.cards?.length : '' }}\n                    </span>\n                </template>\n                <!-- with groups -->\n                <template v-if=\"hasGroups\">\n                    <template\n                        v-for=\"(group, gIndex) in combinedSelectGroups\"\n                        :key=\"group.id || `g-${gIndex}`\"\n                    >\n                        <el-option-group\n                            v-if=\"group.text\"\n                            :label=\"group.text\"\n                            :disabled=\"Boolean(group.disabled)\"\n                        >\n                            <template v-for=\"parent in group.items\" :key=\"getSliceId(parent)\">\n                                <!-- parent -->\n                                <el-option :value=\"getSliceId(parent)\" :label=\"parent.info.caption\" />\n\n                                <!-- children -->\n                                <template v-if=\"showChildren(parent)\">\n                                    <el-option\n                                        v-for=\"child in parent.slices || []\"\n                                        :key=\"getSliceId(child)\"\n                                        :value=\"getSliceId(child)\"\n                                        class=\"child-option\"\n                                        :label=\"child.info.caption\"\n                                    >\n                                        <template #suffix>\n                                            <span v-if=\"hasCounter(child)\" class=\"s-side-menu-control__element-counter select-counter\">\n                                                {{ child.data.cards.length }}\n                                            </span>\n                                        </template>\n                                    </el-option>\n                                </template>\n                            </template>\n                        </el-option-group>\n\n                        <!-- ungrouped (no title) -->\n                        <template v-else>\n                            <template v-for=\"parent in group.items\" :key=\"getSliceId(parent)\">\n                                <el-option :value=\"getSliceId(parent)\" :label=\"parent.info.caption\" />\n                                <template v-if=\"showChildren(parent)\">\n                                    <el-option\n                                        v-for=\"child in parent.slices || []\"\n                                        :key=\"getSliceId(child)\"\n                                        :value=\"getSliceId(child)\"\n                                        class=\"child-option\"\n                                        :label=\"child.info.caption\"\n                                    >\n                                        <template #suffix>\n                                            <span v-if=\"hasCounter(child)\" class=\"s-side-menu-control__element-counter select-counter\">\n                                                {{ child.data.cards.length }}\n                                            </span>\n                                        </template>\n                                    </el-option>\n                                </template>\n                            </template>\n                        </template>\n                    </template>\n                </template>\n\n                <!-- no groups -->\n                <template v-else>\n                    <template v-for=\"parent in slices\" :key=\"getSliceId(parent)\">\n                        <el-option :value=\"getSliceId(parent)\" :label=\"parent.info.caption\" />\n                        <template v-if=\"showChildren(parent)\">\n                            <el-option\n                                v-for=\"child in parent.slices || []\"\n                                :key=\"getSliceId(child)\"\n                                :value=\"getSliceId(child)\"\n                                class=\"child-option\"\n                                :label=\"child.info.caption\"\n                            >\n                                <template #suffix>\n                                    <span v-if=\"hasCounter(child)\" class=\"s-side-menu-control__element-counter select-counter\">\n                                        {{ child.data.cards.length }}\n                                    </span>\n                                </template>\n                            </el-option>\n                        </template>\n                    </template>\n                </template>\n            </el-select>\n\n            <a-accordion one-only-mode class=\"s-side-menu-control__list\">\n                <template\n                    v-for=\"(group, gIndex) in combinedSelectGroups\"\n                    :key=\"group.id || gIndex\"\n                >\n                    <!-- group header (same look as tabs/links) -->\n                    <side-menu-group-header\n                        :text=\"group.text\"\n                        :glyph=\"group.glyph\"\n                        tag=\"div\"\n                    />\n\n                    <a-accordion-item v-for=\"item in group.items\" :key=\"getSliceId(item)\">\n                        <template #title>\n                            <button\n                                class=\"s-side-menu-control__element a-accordion__title\"\n                                :class=\"getClassElement(item)\"\n                                @click=\"onChange(getSliceId(item))\"\n                            >\n                                <a-glyph\n                                    v-if=\"item.slices?.length > 1\"\n                                    class=\"s-side-menu-control__arrow\"\n                                    name=\"drop-down\"\n                                />\n                                {{ item.info.caption }}\n                            </button>\n                        </template>\n\n                        <ul\n                            v-if=\"item.slices?.length > 1 && !isAggregateCombined\"\n                            class=\"s-side-menu-control__sublist\"\n                        >\n                            <li\n                                v-for=\"child in item.slices\"\n                                :key=\"getSliceId(child)\"\n                                class=\"s-side-menu-control__subitem\"\n                            >\n                                <button\n                                    type=\"button\"\n                                    class=\"s-side-menu-control__link a-link\"\n                                    @click=\"onCombinedDesktopChildClick(item, child)\"\n                                >\n                                    {{ child.info.caption }}\n                                </button>\n                            </li>\n                        </ul>\n                    </a-accordion-item>\n                </template>\n            </a-accordion>\n        </div>\n    </div>\n</template>\n\n<script setup>\nimport { computed, ref, watch, onMounted } from 'vue';\nimport AAccordionItem from '@core/components/accordion/accordion-item.vue';\nimport AAccordion from '@core/components/accordion/accordion.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport ElOptionGroup from '@core/components/select/option-group.vue';\nimport ElOption from '@core/components/select/option.vue';\nimport ElSelect from '@core/components/select/select.vue';\nimport { useBreakpoint } from '@core/composables/useBreakpoint';\nimport { getElementPath } from '@utils/analytics.ts';\nimport SideMenuGroupHeader from './side-menu-group-header.vue';\nimport SideMenuListItem from './side-menu-list-item.vue';\n\ndefineOptions({ name: 'SSideMenuControl' });\n\nconst emit = defineEmits(['tab-change']);\n\nconst props = defineProps({\n    activeElement: {\n        type: String,\n        required: true,\n    },\n    groups: {\n        type: Array,\n        default: () => [],\n    },\n    type: {\n        type: String,\n        required: true,\n    },\n    slices: {\n        type: Array,\n        required: true,\n    },\n});\n\nconst menu = ref(null);\nconst isMounted = ref(false);\nconst combinedMobileValue = ref('');\n\nconst { isDesktop } = useBreakpoint();\n\nconst hasGroups = computed(() => Array.isArray(props.groups) && props.groups.length > 0);\nconst groupedSlices = computed(() => {\n    if (!hasGroups.value) return [{ id: null, items: props.slices }];\n\n    const map = new Map();\n    props.groups.forEach((group) => map.set(group.id, { ...group, items: [] }));\n\n    const ungrouped = { id: '__ungrouped', text: null, glyph: null, items: [] };\n\n    props.slices.forEach((slice) => {\n        if (slice.groupId && map.has(slice.groupId)) {\n            map.get(slice.groupId).items.push(slice);\n        } else {\n            ungrouped.items.push(slice);\n        }\n    });\n\n    if (ungrouped.items.length) map.set('__ungrouped', ungrouped);\n    return Array.from(map.values()).filter((g) => g.items?.length);\n});\n\nconst flatSlices = computed(() => groupedSlices.value.flatMap((g) => g.items));\nconst activeItem = computed(() => flatSlices.value.find((el) => el.info.id === props.activeElement));\n\nconst listGroups = computed(() => groupedSlices.value.map((group) => ({\n    id: group.id,\n    text: group.text,\n    glyph: group.glyph,\n    items: group.items.map((item) => ({\n        id: getSliceId(item),\n        label: item.info.caption,\n        href: props.type === 'links' ? (item.info.link || `#${getSliceId(item)}`) : undefined,\n        tag: props.type === 'links' ? 'a' : 'button',\n        counter: hasCounter(item) ? item?.data?.cards?.length : null,\n        raw: item,\n    })),\n})));\n\n/**\n * IMPORTANT: global detection for \"all docs\" aggregate combined mode.\n * If ANY parent has children with empty captions => never show children anywhere.\n */\nconst isAggregateCombined = computed(() => {\n    if (props.type !== 'combined') return false;\n\n    return (props.slices || []).some((parent) => {\n        const children = parent?.slices || [];\n        return children.length > 1 && children.every((c) => !c?.info?.caption);\n    });\n});\n\nconst combinedSelectGroups = computed(() => {\n    if (props.type !== 'combined') return [];\n\n    const map = new Map();\n    (props.groups || []).forEach((g) => map.set(g.id, { ...g, items: [] }));\n\n    const ungrouped = { id: '__ungrouped', text: null, glyph: null, items: [] };\n    (props.slices || []).forEach((parent) => {\n        const children = Array.isArray(parent?.slices) ? parent.slices : [];\n        const groupId = parent?.groupId || children.find((c) => c?.groupId)?.groupId;\n\n        if (groupId && map.has(groupId)) map.get(groupId).items.push(parent);\n        else ungrouped.items.push(parent);\n    });\n\n    if (ungrouped.items.length) map.set('__ungrouped', ungrouped);\n\n    return Array.from(map.values()).filter((g) => g.items?.length);\n});\n\nwatch(\n    () => props.activeElement,\n    (val) => {\n        combinedMobileValue.value = val;\n    },\n    { immediate: true },\n);\n\nonMounted(() => {\n    isMounted.value = true;\n});\n\nfunction normalizeId(id) {\n    return String(id || '')\n        .replace(/^#/, '')\n        .trim();\n}\n\nfunction getSliceId(item) {\n    return normalizeId(item?.info?.id);\n}\n\nfunction hasCounter(item) {\n    return item?.data?.counter;\n}\n\nfunction getClassElement(item) {\n    return {\n        's-side-menu-control__element_with-counter': hasCounter(item),\n        's-side-menu-control__element_active': getSliceId(item) === props.activeElement,\n    };\n}\n\nfunction showChildren(parent) {\n    return !isAggregateCombined.value && (parent?.slices || []).length > 1;\n}\n\nfunction onChange(event) {\n    const normalizedEvent = normalizeId(event);\n    const index = (props.slices || []).findIndex(\n        (item) => getSliceId(item) === normalizedEvent,\n    );\n    if (index === -1) return;\n\n    const active = props.slices[index];\n\n    if (active?.info?.link) {\n        window.location.assign(active.info.link);\n        return;\n    }\n\n    const info = active?.info || {};\n\n    window.dataLayer = window.dataLayer || [];\n    window.dataLayer.push({\n        event: 'Acronis',\n        eventCategory: 'Interactions',\n        eventAction: 'Side Menu',\n        eventLabel: info.caption || '',\n        eventContent: info.caption || '',\n        eventLocation: getElementPath(menu.value?.children?.[0]),\n        eventButton: (index + 1).toString(),\n        ...info.event,\n    });\n\n    emit('tab-change', normalizedEvent);\n}\n\nfunction getCombinedTargetByAnyId(anyId) {\n    const id = normalizeId(anyId);\n    const parent = (props.slices || []).find((p) => getSliceId(p) === id);\n    if (parent) return { parentId: id, childId: null };\n\n    const parentByChild = (props.slices || []).find(\n        (p) => Array.isArray(p?.slices) && p.slices.some((c) => getSliceId(c) === id),\n    );\n\n    return parentByChild\n        ? { parentId: getSliceId(parentByChild), childId: id }\n        : { parentId: id, childId: null };\n}\n\nfunction onCombinedMobileChange(value) {\n    const { parentId, childId } = getCombinedTargetByAnyId(value);\n\n    emit('tab-change', parentId, undefined, {\n        scrollToId: childId || parentId,\n        shouldScroll: true,\n        allowSameId: true,\n        syncHash: false,\n    });\n}\n\nfunction onCombinedDesktopChildClick(parent, child) {\n    const parentId = getSliceId(parent);\n    const childId = getSliceId(child);\n\n    emit('tab-change', parentId, undefined, {\n        scrollToId: childId,\n        shouldScroll: true,\n        allowSameId: true,\n        syncHash: false,\n    });\n}\n</script>\n\n<style lang=\"postcss\" scoped>\n.s-side-menu-control {\n  background: white;\n  border: 1px solid rgba(26, 96, 179, 0.15);\n  border-radius: 4px;\n\n  @media (--viewport-desktop) {\n    top: 88px;\n    max-height: calc(100vh - 88px);\n    border: none;\n    overflow-y: auto;\n    scrollbar-width: none;\n    -ms-overflow-style: none;\n    background: rgba(255, 255, 255, 0);\n  }\n\n  &--sticky {\n    position: sticky;\n    top: 20px;\n  }\n\n  :deep(.el-select-group) {\n    &__title {\n      @mixin note-accent;\n      padding: 8px 20px 8px;\n      color: var(--av-brand-primary);\n      text-transform: uppercase;\n    }\n\n    .child-option {\n      padding-inline-start: 40px;\n    }\n  }\n\n  :deep(.el-select-group__wrap.is-visible) {\n    &:has(+ .el-select-group__wrap.is-visible) {\n      margin-bottom: 8px;\n      padding-bottom: 8px;\n    }\n  }\n\n  &__list {\n    display: none;\n\n    @media (--viewport-desktop) {\n      display: block;\n    }\n  }\n\n  &__select {\n    display: block;\n\n    :deep(.el-input) {\n      &__icon {\n        color: #024aa2 !important;\n      }\n\n      &__editor--absolute-position {\n        color: var(--av-nav-primary);\n        font-size: 16px;\n      }\n    }\n\n    @media (--viewport-desktop) {\n      display: none !important;\n    }\n  }\n\n  &__arrow {\n    margin-inline-end: 11px;\n    fill: var(--av-nav-primary);\n    transform: rotate(-90deg);\n    transition: transform 0.3s ease-out;\n  }\n\n  &__sublist {\n    padding: 16px 40px 16px;\n  }\n\n  &__subitem {\n    &:not(:last-of-type) {\n      margin-bottom: 16px;\n    }\n  }\n\n  &__link {\n    color: var(--av-nav-primary);\n\n    &:hover {\n      color: var(--av-nav-secondary);\n    }\n  }\n\n  &__combined-wrapper {\n    &--aggregate {\n      display: none;\n    }\n\n    :deep(.s-side-menu-control) {\n      &__select {\n        @media (--viewport-desktop) {\n          display: none;\n        }\n      }\n\n      &__list {\n        display: none;\n\n        @media (--viewport-desktop) {\n          display: block;\n        }\n      }\n    }\n  }\n\n  :deep(.a-accordion-item) {\n    border: 0;\n\n    .title {\n      padding: 0;\n    }\n\n    .content {\n      @mixin paragraph;\n    }\n\n    .content-wrapper {\n      padding: 0;\n    }\n\n    &.active {\n      .s-side-menu-control__arrow {\n        transform: rotate(0);\n      }\n    }\n  }\n\n  /* Shared extracted + parent-rendered styles */\n\n  :deep(.s-side-menu-control__group) {\n    display: flex;\n    align-items: center;\n    padding: 12px 16px;\n    gap: 8px;\n\n    &:not(:first-child) {\n      padding-top: 32px;\n    }\n  }\n\n  :deep(.s-side-menu-control__group-icon) {\n    max-width: 16px;\n    max-height: 16px;\n\n    &:not(.a-glyph_noFill) {\n      fill: var(--av-brand-primary);\n    }\n  }\n\n  :deep(.s-side-menu-control__group-title) {\n    @mixin note-accent;\n    max-width: calc(100% - 24px);\n    text-transform: uppercase;\n    color: var(--av-brand-primary);\n  }\n\n  :deep(.s-side-menu-control__element) {\n    @mixin paragraph;\n\n    display: flex;\n    align-items: center;\n    width: 100%;\n    padding: 12px 16px;\n    border: none;\n    border-radius: 4px;\n    background: none;\n    text-align: start;\n    text-decoration: none;\n    color: var(--av-nav-primary);\n    cursor: pointer;\n\n    &:hover {\n      background-color: var(--av-brand-lightest);\n      color: var(--av-nav-primary);\n    }\n  }\n\n  :deep(.s-side-menu-control__element_active) {\n    background-color: var(--av-brand-accent);\n  }\n\n  :deep(.s-side-menu-control__element_with-counter) {\n    justify-content: space-between;\n  }\n\n  :deep(.qa-input-select-suffix) {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  :deep(.s-side-menu-control__element-counter) {\n    @mixin body;\n    font-weight: 400;\n    color: var(--av-fixed-light);\n\n    &.select-counter {\n      @mixin paragraph;\n      margin-inline-start: auto;\n      color: var(--av-fixed-primary);\n    }\n  }\n}\n</style>\n","<template>\n    <section\n        :id=\"id\"\n        class=\"s-slice s-side-menu\"\n        :class=\"{ ...className, ...basicClassName }\"\n    >\n        <div class=\"a-container\">\n            <a-slice-header\n                v-if=\"title || lead\"\n                :title=\"title\"\n                :lead=\"lead\"\n                :body-text=\"bodyText\"\n            />\n            <div\n                class=\"s-side-menu__leftside\"\n                :class=\"{\n                    's-side-menu__leftside--sticky': sticky,\n                    's-side-menu__leftside--sticky-active': stickyActive,\n                }\"\n                :style=\"{ top: stickyMobileTopOffset + 'px' }\"\n            >\n                <s-side-menu-control\n                    :type=\"type\"\n                    :slices=\"slices\"\n                    :groups=\"groups\"\n                    :active-element=\"activeElement\"\n                    :style=\"{ top: stickyTopOffset + 'px' }\"\n                    @tab-change=\"tabChange\"\n                />\n                <div v-if=\"links\" class=\"s-side-menu__links\">\n                    <a-link\n                        v-for=\"(link, i) in links\"\n                        :key=\"i\"\n                        class=\"s-side-menu__link\"\n                        v-bind=\"link\"\n                        :to=\"link.link\"\n                        :class=\"link.class || ''\"\n                        :glyph-position=\"link.glyphPosition || 'left'\"\n                        :size=\"link.size || 'paragraph'\"\n                        @click=\"tabChange(link.id, link.text)\"\n                    />\n                </div>\n            </div>\n            <div class=\"s-side-menu__rightside\">\n                <s-side-menu-content\n                    ref=\"contentEl\"\n                    :type=\"type\"\n                    :slices=\"slices\"\n                    :active-element=\"activeElement\"\n                />\n            </div>\n        </div>\n    </section>\n</template>\n\n<script setup>\nimport { throttle } from 'lodash-es';\nimport {\n    ref,\n    computed,\n    watch,\n    onMounted,\n    onBeforeUnmount,\n    nextTick,\n} from 'vue';\nimport { useRoute, useRouter } from 'vue-router';\n\nimport ALink from '@core/components/link/link.vue';\nimport ASliceHeader from '@core/components/slice-header/slice-header.vue';\nimport { contentProps } from '@core/composables/useContent';\nimport { styleProps, useStyle } from '@core/composables/useStyle';\nimport SSideMenuContent from './side-menu-content.vue';\nimport SSideMenuControl from './side-menu-control.vue';\n\n\ndefineOptions({ name: 'SSideMenu' });\n\nconst emit = defineEmits(['click']);\n\nconst props = defineProps({\n    ...styleProps,\n    ...contentProps,\n    /**\n     * Content slice data\n     */\n    slices: { type: Array, required: true },\n\n    /**\n     * Type of side menu\n     */\n    type: { type: String, default: 'tabs' },\n\n    /**\n     * Is wide layout\n     */\n    isWide: { type: Boolean, default: false },\n\n    /**\n     * Extra links after menu\n     */\n    links: { type: Array, default: undefined },\n\n    /**\n     * Title's lead text\n     */\n    lead: { type: String, required: false, default: undefined },\n\n    /**\n     * Title's body text\n     */\n    bodyText: { type: String, default: undefined },\n\n    sticky: Boolean,\n\n    /**\n     * Used to pull scroll up in case there are other sticky elements on the page\n     */\n    scrollTopOffset: { type: Number, default: 0 },\n\n    /**\n     * Used to push sticky dropdown and menu down in case there are other sticky elements on the page\n     */\n    stickyTopOffset: { type: Number, default: 58 },\n\n    stickyMobileTopOffset: { type: Number, default: 0 },\n\n    isMobileCompact: Boolean,\n\n    activeSlice: { type: String, default: '' },\n\n    groups: { type: Array, default: () => [] },\n});\n\nconst route = useRoute();\nconst router = useRouter();\nconst routeHash = computed(() => route?.hash ?? '');\n\nconst { className } = useStyle(props);\n\nconst basicClassName = computed(() => ({\n    's-side-menu_layout_wide': props.isWide,\n    's-side-menu_layout_narrow': !props.isWide,\n    's-side-menu_layout_mobile-compact': props.isMobileCompact,\n}));\n\n\nfunction normalizeId(id) {\n    return String(id || '').replace(/^#/, '').trim();\n}\n\nfunction getSliceId(slice) {\n    return normalizeId(slice?.info?.id);\n}\n\nconst contentEl = ref(null);\nconst isScrolled = ref(false);\nconst stickyActive = ref(false);\nconst activeElement = ref('');\nlet observer = null;\nlet scrollCb = null;\n\nconst tabIds = computed(() => props.slices.map(getSliceId).filter(Boolean));\n\nfunction matchedTabHash() {\n    const hash = normalizeId(routeHash.value);\n    if (!hash) return '';\n    return tabIds.value.includes(hash) ? hash : '';\n}\n\nwatch(\n    () => props.activeSlice,\n    (value) => {\n        const normalizedValue = normalizeId(value);\n        if (normalizedValue) activeElement.value = normalizedValue;\n    },\n);\n\nwatch(routeHash, () => {\n    const hash = matchedTabHash();\n\n    if (props.type === 'tabs' && hash && hash !== activeElement.value) {\n        checkTabAnchors({\n            allowSameId: true,\n            syncHash: false,\n            shouldScroll: true,\n            fallbackToDefault: false,\n        });\n    }\n});\n\n\nonMounted(() => {\n    if (props.type === 'links' || props.sticky) {\n        const hash = normalizeId(routeHash.value);\n        activeElement.value = normalizeId(props.activeSlice) || hash || activeElement.value;\n        window.addEventListener('load', () => nextTick(registerObserver));\n    }\n\n    if (props.type === 'tabs') {\n        const hasHash = Boolean(matchedTabHash());\n\n        nextTick(() => {\n            checkTabAnchors({\n                allowSameId: true,\n                syncHash: hasHash,\n                shouldScroll: hasHash,\n                fallbackToDefault: true,\n            });\n        });\n    }\n\n    if (props.type === 'combined' && props.slices.length) {\n        nextTick(() => {\n            activeElement.value = getSliceId(props.slices[0]);\n        });\n    }\n});\n\nonBeforeUnmount(() => {\n    if (scrollCb) {\n        window.removeEventListener('scroll', scrollCb);\n    }\n\n    if (observer) {\n        observer.disconnect();\n        observer = null;\n    }\n\n    window.removeEventListener('load', registerObserver);\n});\n\nfunction checkTabAnchors({allowSameId = false,\n    syncHash = false,\n    shouldScroll = false,\n    fallbackToDefault = true} = {}) {\n    if (!Array.isArray(props.slices) || !props.slices.length) return;\n\n    const hash = matchedTabHash();\n\n    const nextActive =\n        normalizeId(props.activeSlice) ||\n        hash ||\n        (fallbackToDefault ? tabIds.value[0] : '');\n\n    if (!nextActive) return;\n\n    tabChange(nextActive, undefined, { allowSameId, syncHash, shouldScroll });\n}\n\nfunction resolveScrollTarget(id, options) {\n    const targetId = options.scrollToId || id;\n    const el = getSliceRefElement(targetId);\n    if (el) return el;\n\n    return contentEl.value?.$el ?? null;\n}\n\nfunction tabChange(id, name, options = {}) {\n    const normalizedId = normalizeId(id);\n    if (!normalizedId) return;\n\n    const {allowSameId = false,\n        syncHash = true,\n        shouldScroll = false,\n        scrollToId = null,\n        syncScrollHash = false} = options;\n\n    if (activeElement.value === normalizedId && !allowSameId && !props.activeSlice) {\n        return;\n    }\n\n    activeElement.value = normalizedId;\n    emit('click', normalizedId, name);\n\n    const dropdownHeight = props.sticky ? 82 : 0;\n\n    requestAnimationFrame(() => {\n        const element = resolveScrollTarget(normalizedId, options);\n        if (!element) return;\n\n        const elCoords = getOffset(element);\n\n        nextTick(() => {\n            if (props.type === 'tabs' && syncHash) {\n                const currentHash = normalizeId(routeHash.value);\n                if (currentHash !== normalizedId) {\n                    router?.replace({\n                        path: route.path,\n                        query: route.query,\n                        hash: `#${normalizedId}`,\n                    });\n                }\n            }\n\n            if (props.type === 'combined' && scrollToId && syncScrollHash) {\n                const currentHash = normalizeId(routeHash.value);\n                if (currentHash !== normalizeId(scrollToId)) {\n                    router?.replace({\n                        path: route.path,\n                        query: route.query,\n                        hash: `#${normalizeId(scrollToId)}`,\n                    });\n                }\n            }\n\n            if (shouldScroll || isScrolled.value) {\n                window.scrollTo({\n                    top: elCoords.top - dropdownHeight - props.scrollTopOffset,\n                });\n            }\n        });\n    });\n}\n\nfunction getSliceRefElement(sliceId) {\n    const maybe = contentEl.value?.$refs?.[sliceId];\n    const target = Array.isArray(maybe) ? maybe[0] : maybe;\n    return target?.$el || target;\n}\n\nfunction getOffset(el) {\n    if (!el || typeof window === 'undefined') return { top: 0, left: 0 };\n\n    const rect = el?.getBoundingClientRect?.();\n    return {\n        left: (rect?.left || 0) + window.scrollX,\n        top: (rect?.top || 0) + window.scrollY,\n    };\n}\n\nconst handleScrollThrottled = throttle(handleScroll, 200);\nfunction registerObserver() {\n    if (typeof IntersectionObserver === 'undefined') return;\n\n    if (observer) {\n        observer.disconnect();\n        observer = null;\n    }\n\n    scrollCb = handleScrollThrottled;\n\n    observer = new IntersectionObserver((entries) => {\n        const intersected = entries[0].isIntersecting;\n\n        if (intersected) {\n            window.addEventListener('scroll', scrollCb);\n        } else {\n            window.removeEventListener('scroll', scrollCb);\n        }\n    });\n\n    const el = contentEl.value?.$el;\n    if (el) observer.observe(el);\n}\n\nfunction handleScroll() {\n    if (props.sticky) {\n        const stickyElement = document.querySelector('.s-side-menu__leftside--sticky');\n        if (!stickyElement || !stickyElement.offsetParent) return;\n\n        const offsetParent = stickyElement.offsetParent.offsetTop;\n        const stickyTop = stickyElement.offsetTop + offsetParent - props.stickyTopOffset;\n\n        stickyActive.value = window.pageYOffset >= stickyTop;\n        isScrolled.value = window.pageYOffset >= stickyTop;\n    }\n\n    const SCROLL_OFFSET = 250;\n\n    requestAnimationFrame(() => {\n        const entries = Object.entries(contentEl.value?.$refs || {});\n\n        const found = entries.find(([key, value]) => {\n            if (!key) return false;\n\n            const maybeComp = Array.isArray(value) ? value[0] : value;\n            const el = maybeComp?.$el || maybeComp;\n\n            const rect = el?.getBoundingClientRect?.();\n            return rect?.bottom > SCROLL_OFFSET;\n        });\n\n        if (found) activeElement.value = found[0];\n    });\n}\n</script>\n\n<style lang=\"postcss\">\n.s-side-menu {\n  &_layout {\n    &_wide {\n      .s-side-menu {\n        &__leftside {\n          width: 100%;\n\n          @media (--viewport-mobile-wide) {\n            .s-side-menu-control {\n              width: 50%;\n            }\n          }\n\n          @media (--viewport-desktop) {\n            .s-side-menu-control {\n              width: 100%;\n              top: 24px;\n            }\n            width: 33.33%;\n          }\n\n          @media (--viewport-desktop-wide) {\n            width: 25%;\n          }\n        }\n\n        &__rightside {\n          @media (--viewport-desktop) {\n            width: 66.66%;\n          }\n\n          @media (--viewport-desktop-wide) {\n            width: 75%;\n          }\n        }\n      }\n    }\n\n    &_narrow {\n      .s-side-menu {\n        &__leftside {\n          @media (--viewport-desktop) {\n            width: 25%;\n          }\n\n          @media (--viewport-desktop-wide) {\n            width: 16.66%;\n          }\n        }\n\n        &__rightside {\n          @media (--viewport-desktop) {\n            width: 75%;\n          }\n\n          @media (--viewport-desktop-wide) {\n            width: 83.34%;\n          }\n        }\n      }\n    }\n\n    &_mobile-compact {\n      .a-container {\n        .a-slice-header {\n          margin-bottom: 40px;\n        }\n      }\n      .s-side-menu {\n        &__leftside {\n          margin-bottom: -16px;\n        }\n      }\n    }\n  }\n\n  .a-slice-header {\n    width: 100%;\n    margin-bottom: 56px;\n\n    @media (--viewport-desktop) {\n      &__lead,\n      &__title {\n        max-width: 635px;\n      }\n    }\n\n    @media (--viewport-desktop-wide) {\n      &__lead,\n      &__title {\n        max-width: 763px;\n      }\n    }\n\n    @media (--viewport-desktop-large) {\n      &__lead,\n      &__title {\n        max-width: 869px;\n      }\n    }\n  }\n\n  & > .a-container {\n    @media (--viewport-desktop) {\n      display: flex;\n      flex-wrap: wrap;\n    }\n  }\n\n  &__leftside {\n    width: 100%;\n    padding-inline-end: 16px;\n    padding: 0 0 16px;\n    inset-inline-start: 0;\n\n    &--sticky {\n      position: sticky;\n      z-index: 10;\n      @media only screen and (max-width: 1023px) {\n        background: var(--av-inversed-primary);\n        position: sticky;\n        width: calc(100% + 32px) !important;\n        margin: 0 -32px;\n        padding: 16px 32px;\n        inset-inline-start: 0;\n\n        @media (--viewport-mobile-wide) {\n          width: calc(100% + 64px) !important;\n          margin: 0 -64px;\n        }\n\n        @media (--viewport-desktop) {\n          margin: 0;\n        }\n\n        .s-side-menu-control {\n          width: 100%;\n\n          @media (--viewport-tablet) {\n            width: 50%;\n          }\n        }\n      }\n    }\n\n    &--sticky-active {\n      background-color: white;\n      box-shadow: 0 7px 7px var(--av-fixed-invisible);\n    }\n\n    @media (--viewport-desktop) {\n      padding-inline-end: 32px;\n      box-shadow: none;\n\n      &--sticky {\n        position: static;\n\n        .s-side-menu-control {\n          width: unset;\n          position: sticky;\n        }\n      }\n    }\n  }\n\n  &__links {\n    padding-top: 24px;\n\n    @media (--viewport-desktop) {\n      border-top: 1px solid var(--av-brand-secondary-light);\n      margin-top: 36px;\n    }\n  }\n\n  &__link {\n    display: block;\n    padding-inline-start: 16px;\n    margin-bottom: 16px;\n\n    .a-link__glyph {\n      width: 16px;\n      float: left;\n      margin-inline-end: 8px;\n      margin-inline-start: 0;\n      position: relative;\n      top: 6px;\n    }\n  }\n\n  .s-video-list {\n    .a-slice-header {\n      &__title {\n        font-size: 24px;\n\n        @media (--viewport-tablet) {\n          font-size: 32px;\n        }\n      }\n\n      &__lead {\n        font-size: 16px;\n      }\n    }\n\n    &__item {\n      @media (--viewport-tablet) {\n        padding: 0 8px;\n        width: 50%;\n      }\n\n      @media (--viewport-desktop) {\n        width: 50%;\n      }\n\n      @media (--viewport-desktop-wide) {\n        width: 33.33%;\n      }\n    }\n  }\n}\n\n.el-select-dropdown.el-popper {\n  background: var(--av-inversed-primary);\n}\n</style>\n","<template>\n    <dynamic-link class=\"a-asset-card\" :to=\"link\" :title=\"title\">\n        <template v-if=\"imageList && imageList.length > 1\">\n            <div class=\"a-asset-card__slider\">\n                <span v-for=\"(item, index) in imageList\" :key=\"`a-asset-card-img-${index}`\" class=\"a-asset-card__slide\">\n                    <a-picture class=\"a-asset-card__img\" :link=\"item.imagePath\" :alt=\"item.imageAlt\" />\n                </span>\n                <span class=\"a-asset-card__markers-container\" :aria-hidden=\"true\">\n                    <span\n                        v-for=\"(_, index) in imageList\"\n                        :key=\"`a-asset-card-marker-${index}`\"\n                        class=\"a-asset-card__marker\"\n                    />\n                </span>\n            </div>\n        </template>\n        <div v-else class=\"a-asset-card__single\">\n            <a-picture class=\"a-asset-card__single__img\" :link=\"imageList[0].imagePath\" :alt=\"imageList[0].imageAlt\" />\n        </div>\n        <div class=\"a-asset-card__desc\">\n            <h4 v-if=\"title\" class=\"a-asset-card__title\">\n                {{ title }}\n            </h4>\n            <span v-if=\"text\" class=\"a-asset-card__text\">{{ text }}</span>\n            <span class=\"a-asset-card__file\">\n                <span class=\"a-asset-card__file-info\">{{ fileInfo }}</span>\n                <a-glyph class=\"a-asset-card__file-icon\" name=\"download-arrow\" :aria-hidden=\"true\" />\n            </span>\n        </div>\n        <div class=\"a-asset-card__inner-border\" />\n    </dynamic-link>\n</template>\n\n<script>\nimport DynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport APicture from '@core/components/picture/picture.vue';\n\nexport default {\n    name: 'AAssetCard',\n\n    components: {\n        AGlyph,\n        APicture,\n        DynamicLink,\n    },\n\n    props: {\n        link: {\n            type: String,\n            required: true,\n        },\n\n        imageList: {\n            type: Array,\n            required: true,\n        },\n\n        title: {\n            type: String,\n            required: true,\n        },\n\n        text: {\n            type: String,\n            required: true,\n        },\n\n        fileInfo: {\n            type: String,\n            required: true,\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-asset-card {\n    position: relative;\n    display: block;\n    border: 1px solid transparent;\n    border-radius: 4px;\n    text-decoration: none;\n    box-shadow: var(--av-shadow-small);\n    transition: box-shadow 0.15s ease-in-out;\n    width: 100%;\n    background: var(--av-inversed-primary);\n    padding: 0;\n\n    &:hover {\n        box-shadow: none;\n        transition: box-shadow 0.3s ease-in-out;\n\n        .a-asset-card {\n            &__slide {\n                &:nth-child(1) {\n                    opacity: 0;\n                }\n\n                &:nth-child(2) {\n                    opacity: 1;\n                }\n            }\n\n            &__marker {\n                &:nth-child(1) {\n                    background-color: var(--av-brand-secondary);\n                }\n\n                &:nth-child(2) {\n                    background-color: var(--av-inversed-primary);\n                }\n            }\n        }\n    }\n\n    &:focus-visible {\n        outline: none;\n        box-shadow: none;\n\n        .a-asset-card__inner-border {\n            opacity: 1;\n        }\n    }\n\n    &__slider,\n    &__single {\n        border-top-left-radius: 4px;\n        border-top-right-radius: 4px;\n        overflow: hidden;\n        position: relative;\n        display: block;\n        padding-top: 67%;\n        width: 100%;\n        margin: 0;\n    }\n\n    &__slide,\n    &__single__img {\n        position: absolute;\n        top: 0;\n        inset-inline-start: 0;\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        width: 100%;\n        height: 100%;\n        transition: opacity 0.25s ease-out;\n\n        &:nth-child(1) {\n            opacity: 1;\n        }\n\n        &:nth-child(2) {\n            opacity: 0;\n        }\n    }\n\n    &__img {\n        position: relative;\n        width: 100%;\n        height: 100%;\n\n        .a-picture__img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n        }\n    }\n    &__markers-container {\n        margin: 0 -5px;\n        position: absolute;\n        inset-inline-start: 23px;\n        inset-inline-end: 23px;\n        bottom: 10px;\n        display: flex;\n        align-items: center;\n    }\n\n    &__marker {\n        margin: 0 5px;\n        display: block;\n        width: 8px;\n        height: 8px;\n        border-radius: 50%;\n\n        &:nth-child(1) {\n            background-color: var(--av-inversed-primary);\n        }\n\n        &:nth-child(2) {\n            background-color: var(--av-brand-secondary);\n        }\n    }\n\n    &__desc {\n        display: block;\n        padding: 16px 24px 24px;\n    }\n\n    &__title {\n        display: block;\n        margin-bottom: 8px;\n        font-size: 16px;\n        font-weight: 600;\n        line-height: 24px;\n        color: var(--av-nav-primary);\n    }\n\n    &__text {\n        display: block;\n        margin-bottom: 16px;\n        font-size: 14px;\n        line-height: 20px;\n        color: var(--av-fixed-secondary);\n    }\n\n    &__file {\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n    }\n\n    &__file-info {\n        display: block;\n        font-size: 14px;\n        line-height: 20px;\n        color: var(--av-fixed-light);\n    }\n\n    &__file-icon {\n        width: 16px;\n        height: 16px;\n    }\n\n    &__inner-border {\n        position: absolute;\n        inset: -1px;\n        background: transparent;\n        border-radius: 4px;\n        border: 1px solid var(--av-brand-primary);\n        opacity: 0.2;\n        pointer-events: none;\n    }\n}\n</style>\n","import { merge } from 'lodash-es';\nimport { computed, useAttrs } from 'vue';\n\nexport function useL10n(props: Record<string, any>) {\n    const attrs = useAttrs();\n\n    const l10n = computed(() => merge({}, attrs, props, props.translations ?? {}));\n\n    return {\n        l10n,\n    };\n}\n","import { chunk, merge } from 'lodash-es';\nimport { computed, ref, unref, type Ref, type ComputedRef } from 'vue';\nimport { useRoute } from 'vue-router';\nimport { useStore } from 'vuex';\n\ntype MaybeRef<T> = T | Ref<T> | ComputedRef<T>;\n\nfunction resolve<T>(value: MaybeRef<T>): T {\n    return unref(value);\n}\n\ninterface UsePurchasingDeps {\n    productCurrency: MaybeRef<string | undefined>;\n    purchasePageCTA?: MaybeRef<any>;\n    settings?: MaybeRef<any>;\n    products?: MaybeRef<any>;\n    route?: MaybeRef<{ query?: Record<string, any>; path?: string }>;\n}\n\nexport function usePurchasing(deps: UsePurchasingDeps) {\n    const store = useStore();\n    const promotion = ref<Record<string, any>>({});\n    let routeFromRouter: ReturnType<typeof useRoute> | null = null;\n\n    try {\n        routeFromRouter = useRoute();\n    } catch {\n        routeFromRouter = null;\n    }\n\n    const route = computed(() => {\n        if (deps.route) return resolve(deps.route);\n        return routeFromRouter || { query: {}, path: '' };\n    });\n\n    const promotions = computed(() => store.state.promotions?.data || []);\n    const licensesItems = computed(() => store.state.licenses?.data || []);\n    const productItems = computed(() => store.state.products?.items || {});\n    const internalProductId = computed(() => store.state.pages?.page?.product_id || null);\n\n    function findPromotionForEmails(productID: number | string | null, coupon: string) {\n        if (!productID) return {};\n\n        const licenseIDs = licensesItems.value.map((item: any) => parseInt(item.cleverbridge_id, 10));\n\n        return promotions.value\n            .filter((item: any) => item.is_for_emails_only && item.product_id === productID && item.coupon_code === coupon)\n            .find((item: any) => item.license_ids.find((id: number) => licenseIDs.includes(id))) || {};\n    }\n\n    const hasEmailPromo = computed(() => {\n        const coupon = route.value.query?.coupon || '';\n        if (!coupon) return false;\n\n        if (!route.value.path?.includes('purchasing')) return false;\n\n        const purchasePageCTA = deps.purchasePageCTA ? resolve(deps.purchasePageCTA) : undefined;\n        const productID = purchasePageCTA?.productId || internalProductId.value;\n        const promotionForEmails = findPromotionForEmails(productID, String(coupon));\n\n        return (promotionForEmails as any).discount > 0;\n    });\n\n    const promotionList = computed(() => {\n        const coupon = route.value.query?.coupon || '';\n        const isForEmailsOnly = hasEmailPromo.value;\n\n        return promotions.value.filter((item: any) => {\n            if (!isForEmailsOnly) return !item.is_for_emails_only;\n            return item.is_for_emails_only && item.coupon_code === coupon;\n        });\n    });\n\n    function generateSessionURL(payload: any) {\n        return store.dispatch('cleverbridge/get', payload);\n    }\n\n    function recursiveSearch(obj: any, searchKey: string, results: any[] = []) {\n        Object.keys(obj || {}).forEach((key) => {\n            if (key === searchKey) {\n                results.push(obj);\n                return;\n            }\n            if (typeof obj[key] === 'object' && obj[key] !== null) {\n                recursiveSearch(obj[key], searchKey, results);\n            }\n        });\n\n        return results;\n    }\n\n    function productCTA(settings: any) {\n        const type = settings?.isPurchase ? 'purchasePageCTA' : 'productPageCTA';\n        const productId = settings?.productId || internalProductId.value;\n        return productItems.value?.[productId]?.parameters?.common?.[type] || {};\n    }\n\n    function promotionActive(productId: number | string | null, cleverBridgeCartIDs: number[]) {\n        if (!productId) return {};\n        if (!cleverBridgeCartIDs?.length) return {};\n\n        return promotionList.value.find((item: any) => {\n            if (item.product_id !== productId) return false;\n            return cleverBridgeCartIDs.find((id) => item.license_ids?.includes(id));\n        }) || {};\n    }\n\n    async function getLicenses(settings: any) {\n        const locale = settings?.locale ||\n            store.state.geolocation?.desiredLocale ||\n            store.state.geolocation?.requestedLocale;\n\n        await store.dispatch('locales/getLocaleData', { locale });\n\n        const PAGINATE_SIZE = 50;\n        const payload = {\n            locale,\n            currency: resolve(deps.productCurrency),\n            paginate: { number: 1, size: PAGINATE_SIZE },\n        };\n\n        const pageSettingsCTA = productCTA(settings);\n\n        const license = merge({}, pageSettingsCTA, settings);\n        const licenses = license?.cleverBridgeCartList || [license?.cleverBridgeCartID] || [];\n\n        if (licenses.length === 1) {\n            const cleverBridgeCartID = licenses[0];\n\n            // Keeping original parity:\n            // original code used this.settings?.productId here, not the method arg.\n            const componentSettings = deps.settings ? resolve(deps.settings) : undefined;\n            const productId = componentSettings?.productId || internalProductId.value;\n\n            const promoLocal = promotionActive(productId, [cleverBridgeCartID]);\n            const promoLocalLicenseID = (promoLocal as any).promoSettings?.product_page_license_id;\n\n            const promoGlobal = promotionList.value.find(\n                (item: any) => item.product_id === productId && !item.is_for_emails_only,\n            ) || {};\n            const promoGlobalLicenseID = (promoGlobal as any).promoSettings?.product_page_license_id;\n\n            licenses.push(promoLocalLicenseID || promoGlobalLicenseID);\n        }\n\n        const promisesWithOutPromo = chunk(licenses.filter(Number), PAGINATE_SIZE)\n            .map((cleverbridgeIDs) => store.dispatch('licenses/getList', { ...payload, cleverbridgeIDs }));\n\n        await Promise.all(promisesWithOutPromo);\n    }\n\n    function findCleverBridgeCart(slice: any, settings: any) {\n        const licenses = recursiveSearch(slice || {}, 'cleverBridgeCartID').flat(2);\n        const cleverBridgeCartList = licenses.map((license: any) => license.cleverBridgeCartID).flat(2);\n        return getLicenses({ ...settings, cleverBridgeCartList });\n    }\n\n    function licenseData({ cleverBridgeCartID, settingsCTA }: { cleverBridgeCartID?: number | string; settingsCTA?: any }) {\n        const resultDefault = { price: 0, price_promo: 0 };\n        const cleverbBridgeID = (cleverBridgeCartID || settingsCTA?.cleverBridgeCartID || '').toString();\n        if (!cleverbBridgeID) return resultDefault;\n\n        const compare = (i: any) => i.cleverbridge_id === cleverbBridgeID && i.currency === resolve(deps.productCurrency);\n        const license = licensesItems.value.find(compare) || resultDefault;\n        const productId = (license as any).product_id;\n        const promotionActiveItem = promotionActive(productId, [Number(cleverBridgeCartID)]);\n        const promotionData = merge({}, promotionActiveItem, settingsCTA);\n        const discounts = (promotionData as any).discounts || [];\n        const promotionItem = discounts.find((item: any) => item.list.includes(cleverBridgeCartID)) || {};\n        const discount = promotionItem.discount || (promotionData as any).discount || 0;\n\n        if (discount) {\n            const priceDiscount = ((license as any).price * discount) / 100;\n            const pricePromo = (license as any).price - priceDiscount;\n\n            return {\n                ...(license as any),\n                ...promotionData,\n                discount,\n                cleverbridge_id: cleverBridgeCartID,\n                price_promo: Math.floor(pricePromo * 100) / 100,\n            };\n        }\n\n        return license;\n    }\n\n    function setPromo() {\n        const purchasePageCTA = deps.purchasePageCTA ? resolve(deps.purchasePageCTA) : undefined;\n        const products = deps.products ? resolve(deps.products) : undefined;\n\n        const productId = purchasePageCTA?.productId || internalProductId.value;\n        const cleverBridgeCartIDs = licensesItems.value.map((item: any) => Number(item.cleverbridge_id));\n        const promotionActiveItem = promotionActive(productId, cleverBridgeCartIDs);\n\n        const nextPromotion = merge({}, promotionActiveItem, purchasePageCTA);\n        nextPromotion.isActive = Boolean(nextPromotion.discount && !nextPromotion?.doNotApplyPromo);\n        promotion.value = nextPromotion;\n\n        if (!promotion.value.isActive) return;\n        if (!products?.items) return;\n\n        // Preserving original mutative behavior\n        products.selected = Number(promotion.value?.selected_licenses_count || 0);\n\n        products.items = products.items.map((item: any) => ({\n            ...item,\n            pc: {\n                ...item.pc,\n                selected: Number(promotion.value?.selected_computers_count || 0),\n            },\n            cloud: {\n                ...item.cloud,\n                selected: Number(promotion.value?.[`default_cloud_capacity_${item.id}`] || 0),\n            },\n        }));\n    }\n\n    function initSettingsCTA(list: any[]) {\n        const settings = (list || []).filter((item) => item?.productPageCTA?.productId);\n        return settings.map((product) => getLicenses(product.productPageCTA));\n    }\n\n    return {\n        promotions,\n        licensesItems,\n        productItems,\n        internalProductId,\n        promotion,\n        hasEmailPromo,\n        promotionList,\n        generateSessionURL,\n        findPromotionForEmails,\n        findCleverBridgeCart,\n        productCTA,\n        promotionActive,\n        getLicenses,\n        licenseData,\n        setPromo,\n        initSettingsCTA,\n        recursiveSearch,\n    };\n}\n","<template>\n    <template v-if=\"cell.title\">\n        <div class=\"a-table__head-title\">\n            {{ cell.title }}\n        </div>\n    </template>\n    <template v-else>\n        <a-link\n            v-if=\"cell.to && isTypeOne\"\n            class=\"a-table__head-link\"\n            v-bind=\"cell\"\n            type=\"regular\"\n            :size=\"cell.size || 'paragraph'\"\n        />\n        <a-link\n            v-else-if=\"cell.to\"\n            class=\"a-table__head-link\"\n            v-bind=\"cell\"\n            :size=\"cell.size || 'paragraph'\"\n        />\n        <div v-if=\"cell.val\" class=\"a-table__head-text\">\n            {{ cell.val }}\n        </div>\n        <div v-if=\"cell.desc\" class=\"a-table__head-desc\">\n            {{ cell.desc }}\n        </div>\n        <div v-if=\"cell.label\" class=\"a-table__head-label\">\n            {{ cell.label }}\n        </div>\n        <div v-if=\"cell.product\" class=\"a-table__head-product\">\n            {{ cell.product }}\n        </div>\n    </template>\n</template>\n\n<script setup>\nimport ALink from '@core/components/link/link.vue';\n\ndefineOptions({\n    name: 'STableHeadCell',\n});\n\n\ndefineProps({\n    cell: {\n        type: Object,\n        required: true,\n    },\n    isTypeOne: {\n        type: Boolean,\n        default: false,\n    },\n});\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-table__head-text {\n    @mixin paragraph;\n\n    font-weight: 700;\n    color: var(--av-nav-primary);\n}\n\n.a-table__head-desc {\n    color: var(--av-nav-primary);\n}\n\n.a-table__head-title {\n    @mixin hero-subtle;\n    color: var(--av-nav-primary);\n}\n\n.a-table__head-label {\n    @mixin body;\n\n    color: var(--av-fixed-success);\n    margin-bottom: 4px;\n}\n\n.a-table__head-product {\n    font-size: 24px;\n    line-height: 24px;\n    font-weight: bold;\n}\n</style>\n","<template>\n    <div class=\"a-table__head-cell\">\n        <label class=\"a-table-switcher\">\n            <input\n                class=\"a-table-switcher__input\"\n                type=\"checkbox\"\n                :checked=\"modelValue\"\n                @change=\"$emit('update:modelValue', $event.target.checked)\"\n            />\n            <span class=\"a-table-switcher__text\">{{ text }}</span>\n            <span class=\"a-table-switcher__decor\" :aria-hidden=\"true\" />\n        </label>\n    </div>\n</template>\n\n<script setup>\ndefineOptions({\n    name: 'STableHeadSwitcher',\n});\n\ndefineProps({\n    modelValue: {\n        type: Boolean,\n        default: true,\n    },\n    text: {\n        type: String,\n        required: true,\n    },\n});\n\ndefineEmits(['update:modelValue']);\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-table-switcher {\n    display: flex;\n    align-items: center;\n    cursor: pointer;\n}\n\n.a-table-switcher__input {\n    position: absolute;\n    visibility: hidden;\n}\n\n.a-table-switcher__input:checked ~ .a-table-switcher__decor {\n    background-color: var(--av-fixed-success);\n}\n\n.a-table-switcher__input:checked ~ .a-table-switcher__decor::after {\n    transform: translate(17px, -50%);\n}\n\n.a-table-switcher__text {\n    @mixin paragraph;\n\n    display: inline-block;\n    position: relative;\n    margin-inline-end: 16px;\n    color: var(--av-fixed-secondary);\n}\n\n.a-table-switcher__decor {\n    position: relative;\n    flex: 0 0 37px;\n    height: 22px;\n    border-radius: 100px;\n    background-color: var(--av-brand-light);\n    transition: background-color 0.15s ease-out;\n}\n\n.a-table-switcher__decor::after {\n    content: '';\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    inset-inline-start: 2px;\n    width: 16px;\n    border-radius: 100px;\n    height: 16px;\n    background-color: var(--av-inversed-primary);\n    transition: transform 0.25s ease-out;\n}\n</style>\n","<template>\n    <template v-if=\"headCell?.title\">\n        <div\n            class=\"a-table__head-mobile-field a-table__head-mobile-title\"\n            v-html=\"headCell.title\"\n        />\n    </template>\n    <template v-else>\n        <div\n            v-if=\"headCell?.val\"\n            class=\"a-table__head-mobile-field a-table__head-mobile-text\"\n            v-html=\"headCell.val\"\n        />\n        <div\n            v-if=\"headCell?.desc\"\n            class=\"a-table__head-mobile-field a-table__head-mobile-desc\"\n            v-html=\"headCell.desc\"\n        />\n        <div\n            v-if=\"headCell?.label\"\n            class=\"a-table__head-mobile-field a-table__head-mobile-label\"\n            v-html=\"headCell.label\"\n        />\n        <div\n            v-if=\"headCell?.product\"\n            class=\"a-table__head-mobile-field a-table__head-mobile-product\"\n            v-html=\"headCell.product\"\n        />\n    </template>\n</template>\n\n<script setup>\ndefineOptions({\n    name: 'STableMobileHeadCell',\n});\n\ndefineProps({\n    headCell: {\n        type: Object,\n        default: null,\n    },\n});\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-table__head-mobile-field {\n    margin-bottom: 16px;\n}\n\n.a-table__head-mobile-text {\n    @mixin paragraph;\n\n    font-weight: 700;\n    color: var(--av-nav-primary);\n}\n\n.a-table__head-mobile-desc {\n    color: var(--av-nav-primary);\n}\n\n.a-table__head-mobile-title {\n    @mixin hero-subtle;\n    color: var(--av-nav-primary);\n}\n\n.a-table__head-mobile-label {\n    @mixin body;\n\n    color: var(--av-fixed-success);\n    margin-bottom: 4px;\n}\n\n.a-table__head-mobile-product {\n    font-size: 24px;\n    line-height: 24px;\n    font-weight: bold;\n}\n</style>\n","<template>\n    <div class=\"a-table__wrapper\" :class=\"`a-table__wrapper_type-${l10n.settings.type}`\">\n        <div class=\"a-table\" :class=\"className\" :style=\"cssVars\">\n            <a-dangerous-html\n                v-if=\"l10n.settings.lead?.length\"\n                class=\"a-table__lead\"\n                :content=\"l10n.settings.lead\"\n            />\n            <!-- Conditional scroll container for type-1 tables -->\n            <div v-if=\"l10n.settings.type === 1\" class=\"a-table__scroll-container\">\n                <div ref=\"headRef\" class=\"a-table__head syncscroll\" name=\"table-part\">\n                    <div\n                        class=\"a-table__head-row\"\n                        :class=\"{ 'a-table__head-row_no-scroll': l10n.settings.headMobileType === 'no-scroll' }\"\n                    >\n                        <s-table-head-switcher\n                            v-if=\"l10n.settings.switcher\"\n                            v-model=\"withOptionalRows\"\n                            :text=\"l10n.settings.switcher\"\n                        />\n                        <div\n                            v-for=\"(cell, index) in l10n.head\"\n                            :key=\"`table-head-cell-${index}`\"\n                            class=\"a-table__head-cell\"\n                            :class=\"{\n                                ['a-table__cell_colspan_' + cell.colspan]: cell.colspan,\n                                ['a-table__cell_align_' + cell.align]: cell.align\n                            }\"\n                        >\n                            <s-table-head-cell :cell=\"cell\" is-type-one />\n                        </div>\n                    </div>\n                </div>\n                <table ref=\"bodyRef\" class=\"a-table__body syncscroll\" name=\"table-part\">\n                    <tbody class=\"syncscroll\">\n                        <tr\n                            v-for=\"(row, rowIndex) in l10n.rows\"\n                            :key=\"`table-row-${rowIndex}`\"\n                            class=\"a-table__row\"\n                            :class=\"getClassNameForTableRow(row)\"\n                        >\n                            <td\n                                v-for=\"(cell, cellIndex) in row.content\"\n                                :key=\"`table-cell-${cellIndex}`\"\n                                class=\"a-table__cell\"\n                                :class=\"getClassNameForTableCell(cell)\"\n                            >\n                                <div v-if=\"effectiveMobileType === 'column'\" class=\"a-table__head-mobile\">\n                                    <s-table-mobile-head-cell :head-cell=\"l10n.head[cellIndex]\" />\n                                </div>\n                                <template v-if=\"isTextCell(cell) && !cell.expand\">\n                                    <div :class=\"[`a-table__${cell.type}`]\">\n                                        <a-glyph\n                                            v-if=\"cell.glyph\"\n                                            class=\"a-table__glyph\"\n                                            :name=\"cell.glyph\"\n                                            :fill=\"cell.fill\"\n                                        />\n                                        <template v-if=\"cell.productPageCTA\">\n                                            <a-product-cta\n                                                :settings=\"{ hasDescription: true, ...cell.productPageCTA }\"\n                                            />\n                                        </template>\n                                        <template v-else>\n                                            <a-link\n                                                v-if=\"cell.to\"\n                                                v-bind=\"cell\"\n                                                class=\"a-table__category-link\"\n                                                :text=\"cell.val\"\n                                                :size=\"cell.size || 'paragraph'\"\n                                            />\n                                            <span v-else v-html=\"cell.val\" />\n                                        </template>\n                                        <a-tooltip v-if=\"cell.tooltip\" class=\"a-table__tooltip\" :content=\"cell.tooltip\" />\n                                    </div>\n                                </template>\n                                <template v-if=\"cell.expand\">\n                                    <div\n                                        :class=\"[`a-table__${cell.type}`, `a-table__expand`]\"\n                                        @click=\"toggleExpand(cellIndex, rowIndex)\"\n                                    >\n                                        <a-glyph\n                                            :name=\"isExpand(cellIndex, rowIndex) ? 'chevron-big-down' : 'i-chevron-big-right--16'\"\n                                            class=\"toggleIcon\"\n                                        />\n                                        <template v-if=\"cell.productPageCTA\">\n                                            <a-product-cta\n                                                :settings=\"{ hasDescription: true, ...cell.productPageCTA }\"\n                                            />\n                                        </template>\n                                        <template v-else>\n                                            <a-link\n                                                v-if=\"cell.to\"\n                                                v-bind=\"cell\"\n                                                class=\"a-table__category-link\"\n                                                :text=\"cell.val\"\n                                                :size=\"cell.size || 'paragraph'\"\n                                            />\n                                            <span v-else v-html=\"cell.val\" />\n                                        </template>\n                                        <template v-if=\"cell.tooltips\">\n                                            <a-tooltip\n                                                v-for=\"tooltip in cell.tooltips\"\n                                                :key=\"tooltip.text\"\n                                                :glyph=\"tooltip.glyph\"\n                                                class=\"a-table__tooltip\"\n                                                :content=\"tooltip.text\"\n                                            />\n                                        </template>\n                                        <a-tooltip v-if=\"cell.tooltip\" class=\"a-table__tooltip\" :content=\"cell.tooltip\" />\n                                    </div>\n                                </template>\n                                <template v-else-if=\"cell.type === 'list'\">\n                                    <div class=\"a-table__list-wrap\">\n                                        <ul class=\"a-table__list\">\n                                            <li v-for=\"(item, i) in cell.list\" :key=\"i\" class=\"a-table__list-item\">\n                                                {{ item }}\n                                            </li>\n                                        </ul>\n                                    </div>\n                                </template>\n                                <template v-else-if=\"cell.type === 'checked'\">\n                                    <div class=\"a-table__check\">\n                                        <div v-if=\"l10n.translated?.checked\" class=\"a-table__check-text\">\n                                            {{ l10n.translated.checked[cell.val] }}\n                                        </div>\n                                        <div v-else class=\"a-table__check-icon\" :class=\"[`a-table__check-icon_${cell.val}`]\" />\n                                    </div>\n                                </template>\n                                <template v-else-if=\"cell.type === 'button'\">\n                                    <div class=\"a-table__button-wrapper\">\n                                        <a-button\n                                            v-modal=\"getButtonModalId(cell.val)\"\n                                            v-bind=\"cell.val\"\n                                            :to=\"getButtonModalId(cell.val) ? null : cell.val.link\"\n                                        />\n                                    </div>\n                                </template>\n                                <template v-if=\"cell.description && (!cell.expand || isExpand(cellIndex, rowIndex))\">\n                                    <div\n                                        class=\"a-table__description\"\n                                        :class=\"{ 'a-table__description-full': cell.description.full }\"\n                                    >\n                                        <a-icon\n                                            v-if=\"cell.description.icon\"\n                                            class=\"a-table__description-icon\"\n                                            icon-variant\n                                            :number=\"cell.description.icon\"\n                                        />\n                                        <div v-if=\"cell.description.title\" class=\"a-table__description-title\">\n                                            {{ cell.description.title }}\n                                        </div>\n                                        <div v-if=\"cell.description.text\" class=\"a-table__description-text\">\n                                            {{ cell.description.text }}\n                                        </div>\n                                        <a-link\n                                            v-if=\"cell.description.link\"\n                                            class=\"a-table__description-link\"\n                                            v-bind=\"cell.description.link\"\n                                        />\n                                        <div\n                                            v-if=\"cell.description.note\"\n                                            class=\"a-table__description-note\"\n                                        >\n                                            {{ cell.description.note }}\n                                        </div>\n                                    </div>\n                                </template>\n                            </td>\n                        </tr>\n                    </tbody>\n                </table>\n            </div>\n            <template v-else>\n                <div ref=\"headRef\" class=\"a-table__head syncscroll\" name=\"table-part\">\n                    <div\n                        class=\"a-table__head-row\"\n                        :class=\"{ 'a-table__head-row_no-scroll': l10n.settings.headMobileType === 'no-scroll' }\"\n                    >\n                        <s-table-head-switcher\n                            v-if=\"l10n.settings.switcher\"\n                            v-model=\"withOptionalRows\"\n                            :text=\"l10n.settings.switcher\"\n                        />\n                        <div\n                            v-for=\"(cell, index) in l10n.head\"\n                            :key=\"`table-head-cell-${index}`\"\n                            class=\"a-table__head-cell\"\n                            :class=\"{\n                                ['a-table__cell_colspan_' + cell.colspan]: cell.colspan,\n                                ['a-table__cell_align_' + cell.align]: cell.align\n                            }\"\n                        >\n                            <s-table