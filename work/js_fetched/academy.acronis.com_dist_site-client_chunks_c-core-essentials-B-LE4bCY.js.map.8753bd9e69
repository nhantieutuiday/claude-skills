: var(--el-secondary-active);\n    }\n    &:hover, &.hover {\n        background-color: var(--el-secondary-hover);\n    }\n    span {\n        overflow: hidden;\n        text-overflow: ellipsis;\n        white-space: nowrap;\n        line-height: 32px !important;\n    }\n    :deep(.el-text--highlighting) {\n        background: var(--av-fixed-highlight);\n    }\n}\n</style>\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <div\n        class=\"el-divider\"\n        :class=\"{\n            [`el-divider--color-${color}`]: color,\n            'is-vertical': vertical\n        }\"\n        :style=\"`height: ${height}px`\"\n    />\n</template>\n\n<script setup>\nimport { isInteger } from 'lodash-es';\nimport { ref } from 'vue';\n\nconst props = defineProps({\n    color: { type: String, default: 'brand-accent' },\n    vertical: { type: [Boolean, Number], default: false },\n});\n\nconst height = ref(isInteger(props.vertical) ? props.vertical : null);\n</script>\n\n<style scoped>\n.el-divider {\n    margin: 8px auto;\n    width: 100%;\n    height: 1px;\n    min-height: 1px;\n    vertical-align: middle\n}\n\n.el-divider--color-brand-light {\n    background-color: var(--av-brand-light)\n}\n\n.el-divider--color-brand-lightest {\n    background-color: var(--av-brand-lightest)\n}\n\n.el-divider--color-brand-accent {\n    background-color: var(--av-brand-accent)\n}\n\n.el-divider.is-vertical {\n    display: block;\n    width: 1px;\n    min-width: 1px;\n    min-height: 24px;\n    height: 100%;\n}\n</style>\n","<template>\n    <div\n        v-show=\"visible\"\n        ref=\"wrap\"\n        class=\"el-select-dropdown el-popper qa-select-dropdown\"\n        :class=\"[\n            { 'is-multiple': select?.props?.multiple },\n            select?.props?.popperClass,\n            { 'dynamic-width': dynamicWidth }\n        ]\"\n        :style=\"dropdownStyle\"\n    >\n        <div\n            v-if=\"filterable\"\n            class=\"el-select-dropdown-search qa-