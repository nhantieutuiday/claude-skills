,\n    };\n});\n\nfunction onSearchEdit(val) {\n    emit('searchedit', val);\n}\n\nfunction scrollToReference() {\n    const rect = referenceElm.value?.getBoundingClientRect?.();\n    if (!rect) return;\n\n    if (rect.bottom > window.innerHeight) {\n        referenceElm.value.scrollIntoView(false);\n    } else if (rect.top < 0) {\n        referenceElm.value.scrollIntoView();\n    }\n\n    nextTick(() => select?.updatePopper?.());\n}\n\nfunction updateMinWidthFromTrigger() {\n    nextTick(() => {\n        const el = select?.triggerRef?.value?.$el;\n        if (el?.offsetWidth) {\n            minWidth.value = `${el.offsetWidth}px`;\n        }\n        windowWidth.value = `${window.innerWidth}px`;\n    });\n}\n\nfunction handleResize() {\n    updateMinWidthFromTrigger();\n}\n\nwatch(() => props.visible, (val) => {\n    if (val) {\n        updateMinWidthFromTrigger();\n        if (search.value && props.filterable) search.value.focus();\n    } else {\n        searchValue.value = '';\n        select?.destroyPopper?.();\n        emit('onHidePopper');\n    }\n});\n\nonMounted(() => {\n    window.addEventListener('resize', updateMinWidthFromTrigger);\n    updateMinWidthFromTrigger();\n\n    nextTick(() => {\n        if (select?.triggerRef?.offsetWidth) {\n            minWidth.value = select.triggerRef.offsetWidth + 'px';\n        }\n\n        if (props.visible && search.value && props.filterable) {\n            search.value.focus();\n        }\n    });\n\n    select.selectDropdownMounted.value = true;\n\n    select?.on?.('updatePopper', () => {\n        if (select?.visible) {\n            select?.updatePopper?.();\n        }\n    });\n});\n\nonBeforeUnmount(() => {\n    window.removeEventListener('resize', handleResize);\n    emit('onHidePopper');\n});\n\ndefineExpose({\n    search,\n    wrap,\n});\n</script>\n\n<style scoped lang=\"postcss\">\n.el-select-dropdown {\n    will-change: transform, opacity;\n    &-search {\n        &-form {\n            :deep(.el-input__editor) {\n                height: 100%;\n            }\n        }\n    }\n}\n</style>\n","/* eslint-disable no-param-reassign */\n\nexport const scrollIntoView = (container, selected) => {\n    if (typeof window === 'undefined') return; // SSR-safe check\n\n    if (!selected) {\n        container.scrollTop = 0;\n        return;\n    }\n\n    const top = selected.offsetTop;\n    const bottom = selected.offsetTop + selected.offsetHeight;\n    const viewRectTop = container.scrollTop;\n    const viewRectBottom = viewRectTop + container.clientHeight;\n\n    if (top < viewRectTop) {\n        container.scrollTop = top;\n    } else if (bottom > viewRectBottom) {\n        container.scrollTop = bottom - container.clientHeight;\n    }\n};\n\nexport const valueEquals = (a, b) => {\n    // see: https://stackoverflow.com/questions/3115982/how-to-check-if-two-arrays-are-equal-with-javascript\n    if (a === b) return true;\n    if (!(a instanceof Array)) return false;\n    if (!(b instanceof Array)) return false;\n    if (a.length !== b.length) return false;\n    for (let i = 0; i !== a.length; ++i) {\n        if (a[i] !== b[i]) return false;\n    }\n    return true;\n};\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <div\n        v-clickoutside=\"{\n            handler: preventHideOnClick ? handlePreventHideOnClick : closeDropdown,\n            include: [dropdownRef] }\n        \"\n        :class=\"[\n            'el-select',\n            'qa-select',\n            translucent ? 'el-select--translucent' : ''\n        ]\"\n        @keydown.enter.stop.prevent=\"handleEnterKey\"\n    >\n        <el-input\n            :id=\"id\"\n            ref=\"triggerRef\"\n            v-bind=\"$attrs\"\n            :model-value=\"computedLabel\"\n            :disabled=\"disabled\"\n            :name=\"name\"\n            :label=\"label\"\n            :readonly=\"true\"\n            :title=\"computedTitle\"\n            :placeholder=\"placeholder\"\n            :validate-event=\"false\"\n            :class=\"{\n                'is-focus': visible,\n                'qa-select-input': true\n            }\"\n            :prefix-icon=\"placeholderIcon\"\n            :icon-color=\"placeholderIconColor\"\n            :aria-label=\"ariaLabel || label || placeholder\"\n            @click=\"!openOnIconClick && handleClick($event)\"\n            @focus=\"handleFocus\"\n            @blur=\"handleBlur\"\n            @input=\"changeValue\"\n            @keydown.down.stop.prevent=\"handleArrowKey('next')\"\n            @keydown.up.stop.prevent=\"handleArrowKey('prev')\"\n            @keydown.tab=\"closeDropdown({ blur: false })\"\n        >\n            <template v-if=\"!!$slots.prefix\" #selectPrefix>\n                <slot name=\"prefix\" />\n            </template>\n            <template v-if=\"!!$slots.selectSuffix\" #selectSuffix>\n                <slot name=\"selectSuffix\" />\n            </template>\n            <template #suffix>\n                <slot name=\"suffix\" />\n                <a-glyph\n                    :name=\"iconClass\"\n                    fill=\"brand-primary\"\n                    :class=\"['el-select__caret', 'el-input__icon', 'qa-select-icon']\"\n                    @click=\"deleteSelected\"\n                />\n            </template>\n        </el-input>\n\n        <teleport to=\"#teleports\" :disabled=\"!shouldTeleport\">\n            <el-select-dropdown\n                v-if=\"showDropdown || visible || selectDropdownMounted || !flyweight\"\n                ref=\"dropdownRef\"\n                :visible=\"showDropdown || visible\"\n                :filterable=\"filterable\"\n                :search-placeholder=\"searchPlaceholder\"\n                :placement=\"popperPlacement\"\n                :max-width=\"popperMaxWidth\"\n                :dynamic-width=\"dynamicWidth\"\n                :hide-on-resize=\"hideOnResize\"\n                @searchedit=\"onSearchEdit\"\n                @keydown.down.stop.prevent=\"handleArrowKey('next')\"\n                @keydown.up.stop.prevent=\"handleArrowKey('prev')\"\n                @keydown.esc.stop.prevent=\"closeDropdown({ blur: false })\"\n                @keydown.enter.stop.prevent=\"handleEnterKey\"\n                @keydown.tab=\"closeDropdown()\"\n            >\n                <el-scrollbar\n                    v-show=\"isOptionsSectionShown\"\n                    ref=\"scrollbar\"\n                    tag=\"ul\"\n                    role=\"listbox\"\n                    :aria-multiselectable=\"multiple || null\"\n                    :wrap-style=\"`max-height: ${popperMaxHeight};`\"\n                    wrap-class=\"el-select-dropdown__wrap\"\n                    view-class=\"el-select-dropdown__list\"\n                    :dropdown=\"true\"\n                    :class=\"{ 'is-empty': hasQuery && filteredOptionsCount === 0 }\"\n                    @scroll=\"handleDropdownScroll\"\n                >\n                    <div\n                        v-if=\"multiple && selectAll\"\n                        v-show=\"!hasQuery\"\n                    >\n                        <el-option\n                            :key=\"selectAllValue\"\n                            :value=\"selectAllValue\"\n                            :label=\"selectAllLabel\"\n                            :is-touch-scrolling=\"isTouchScrolling\"\n                            @click.stop.prevent=\"handleAllClick\"\n                        />\n                        <el-divider />\n                    </div>\n                    <div v-if=\"isRemoteSelectedSectionShown\">\n                        <el-option\n                            v-for=\"item in previousSelected\"\n                            :key=\"item.value\"\n                            :label=\"item.label\"\n                            :value=\"item.value\"\n                            :icon=\"item.icon\"\n                            :is-touch-scrolling=\"isTouchScrolling\"\n                            :icon-color=\"item.iconColor\"\n                            :force-visible=\"true\"\n                        />\n                        <el-divider v-show=\"isDividerShown\" />\n                    </div>\n                    <div\n                        v-if=\"isRemoteSearchResultsCountShown\"\n                        class=\"el-select-dropdown__search-count\"\n                    >\n                        {{ computedRemoteSearchResultsCount }}\n                    </div>\n                    <!-- @slot Default slot to render the contents to show inside the select input -->\n                    <slot v-if=\"!isLoadingShown\" />\n                    <div\n                        v-if=\"scrollLoading && !isLoadingShown\"\n                        class=\"el-select-dropdown__scroll-loading\"\n                    >\n                        <el-spinner\n                            color=\"brand-primary\"\n                            class=\"mr-8\"\n                        />\n                    </div>\n                    <div v-if=\"emptyText && !hasCount\" class=\"el-select-dropdown__empty\">\n                        {{ emptyText }}\n                    </div>\n                </el-scrollbar>\n                <div\n                    v-if=\"isLoadingShown\"\n                    v-loading=\"isLoadingShown\"\n                    class=\"el-select__loading\"\n                    el-loading-size=\"24\"\n                />\n            </el-select-dropdown>\n        </teleport>\n    </div>\n</template>\n\n<script setup>\nimport { isEqual } from 'lodash-es';\nimport { ref, computed, inject, watch, nextTick, provide, onMounted, onBeforeUnmount } from 'vue';\nimport ElDivider from '@core/components/divider/divider.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport ElInput from '@core/components/input/input.vue';\nimport { Loading } from '@core/components/loading';\nimport ElScrollbar from '@core/components/scrollbar/scrollbar.vue';\nimport ElSpinner from '@core/components/spinner/spinner.vue';\nimport { useDebouncedFn } from '@core/composables/useDebouncedFn';\nimport { useDropdownScroll } from '@core/composables/useDropdownScroll.ts';\nimport { useKeyboardNavigate } from '@core/composables/useKeyboardNavigate.ts';\nimport { usePopper } from '@core/composables/usePopper.ts';\nimport Clickoutside from '@core/directives/v-clickoutside';\nimport ElOption from './option.vue';\nimport ElSelectDropdown from './select-dropdown.vue';\nimport { valueEquals } from './utils.js';\n\nconst emit = defineEmits([\n    'update:modelValue',\n    'change',\n    'focus',\n    'input',\n    'click',\n    'blur',\n    'visible-change',\n    'remove-tag',\n    'searchedit',\n    'queryChange',\n    'clear',\n    'update:showDropdown',\n]);\n\ndefineOptions({\n    directives: {\n        loading: Loading.directive,\n        clickoutside: Clickoutside,\n    },\n});\n\nconst elFormItem = inject('elFormItem', null);\n\nconst props = defineProps({\n    name: { type: String, default: '' },\n    id: { type: String, default: '' },\n    label: { type: String, default: '' },\n    modelValue: {type: [String, Number, Boolean, Object, Array, null], required: true },\n    size: { type: String, default: '' },\n    disabled: Boolean,\n    clearable: Boolean,\n    customText: { type: String, default: '' },\n    customHint: Boolean,\n    filterable: { type: Boolean, default: false },\n    loading: Boolean,\n    scrollLoading: Boolean,\n    isScrollEnd: {type: Boolean, default: true },\n    popperClass: { type: String, default: '' },\n    popperPlacement: { type: String, default: 'bottom-start' },\n    openOnIconClick: Boolean,\n    hideOnScroll: Boolean,\n    hideOnResize: Boolean,\n    dynamicWidth: Boolean,\n    popperMaxWidth: { type: String, default: '' },\n    popperMaxHeight: { type: String, default: '336px' },\n    readonly: Boolean,\n    remote: Boolean,\n    validateEvent: { type: Boolean, default: true },\n    loadingText: { type: String, default: 'Loading' },\n    noMatchText: { type: String, default: 'No match' },\n    noDataText: { type: String, default: 'No data' },\n    remoteMethod: {type: Function, default: undefined},\n    remoteScrollMethod: { type: Function, default: undefined },\n    filterMethod: { type: Function, default: undefined },\n    multiple: Boolean,\n    multipleLimit: { type: Number, default: 0 },\n    multipleShowItemsLimit: { type: Number, default: 3 },\n    showDropdown: Boolean,\n    allowCreate: Boolean,\n    defaultFirstOption: Boolean,\n    placeholder: { type: String, default: 'Select' },\n    placeholderIcon: { type: String, default: '' },\n    placeholderIconColor: { type: String, default: '' },\n    searchPlaceholder: { type: String, default: 'Search' },\n    selectAll: { type: [Boolean, String], default: false },\n    allItemsSelectedText: { type: String, default: '' },\n    reserveKeyword: Boolean,\n    valueKey: { type: String, default: 'value' },\n    flyweight: Boolean,\n    changeOnOptionsRemoval: { type: Boolean, default: true },\n    remoteSearchResultsCount: { type: [Number, String], default: undefined },\n    showSelectedIcon: Boolean,\n    translucent: Boolean,\n    preventHideOnClick: Boolean,\n    shouldTeleport: Boolean,\n    ariaLabel: { type: String, default: '' },\n});\n\n/* Refs */\nconst triggerRef = ref(null);\nconst dropdownRef = ref(null);\nconst scrollbar = ref(null);\nconst options = ref([]);\nconst optionsCount = ref(0);\nconst cachedOptions = ref([]);\nconst filteredOptionsCount = ref(0);\nconst currentPlaceholder = ref('');\nconst cachedPlaceHolder = ref('');\nconst createdLabel = ref(null);\nconst createdSelected = ref(false);\nconst query = ref('');\nconst selectAllValue = ref('all');\nconst previousQuery = ref('');\nconst previousScrollTop = ref('');\nconst previousSelected = ref([]);\nconst searchUnchangedSinceOpen = ref(true);\nconst visible = ref(false);\nconst selectDropdownMounted = ref(false);\nconst selected = ref(props.multiple ? [] : {});\nconst selectedIcon = ref('');\nconst selectedIconColor = ref('');\nconst selectedLabel = ref('');\nconst isTouchScrolling = ref(false);\n\n/* Composables */\nconst { initializePopper, updatePopper, destroyPopper } = usePopper(triggerRef, dropdownRef, {\n    placement: props.popperPlacement,\n    strategy: 'fixed',\n    modifiers: [\n        { name: 'offset', options: { offset: [0, 8] } },\n        {\n            name: 'flip',\n            options: { padding: 8, fallbackPlacements: ['top-start'] },\n        },\n        {\n            name: 'preventOverflow',\n            options: {\n                boundary: 'clippingParents',\n                tether: false,\n            },\n        },\n    ],\n});\nconst {scrollToOption,\n    setScrollPosition,\n    updateHoverOption,\n    setDefaultHoverIndex,\n    receiveScrollTop} = useDropdownScroll(dropdownRef, 'el-select-dropdown__wrap');\n\nconst { debouncedFn: updateValueDeb } = useDebouncedFn(updateValue, 100);\nconst {debouncedFn: debouncedRemoteMethod,\n    isDebouncing: isWithinRemoteDecouncePeriod} = useDebouncedFn(\n    props.remoteMethod,\n    500,\n    {\n        onDebounceEnd: () => {\n            isWithinRemoteDecouncePeriod.value = false;\n        },\n        onDebounceStart: () => {\n            isWithinRemoteDecouncePeriod.value = true;\n        },\n    },\n);\n\nconst {hoverIndex,\n    hoverOption,\n    keyboardNavigate,\n    navigateOptions,\n    resetHoverState} = useKeyboardNavigate({\n    options,\n    visible,\n    scrollToOption,\n    selected,\n    multiple: props.multiple,\n});\n\n\n/* Computed */\nconst selectAllLabel = computed(() => typeof props.selectAll === 'string' ? props.selectAll : 'All');\nconst computedLabel = computed(() => {\n    if (props.customText && typeof props.customText === 'string') return props.customText;\n    return props.multiple ? multipleText.value.text : selectedLabel.value;\n});\nconst multipleText = computed(() => {\n    const selectedList = selected.value ?? [];\n    if (!selectedList.length) return '';\n\n    const filtered = selectedList;\n    const sorted = props.remote ? filtered : [...filtered].sort((a, b) => a._uid - b._uid); // eslint-disable-line no-underscore-dangle\n    const count = sorted.length;\n    const title = sorted.map(x => x.currentLabel).join(', ').trim();\n    const allSelected = props.selectAll &&\n    options.value.length - 1 === props.modelValue.length &&\n    props.allItemsSelectedText;\n    const text = allSelected\n        ? props.allItemsSelectedText\n        : count <= props.multipleShowItemsLimit\n            ? title\n            : `${count} items selected`;\n\n    return { text, title };\n});\nconst computedTitle = computed(() => {\n    if (triggerRef.value?.type === 'password') return '';\n    if (typeof props.customHint === 'string') return props.customHint;\n\n    const hasLabel = props.multiple ? multipleText.value?.title?.length : selectedLabel.value?.length;\n    return hasLabel ? (\n        props.multiple ? multipleText.value.title : selectedLabel.value\n    ) : props.placeholder;\n});\nconst selectionCount = computed(() => {\n    if (props.multiple) return selected.value.length;\n    return selected.value ? 1 : 0;\n});\nconst isDividerShown = computed(() =>\n    typeof props.remoteSearchResultsCount === 'number' &&\n    previousSelected.value?.length &&\n    props.remoteSearchResultsCount > previousSelected.value.length,\n);\nconst isClearable = computed(() =>  props.clearable && !props.disabled && selectionCount.value);\nconst iconClass = computed(() => isClearable.value ? 'times' : (visible.value ? 'i-chevron-up--16' : 'i-chevron-down--16'));\nconst computedRemoteSearchResultsCount = computed(() => {\n    return typeof props.remoteSearchResultsCount === 'number'\n        ? `${props.remoteSearchResultsCount} items found`\n        : props.remoteSearchResultsCount;\n});\nconst isLoadingShown = computed(() => props.loading\n    ? props.loading\n    : (props.remote && props.remoteMethod && isWithinRemoteDecouncePeriod.value));\n\nconst isRemoteFilterableMultiple = computed(() => {\n    return props.remote && props.filterable && props.multiple;\n});\n\nconst isRemoteSelectedSectionShown = computed(() => {\n    return isRemoteFilterableMultiple.value &&\n          !isLoadingShown.value && previousSelected.value.length && !query.value.length;\n});\nconst hasResults = computed(() => options.value.length);\nconst hasQuery = computed(() => Boolean(query.value?.trim()));\nconst hasCount = computed(() => Boolean(computedRemoteSearchResultsCount.value));\nconst isRemoteSearchResultsCountShown = computed(() =>\n    props.remote &&\n  props.filterable &&\n  hasCount.value &&\n  hasQuery.value &&\n  hasResults.value &&\n  !isLoadingShown.value,\n);\n\nconst emptyText = computed(() => {\n    if (isLoadingShown.value) return '';\n    if (!filteredOptionsCount.value) {\n        return hasQuery.value ? props.noMatchText : props.noDataText;\n    }\n    return '';\n});\n\nconst isOptionsSectionShown = computed(() => !isLoadingShown.value && (hasResults.value || Boolean(emptyText.value)));\n\n/* Methods */\nlet touchScrollTimer = null;\nlet wrapEl = null;\n\nfunction markTouchScrolling() {\n    isTouchScrolling.value = true;\n    clearTimeout(touchScrollTimer);\n    touchScrollTimer = setTimeout(() => {\n        isTouchScrolling.value = false;\n    }, 60);\n}\n\nfunction bindWrapListeners() {\n    // get the fresh wrap every time the dropdown appears\n    wrapEl = dropdownRef.value?.$el?.querySelector('.el-select-dropdown__wrap');\n    if (!wrapEl) return;\n    wrapEl.addEventListener('touchmove', markTouchScrolling, { passive: true });\n    wrapEl.addEventListener('touchcancel', markTouchScrolling, { passive: true });\n    wrapEl.addEventListener('pointercancel', markTouchScrolling, { passive: true });\n}\n\nfunction unbindWrapListeners() {\n    if (!wrapEl) return;\n    wrapEl.removeEventListener('touchmove', markTouchScrolling);\n    wrapEl.removeEventListener('touchcancel', markTouchScrolling);\n    wrapEl.removeEventListener('pointercancel', markTouchScrolling);\n    wrapEl = null;\n}\n\nfunction updatePlaceholder(val) {\n    currentPlaceholder.value = val.length > 0 ? '' : cachedPlaceHolder.value;\n}\n\nfunction updateValue(val) {\n    if (props.multiple) {\n        updatePlaceholder(val);\n        if (props.selectAll && options.value.length) {\n            syncSelectAllOption(options.value);\n        }\n    } else {\n        resetHoverState();\n    }\n\n    setSelected();\n};\n\nfunction setSelected() {\n    cacheDropdownScroll();\n\n    if (props.multiple) {\n        updateMultipleSelected();\n    } else {\n        updateSingleSelected();\n    }\n}\n\nfunction changeValue(val) {\n    if (!valueEquals(props.modelValue, val)) {\n        emit('update:modelValue', val);\n        emit('input', val);\n        emit('change', val);\n\n        if (props.validateEvent) {\n            elFormItem?.validate?.('change');\n            elFormItem?.markAsTouched?.();\n        }\n    }\n};\n\nfunction getOption(val) {\n    return options.value.find(opt => isEqual(opt.value, val)) ||\n        cachedOptions.value.find(opt => isEqual(opt.value, val)) ||\n        null;\n}\n\nfunction updateSingleSelected() {\n    const option = getOption(props.modelValue);\n    selected.value = option || null;\n\n    if (!option) {\n        selectedLabel.value = '';\n        selectedIcon.value = '';\n        selectedIconColor.value = '';\n        return;\n    }\n\n    selectedLabel.value = option.label;\n    createdSelected.value = Boolean(option.created);\n    createdLabel.value = option.created ? option.currentLabel : null;\n\n    if (props.showSelectedIcon && option.icon) {\n        selectedIcon.value = option.icon;\n        selectedIconColor.value = option.iconColor;\n    } else {\n        selectedIcon.value = '';\n        selectedIconColor.value = '';\n    }\n}\n\nfunction updateMultipleSelected() {\n    selected.value = [];\n    if (!Array.isArray(props.modelValue)) return;\n\n    props.modelValue.forEach((value) => {\n        selected.value.push(getOption(value));\n    });\n}\n\nfunction cacheDropdownScroll() {\n    const dropdown = dropdownRef.value?.$el?.querySelector('.el-select-dropdown__wrap');\n    if (!dropdown) return;\n    previousScrollTop.value = dropdown.scrollTop;\n}\n\nfunction onSearchEdit(newValue) {\n    emit('searchedit', newValue);\n    query.value = newValue;\n    handleQueryChange(query.value);\n    if (hasQuery.value) return;\n    previousSelected.value = selected.value;\n};\n\nasync function handleQueryChange(val, forceQuery = false) {\n    if (previousQuery.value === val && !forceQuery) return;\n    previousQuery.value = val;\n    hoverIndex.value = -1;\n\n    if (props.remote && typeof props.remoteMethod === 'function') {\n        hoverIndex.value = -1;\n        scrollbar.value?.$refs?.wrap?.scrollTo?.(0, 0);\n        debouncedRemoteMethod(val);\n    } else if (typeof props.filterMethod === 'function') {\n        props.filterMethod(val);\n        emit('queryChange');\n    } else {\n        emit('queryChange', val);\n        await nextTick();\n        filteredOptionsCount.value = options.value.filter(opt => {\n            try {\n                return opt.visible;\n            } catch {\n                return true;\n            }\n        }).length;\n    }\n\n    await nextTick();\n    updatePopper();\n    maybeCheckDefaultFirstOption();\n    if (!props.remote) {\n        options.value.forEach(option => {\n            // eslint-disable-next-line no-param-reassign\n            option.keyword = val;\n        });\n    }\n}\n\nfunction handleEnterKey() {\n    if (visible.value) {\n        selectOption();\n    } else {\n        openDropdown();\n    }\n}\n\nfunction handleArrowKey(direction) {\n    if (!visible.value && !props.disabled) {\n        openDropdown();\n        nextTick(() => navigateOptions(direction));\n    } else {\n        navigateOptions(direction);\n    }\n}\n\nfunction handleDropdown