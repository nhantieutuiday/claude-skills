];\n        errorMessage.value = '';\n        validateState.value = val ? 'error' : '';\n    } else if (Array.isArray(val)) {\n        errorMessages.value = val;\n        errorMessage.value = val[0] || '';\n        validateState.value = val.length ? 'error' : '';\n    } else {\n        errorMessages.value = val ? [val] : [];\n        errorMessage.value = val;\n        validateState.value = val ? 'error' : '';\n    }\n}, { immediate: true });\n\nwatch(() => props.validateStatus, (val) => {\n    validateState.value = val;\n});\n\n// Status propagation\nconst statusMap = { touched, dirty, valid, invalid, isEmpty, isValidating };\n\nObject.entries(statusMap).forEach(([key, source]) => {\n    watch(source, (val) => {\n        emit('status', { name: key, value: val });\n    }, { immediate: true });\n});\n\nconst publicMethods = {\n    prop: props.prop,\n    validate,\n    clearValidate,\n    resetField,\n    resetInitialValue,\n    focus: () => inputComponent.value?.focus?.(),\n    touched: computed(() => touched.value),\n    dirty: computed(() => dirty.value),\n    valid: computed(() => valid.value),\n    invalid: computed(() => invalid.value),\n    isEmpty: computed(() => isEmpty.value),\n    isValidating: computed(() => isValidating.value),\n    validateState: computed(() => validateState.value),\n};\n\n\nonMounted(async () => {\n    const AsyncValidatorPackage = await AsyncValidatorImport();\n    AsyncValidator = AsyncValidatorPackage.default;\n\n    if (props.prop && elForm) {\n        nextTick(() => {\n            elForm.addField(publicMethods);\n            resetInitialValue();\n        });\n    }\n});\n\nonBeforeUnmount(() => {\n    elForm?.removeField(publicMethods);\n});\n\nfunction getFilteredRule(trigger, isSubmit = false) {\n    if (isSubmit) {\n        return allRules.value.map(rule => objectAssign({}, rule));\n    }\n\n    return allRules.value\n        .filter(rule => {\n            if (rule.trigger == null) return true;\n            if (Array.isArray(rule.trigger)) return rule.trigger.includes(trigger);\n            if (typeof rule.trigger === 'string' && rule.trigger.includes(' ')) {\n                return rule.trigger.split(' ').includes(trigger);\n            }\n            return rule.trigger === trigger;\n        })\n        .map(rule => objectAssign({}, rule));\n}\n\nfunction getRulesByPath(rules, prop = '') {\n    const paths = prop.split('.');\n    let current = rules;\n    for (let i = 0, j = paths.length; i < j; i++) {\n        const path = paths[i];\n        if (!current) break;\n\n        if (current[path] !== undefined) {\n            current = current[path];\n        } else if (current.fields && typeof current.fields === 'object' && current.fields[path] !== undefined) {\n            current = current.fields[path];\n        } else {\n            current = current.defaultField;\n        }\n    }\n    return current || null;\n}\n\nfunction validate(trigger = '', callback = () => {}, isSubmit = false) {\n    // Avoid flacky tests\n    // TODO: this is a quick & dirty solution.\n    // Instead, we must make this method async and wait for the import\n    // until the AsyncValidator constructor is ready.\n    // Can't do it right now because I have no idea if this method callers are ok with changing it to async,\n    // even though they should be, given there is a callback in the args.\n    // eslint-disable-next-line no-underscore-dangle\n    if (typeof window !== 'undefined' && window.__vitest_browser__ && !AsyncValidator) {\n        return false;\n    }\n\n    const rules = getFilteredRule(trigger, isSubmit);\n    // Legacy fallback: handle manual error prop if no rules defined\n    if ((!rules || rules.length === 0)) {\n        if (typeof props.error === 'boolean' && props.error) {\n            errorMessages.value = [];\n            errorMessage.value = '';\n            validateState.value = 'error';\n        } else if (Array.isArray(props.error) && props.error.length > 0) {\n            errorMessages.value = props.error;\n            errorMessage.value = props.error[0];\n            validateState.value = 'error';\n        } else if (props.error) {\n            errorMessages.value = [props.error];\n            errorMessage.value = props.error;\n            validateState.value = 'error';\n        }\n        callback?.(errorMessage.value);\n        return true;\n    }\n\n    // Reset errors unless in error/validating\n    if (validateState.value !== 'error' && validateState.value !== 'validating') {\n        validateState.value = '';\n        errorMessages.value = [];\n        errorMessage.value = '';\n    }\n\n    validateState.value = 'validating';\n\n    const descriptor = { [props.prop]: rules.map(r => ({ ...r, trigger: undefined })) };\n    const validator = new AsyncValidator(descriptor);\n    const model = { [props.prop]: modelValue.value };\n\n    validator.validate(model, { firstFields: true }, (errors) => {\n        if (errors) {\n            validateState.value = 'error';\n            errorMessages.value = errors.map(err => err.message);\n            errorMessage.value = errorMessages.value[0] || '';\n        } else {\n            validateState.value = 'success';\n            errorMessages.value = [];\n            errorMessage.value = '';\n        }\n\n        hasValidated.value = true;\n        callback?.(errorMessage.value);\n    });\n}\n\nfunction clearValidate() {\n    validateState.value = '';\n    errorMessages.value = [];\n    errorMessage.value = '';\n}\n\nfunction resetField() {\n    validateDisabledByChange.value = true;\n    validateDisabledByInput.value = true;\n\n    touched.value = false;\n    clearValidate();\n    const path = props.prop.replace(/:/, '.');\n    const propVal = getPropByPath(elForm.model, path, true);\n    propVal.o[propVal.k] = Array.isArray(initialValue.value)\n        ? [...initialValue.value]\n        : initialValue.value;\n}\n\nfunction resetInitialValue() {\n    initialValue.value = Array.isArray(modelValue.value)\n        ? [...modelValue.value]\n        : modelValue.value;\n}\n\n// Contexts\nprovide('elFormItem', {\n    prop: props.prop,\n    validate,\n    clearValidate,\n    resetField,\n    markAsFocused: () => { isFocused.value = true; },\n    markAsBlurred: () => { isFocused.value = false; },\n    markAsTouched: () => { touched.value = true; },\n});\nprovide('elFormItemIsInvalid', () => invalid.value);\nprovide('elFormItemRegisterInput', (comp) => {\n    inputComponent.value = comp;\n});\n\n// Expose public methods\ndefineExpose({\n    focus: () => inputComponent.value?.focus?.(),\n    validate,\n    clearValidate,\n    resetField,\n    resetInitialValue,\n});\n</script>\n\n<style lang=\"postcss\" scoped>\n.el-form-item {\n    padding-bottom: 8px;\n    font-family: var(--font-family-default);\n    @mixin body;\n    color: var(--av-fixed-primary);\n    display: flex;\n    flex-direction: column;\n    user-select: none;\n    &__label {\n        line-height: 32px;\n    }\n    &__content {\n        position: relative;\n    }\n    &__error-holder {\n        min-height: 16px;\n    }\n    &__error {\n        @mixin caption;\n        display: flex;\n        justify-content: flex-start;\n        align-items: center;\n        color: var(--av-fixed-danger);\n        white-space: normal;\n        word-break: break-all;\n        user-select: none;\n    }\n    &.is-error.is-focus {\n        .el-form-item__error {\n            color: var(--av-fixed-light);\n        }\n    }\n}\n</style>\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <form class=\"el-form\" :class=\"className\" @submit.prevent=\"handleSubmit\">\n        <slot />\n    </form>\n</template>\n\n<script setup>\nimport { reactive, computed, toRefs, watch, nextTick, provide } from 'vue';\n\nconst props = defineProps({\n    inlineMessage: {\n        type: Boolean,\n        default: true,\n    },\n    model: {\n        type: Object,\n        default: () => ({}),\n    },\n    rules: {\n        type: Object,\n        default: () => ({}),\n    },\n    loading: {\n        type: Boolean,\n        default: false,\n    },\n    showMessage: {\n        type: Boolean,\n        default: true,\n    },\n    hints: {\n        type: Object,\n        default: () => ({}),\n    },\n});\nconst emit = defineEmits(['submit', 'status', 'error']);\nconst state = reactive({ fields: [] });\n\nconst touched = computed(() => state.fields.some(f => f.touched));\nconst dirty = computed(() => state.fields.some(f => f.dirty));\nconst isValidating = computed(() => state.fields.some(f => f.isValidating));\nconst isEmpty = computed(() => state.fields.some(f => f.isEmpty));\nconst invalid = computed(() =>\n    state.fields.some(f => f.invalid) || (isEmpty.value && dirty.value),\n);\nconst valid = computed(() => !state.fields.some(f => f.invalid) && !(isEmpty.value && dirty.value));\nconst className = computed(() => ({\n    'is-valid': valid.value,\n    'is-invalid': invalid.value,\n    'is-touched': touched.value,\n    'is-untouched': !touched.value,\n    'is-dirty': dirty.value,\n    'is-pristine': !dirty.value,\n    'is-validating': isValidating.value,\n    'is-submitting': props.loading,\n}));\n\nprovide('elForm', {\n    ...toRefs(props),\n    touched,\n    untouched: computed(() => !touched.value),\n    dirty,\n    pristine: computed(() => !dirty.value),\n    invalid,\n    valid,\n    isValidating,\n    isSubmitting: computed(() => props.loading),\n    className,\n    model: props.model,\n    rules: props.rules,\n    hints: props.hints,\n    addField: (field) => state.fields.push(field),\n    removeField: (field) => {\n        const idx = state.fields.indexOf(field);\n        if (idx !== -1) state.fields.splice(idx, 1);\n    },\n});\n\nwatch(touched, val => emit('status', { name: 'touched', value: val }), { immediate: true });\nwatch(dirty, val => emit('status', { name: 'dirty', value: val }), { immediate: true });\nwatch(invalid, val => emit('status', { name: 'invalid', value: val }), { immediate: true });\nwatch(valid, val => emit('status', { name: 'valid', value: val }), { immediate: true });\nwatch(isValidating, val => emit('status', { name: 'isValidating', value: val }), { immediate: true });\nwatch(className, val => emit('status', { name: 'className', value: val }), { immediate: true });\n\nwatch(() => props.rules, () => {\n    nextTick(() => validate(() => {}));\n});\n\n// Methods\nfunction validate(callback) {\n    if (!props.model) return;\n    // eslint-disable-next-line @typescript-eslint/no-shadow\n    let valid = true;\n    let count = 0;\n\n    if (typeof callback !== 'function' && window.Promise) {\n        return new Promise((resolve, reject) => {\n            validate((v) => v ? resolve(v) : reject(v));\n        });\n    }\n\n    if (!state.fields.length) {\n        callback(true);\n        return;\n    }\n\n    state.fields.forEach(field => {\n        field.validate('', errors => {\n            if (errors) valid = false;\n            if (++count === state.fields.length) callback(valid);\n        }, true);\n    });\n}\n\nfunction validateField(prop, cb) {\n    const field = state.fields.find(f => f.prop === prop);\n    if (!field) throw new Error('Must call validateField with valid prop!');\n    field.validate('', cb);\n}\n\nfunction handleSubmit() {\n    validate((v) => {\n        if (v) {\n            emit('submit', props.model);\n        } else {\n            emit('error');\n        }\n    });\n}\n\nfunction resetFields() {\n    state.fields.forEach(f => f.resetField());\n}\n\nfunction clearValidate() {\n    state.fields.forEach(f => f.clearValidate());\n}\n\nfunction resetInitialValue() {\n    state.fields.forEach(f => f.resetInitialValue());\n}\n\ndefineExpose({\n    validate,\n    validateField,\n    fields: state.fields,\n    resetFields,\n    clearValidate,\n    resetInitialValue,\n});\n</script>\n","export default [\n    'AT',\n    'AU',\n    'BE',\n    'BG',\n    'BR',\n    'CN',\n    'CY',\n    'CZ',\n    'DE',\n    'DK',\n    'EE',\n    'ES',\n    'FI',\n    'FR',\n    'GB',\n    'GR',\n    'HR',\n    'HU',\n    'IE',\n    'IS',\n    'IT',\n    'JP',\n    'LI',\n    'LT',\n    'LU',\n    'LV',\n    'MT',\n    'NG',\n    'NL',\n    'NO',\n    'NZ',\n    'PL',\n    'PT',\n    'RO',\n    'SE',\n    'SG',\n    'SI',\n    'SK',\n    'TH',\n    'ZA',\n];\n","import Cookies from 'js-cookie';\nimport { findKey, isEmpty, groupBy, isBoolean } from 'lodash-es';\nimport { mapState, mapActions } from 'vuex';\nimport listCountriesGDPR from '@model/const/countries-gdpr.ts';\nimport { LOCALE_DEFAULT } from '@model/const/locales.ts';\nimport utils from '@utils/form.js';\nimport { getLanguageCodeFromLocale } from '@utils/languages.ts';\nimport { Logger } from '@utils/logger.ts';\n\nconst EMAIL_DOMAINS_BLACKLIST = ['acronis.'];\n\nexport default {\n    data: () => ({\n        isLoading: false,\n        searchParams: null,\n        isVisibleOptIn: false,\n        validatedEmailOptIn: '',\n        guid: null,\n        freeEmailServices: new Set(),\n    }),\n\n    async mounted() {\n        this.searchParams = new URLSearchParams(this.queryStringData);\n\n        const listFreeDomains = await import('@model/const/emails-services-free.ts');\n        this.freeEmailServices = new Set(listFreeDomains.default);\n    },\n\n    computed: {\n        ...mapState({\n            accountData: (state) => state.user?.data || null,\n            location: (state) => state.geolocation?.location || null,\n            settingsEvent: (state) => state.events?.event?.items?.[0] || null,\n            formElementsDefault: (state) => state.slices.items?.['s-list-form-elements'] || {},\n            formGlobalSettings: (state) => state.slices.items?.['s-form-global-settings'] || {},\n            queryStringData: (state) => state.trial?.queryStringData || {},\n        }),\n\n        formUpdatePresetName() {\n            return this.form?.update?.preset || 's-preset-form-trial-update';\n        },\n\n        settingsFormUpdate() {\n            return this.$store.state.slices.items?.[this.formUpdatePresetName] || {};\n        },\n\n        payloadAccount() {\n            const companySize = {\n                '6-10': '1-10',\n                '51-100': '11-100',\n                '101-250': '101-500',\n                '251-500': '101-500',\n                '501-1000': '501-1000',\n                '1001-5000': '1001-5000',\n                '5001+': '5000+',\n            };\n            const companyType = {\n                'Corporate End-Customer': 'EndUser',\n                'Service Provider': 'ServiceProvider',\n            };\n            const industry = {\n                'Educational Services': 'Education',\n                'Public Administration': 'Government',\n                'Health Care and Social Assistance': 'Healthcare & Pharmaceutical',\n            };\n            const subscription = Number(this.userData.gdpr_opt_in);\n            const isCorporate = companyType[this.userData.company_type];\n            const payload = {\n                country: this.userData.country,\n                email: this.userData.email,\n                first: this.userData.first_name,\n                is_beta: this.userData.is_beta || false,\n                last: this.userData.last_name,\n                password: this.userData.password,\n                phone: this.userData.phone || '000000000',\n                postponed_activation: true,\n                state: this.userData.state || '',\n                subscription_corporate: isCorporate ? subscription : 0,\n                subscription_home: !isCorporate ? subscription : 0,\n                subscription_language: 'en-US',\n                type: 'consumer',\n            };\n            if (isCorporate) {\n                payload.company_name = this.userData.company || 'Unavailable';\n                payload.company_size = companySize[this.userData.of_Employees__c] || '1-10';\n                payload.company_type = companyType[this.userData.company_type || 'Corporate End-Customer'];\n                payload.industry = industry[this.userData.industry] || '';\n                payload.type = 'enterprise';\n            }\n            if (this.userData.postal_code) {\n                payload.zip = this.userData.postal_code;\n            }\n\n            return payload;\n        },\n\n        locale() {\n            return this.$store.state.geolocation.finalLocale || LOCALE_DEFAULT;\n        },\n\n        // TODO: should these two use getLanguageCodeFromLocale?\n        countryCode() {\n            return this.locale.split('-').pop();\n        },\n\n        language() {\n            return this.locale.split('-').shift();\n        },\n\n        showPostalCodeField() {\n            const result = this.form.country === 'DE';\n            if (!result) {\n                this.form.postal_code = '';\n            }\n            return result;\n        },\n\n        showStatesField() {\n            const result = this.form.country === 'US';\n            if (!result) {\n                this.form.state = '';\n            }\n            return result;\n        },\n\n        labelSelect() {\n            return {\n                placeholder: this.formElementsDefault.errors?.select?.placeholder,\n                noMatchText: this.formElementsDefault.errors?.select?.noMatch,\n                noDataText: this.formElementsDefault.errors?.select?.noData,\n                searchPlaceholder: this.formElementsDefault.errors?.select?.searchPlaceholder,\n            };\n        },\n\n        isCountryGDPR() {\n            return listCountriesGDPR.includes(this.form.country);\n        },\n\n        isCloudConsoleLoginFlowEnabled() {\n            return Boolean(this.form?.flow?.isCloudConsoleLoginFlowEnabled);\n        },\n\n        formRecaptchaText() {\n            return this.content?.recaptcha?.text || this.formElementsDefault.recaptcha || '';\n        },\n        web46922() {\n            // WEB-46922\n            const result = {\n                1: 'homepage-2024-control',\n                2: 'homepage-2024-b',\n                3: 'homepage-2024-c',\n                4: 'homepage-2024-d',\n            };\n            const value = Cookies.get('_vis_opt_exp_123_combi') || '';\n            return result[value] || '';\n        },\n        web47483() {\n            const result = Object.keys(localStorage || {})\n                .filter((item) => item.startsWith('demoButtonClick'))\n                .map((item) => ({ [item]: localStorage.getItem(item) }));\n\n            return !result.length ? false : Object.assign(...result);\n        },\n        setUtmTerm() {\n            return this.web47483 || this.web46922;\n        },\n\n        firstEmptyInputFieldName() {\n            const isEmptyValue = (item) => !this.form[item.name];\n            const isInputField = (item) => !item.type?.startsWith('select');\n            return this.listField.find((item) => isInputField(item) && isEmptyValue(item))?.name || null;\n        },\n\n        formSelectFields() {\n            const steps = this.content?.steps || this.form?.registration?.steps || [];\n            const stepFields = steps.flatMap((step) => step.fields || step.form?.registration?.fields || []);\n            const fields = this.content?.fields || this.form?.registration?.fields || stepFields;\n            return (Array.isArray(fields) ? fields : []).filter((item) => item.type?.startsWith('select'));\n        },\n\n        hasBusinessEmailSelectOption() {\n            return this.formSelectFields.some((item) => item.options?.some((opt) => opt.isBusinessEmail));\n        },\n\n        isBusinessEmailBySelectOption() {\n            return this.formSelectFields.some((item) => {\n                const value = this.form?.[item.name];\n                if (!value) return false;\n\n                const options = item.options;\n                const selected = utils.findOptionByValue(options, value);\n                return selected?.isBusinessEmail;\n            });\n        },\n    },\n\n    methods: {\n        ...mapActions({\n            getOptInStatus: 'trial/getOptInStatus',\n        }),\n\n        setErrorMessage(type) {\n            return this.formElementsDefault.errors?.[type];\n        },\n\n        setFocus(str = '') {\n            const name = this.settingsForm?.focus || str;\n\n            this.$nextTick(() => {\n                const elements = this.getFormElements();\n                if (!elements) return;\n\n                const elementID = name ? findKey(elements, { name }) : 0;\n                elements[elementID]?.focus?.();\n                if (this.settingsForm?.validate) {\n                    this.$refs.form?.validate?.(() => false);\n                }\n            });\n        },\n\n        getFormElements() {\n            return this.$refs.form?.$el?.elements;\n        },\n\n        getFormErrorProps() {\n            const formFields = this.$refs.form?.fields || [];\n            return new Set(formFields.filter((f) => f.validateState === 'error').map((f) => f.prop));\n        },\n\n        getFirstAnimateErrorFieldName() {\n            const errorProps = this.getFormErrorProps();\n            if (this.firstEmptyInputFieldName) errorProps.add(this.firstEmptyInputFieldName);\n            return this.listField.find((item) => errorProps.has(item.name))?.name || null;\n        },\n\n        setFocusAnimateErrorField() {\n            const fieldName = this.getFirstAnimateErrorFieldName();\n            if (!fieldName) return null;\n\n            this.getFormElements()?.[fieldName]?.focus?.();\n            return fieldName;\n        },\n\n        setFocusErrorField() {\n            if (this.hasAnimate) {\n                this.setFocusAnimateErrorField();\n                return;\n            }\n\n            const errorField = this.$refs.form?.fields?.find((f) => f.validateState === 'error');\n            if (errorField && errorField.prop !== 'email') {\n                errorField?.focus?.();\n            }\n        },\n\n        isVisibleField(item, type) {\n            if (item.type === 'hidden') {\n                this.form[item.name] = item.value;\n                return false;\n            }\n\n            if (!item.type || !type.includes(item.type)) {\n                return false;\n            }\n\n            if (item.visible) {\n                if (!item.visible.list || !item.visible.field) {\n                    return false;\n                }\n\n                const dependent = this.form[item.visible.field];\n                const isVisible = item.visible.list.includes(dependent);\n\n                if (!isVisible) {\n                    this.form[item.name] = '';\n                }\n\n                return isVisible;\n            }\n\n            if (item.name === 'state') {\n                return this.showStatesField;\n            }\n\n            if (/postal_?code/i.test(item.name)) {\n                return this.showPostalCodeField;\n            }\n\n            if (item.getReseller && !this.resellerList.length) return false;\n            if (item.getDistributor && !this.distributorList.length) return false;\n\n            return true;\n        },\n\n        isFreeEmail(email) {\n            if (!email) return false;\n            const domain = email.replace(/.*?@/, '');\n            return this.freeEmailServices.has(domain);\n        },\n\n        isBusinessEmail() {\n            const fields = this.form.registration?.fields || [];\n            const email = fields.find((x) => x.name === 'email') || {};\n            return email.isBusinessEmail;\n        },\n\n        isBusinessOnlyEmail() {\n            const fields = this.form.registration?.fields || this.content?.fields || [];\n            const email = fields.find((x) => x.name === 'email') || {};\n            return email.isBusinessOnlyEmail;\n        },\n\n        isRequired(item) {\n            return this.content.hasAsterisks && item.required;\n        },\n\n        isRequiredSelect(item) {\n            return !['country', 'state'].includes(item.name) && this.isRequired(item);\n        },\n\n        replaceLocale(str = '') {\n            const locale = this.locale ?? LOCALE_DEFAULT;\n            const localeMarker = this.$store.state.geolocation.isLanguageAware\n                ? getLanguageCodeFromLocale(locale)\n                : locale;\n            return str.replace(/\\/LOCALE\\//g, `/${localeMarker}/`);\n        },\n\n        validateLogin(rule, value, callback) {\n            if (rule.errorMessageLogin && this.form.login === this.userData.login) {\n                return callback(new Error(rule.errorMessageLogin));\n            }\n            if (!/^[a-zA-Z0-9.@_\\-+:!#$%^*={}'`/?]+$/.test(value)) {\n                return callback(new Error(rule.errorMessage));\n            }\n            return callback();\n        },\n\n        validateEmail(rule, value, callback) {\n            if (!value) {\n                return callback(new Error(rule.errorMessage));\n            }\n            if (rule?.errorMessageMailgun?.message) {\n                if (rule.errorMessageMailgun.email !== this.form.email) return callback();\n                return callback(new Error(rule.errorMessageMailgun.message));\n            }\n            if (!utils.checkIfFieldLengthValid('input', value)) {\n                return callback(new Error(this.setErrorMessage('invalidInputLength')));\n            }\n            if (!utils.checkIfEmailHasAddressSign(value)) {\n                return callback(new Error(this.setErrorMessage('missingEmailSymbol')));\n            }\n            if (!utils.checkIfEmailValid(value)) {\n                return callback(new Error(this.setErrorMessage('invalidEmail')));\n            }\n            const businessEmailOnly = rule?.isBusinessOnlyEmail || this.isBusinessEmailBySelectOption;\n            if (businessEmailOnly && this.isFreeEmail(value)) {\n                return callback(new Error(rule.errorMessageBusiness));\n            }\n            if (rule?.isBusinessEmailByCountry) {\n                const coutries = new Set(['in', 'bd', 'bt', 'io', 'lk', 'mv', 'np']);\n                const country = this.form?.country?.toLowerCase() || '';\n                if (coutries.has(country) && this.isFreeEmail(value)) {\n                    return callback(new Error(rule.errorMessageBusiness));\n                }\n            }\n            return callback();\n        },\n\n        validatePhone(rule, value, callback) {\n            const cleanedValue = value?.replaceAll(' ', '');\n            if (!cleanedValue || cleanedValue === '+') {\n                return callback(new Error(rule.errorMessage));\n            }\n            if (!utils.checkIfFieldLengthValid('input', cleanedValue)) {\n                return callback(new Error(this.setErrorMessage('invalidInputLength')));\n            }\n            if (!utils.checkIfPhoneValid(cleanedValue)) {\n                return callback(new Error(this.setErrorMessage('invalidPhone')));\n            }\n            return callback();\n        },\n\n        validatePassword(rule, value, callback) {\n            if (!value) {\n                return callback(new Error(rule.errorMessage));\n            }\n            if (!utils.checkIfFieldLengthValid('input', value)) {\n                return callback(new Error(this.setErrorMessage('invalidInputLength')));\n            }\n            if (value.length < 8) {\n                return callback(new Error(this.setErrorMessage('shortPassword')));\n            }\n\n            return callback();\n        },\n\n        validateFieldValue(rule, value, callback) {\n            const hasValue = value && value.toString().replaceAll(' ', '').length;\n            if (!hasValue && rule.required) {\n                return callback(new Error(rule.errorMessage));\n            }\n            if (!utils.checkIfFieldLengthValid(rule.fieldType, value)) {\n                const type = rule.fieldType === 'input' ? 'invalidInputLength' : 'invalidTextAreaLength';\n                return callback(new Error(this.setErrorMessage(type)));\n            }\n            if (rule.isNumber && !Number.isInteger(Number(value))) {\n                return callback(new Error(rule.errorMessage));\n            }\n            if (rule.minLength && value.length < rule.minLength) {\n                return callback(new Error(rule.errorMessage));\n            }\n            if (rule.maxLength && value.length > rule.maxLength) {\n                return callback(new Error(rule.errorMessage));\n            }\n            return callback();\n        },\n\n        /**\n        * Extended validation for first and last name - WEB-46734\n        */\n        validateNameFieldExtended(rule, value, callback) {\n            const fieldName = rule.field === 'first_name' ? 'First name' : 'Last name';\n            const errorMessage = `Please use only letters in the ${fieldName}—no numbers, symbols, or extra spaces.`;\n\n            if (!value || value.length < 2) {\n                return callback(new Error(errorMessage));\n            }\n            if (!utils.checkIfFieldLengthValid('input', value)) {\n                return callback(new Error(this.setErrorMessage('invalidInputLength')));\n            }\n\n            const validNameRegex = /^[A-Za-z\\u00C0-\\u017F\\u0400-\\u04FF]+(?:[-' ][A-Za-z\\u00C0-\\u017F\\u0400-\\u04FF]+)*$/;\n            const hasNumbers = /\\d/.test(value);\n            const invalidSymbolsRegex = /[!@#$%^&*()_+={}[\\]:;\"<>,.?/\\\\|~]/;\n            const hasInvalidSymbols = invalidSymbolsRegex.test(value);\n            const hasInvalidWhitespace = /^\\s|\\s{2,}|\\s$/.test(value);\n\n            if (hasNumbers || hasInvalidSymbols || hasInvalidWhitespace || !validNameRegex.test(value)) {\n                return callback(new Error(errorMessage));\n            }\n\n            return callback();\n        },\n\n        sendDataLayer(data) {\n            utils.sendDataLayer({\n                ...data,\n                eventLabel: data.eventLabel || '(not set)',\n            });\n        },\n\n        exceptionList() {\n            if (!Array.isArray(this.content?.fields)) return [];\n            return this.content.fields.filter((item) => item.notUseAccountData).map((item) => item.name);\n        },\n\n        setAccountData() {\n            // To pre-fill the form, we use the user's data from the personal account (account.acronis.com)\n            // The same field in different forms on the site has different names (company or companyName)\n            // But in the personal account this field has a name (company_name)\n            // Below is the mapping between the names of the fields on the site and in the personal account that must be pre-filled\n\n            const prefill = {\n                country: 'country',\n                company: 'company_name',\n                companyName: 'company_name',\n                company_type: {\n                    HomeUser: 'Prosumer End-Customer',\n                    EndUser: 'Corporate End-Customer',\n                    ServiceProvider: 'Service Provider',\n                    Reseller: 'Reseller',\n                },\n                email: 'email',\n                firstName: 'first',\n                first_name: 'first',\n                industry: {\n                    Other: 'Other',\n                    Technology: 'Information',\n                    'Healthcare & Pharmaceutical': 'Health Care and Social Assistance',\n                    Education: 'Educational Services',\n                    Manufacturing: 'Manufacturing',\n                    Government: 'Public Administration',\n                    Transportation: 'Transportation and Warehousing',\n                },\n                lastName: 'last',\n                last_name: 'last',\n                phone: 'phone',\n                zip: 'zip',\n            };\n\n            const exceptions = this.exceptionList();\n            const suitableKeys = Object.keys(prefill).filter((key) => key in this.form && !exceptions.includes(key));\n\n            const { custom, generic } = groupBy(suitableKeys, (key) => (typeof prefill[key] === 'object' ? 'custom' : 'generic'));\n\n            (generic || []).forEach((item) => {\n                this.form[item] = this.accountData?.[prefill[item]] || this.form[item] || '';\n            });\n\n            (custom || [])\n                .map((item) => {\n                    const option = this.accountData?.[item];\n                    const value = prefill[item]?.[option];\n                    return value ? { item, value } : null;\n                })\n                .filter(Boolean)\n                .forEach(({ item, value }) => {\n                    const currentForm = this.content?.fields;\n                    let option = null;\n\n                    if (Array.isArray(currentForm)) {\n                        const options = currentForm.flatMap((el) => el.options).filter(Boolean);\n                        option = utils.findOptionByValue(options, value);\n\n                        if (!option && this.formElementsDefault?.options?.[item]) {\n                            const defaultOptions = this.formElementsDefault.options[item];\n                            option = utils.findOptionByValue(defaultOptions, value);\n                        }\n                    }\n\n                    if (!option && currentForm?.companyType?.list) {\n                        const options = currentForm.companyType.list;\n                        option = utils.findOptionByValue(options, value);\n                    }\n\n                    if (!option && currentForm?.industry?.options) {\n                        const options = currentForm.industry.options;\n                        option = utils.findOptionByValue(options, value);\n                    }\n\n                    this.form[item] = option?.code || option?.value || '';\n                });\n\n            this.checkEmailOptIn('isAuthorized');\n        },\n\n        payloadMarketo() {\n            const params = this.form?.flow || {};\n            const userID = utils.getCookies(utils.UID_COOKIE_NAME) || '';\n            const clientId = utils.getCIDval() || '[ERROR] Client ID not generated';\n\n            let payload = {\n                ...params.needToAddEmptyValues,\n                ...this.userData,\n                ck: this.userData.ck,\n                google_analytics_clientid: clientId,\n                google_analytics_id: clientId,\n                google_analytics_trackingid: utils.GA_TRACKING_ID,\n                google_analytics_userid: userID,\n                language: this.language,\n                lead_source: 'Website',\n                lead_source_detail: '',\n                locale: this.countryCode,\n                new_lead_source_detail: params.marketo?.new_lead_source_detail || 'Request Trial',\n                osauid: this.guid,\n                product_title: this.setProductTitle(),\n                conversion_page: window.location.href,\n            };\n\n            // WEB-50827\n            if (!payload.country) {\n                payload.country = this.userData.phoneCountryCode || '(not set)';\n            }\n\n            if (this.recaptchaResponse) {\n                // eslint-disable-next-line no-underscore-dangle\n                payload._recaptchaResponse = this.recaptchaResponse;\n            }\n\n            if (sessionStorage?.getItem('x-opp-id')) {\n                payload['x-opp-id'] = sessionStorage.getItem('x-opp-id');\n            }\n\n            payload.munchkinId = params.ckToMunchkin ? payload.ck : '';\n            payload.webuid = params.osaToWebUid ? payload.osauid : '';\n\n            if (!isEmpty(params.needToAddEmptyValues)) {\n                Object.keys(payload)\n                    .filter((i) => typeof payload[i] === 'undefined')\n                    .forEach((i) => {\n                        payload[i] = '';\n                    });\n            } else {\n                Object.keys(payload)\n                    .filter((i) => ['password', 'phoneCountryCode'].includes(i) || !payload[i] || i.startsWith('dont_send_field'))\n                    .forEach((i) => delete payload[i]);\n            }\n\n            if (this.userData.form_id) {\n                params.marketo.form_id = this.userData.form_id;\n            }\n\n            payload = { ...payload, ...params.marketo };\n\n            if (params.marketo?.title === 'setTitle') {\n                payload.title = this.setTitle();\n            }\n\n            if (params.marketo?.country === 'setCountry') {\n                const country = this.location?.data?.country?.code || '';\n                payload.country = country;\n            }\n\n            if (params.marketo?.country === 'setPhoneCountryCode') {\n                payload.country = this.userData.phoneCountryCode || '(not set)';\n            }\n\n            payload.business_email = !this.isFreeEmail(this.userData.email);\n\n            localStorage.setItem('trial_es_osauid', payload.osauid);\n            localStorage.setItem('trial_es_email', this.userData.email);\n\n            if ('gdpr_opt_in' in this.userData) {\n                payload.gdpr_opt_in = this.userData.gdpr_opt_in || false;\n            }\n\n            if (params.isFormExpressSignup && payload.country === 'US') {\n                payload.gdpr_opt_in = false;\n            }\n\n            // WEB-45086\n            if (payload.country) {\n                payload = {\n                    ...payload,\n                    state: payload.state || null,\n                    postal_code: payload.postal_code || null,\n                };\n            }\n\n            if (isBoolean(this.userData.terms)) {\n                payload.terms = !this.isCountryGDPR || payload.terms || null;\n            }\n\n            if ('sp_support_requested' in this.userData) {\n                payload.sp_support_requested = this.parseBooleanString(this.userData.sp_support_requested);\n            }\n\n            const result = {\n                ...payload,\n                ...utils.labelsUTM({\n                    utm_term: this.setUtmTerm || params.marketo?.utm_term || null,\n                    utm_medium: params.marketo?.utm_medium || null,\n                    utm_source: params.marketo?.utm_source || null,\n                    utm_campaign: params.marketo?.utm_campaign || null,\n                }),\n                ...utils.sfdcCampaign({\n                    sfdc_campaign_id: params.marketo?.sfdc_campaign_id || null,\n                    sfdc_campaign_status: params.marketo?.sfdc_campaign_status || null,\n                }),\n                ...utils.sfdcCampaignSmart(),\n            };\n\n            const compare = ([key, value]) => [key, value === 'NULL' ? null : value];\n            return Object.fromEntries(Object.entries(result).map(compare));\n        },\n\n        setTitle() {\n            const form = this.form?.registration?.fields || [];\n            const formField = form.find((item) => item.name === 'company_type');\n            if (!formField?.options) return '';\n            const options = formField?.options;\n            const value = this.userData.company_type;\n            const option = utils.findOptionByValue(options, value) || {};\n            return option?.name || '';\n        },\n\n        setProductTitle() {\n            const product = {\n                Reseller: 'Acronis Cyber Protect',\n                'Corporate End-Customer': 'Acronis Cyber Protect',\n                'Service Provider': 'Acronis Cyber Protect Cloud',\n                'Prosumer End-Customer': 'Acronis True Image',\n            };\n\n            const productTitle = product[this.userData.company_type] || '';\n\n            const form = this.form?.registration?.fields || [];\n            const formField = form.find((item) => item.setProductTitle);\n\n            if (formField && formField.options) {\n                const field = formField.name;\n                const options = formField.options;\n                const value = this.userData[field];\n                const option = utils.findOptionByValue(options, value) || {};\n                return option?.product_title || productTitle;\n            }\n\n            return productTitle;\n        },\n\n        setDefaultOptIn() {\n            this.isVisibleOptIn = false;\n            this.form.opt_in = false;\n            this.form.gdpr_opt_in = false;\n        },\n\n        async checkEmailOptIn(type) {\n            const email = this.form?.email || this.accountData?.email;\n\n            if (this.content?.skipEmailOptIn) return;\n\n            if (this.isLoading && type !== 'isAuthorized') {\n                return;\n            }\n\n            if (!'email|country|isAuthorized'.includes(type)) {\n                return;\n            }\n\n            if (!email || !this.form.country) {\n                return;\n            }\n\n            if (email === this.validatedEmailOptIn && type === 'email') {\n                return;\n            }\n\n            if (this.isVisibleOptIn) {\n                if (this.form?.form_id === 'RESOURCE_CENTER') {\n                    this.form.gdpr_opt_in = false;\n                }\n            }\n\n            if (this.form.country === 'US') {\n                this.setDefaultOptIn();\n                this.form.gdpr_opt_in = true;\n                return;\n            }\n\n            if (this.validateEmail(this.rules.email, email, (errorMessage) => errorMessage)) {\n                return;\n            }\n\n            try {\n                this.isLoading = true;\n                const response = await this.getOptInStatus(email);\n\n                if (!response.success) {\n                    this.setDefaultOptIn();\n                    return;\n                }\n\n                const isOptIn = response.data?.optIn || false;\n\n                this.form.gdpr_opt_in = isOptIn;\n\n                this.isVisibleOptIn = !isOptIn;\n\n                this.validatedEmailOptIn = email;\n            } catch {\n                this.setDefaultOptIn();\n            } finally {\n                this.isLoading = false;\n            }\n        },\n\n        prepareFormToValidate() {\n            Object\n                .keys(this.form)\n                .filter((key) => typeof this.form[key] === 'string')\n                .forEach((key) => {\n                    this.form[key] = this.form[key].trim();\n                });\n        },\n\n        sendEventMarketingSubscription(isChecked) {\n            if (!isChecked) {\n                return;\n            }\n            utils.sendDataLayer({\n                eventCategory: 'form',\n                eventAction: 'clicked checkbox',\n                eventLabel: 'marketing subscription',\n            });\n        },\n\n        formLabelText(item) {\n            if (item?.placeholder) return '';\n            return item?.label || this.formElementsDefault.labels?.[item.name] || item.name;\n        },\n\n        formPlaceholderText(item) {\n            const defaultPlaceholder = this.formElementsDefault.placeholders?.[item.name] || '';\n            if (this.isVisibleField(item, ['select', 'select-searchable'])) {\n                return item?.placeholder || this.labelSelect.placeholder || defaultPlaceholder;\n            }\n            return item?.placeholder || defaultPlaceholder;\n        },\n\n        formErrorText(item) {\n            if (item.error) return item.error;\n            const type = item?.type?.startsWith('select') ? 'select' : 'input';\n            const text = this.formElementsDefault.errors?.[item.name];\n            return text || this.formElementsDefault.errorsDefault?.[type] || 'This field is required';\n        },\n\n        formListOption(name) {\n            return this.formElementsDefault?.options?.[name] || [];\n        },\n\n        formCheckboxText(item) {\n            if (item.text) return this.replaceLocale(item.text);\n            const buttonName = item.buttonName || '';\n            const text = this.formElementsDefault?.checkboxes?.[item.name] || '';\n            return text.replace('@buttonName', buttonName);\n        },\n\n        handleError(error) {\n            const defaultError = this.formElementsDefault.errors?.apiErrorCodes?.default || 'Error';\n            this.errorTitle = this.formElementsDefault.errors?.apiErrorCodes?.[error.code] || defaultError;\n            this.errorCode = error.code;\n            this.isErrorShown = true;\n            Logger.error({ error });\n        },\n\n        setEvent(item) {\n            if (item.event) return item.event;\n            return item && item.sendEventGA ? { label: item.to, ...item.sendEventGA } : {};\n        },\n\n        sendNotSpEvent() {\n            window.dataLayer = window.dataLayer || [];\n            window.dataLayer.push({\n                event: 'NotSP',\n                notSP: 'true',\n            });\n        },\n\n        parseBooleanString(value) {\n            if (value === 'true') return true;\n            if (value === 'false') return false;\n            return value || null;\n        },\n\n        async checkIfSuitableForNotSpEvent() {\n            try {\n                const utmTerm = this.$route.query?.utm_term;\n\n                if (!['form', 'ccform'].includes(utmTerm)) {\n                    return false;\n                }\n\n                const emailDomain = this.form.email.split('@').pop();\n\n                // Email domain is listed in the \"free email domains\" list\n                if (this.freeEmailServices.has(emailDomain)) {\n                    return true;\n                }\n\n                // Email domain is listed in the hardcoded array of domains\n                const isInBlacklist = EMAIL_DOMAINS_BLACKLIST.some((domainPart) => emailDomain.includes(domainPart));\n                if (isInBlacklist) {\n                    return true;\n                }\n\n                // For \"form\" only: email domain is NOT listed in the SFDC database of verified SP companies\n                if (utmTerm === 'form') {\n                    const { data } = await this.$store.dispatch('events/checkEmailInSpDomain', this.form.email);\n                    return !data.isSp;\n                }\n\n                // For \"ccform\" only: email domain is NOT listed in 6sense validated DB\n                if (utmTerm === 'ccform') {\n                    const isInList = await this.$store.dispatch('events/checkEmailIn6senseList', emailDomain);\n                    return !isInList;\n                }\n\n                return false;\n            } catch (error) {\n                Logger.error({ error });\n                return false;\n            }\n        },\n    },\n\n    async serverPrefetch() {\n        const locale = this.locale;\n\n        const promises = [\n            this.$store.dispatch('slices/getSyncedData', { slice: 's-form-global-settings', locale: LOCALE_DEFAULT }),\n        ];\n\n        if (!this.settingsEvent) {\n            promises.push(this.$store.dispatch('slices/getSyncedData', { slice: 's-list-form-elements', locale }));\n        }\n\n        if (this.form?.update || this.form?.registration?.steps?.find((item) => item.form?.update)) {\n            promises.push(this.$store.dispatch('slices/getSyncedData', { slice: this.formUpdatePresetName, locale }));\n        }\n        await Promise.all(promises);\n    },\n};\n","<template>\n    <ul class=\"a-social\">\n        <li v-for=\"socialItem in social\" :key=\"socialItem.link\" class=\"a-social__item\">\n            <dynamic-link\n                data-allow-mismatch=\"attribute\"\n                class=\"a-social__link\"\n                :to=\"socialItem.link\"\n                :title=\"socialItem.title\"\n                native-type=\"a\"\n                :aria-label=\"socialItem.title\"\n                :event=\"{ ...event, label: socialItem.link, action: getDataLayerAction(socialItem, socialItem.name) }\"\n            >\n                <span class=\"sr-only\">{{ socialItem.name }}</span>\n                <a-glyph class=\"a-social__icon\" :name=\"socialItem.glyph || socialItem.name\" :size=\"glyphSize\" />\n            </dynamic-link>\n        </li>\n    </ul>\n</template>\n\n<script>\nimport DynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\n\nexport default {\n    name: 'ASocial',\n\n    components: {\n        AGlyph,\n        DynamicLink,\n    },\n\n    props: {\n        /**\n         * Social glyphs-library\n         */\n        social: {\n            type: Array,\n            required: true,\n        },\n\n        /**\n         * GA Event\n         */\n        event: {\n            type: Object,\n            default() {\n                return {\n                    category: 'Social',\n                };\n            },\n        },\n\n        glyphSize: {\n            type: String,\n            default: 's',\n        },\n    },\n\n    methods: {\n        getDataLayerAction(item, defaultAction) {\n            if (item.dataLayer && item.dataLayer.action) {\n                return item.dataLayer.action;\n            }\n            return defaultAction;\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-social {\n    display: flex;\n    justify-content: center;\n\n    &__link {\n        margin: 0 8px;\n        cursor: pointer;\n        border: 0;\n        padding: 0;\n        background: rgba(255, 255, 255, 0);\n    }\n\n    &__icon {\n        &:hover {\n            fill: var(--av-brand-secondary);\n        }\n    }\n}\n</style>\n","<!-- eslint-disable max-len -->\n<template>\n    <div class=\"tru-logo\">\n        <svg\n            xmlns=\"http://www.w3.org/2000/svg\"\n            width=\"125\"\n            height=\"28\"\n            viewBox=\"0 0 125 28\"\n            fill=\"none\"\n            class=\"logo\"\n        >\n    