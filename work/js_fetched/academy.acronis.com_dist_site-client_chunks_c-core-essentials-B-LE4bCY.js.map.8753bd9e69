{ type: String, default: '' },\n    modelValue: { type: String, default: '' },\n    autofocus: Boolean,\n    fetchSuggestions: { type: Function, default: null },\n    triggerOnFocus: { type: Boolean, default: true },\n    customItem: { type: String, default: '' },\n    selectWhenUnmatched: { type: Boolean, default: true },\n    prefixIcon: { type: String, default: '' },\n    suffixIcon: { type: String, default: 'search' },\n    label: { type: String, default: '' },\n    id: { type: String, default: '' },\n    debounceTimer: { type: Number, default: 500 },\n});\n\ndefineOptions({\n    directives: {\n        clickoutside: Clickoutside,\n    },\n});\n\nconst suggestionsRef = ref(null);\nconst input = ref(null);\nconst autocomplete = ref(null);\nconst { debouncedFn: debouncedGetData } = useDebouncedFn(getData, props.debounceTimer);\n\nconst autocompleteId = ref(props.id || `el-autocomplete-${Math.floor(Math.random() * 10000)}`);\nconst activated = ref(false);\nconst suggestions = ref([]);\nconst loading = ref(false);\nconst isValidData = ref(false);\n\nconst showClear = computed(() => props.clearable && props.modelValue && !loading.value);\nconst suggestionVisible = computed(() => activated.value && !loading.value && props.modelValue && !props.disableSuggestions);\n\nconst options = computed(() =>\n    suggestions.value.map((item) => ({\n        value: item[props.valueKey],\n        label: item[props.valueKey],\n        visible: true,\n        disabled: false,\n        groupDisabled: false,\n        isSelected: item[props.valueKey] === props.modelValue,\n    })),\n);\n\nconst { scrollToOption } = useDropdownScroll(suggestionsRef, 'el-autocomplete-suggestion__wrap');\nconst { hoverIndex: highlightedIndex, navigateOptions } = useKeyboardNavigate({\n    options,\n    visible: suggestionVisible,\n    scrollToOption,\n    selected: ref({ value: props.modelValue }),\n});\n\nconst dropdown = reactive({\n    get input() {\n        return input.value;\n    },\n    visible: false,\n    show(val) { dropdown.visible = val; },\n    hide() { dropdown.visible = false; },\n});\n\nprovide('autocomplete', dropdown);\n\ndefineExpose({ input });\n\n\nonMounted(() => {\n    const $input = autocomplete.value?.querySelector('.el-input__container');\n    if ($input) {\n        $input.setAttribute('role', 'textbox');\n        $input.setAttribute('aria-autocomplete', 'list');\n    }\n});\n\nwatch(suggestions, (value) => {\n    isValidData.value = Array.isArray(value) && value.length > 0;\n});\n\nwatch(suggestionVisible, (val) => {\n    dropdown.show(val);\n});\n\nwatch(highlightedIndex, (val) => {\n    const container = autocomplete.value?.querySelector('.el-input__container');\n\n    if (val >= 0) {\n        scrollToOption(options.value[val]);\n        if (container) {\n            container.setAttribute('aria-activedescendant', `${autocompleteId.value}-item-${val}`);\n        }\n        return;\n    }\n\n    if (container) {\n        container.removeAttribute('aria-activedescendant');\n    }\n});\nfunction handleChange(value) {\n    loading.value = !props.disableSuggestions;\n    emit('update:modelValue', value);\n    emit('input', value);\n    if (!props.triggerOnFocus && !value) {\n        suggestions.value = [];\n        return;\n    }\n    debouncedGetData(value);\n    activated.value = true;\n}\n\nfunction handleFocus(event) {\n    emit('focus', event);\n}\n\nfunction handleBlur(event) {\n    emit('blur', event);\n}\n\nfunction handleClear() {\n    emit('clear');\n}\n\nfunction getData(queryString) {\n    highlightedIndex.value = -1;\n    if (!queryString || props.disableSuggestions) {\n        loading.value = false;\n        return;\n    }\n    loading.value = true;\n    if (!props.fetchSuggestions) {\n        loading.value = false;\n        suggestions.value = [];\n    }\n    props.fetchSuggestions?.(queryString, (res) => {\n        loading.value = false;\n        if (Array.isArray(res)) suggestions.value = res;\n    });\n}\n\nfunction handleKeyEnter(e) {\n    if (suggestionVisible.value && highlightedIndex.value >= 0 && highlightedIndex.value < suggestions.value.length) {\n        dropdown.hide();\n        e.preventDefault();\n        select(suggestions.value[highlightedIndex.value]);\n    } else if (props.selectWhenUnmatched) {\n        emit('update:modelValue', props.modelValue);\n        emit('select', props.modelValue);\n        activated.value = false;\n        nextTick(() => {\n            suggestions.value = [];\n        });\n    }\n}\n\nfunction select(item) {\n    emit('update:modelValue', item[props.valueKey]);\n    emit('input', item[props.valueKey]);\n    emit('select', item);\n    nextTick(() => {\n        dropdown.hide();\n        close();\n        suggestions.value = [];\n    });\n}\n\nfunction close() {\n    activated.value = false;\n}\n</script>\n\n<style lang=\"postcss\" scoped>\n.el-autocomplete {\n    :deep(.el-input) {\n        &__container {\n            height: 32px;\n        }\n        &__wrapper {\n            padding-top: 3px;\n        }\n        &__editor {\n            font-size: 14px;\n        }\n    }\n    &-suggestion {\n        position: absolute;\n        z-index: 2100;\n        background: var(--av-inversed-primary);\n        border: 1px solid var(--av-brand-primary);\n        box-shadow: var(--av-shadow-regular);\n        color: var(--av-fixed-primary);\n        border-radius: 4px;\n        box-sizing: border-box;\n        :deep(&__wrap) {\n            margin: 8px 0;\n        }\n        :deep(&__item) {\n            overflow: hidden;\n            text-overflow: ellipsis;\n            white-space: nowrap;\n            padding: 4px 16px;\n            margin: 0;\n            cursor: pointer;\n            color: var(--av-fixed-primary);\n            font-size: 14px;\n            line-height: 32px;\n            list-style: none;\n            &:hover {\n                background-color: var(--el-secondary-hover);\n            }\n            &.highlighted {\n                color: var(--av-fixed-primary);\n                font-weight: 400;\n                background-color: var(--el-secondary-active);\n            }\n        }\n        &__no-data {\n            @mixin body;\n            text-align: center;\n            padding: 24px 16px;\n                color: var(--av-fixed-light);\n        }\n    }\n}\n</style>\n","import { LOCALE_DEFAULT } from '@model/const/locales';\n\nexport default {\n    computed: {\n        isPageLanguageAware() {\n            return this.$store?.state.geolocation.isLanguageAware;\n        },\n\n        pageLanguage() {\n            return this.$store?.state.geolocation.language;\n        },\n\n        pageDesiredLocale() {\n            return this.$store?.state.geolocation.desiredLocale ?? LOCALE_DEFAULT;\n        },\n\n        pageLocale() {\n            return this.$store?.state.geolocation.finalLocale ?? LOCALE_DEFAULT;\n        },\n\n        pageLocaleMarker() {\n            return this.isPageLanguageAware ? this.pageLanguage : this.pageLocale;\n        },\n    },\n};\n","export interface URLDescriptorUnaware {\n    localizationStrategy: 'none';\n}\n\nexport interface URLDescriptorLocaleAware {\n    localizationStrategy: 'locale';\n    isLocalePresent: boolean;\n    requestedLocale: string | null;\n    desiredLocale: string | null;\n}\n\nexport interface URLDescriptorLanguageAware {\n    localizationStrategy: 'language';\n    isLanguagePresent: boolean;\n    requestedLocale: string | null;\n    desiredLocale: string | null;\n    language: string | null;\n}\n\nexport type URLLocalizationDescriptor = URLDescriptorUnaware | URLDescriptorLocaleAware | URLDescriptorLanguageAware;\n\n// Variations of the first URL segment that look like a language code,\n// but are, in fact, valid subroutes\nexport const languageExceptions = new Set([\n    'lp',\n    'pr',\n]);\n\n// URL segments which must keep \"locale\" strategy even if the domain is language-aware\nexport const forceLocaleAwareFor = new Set([\n    'inapp',\n]);\n","import { languageExceptions } from '../model/ssr/l10n.ts';\n\nconst localeRegexp = /^[/][\\w]{2}-[\\w]{2}[/]/;\nconst languageRegexp = /^[/][\\w]{2}[/]/;\n\nexport function normalizeHref(input, localeOrLanguage) {\n    const initialLink = (input || '').trim();\n\n    if (!initialLink) return false;\n\n    const [, proto] = initialLink.match(/^(\\w+):/) || [];\n\n    if (['http', 'https', 'tel', 'mailto'].includes(proto)) {\n        return initialLink;\n    }\n    if (proto) {\n        return initialLink;\n    }\n    if (initialLink.startsWith('#')) {\n        return initialLink;\n    }\n    if (initialLink.startsWith('/localize/')) {\n        return initialLink;\n    }\n\n    const FAKE_DOMAIN = 'https://www.acronis.com';\n    const target = new URL(initialLink, FAKE_DOMAIN);\n\n    // ensure trailing slash\n    const isFile = Boolean(target.pathname.match(/\\.\\w+$/));\n\n    if (!isFile) {\n        target.pathname = target.pathname.replace(/[/]$/, '');\n        target.pathname += '/';\n    }\n\n    // fix double slashes if any\n    target.pathname = target.pathname.replace(/[/]+/g, '/');\n\n    // inject locale/language if it's not here yet and it's localizable\n    const hasLocale = target.pathname.match(localeRegexp);\n\n    const firstSegment = target.pathname.split('/').filter(Boolean)[0];\n    const hasLanguage = target.pathname.match(languageRegexp) && !languageExceptions.has(firstSegment);\n\n    if (!isFile && !hasLocale && !hasLanguage) {\n        target.pathname = `/${localeOrLanguage}${target.pathname}`;\n    }\n\n    return target.toString().replace(FAKE_DOMAIN, '');\n}\n\n// Done with regexp replace because isomorphic DOM fragment parser is too heavyweight for this task\nexport function normalizeHrefsInHtmlFragment(input, localeOrLanguage) {\n    const ANCHOR_REGEXP = /<a[^>]*>[^<]*<[/]a>/gi; // to find all occurences of <a...>...</a>\n    const HREF_REGEXP = /href=['\"]([^'\"]+)['\"]/i; // to find href=\"...\" attribute inside the anchor HTML fragment\n\n    const hrefReplacer = (attr, href) => attr.replace(href, normalizeHref(href, localeOrLanguage));\n    const anchorReplacer = (outerHtml) => outerHtml.replace(HREF_REGEXP, hrefReplacer);\n    if (typeof input !== 'string') return input;\n    return input.replace(ANCHOR_REGEXP, anchorReplacer);\n}\n","<script>\nimport { h } from 'vue';\nimport language from '@core/mixins/language';\nimport { normalizeHrefsInHtmlFragment } from '@utils/normalize-href.js';\n\nexport default {\n    name: 'ADangerousHtml',\n\n    mixins: [language],\n\n    inheritAttrs: false,\n\n    props: {\n        content: {\n            type: String,\n            default: '',\n        },\n\n        tag: {\n            type: String,\n            default: 'div',\n        },\n\n        refinements: {\n            type: Object,\n            default: () => ({}),\n        },\n    },\n\n    computed: {\n        normalizedRefinements() {\n            return { injectHrefLocale: true, ...this.refinements };\n        },\n\n        refinedContent() {\n            let result = this.content || '';\n\n            if (this.normalizedRefinements.injectHrefLocale) {\n                result = normalizeHrefsInHtmlFragment(result, this.pageLocaleMarker);\n            }\n            return result;\n        },\n    },\n\n    render() {\n        const vnodeAttrs = {\n            ...this.$attrs,\n            class: [this.$attrs.class, 'a-dangerous-html'],\n            innerHTML: this.refinedContent,\n        };\n\n        return h(this.tag, vnodeAttrs);\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-dangerous-html {\n    p:not(:last-of-type) {\n        margin-bottom: 16px;\n    }\n\n    ::marker {\n        content: initial;\n    }\n\n    ul {\n        & > li {\n            margin-bottom: 16px;\n            padding-inline-start: 24px;\n\n            &:last-child {\n                margin: 0;\n            }\n            &::before {\n                content: '';\n                position: relative;\n                top: -.1em;\n                inset-inline-start: -18px;\n                margin-inline-end: -4px;\n                width: 4px;\n                height: 4px;\n                display: inline-block;\n                vertical-align: middle;\n                background-color: currentcolor;\n                border-radius: 50%;\n            }\n        }\n    }\n\n    ul > li > p, ol > li > p {\n        display: contents;\n    }\n\n    a {\n        cursor: pointer;\n        color: var(--av-brand-primary);\n        text-decoration: none;\n        &:hover {\n            color: var(--av-brand-secondary);\n        }\n        &:focus {\n            background: var(--av-brand-secondary-light);\n            color: var(--av-brand-primary);\n        }\n        &:active {\n            background: none;\n            color: var(--av-brand-primary);\n        }\n    }\n\n    a:hover {\n        color: var(--av-brand-secondary);\n    }\n\n    sup {\n        font-size: 10px;\n        vertical-align: super;\n    }\n\n    small {\n        font-size: 10px;\n    }\n\n    small sup {\n        font-size: 8px;\n    }\n\n    mark.cdx-marker {\n        background-color: var(--av-brand-light);\n        padding: 0 0.25em;\n    }\n}\n</style>\n","import { isEmpty } from 'lodash';\nimport { mapState } from 'vuex';\nimport { LOCALE_DEFAULT } from '@model/const/locales.ts';\n\nexport default {\n    computed: {\n        ...mapState({\n            licensesItems: (state) => state.licenses.data,\n            productItems: (state) => state.products.items,\n            productID: (state) => state.pages?.page?.product_id,\n            storePage: (state) => state.pages?.page || {},\n        }),\n\n        pageType() {\n            const types = this.$store.state.pages?.types?.items || [];\n            const type = types.find((el) => el.id === this.storePage.type_id) || {};\n            return type.name || '(not set)';\n        },\n\n        pageAudience() {\n            const audiences = this.$store.state.pages?.audiences?.items || [];\n            const audience = audiences.find((el) => el.id === this.storePage.audience_id) || {};\n            return audience.name || '(not set)';\n        },\n\n        locale() {\n            return this.$store.state.geolocation.finalLocale || LOCALE_DEFAULT;\n        },\n\n        brandName() {\n            return this.productItems?.[this.productID]?.parameters?.common?.productName || '(not set)';\n        },\n    },\n\n    methods: {\n        ecommerceSendEvent({ event, license }) {\n            if (typeof window === 'undefined') return;\n\n            if (!license?.cleverbridge_id) {\n                return;\n            }\n\n            const result = {\n                event: 'AcronisEcommerce',\n                eventLabel: event.eventLabel || license.name || '',\n                eventAction: event.eventAction || 'Add to cart',\n                eventContext: event.eventContext || 'click',\n                eventCategory: event.eventCategory || 'Conversions',\n                eventContent: this.productItems?.[this.productID]?.name || '(not set)',\n                eventLocation: this.pageType,\n                eventProductName: license.name || '',\n                eventProductPrice: license.price || '',\n                eventProductId: Number(license.cleverbridge_id) || null,\n                eventPosition: 1,\n                ecommerce: {},\n            };\n\n            const quantity = event.quantity || 1;\n            const type = event?.ecommerce?.type || '';\n            const products = [this.ecommerceLicense(license, quantity)];\n\n            result.ecommerce[type] = {\n                products,\n                currencyCode: this.productCurrency,\n                actionField: { list: this.pageType },\n            };\n\n            window.dataLayer = window.dataLayer || [];\n            window.dataLayer.push(result);\n        },\n\n        ecommerceProducts(licenses) {\n            let count = 0;\n            let position = 0;\n            let quantity = 1;\n            const result = [];\n\n            this.licensesItems.forEach((license) => {\n                if (!isEmpty(licenses)) {\n                    if (!Object.keys(licenses).includes(license.cleverbridge_id)) {\n                        return;\n                    }\n                    quantity = licenses[license.cleverbridge_id];\n                }\n\n                if (!result[count]) {\n                    result[count] = [];\n                }\n\n                position += 1;\n\n                if (!result[count].find((item) => item.id === license.cleverbridge_id)) {\n                    result[count].push(this.ecommerceLicense(license, quantity, position));\n                }\n\n                if (isEmpty(licenses) && !(position % 10)) {\n                    count++;\n                }\n            });\n\n            return result;\n        },\n\n        ecommerceLicense(license, quantity, position) {\n            const name = license?.name || '(not set)';\n            const type = name.match(/.*(\\d\\syears?).*/i) || '';\n            const result = /cloud/i.test(name) ? 'Subscription' : 'Perpetual';\n            const variant = type ? `Subscription ${type[1]}` : result;\n\n            return {\n                list: license.item_list_name || '',\n                position: position || 1,\n                quantity: quantity || 1,\n                brand: this.brandName,\n                price: license.price,\n                category: this.pageAudience,\n                id: Number(license.cleverbridge_id) || null,\n                name,\n                variant,\n                dimension129: license.price_promo || null,\n            };\n        },\n    },\n};\n","export function getElementPath(element: HTMLElement): string {\n    const segments = [];\n\n    let cursor = element;\n\n    while (cursor && cursor.id !== 'router-view') {\n        if (cursor.dataset?.sliceName) {\n            segments.push(cursor.dataset.sliceName);\n        }\n\n        cursor = cursor.parentElement;\n    }\n\n    return segments.reverse().join(' > ');\n}\n\nexport function compileDynamicPageDLParams(store: any) {\n    const page = store.state.pages.page;\n\n    const types = store.state.pages.types?.items.find((x) => x.id === page.type_id);\n    const audience = store.state.pages.audiences?.items.find((x) => x.id === page.audience_id);\n    const product = store.state.products.items?.[page.product_id];\n\n    return {\n        DL_PageType: types?.name,\n        DL_Audience: audience?.name,\n        DL_Product: product?.name,\n    };\n}\n\nexport function convertRCAudience(audiences: { slug: string }[] = []): string | null {\n    if (audiences.length === 0) return null;\n\n    if (audiences.length > 1) return 'Split';\n\n    if (audiences[0].slug === 'homeusers') return 'Consumer';\n    if (audiences[0].slug === 'customers') return 'Corporate';\n    if (audiences[0].slug === 'partners') return 'Cloud';\n\n    return null;\n}\n\nexport function compileRCResourceParams(store: any) {\n    const resource = store.state.resourceCenter.resource.items[0];\n\n    if (!resource) return {};\n\n    return {\n        rcProduct: resource.products?.[0]?.name,\n        rcFeatured: Boolean(resource.is_featured),\n        rcCategory: resource.type.slug,\n        rcType: resource.is_gated ? 'Gated' : 'Ungated',\n    };\n}\n\nexport interface VWOParams {\n    enabled: boolean;\n    pollMaxAttempts: number;\n    pollInterval: number;\n}\n\nexport function compileVWOParams(store: any, locale: string, isEnabled?: boolean): VWOParams {\n    const settings = store.state.pages?.page?.settings ?? {};\n\n    const vwoLocales = settings.vwo_ab_test_enabled;\n    const vwoTestsEnabled = isEnabled ?? (Array.isArray(vwoLocales) && vwoLocales.some((x) => x === 'all' || x === locale));\n    return {\n        enabled: vwoTestsEnabled,\n        pollMaxAttempts: settings.vwo_check_attempts ?? 30,\n        pollInterval: settings.vwo_check_interval ?? 50,\n    };\n}\n","<template>\n    <component\n        v-bind=\"$attrs\"\n        :is=\"tagName\"\n        :target=\"realTarget\"\n        :rel=\"realRel\"\n        :href=\"computedHref\"\n        :title=\"title\"\n        :data-has-no-href=\"hasNoHref\"\n        :aria-disabled=\"ariaDisabled\"\n        :aria-label=\"ariaLabel || title\"\n        :aria-describedby=\"ariaDescribedby\"\n        @click=\"handleClick\"\n        @keydown=\"handleKeydown\"\n    >\n        <slot :key=\"$attrs\" />\n    </component>\n</template>\n\n<script>\nimport analytics from '@core/mixins/analytics.js';\nimport language from '@core/mixins/language';\nimport utm from '@core/mixins/utm.js';\nimport { getElementPath } from '@utils/analytics.ts';\nimport { normalizeHref } from '@utils/normalize-href.js';\n\nexport default {\n    name: 'ADynamicLink',\n    mixins: [analytics, language, utm],\n\n    inheritAttrs: false,\n\n    props: {\n        to: {\n            type: String,\n            default: null,\n        },\n        target: {\n            type: String,\n            default: undefined,\n        },\n        rel: {\n            type: String,\n            default: undefined,\n        },\n        title: {\n            type: String,\n            default: undefined,\n        },\n        nativeType: {\n            type: String,\n            default: 'button',\n        },\n        hasNoHref: {\n            type: Boolean,\n            default: false,\n        },\n        ariaDisabled: {\n            type: Boolean,\n            default: false,\n        },\n        ariaLabel: {\n            type: String,\n            default: undefined,\n        },\n        ariaDescribedby: {\n            type: String,\n            default: undefined,\n        },\n        doNotChangeLocation: {\n            type: Boolean,\n            default: false,\n        },\n        event: {\n            type: Object,\n            default: () => ({}),\n        },\n    },\n    emits: ['click'],\n    computed: {\n        computedHref() {\n            const vwoHref = this.getVwoOverride('data-vwo-href');\n            if (vwoHref) return vwoHref;\n\n            if (this.getSessionUTM.length) {\n                const url = this.setQueryString(this.to || '/');\n                if (url) return url;\n            }\n\n            return normalizeHref(this.to, this.pageLocaleMarker);\n        },\n\n        tagName() {\n            return this.to ? 'a' : 'button';\n        },\n        link() {\n            return (this.to || '').trim();\n        },\n        realTarget() {\n            const defaultTarget = this.target || '_self';\n            const newWindowTarget = '_blank';\n\n            if (!this.isAbsoluteLink()) {\n                return defaultTarget;\n            }\n\n            return this.isAcronisLink() || this.isAcronisScsLink() ? defaultTarget : newWindowTarget;\n        },\n        realRel() {\n            const defaultRel = this.rel || undefined;\n            const noFollow = 'nofollow';\n\n            if (!this.isAbsoluteLink()) {\n                return defaultRel;\n            }\n\n            return this.isAcronisLink() || this.isAcronisScsLink() ? defaultRel : noFollow;\n        },\n\n    },\n    methods: {\n        isAbsoluteLink() {\n            return (\n                this.link.startsWith('http:') ||\n                this.link.startsWith('https://') ||\n                this.link.startsWith('//')\n            );\n        },\n        isAcronisLink() {\n            return this.link.split('//').pop().toLowerCase().startsWith('www.acronis.com');\n        },\n        isAcronisScsLink() {\n            return this.link.includes('acronisscs.com');\n        },\n        handleKeydown(event) {\n            if (event.key === 'Enter' || event.key === ' ') {\n                event.preventDefault();\n                if (event.key === ' ') {\n                    event.target.click();\n                }\n\n                this.handleClick(event);\n            }\n        },\n        handleClick(event) {\n            const href = this.computedHref || '';\n\n            if (!this.event?.doNotSendGA) {\n                // Process GA event\n                const incomingGA = this.event;\n                const linkTarget = /\\.(pdf|zip|pptx)$/.test(href) ? 'documents' : 'link';\n                const linkContext = linkTarget === 'link' ? 'click' : 'download';\n\n                const gaData = {\n                    event: incomingGA.event || 'Acronis',\n                    eventCategory: incomingGA.category || 'Interactions',\n                    eventAction: this.getVwoOverride('data-vwo-text') || incomingGA?.action || linkTarget,\n                    eventLabel: this.getVwoOverride('data-vwo-href') || incomingGA?.label || href || '',\n                    eventContext: incomingGA.context || linkContext,\n                    eventContent: this.getVwoOverride('data-vwo-text') || incomingGA?.content || event.target.innerText || '',\n                    eventLocation: incomingGA.location || getElementPath(event.target),\n                    eventButton: incomingGA.button || '',\n                };\n                if (incomingGA.formFieldA) gaData.formFieldA = incomingGA.formFieldA;\n                window.dataLayer = window.dataLayer || [];\n                window.dataLayer.push(gaData);\n            }\n\n            if (this.doNotChangeLocation) {\n                event.preventDefault();\n                this.$emit('click', event);\n                document.activeElement.blur();\n                return;\n            }\n\n            const runtimeHref = this.$el?.getAttribute?.('href');\n            if (runtimeHref && /\\b(gclid|fbclid|msclkid|_gl)=/.test(runtimeHref)) {\n                event.preventDefault();\n                if (this.realTarget === '_blank') {\n                    window.open(runtimeHref, '_blank');\n                } else {\n                    window.location.href = runtimeHref;\n                }\n                this.$emit('click', event);\n                return;\n            }\n\n            // handle the link\n            if (href) {\n                event.preventDefault();\n\n                const isKeyboardHack =\n                    this.nativeType === 'a' &&\n                    !href.startsWith('tel:') &&\n                    (event.metaKey || event.ctrlKey);\n\n                if (isKeyboardHack || this.realTarget === '_blank') {\n                    window.open(href, '_blank');\n                } else {\n                    window.location.href = href;\n                }\n            }\n\n            this.$emit('click', event);\n        },\n\n        getVwoOverride(attrName) {\n            if (typeof window === 'undefined') return null;\n\n            const el = this.$el;\n            if (el && el.getAttribute) return el.getAttribute(attrName) ?? null;\n            return null;\n        },\n    },\n};\n</script>\n","export const TYPES = ['label', 'text-label'];\n\nexport const VARIANTS = ['info', 'success', 'neutral', 'ai-gradient', 'lime'];\n\nexport const LAYOUTS = ['solid', 'subtle'];\n\nexport const SIZES = ['xl', 'l', 's'];\n\nexport const THEMES = ['light', 'dark'];\n\nexport default {};\n","<template>\n    <div class=\"a-label\" :class=\"classNames\">\n        <a-dynamic-link\n            v-if=\"to\"\n            :to=\"to\"\n            class=\"content\"\n            :target=\"target\"\n        >\n            <a-glyph v-if=\"glyph\" :name=\"glyph\" :size=\"glyphSize\" />\n            <slot />\n        </a-dynamic-link>\n        <div v-else class=\"content\">\n            <a-glyph v-if=\"glyph\" :name=\"glyph\" :size=\"glyphSize\" />\n            <slot />\n        </div>\n    </div>\n</template>\n\n<script lang=\"ts\">\nimport ADynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport { TYPES, VARIANTS, LAYOUTS, SIZES, THEMES } from './constants.js';\n\nexport default {\n    name: 'ALabel',\n\n    components: {\n        AGlyph,\n        ADynamicLink,\n    },\n\n    props: {\n        type: {\n            type: String,\n            default: 'label',\n            validator: (value) => TYPES.includes(String(value)),\n        },\n\n        variant: {\n            type: String,\n            default: 'info',\n            validator: (value) => VARIANTS.includes(String(value)),\n        },\n\n        layout: {\n            type: String,\n            default: 'solid',\n            validator: (value) => LAYOUTS.includes(String(value)),\n        },\n\n        size: {\n            type: String,\n            default: 'l',\n            validator: (value) => SIZES.includes(String(value)),\n        },\n\n        to: {\n            type: String,\n            default: undefined,\n        },\n\n        target: {\n            type: String,\n            default: '_self',\n        },\n\n        theme: {\n            type: String,\n            default: 'light',\n            validator: (value) => THEMES.includes(String(value)),\n        },\n\n        glyph: {\n            type: String,\n            default: '',\n        },\n    },\n\n    computed: {\n        classNames() {\n            return {\n                [`type-${this.type}`]: this.type,\n                [`variant-${this.variant}`]: this.variant,\n                [`layout-${this.layout}`]: this.layout,\n                [`size-${this.size}`]: this.size,\n                [`theme-${this.theme}`]: this.theme,\n            };\n        },\n\n        glyphSize() {\n            if (this.type === 'label') return 's';\n\n            return this.size === 'l' ? 'm' : 's';\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-label {\n    display: inline-block;\n    position: relative;\n    z-index: 1;\n\n    .content {\n        position: relative;\n        z-index: 3;\n        display: flex;\n        justify-content: center;\n        align-items: center;\n    }\n\n    :deep(.a-glyph) {\n        flex-shrink: 0;\n        margin-inline-end: 8px;\n        &:not(.a-glyph_noFill) {\n            fill: currentcolor;\n        }\n    }\n\n    &.size-s {\n        :deep(.a-glyph) {\n            margin-inline-end: 6px;\n        }\n    }\n}\n\n.a-label.type-label {\n    @mixin note-heading;\n    box-sizing: border-box;\n    font-weight: 700;\n    padding: 4px 12px;\n    border-radius: 16px;\n\n    --border-width: 2px;\n\n    &.size-s {\n        padding: 0 8px;\n        border-radius: 8px;\n\n        --border-width: 1px;\n\n        .a-glyph {\n            width: 12px;\n            height: 12px;\n        }\n    }\n\n    &.size-xl {\n        font-size: 16px;\n        line-height: 20px;\n        padding: 6px 16px;\n    }\n\n    &.variant-ai-gradient {\n        color: var(--av-nav-primary);\n        &:deep(.a-glyph) {\n            color: var(--av-nav-primary);\n        }\n    }\n\n    &.variant-info {\n        color: var(--av-nav-primary);\n        &:deep(.a-glyph) {\n            color: var(--av-nav-primary);\n        }\n    }\n\n    &.variant-success {\n        color: rgb(65, 113, 9);\n        &:deep(.a-glyph) {\n            color: rgb(65, 113, 9);\n        }\n    }\n\n    &.variant-neutral {\n        color: var(--av-fixed-neutral-dark);\n        &:deep(.a-glyph) {\n            color: var(--av-fixed-neutral-dark);\n        }\n    }\n\n    &.variant-lime {\n        color: rgba(71, 255, 147, 1);\n        &:deep(.a-glyph) {\n            color: rgba(71, 255, 147, 1);\n        }\n    }\n\n    &.layout-solid {\n        &.variant-ai-gradient {\n            background: linear-gradient(75deg, #3849E0 40%, #FC2DF1 100%);\n            color: var(--av-inversed-primary);\n            &:deep(.a-glyph) {\n                fill: var(--av-inversed-primary);\n            }\n        }\n\n        &.variant-info {\n            background: var(--av-gradient-info-lightest);\n        }\n\n        &.variant-success {\n            background: var(--av-gradient-success-lightest);\n        }\n\n        &.variant-neutral {\n            background: var(--av-fixed-neutral-light);\n        }\n\n        &.variant-lime {\n            background: rgba(71, 255, 147, 1);\n            color: var(--av-nav-primary);\n            &:deep(.a-glyph) {\n                fill: var(--av-nav-primary);\n            }\n        }\n    }\n\n    &.layout-subtle {\n        &:before {\n            content: '';\n            position: absolute;\n            inset: 0;\n            z-index: 1;\n            margin: 0;\n            border-radius: inherit;\n        }\n\n        &:after {\n            content: '';\n            position: absolute;\n            inset: 0;\n            z-index: 2;\n            margin: var(--border-width);\n            border-radius: inherit;\n            background-color: var(--av-inversed-primary);\n        }\n\n        &.variant-ai-gradient {\n            background: linear-gradient(75deg, #3849E0 40%, #FC2DF1 100%);\n        }\n\n        &.variant-info {\n            &:before {\n                background: var(--av-gradient-info);\n            }\n        }\n\n        &.variant-success {\n            &:before {\n                background: var(--av-gradient-success);\n            }\n        }\n\n        &.variant-neutral {\n            &:before {\n                background: var(--av-fixed-neutral);\n            }\n        }\n\n        &.variant-lime {\n            color: var(--av-inversed-primary);\n            &:deep(.a-glyph) {\n                fill: var(--av-inversed-primary);\n            }\n            &:before {\n                background-color: rgba(71, 255, 147, 1);\n            }\n            &:after {\n                background: rgba(1, 101, 73, 1);\n            }\n        }\n    }\n\n    &.theme-dark {\n       color: var(--av-inversed-primary);\n        &:deep(.a-glyph) {\n            color: var(--av-inversed-primary);\n        }\n        &.layout-solid {\n            &.variant-ai-gradient {\n                color: var(--av-inversed-primary);\n                &:deep(.a-glyph) {\n                    color: var(--av-inversed-primary);\n                }\n            }\n            &.variant-info {\n                background: var(--av-gradient-info);\n            }\n\n            &.variant-success {\n                background: var(--av-gradient-success);\n            }\n\n            &.variant-neutral {\n                background: var(--av-fixed-neutral);\n            }\n        }\n\n        &.layout-subtle {\n            &.variant-ai-gradient {\n                color: var(--av-inversed-primary);\n                &:deep(.a-glyph) {\n                    color: var(--av-inversed-primary);\n                }\n            }\n\n            &.variant-lime {\n                &:after {\n                    background: rgba(1, 101, 73, 1);\n                }\n            }\n\n            &:after {\n                background-color: var(--av-nav-primary);\n            }\n\n            &.variant-neutral {\n                color: var(--av-fixed-neutral-light);\n                &:deep(.a-glyph) {\n                    color: var(--av-fixed-neutral-light);\n                }\n            }\n        }\n    }\n}\n\n.a-label.type-text-label {\n    @mixin paragraph-accent;\n\n    &.size-s {\n        @mixin body-accent;\n    }\n\n    &.size-xl {\n        font-size: 16px;\n        line-height: 20px;\n        padding: 6px 16px;\n    }\n\n    &.variant-ai-gradient {\n        color: var(--av-nav-primary);\n        &:deep(.a-glyph) {\n            color: var(--av-nav-primary);\n        }\n    }\n\n    &.variant-info {\n        color: var(--av-nav-secondary);\n        &:deep(.a-glyph) {\n            color: var(--av-nav-secondary);\n        }\n    }\n\n    &.variant-success {\n        color: var(--av-button-action);\n        &:deep(.a-glyph) {\n            color: var(--av-button-action);\n        }\n    }\n\n    &.variant-neutral {\n        color: var(--av-fixed-neutral-dark);\n        &:deep(.a-glyph) {\n            color: var(--av-fixed-neutral-dark);\n        }\n    }\n\n    &.theme-dark {\n        &.variant-ai-gradient {\n            color: var(--av-inversed-primary);\n            &:deep(.a-glyph) {\n                color: var(--av-inversed-primary);\n            }\n        }\n\n        &.variant-info {\n            color: var(--av-brand-secondary);\n            &:deep(.a-glyph) {\n                color: var(--av-brand-secondary);\n            }\n        }\n\n        &.variant-success {\n            color: var(--av-fixed-success);\n            &:deep(.a-glyph) {\n                color: var(--av-fixed-success);\n            }\n        }\n\n        &.variant-neutral {\n            color: var(--av-inversed-light);\n            &:deep(.a-glyph) {\n                color: var(--av-inversed-light);\n            }\n        }\n    }\n}\n\n</style>\n","const defaultBreakpoints = {\n    mobileWide: 576,\n    tablet: 768,\n    desktop: 1024,\n    desktopWide: 1280,\n    desktopLarge: 1440,\n};\n\nexport default {\n    data() {\n        return {\n            currentBreakpoint: '',\n        };\n    },\n\n    computed: {\n        breakpoints() {\n            return defaultBreakpoints;\n        },\n\n        isMobile() {\n            return ['mobile', 'mobileWide'].includes(this.currentBreakpoint);\n        },\n\n        isTablet() {\n            return this.currentBreakpoint === 'tablet';\n        },\n\n        isDesktop() {\n            return ['desktop', 'desktopWide', 'desktopLarge'].includes(this.currentBreakpoint);\n        },\n    },\n\n    methods: {\n        getDeviceTypeByScreenWidth(clientWidth) {\n            if (clientWidth < this.breakpoints.tablet) return 'mobile';\n            if (clientWidth < this.breakpoints.desktop) return 'tablet';\n            return 'desktop';\n        },\n\n        handleResize() {\n            const clientWidth = window.innerWidth;\n            const { mobileWide, tablet, desktop, desktopWide, desktopLarge } = this.breakpoints;\n\n            if (clientWidth < mobileWide) {\n                this.currentBreakpoint = 'mobile';\n            } else if (clientWidth < tablet) {\n                this.currentBreakpoint = 'mobileWide';\n            } else if (clientWidth < desktop) {\n                this.currentBreakpoint = 'tablet';\n            } else if (clientWidth < desktopWide) {\n                this.currentBreakpoint = 'desktop';\n            } else if (clientWidth < desktopLarge) {\n                this.currentBreakpoint = 'desktopWide';\n            } else {\n                this.currentBreakpoint = 'desktopLarge';\n            }\n        },\n    },\n\n    mounted() {\n        if (typeof window !== 'undefined') {\n            window.addEventListener('resize', this.handleResize);\n            this.handleResize();\n        } else {\n            this.currentBreakpoint = 'desktop';\n        }\n    },\n\n    beforeUnmount() {\n        window.removeEventListener('resize', this.handleResize);\n    },\n};\n","/**\n * Link types\n * direct and download-file are legacy types, but left for backward compatibility\n *\n * @return {string[]}\n */\nexport const TYPES = ['download-file', 'direct', 'regular', 'secondary', 'dark', 'light'];\n\n/**\n * Link sizes\n *\n * @return {string[]}\n */\nexport const SIZES = ['caption', 'body', 'paragraph', 'lead', 'title'];\n\n/**\n * Link glyph positions\n *\n * @return {string[]}\n */\nexport const GLYPH_POSITIONS = ['left', 'right'];\n","<template>\n    <dynamic-link\n        class=\"a-link\"\n        :to=\"computedTo\"\n        :event=\"event\"\n        :class=\"className\"\n        :title=\"title\"\n        native-type=\"a\"\n        :tabindex=\"disabled ? -1 : 0\"\n        :has-no-ref=\"hasNoRef\"\n        :do-not-change-location=\"doNotChangeLocation\"\n        :target=\"target\"\n        :aria-disabled=\"disabled\"\n        :aria-label=\"text || undefined\"\n        :rel=\"rel\"\n        @click=\"handleClick\"\n        @keydown.enter.space.prevent=\"!disabled && handleClick($event)\"\n    >\n        <a-label v-if=\"label?.text\" v-bind=\"label\">\n            <span>{{ label.text }}</span>\n        </a-label>\n        <span v-if=\"tag\" class=\"a-link__tag\">{{ tag }}</span>\n        <span\n            class=\"a-link__content\"\n            :class=\"{ hasGlyph: !!glyph, glyphLeft: glyph && glyphPosition === 'left', glyphRight: glyph && glyphPosition === 'right' }\"\n        >\n            <span v-if=\"srOnly\" class=\"sr-only\">{{ srOnly }}</span>\n            <template v-if=\"shouldRenderNobr\">\n                <!-- we need to have the last word attached to the glyph, but &nbsp; only binds to text so we have to have two of them -->\n                <!-- eslint-disable-next-line  -->\n                <a-dangerous-html v-if=\"computedText\" tag=\"span\" :content=\"computedText\" />&nbsp;<span class=\"nowrap\">&nbsp;\n                    <a-glyph\n                        class=\"a-link__content__glyph\"\n                        :name=\"glyph\"\n                        :class=\"{ left: glyphPosition === 'left', right: glyphPosition === 'right' }\"\n                        :size=\"glyphSize || undefined\"\n                        :aria-hidden=\"true\"\n                    />\n                </span>\n            </template>\n            <template v-else>\n                <a-dangerous-html v-if=\"computedText\" tag=\"span\" :content=\"computedText\" />\n                <a-glyph\n                    v-if=\"glyph\"\n                    class=\"a-link__content__glyph\"\n                    :name=\"glyph\"\n                    :class=\"{ left: glyphPosition === 'left', right: glyphPosition === 'right' }\"\n                    :size=\"glyphSize || undefined\"\n                />\n            </template>\n        </span>\n        <span v-if=\"desc\" class=\"a-link__desc\">{{ desc }}</span>\n    </dynamic-link>\n</template>\n\n<script>\nimport { mapState } from 'vuex';\nimport ADangerousHtml from '@core/components/dangerous-html/dangerous-html.vue';\nimport DynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport { SIZES as GLYPH_SIZES } from '@core/components/glyph/constants.js';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport ALabel from '@core/components/label/label.vue';\nimport breakpoint from '@core/mixins/breakpoint.js';\nimport { TYPES, SIZES, GLYPH_POSITIONS } from './constants.js';\n\nexport default {\n    name: 'ALink',\n    components: {\n        AGlyph,\n        ADangerousHtml,\n        DynamicLink,\n        ALabel,\n    },\n    mixins: [breakpoint],\n    props: {\n        /**\n         * Link text\n         */\n        text: {\n            type: String,\n            default: undefined,\n        },\n        /**\n         * Link URL\n         */\n        to: {\n            type: String,\n            default: undefined,\n        },\n        /**\n         * Link Title\n         */\n        title: {\n            type: String,\n            default: undefined,\n        },\n        /**\n         * Link type\n         */\n        type: {\n            type: String,\n            default: 'regular',\n            validator: (value) => TYPES.includes(value),\n            required: false,\n        },\n        /**\n         * Link size\n         */\n        size: {\n            type: String,\n            default: 'body',\n            validator: (value) => value === undefined || SIZES.includes(value),\n        },\n        /**\n         * Glyph name\n         */\n        glyph: {\n            type: String,\n            default: undefined,\n        },\n        /**\n         * Glyph position\n         */\n        glyphPosition: {\n            type: String,\n            validator: (value) => value === undefined || GLYPH_POSITIONS.includes(value),\n            default: 'right',\n        },\n        glyphSize: {\n            type: String,\n            validator: (value) => value === undefined || GLYPH_SIZES.includes(value),\n            default: undefined,\n        },\n        desc: {\n            type: String,\n            default: undefined,\n        },\n        tag: {\n            type: String,\n            default: undefined,\n        },\n        label: {\n            type: Object,\n            default: undefined,\n        },\n        accent: {\n            type: Boolean,\n            default: false,\n        },\n        disabled: {\n            type: Boolean,\n            default: false,\n        },\n        hasNoRef: {\n            type: Boolean,\n            default: false,\n        },\n        target: {\n            type: String,\n            default: undefined,\n        },\n        rel: {\n            type: String,\n            default: undefined,\n        },\n        event: {\n            type: Object,\n            default: undefined,\n        },\n        srOnly: {\n            type: String,\n            default: undefined,\n        },\n        modal: {\n            type: Object,\n            default: undefined,\n        },\n        doNotChangeLocation: {\n            type: Boolean,\n            default: false,\n        },\n        hasNonBreakingGlyph: {\n            type: Boolean,\n            default: false,\n        },\n        phoneFromGeo: {\n            type: Object,\n            default: undefined,\n        },\n    },\n    emits: ['click'],\n    data() {\n        return {\n            updatedText: null,\n            updatedTo: null,\n        };\n    },\n    computed: {\n        ...mapState({\n            location: (state) => state.geolocation?.location || null,\n        }),\n        country() {\n            return this.location?.data?.country?.code;\n        },\n        shouldRenderNobr() {\n            return this.glyph && this.hasNonBreakingGlyph;\n        },\n        computedTo() {\n            return this.updatedTo || this.to;\n        },\n        computedText() {\n            return this.updatedText || this.text;\n        },\n        className() {\n            const { type, size, glyphPosition, accent, disabled, text } = this;\n            return {\n                [`a-link_type_${type}`]: type || 'regular',\n                [`a-link_size_${size}`]: size,\n                [`a-link_glyph_${glyphPosition}`]: glyphPosition,\n                'a-link_noText': !text,\n                'a-link_accent': accent,\n                'a-link_disabled': disabled,\n            };\n        },\n    },\n    watch: {\n        country() {\n            if (!this.phoneFromGeo) return;\n            this.processGeoPhone();\n        },\n    },\n    methods: {\n        handleClick(event) {\n            if (this.disabled) {\n                event.preventDefault();\n                event.stopImmediatePropagation?.();\n                return;\n            }\n\n            if (this.modal?.events) {\n                if (!this.modal.breakpoint || this.modal.breakpoint?.includes(this.currentBreakpoint)) {\n                    localStorage.setItem('modalEvents', JSON.stringify(this.modal.events));\n                }\n            }\n            this.$emit('click', event);\n        },\n        processGeoPhone() {\n            const phone = this.phoneFromGeo?.[this.country];\n            this.updatedText = phone || this.text;\n            this.updatedTo = phone ? `tel:${phone}` : this.to;\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-link {\n    display: inline-block;\n    text-decoration: none;\n    background: none;\n    padding: 0;\n    border: 0;\n    outline: 0;\n    cursor: pointer;\n    color: var(--av-link-primary);\n    &:hover {\n        color: var(--av-link-primary-hover);\n        .a-link__content {\n            color: var(--av-link-primary-hover);\n            &__glyph {\n                fill: var(--av-link-primary-hover);\n            }\n        }\n    }\n    &__desc {\n        @mixin caption;\n        margin-top: 8px;\n        display: block;\n        color: var(--av-fixed-light);\n    }\n    &__tag {\n        @mixin caption;\n        margin-bottom: 8px;\n        display: block;\n        color: var(--av-fixed-secondary);\n    }\n    &__content {\n        color: var(--av-brand-primary);\n        display: inline-block;\n        &.hasGlyph {\n            position: relative;\n        }\n        &.glyphLeft {\n            padding-inline-start: 24px;\n            .a-glyph {\n                position: absolute;\n            }\n            span {\n                display: inline-block;\n            }\n            .nowrap {\n                position: absolute;\n                top: 0;\n                inset-inline-start: 0;\n            }\n        }\n        &.glyphRight {\n            .a-glyph {\n                margin-bottom: 4px;\n            }\n            span {\n                margin-inline-end: 6px;\n            }\n        }\n        &__glyph {\n            fill: var(--av-brand-primary);\n\n            &.left {\n                inset-inline-start: 0;\n            }\n            &.right {\n                inset-inline-end: 0;\n            }\n        }\n    }\n\n    /* Different font sizes / Default body */\n    &_size {\n        &_caption {\n            .a-link__content {\n                @mixin caption;\n                .a-glyph {\n                    margin: 0;\n                }\n            }\n        }\n        &_body {\n            .a-link__content {\n                @mixin body;\n                .a-glyph {\n                    top: 4px;\n                }\n            }\n        }\n        &_paragraph {\n            .a-link__content {\n                @mixin paragraph;\n                .a-glyph {\n                    top: 4px;\n                }\n            }\n        }\n        &_lead {\n            .a-link__content {\n                @mixin lead;\n                .a-glyph {\n                    top: 5px;\n                }\n            }\n        }\n        &_title {\n            .a-link__content {\n                @mixin title;\n                &.glyphLeft {\n                    padding-inline-start: 32px;\n                }\n                .a-glyph {\n                    margin-bottom: 7px;\n                    top: 10px;\n                }\n            }\n        }\n    }\n    &_accent {\n        font-weight: 700;\n    }\n    &_disabled {\n        pointer-events: none;\n    }\n\n    /* Fix for usages with no text only glyph */\n    &_noText {\n        .a-link__content {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            padding: 0;\n            .a-glyph {\n                position: unset;\n            }\n            &__glyph {\n                position: relative;\n            }\n        }\n    }\n\n    /* Support for download-file and direct links alongside new ones */\n    &_type {\n        &_direct,\n        &_regular {\n            .a-link__content {\n                color: var(--av-link-primary);\n                &__glyph {\n                    fill: var(--av-link-primary);\n                }\n            }\n            &:hover {\n                .a-link__content {\n                    color: var(--av-link-primary-hover);\n                    &__glyph {\n                        fill: var(--av-link-primary-hover);\n                    }\n                }\n            }\n            &:focus {\n                .a-link__content {\n                    background: var(--av-brand-secondary-light);\n                    color: var(--av-link-primary);\n                    &__glyph {\n                        fill: var(--av-link-primary);\n                    }\n                }\n            }\n            &:active,\n            &.nuxt-link-active,\n            &.nuxt-link-exact-active {\n                .a-link__content {\n                    background: none;\n                    color: var(--av-link-primary-active);\n                    &__glyph {\n                        fill: var(--av-link-primary-active);\n                    }\n                }\n            }\n            &.a-link_disabled {\n                .a-link__content {\n                    color: var(--av-link-primary-light);\n                    &__glyph {\n                        fill: var(--av-link-primary-light);\n                    }\n                }\n            }\n        }\n        &_dark {\n            .a-link__content {\n                color: var(--av-link-secondary);\n                &__glyph {\n                    fill: var(--av-link-secondary);\n                }\n            }\n            &:hover {\n                .a-link__content {\n                    color: var(--av-link-secondary-hover);\n                    &__glyph {\n                        fill: var(--av-link-secondary-hover);\n                    }\n                }\n            }\n            &:focus {\n                .a-link__content {\n                    background: var(--av-brand-secondary-light);\n                    color: var(--av-link-secondary);\n                    &__glyph {\n                        fill: var(--av-link-secondary);\n                    }\n                }\n            }\n            &:active,\n            &.nuxt-link-active,\n            &.nuxt-link-exact-active {\n                .a-link__content {\n                    background: none;\n                    color: var(--av-link-secondary-active);\n                    &__glyph {\n                        fill: var(--av-link-secondary-active);\n                    }\n                }\n            }\n            &.a-link_disabled {\n                .a-link__content {\n                    color: var(--av-link-secondary-light);\n                    &__glyph {\n                        fill: var(--av-link-secondary-light);\n                    }\n                }\n                .a-link__content:hover,\n                .a-link__content:focus,\n                .a-link__content:active {\n                    color: var(--av-link-secondary-light);\n                    .a-link__content__glyph {\n                        fill: var(--av-link-secondary-light);\n                    }\n                }\n            }\n        }\n        &_secondary {\n            .a-link__content {\n                color: var(--av-brand-secondary);\n                &__glyph {\n                    fill: var(--av-brand-secondary);\n                }\n            }\n            &:hover {\n                .a-link__content {\n                    color: var(--av-brand-primary);\n                    &__glyph {\n                        fill: var(--av-brand-primary);\n                    }\n                }\n            }\n            &:focus {\n                .a-link__content {\n                    background: var(--av-brand-secondary-light);\n                    color: var(--av-brand-secondary);\n                    &__glyph {\n                        fill: var(--av-brand-secondary);\n                    }\n                }\n            }\n            &:active,\n            &.nuxt-link-active,\n            &.nuxt-link-exact-active {\n                .a-link__content {\n                    background: none;\n                    color: var(--av-brand-secondary);\n                    &__glyph {\n                        fill: var(--av-brand-secondary);\n                    }\n                }\n            }\n        }\n        &_light {\n            .a-link__content {\n                color: var(--av-link-inversed);\n                &__glyph {\n                    fill: var(--av-link-inversed);\n                }\n            }\n            &:hover {\n                .a-link__content {\n                    color: var(--av-link-inversed-hover);\n                    &__glyph {\n                        fill: var(--av-link-inversed-hover);\n                    }\n                }\n            }\n            &:focus {\n                .a-link__content {\n                    background: var(--av-brand-secondary-light);\n                    color: var(--av-link-inversed);\n                    &__glyph {\n                        fill: var(--av-link-inversed);\n                    }\n                }\n            }\n            &:active,\n            &.nuxt-link-active,\n            &.nuxt-link-exact-active {\n                .a-link__content {\n                    background: none;\n                    color: var(--av-link-inversed-active);\n                    &__glyph {\n                        fill: var(--av-link-inversed-active);\n                    }\n                }\n            }\n            &.a-link_disabled {\n                .a-link__content {\n                    color: var(--av-link-inversed-light);\n                    &__glyph {\n                        fill: var(--av-link-inversed-light);\n                    }\n                }\n            },\n            .a-link__tag,\n            .a-link__desc {\n                color: var(--av-inversed-secondary);\n            }\n        }\n        &_direct {\n            .a-link__content {\n                @mixin title-accent;\n                .a-glyph {\n                    margin-bottom: 7px;\n                }\n            }\n            .a-link__content {\n                &.glyphLeft {\n                    padding-inline-start: 32px;\n                }\n                .a-glyph {\n                    top: 10px;\n                }\n            }\n        }\n        &_download-file {\n            .a-link__content {\n                @mixin lead-accent;\n                &__glyph {\n                    top: 6px !important;\n                    width: 14px;\n                    height: 14px;\n                    margin-bottom: 4px !important;\n                }\n            }\n            &.a-link_disabled {\n                .a-link__content {\n                    color: var(--av-link-primary-light);\n                    &__glyph {\n                        fill: var(--av-link-primary-light);\n                    }\n                }\n            }\n        }\n    }\n\n    .nowrap {\n        white-space: nowrap;\n        margin-inline-start: -0.5em;\n    }\n}\n</style>\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <span\n        ref=\"triggerRef\"\n        class=\"a-tooltip\"\n        @touchstart=\"onTriggerTouchStart\"\n        @mouseenter=\"onTriggerMouseEnter\"\n        @mouseleave=\"onTriggerMouseLeave\"\n        @click=\"onTriggerClick\"\n    >\n        <div class=\"tooltip-wrapper\">\n            <slot>\n                <a-glyph v-if=\"glyph\" :name=\"glyph\" />\n            </slot>\n        </div>\n        <teleport to=\"#teleports\" :disabled=\"!shouldTeleport\">\n            <transition :name=\"transition\" @after-leave=\"doDestroy\">\n                <div\n                    v-if=\"!disabled && showPopper\"\n                    :key=\"uniqueKey\"\n                    ref=\"dropdownRef\"\n                    role=\"tooltip\"\n                    :class=\"[\n                        'a-popper content',\n                        popperClass,\n                        maxWidth === 'auto-width' ? 'a-popper--auto-width' : '',\n                        visibleArrow ? 'a-popper--with-arrow' : ''\n                    ]\"\n                    :style=\"computedStyle\"\n                    :dynamic-width=\"dynamicWidth\"\n                    :aria-hidden=\"disabled || !showPopper ? true : false\"\n                    @mouseenter=\"onPopperMouseEnter\"\n                    @mouseleave=\"onPopperMouseLeave\"\n                >\n                    <div\n                        v-if=\"visibleArrow\"\n                        ref=\"arrowEl\"\n                        class=\"a-popper__arrow\"\n                        data-popper-arrow\n                    />\n\n                    <slot name=\"content\">\n                        <template v-if=\"isSimpleContent\">\n                            <a-dangerous-html class=\"text content\" :content=\"content\" />\n                        </template>\n\n                        <template v-else-if=\"isStructuredContent\">\n                            <div v-if=\"content.title\" class=\"title\">{{ content.title }}</div>\n                            <a-dangerous-html v-if=\"content.content\" class=\"text content\" :content=\"content.content\" />\n                            <template v-if=\"Array.isArray(content.list)\">\n                                <ul>\n                                    <li v-for=\"(item, index) in content.list\" :key=\"index\" class=\"list-item\">\n                                        <a-link v-if=\"item.to\" v-bind=\"item\" />\n                                        <div v-else>{{ item.text }}</div>\n                                    </li>\n                                </ul>\n                            </template>\n                        </template>\n                    </slot>\n                </div>\n            </transition>\n        </teleport>\n    </span>\n</template>\n\n<script setup>\nimport { ref, computed, watch, nextTick, onMounted, onBeforeUnmount } from 'vue';\nimport ADangerousHtml from '@core/components/dangerous-html/dangerous-html.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport ALink from '@core/components/link/link.vue';\nimport { useDebouncedFn } from '@core/composables/useDebouncedFn';\nimport { usePopper } from '@core/composables/usePopper';\n\nconst props = defineProps({\n    trigger: { type: String, default: 'hover' },\n    openDelay: { type: Number, default: 500 },\n    disabled: Boolean,\n    manual: Boolean,\n    enterable: { type: Boolean, default: true },\n    popperClass: { type: String, default: '' },\n    content: { type: [String, Number, Object], default: '' },\n    visibleArrow: { type: Boolean, default: true },\n    transition: { type: String, default: '' },\n    popperOptions: { type: Object, default: () => ({ boundariesPadding: 10, gpuAcceleration: false }) },\n    hideAfter: { type: Number, default: 0 },\n    placement: { type: String, default: 'top' },\n    dynamicWidth: { type: Boolean, default: false },\n    glyph: { type: String, default: 'tooltip-icon' },\n    maxWidth: {\n        type: [Number, String],\n        default: 325,\n        validator: val => typeof val === 'number' && val > 0 || val === 'auto-width',\n    },\n});\n\nconst triggerRef = ref(null);\nconst dropdownRef = ref(null);\nconst arrowEl = ref(null);\n\nconst shouldTeleport = ref(false);\nconst showPopper = ref(false);\nconst expectedState = ref(false);\nlet timeout = null;\nlet timeoutPending = null;\n\nconst popperOptions = computed(() => ({\n    placement: props.placement,\n    strategy: 'fixed',\n    modifiers: [\n        { name: 'offset', options: { offset: [0, 8] } },\n        { name: 'arrow', options: { element: arrowEl.value || undefined } },\n        { name: 'preventOverflow', options: { boundary: 'viewport' } },\n        { name: 'flip', options: { fallbackPlacements: ['top', 'right', 'left', 'bottom'] } },\n    ],\n    ...props.popperOptions,\n}));\n\nconst uniqueKey = computed(() => `${Math.random().toString(36).slice(2)}-${Date.now()}`);\nconst isStructuredContent = computed(() => typeof props.content === 'object' && props.content !== null);\nconst isSimpleContent = computed(() => typeof props.content === 'string' || typeof props.content === 'number');\n\nconst computedStyle = computed(() => {\n    return typeof props.maxWidth === 'number' ? { maxWidth: `${props.maxWidth}px` } : {};\n});\n\nconst { initializePopper, destroyPopper, updatePopper } = usePopper(\n    triggerRef,\n    dropdownRef,\n    popperOptions.value,\n);\n\nconst { debouncedFn: debounceClose } = useDebouncedFn(handleClosePopper, 200);\n\nfunction onTriggerTouchStart() {\n    if (props.trigger === 'hover' || props.trigger === 'click') show();\n}\nfunction onTriggerMouseEnter() {\n    if (props.trigger === 'hover') show();\n}\nfunction onTriggerMouseLeave() {\n    if (props.trigger === 'hover') hide();\n}\nfunction onTriggerClick() {\n    if (props.trigger === 'click') toggle();\n}\nfunction onPopperMouseEnter() {\n    if (props.enterable) expectedState.value = true;\n}\nfunction onPopperMouseLeave() {\n    if (props.enterable) {\n        expectedState.value = false;\n        debounceClose();\n    }\n}\nfunction doDestroy() {\n    showPopper.value = false;\n    nextTick(() => {\n        destroyPopper();\n    });\n}\n\nfunction show() {\n    setExpectedState(true);\n    handleShowPopper();\n}\nfunction hide() {\n    setExpectedState(false);\n    debounceClose();\n}\nfunction toggle() {\n    return expectedState.value ? hide() : show();\n}\n\nfunction handleShowPopper() {\n    if (!expectedState.value || props.manual) return;\n    clearTimeout(timeout);\n    timeout = setTimeout(() => {\n        showPopper.value = true;\n        nextTick(updatePopper);\n    }, props.openDelay);\n\n    if (props.hideAfter > 0) {\n        timeoutPending = setTimeout(() => {\n            showPopper.value = false;\n            expectedState.value = false;\n        }, props.hideAfter);\n    }\n}\n\nfunction handleClosePopper() {\n    if ((props.enterable && expectedState.value) || props.manual) return;\n    clearTimeout(timeout);\n    if (timeoutPending) clearTimeout(timeoutPending);\n    showPopper.value = false;\n}\n\nfunction setExpectedState(val) {\n    if (!val) clearTimeout(timeoutPending);\n    expectedState.value = val;\n}\n\nwatch(showPopper, (visible) => {\n    if (visible) {\n        nextTick(async () => {\n            if (!dropdownRef.value || !triggerRef.value) return;\n            await initializePopper();\n            requestAnimationFrame(updatePopper);\n        });\n    }\n});\n\nonMounted(() => {\n    if (props.manual && showPopper.value) {\n        nextTick(async () => {\n            await initializePopper();\n        });\n    }\n    requestAnimationFrame(() => {\n        shouldTeleport.value = true;\n    });\n});\nonBeforeUnmount(destroyPopper);\n</script>\n\n<style scoped lang=\"postcss\">\n.a-tooltip {\n  display: inline-flex;\n  align-items: center;\n  vertical-align: middle;\n\n  .title {\n    font-weight: 600;\n    margin-bottom: 8px;\n  }\n\n  .content {\n    @mixin caption-accent;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    position: relative;\n    &:after {\n        content:\"\";\n        display: block;\n    }\n  }\n\n  .tooltip-wrapper {\n    cursor: pointer;\n    display: inline-flex;\n    align-items: center;\n  }\n}\n</style>\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <li\n        ref=\"menuItemRef\"\n        class=\"el-menu-item\"\n        :class=\"{\n            'is-active': active,\n            'is-disabled': disabled,\n            'is-focus': focused,\n            'is-root': isRoot,\n            'is-multiline': multiline,\n            [`multiline-limit--${multilineLimit}`]: multiline && multilineLimit\n        }\"\n        role=\"menuitem\"\n        :tabindex=\"disabled ? -1 : 0\"\n        :title=\"computedTitle\"\n        @mousedown=\"handleMouseDown\"\n        @mouseup=\"handleMouseUp\"\n        @click=\"handleClick\"\n        @focus=\"handleFocus\"\n        @blur=\"handleBlur\"\n        @keydown.enter=\"handleClick\"\n    >\n        <a-tooltip\n            v-if=\"isCollapsedRoot\"\n            placement=\"right\"\n        >\n            <div v-if=\"$slots.title\">\n                <slot name=\"title\" />\n            </div>\n            <span v-if=\"$slots.icon\" class=\"el-menu__bar-icon\">\n                <slot name=\"icon\" />\n            </span>\n        </a-tooltip>\n\n        <template v-else>\n            <span v-if=\"$slots.icon\" class=\"el-menu__bar-icon\">\n                <slot name=\"icon\" />\n            </span>\n            <span v-if=\"$slots.title || $slots.subtitle\" class=\"el-menu-item__content\">\n                <div v-if=\"$slots.title\" class=\"el-menu-item__title el-text el-text--body-24 el-text--ellipsis\">\n                    <slot name=\"title\" />\n                </div>\n                <div v-if=\"$slots.subtitle\" class=\"el-menu-item__subtitle el-text--caption el-text--ellipsis el-text--color-fixed-light\">\n                    <slot name=\"subtitle\" />\n                </div>\n            </span>\n            <div class=\"el-text el-text--body-24 el-text--ellipsis\">\n                <slot />\n            </div>\n        </template>\n\n        <span\n            v-if=\"counter\"\n            class=\"el-tag ml-8\"\n            :class=\"{\n                [`el-tag--${counterType}`]: counterType,\n                'is-inverse': counterInverse,\n                'is-small': counterSmall\n            }\"\n            @mouseenter.stop=\"emit('mouseenter', $event)\"\n            @mouseleave.stop=\"emit('mouseleave', $event)\"\n        >\n            <span class=\"el-tag__text\">{{ counter }}</span>\n        </span>\n\n        <span v-if=\"$slots['right-icon']\" class=\"el-menu-item__right-icon mr-8 ml-16\">\n            <slot name=\"right-icon\" />\n        </span>\n    </li>\n</template>\n\n<script setup>\nimport { ref, computed, inject, useSlots, onBeforeUnmount, watchEffect, nextTick } from 'vue';\nimport ATooltip from '@core/components/tooltip/tooltip.vue';\n\nconst emit = defineEmits(['mousedown', 'mouseup', 'mouseenter', 'mouseleave']);\nconst slots = useSlots();\nconst props = defineProps({\n    index: { type: String, required: true },\n    multiline: { type: Boolean, default: false },\n    multilineLimit: {\n        type: Number,\n        validator: (val) => [2, 3].includes(val),\n        default: 2,\n    },\n    route: { type: [String, Object], default: '' },\n    disabled: Boolean,\n    exact: Boolean,\n    showHoverHint: { type: Boolean, default: false },\n    counter: { type: Number, default: 0 },\n    counterType: { type: String, default: 'info' },\n    counterSmall: { type: Boolean, default: false },\n    counterInverse: { type: Boolean, default: false },\n});\n\nconst menuContext = inject('menuContext');\nconst parentMenu = inject('parentMenu', null);\n\nconst indexPath = computed(() => [...(parentMenu?.indexPath || []), props.index]);\nconst isRoot = computed(() => (parentMenu?.level || 1) === 1);\nconst isCollapsedRoot = computed(() => isRoot.value && menuContext.collapse?.value);\nconst menuItemRef = ref(null);\nconst focused = ref(false);\nconst isClick = ref(false);\n\nconst active = computed(() => props.index === menuContext.activeIndex?.value);\n\nconst computedTitle = computed(() => {\n    if (!props.showHoverHint || isCollapsedRoot.value) return null;\n    const slot = (slots.title || slots.default || []);\n    return Array.isArray(slot) ? slot.map(n => n.children?.toString?.() || '').join('').trim() : '';\n});\n\nfunction handleClick() {\n    if (props.disabled) return;\n    menuContext.handleItemClick({\n        index: props.index,\n        indexPath: indexPath.value,\n        route: props.route,\n        $el: menuItemRef.value,\n    });\n}\n\nfunction handleFocus(e) {\n    if (props.disabled) return;\n    if (!isClick.value && menuContext.prevFocusItem !== e.target) {\n        focused.value = true;\n    } else {\n        isClick.value = false;\n    }\n    menuContext.prevFocusItem = e.target;\n}\n\nfunction handleBlur() {\n    focused.value = false;\n    isClick.value = false;\n    nextTick(() => {\n        if (!menuContext?.$el?.contains(document.activeElement)) {\n            menuContext.prevFocusItem = null;\n        }\n    });\n}\n\nfunction handleMouseDown() {\n    isClick.value = !props.disabled;\n    if (!props.disabled) emit('mousedown', props.index);\n}\n\nfunction handleMouseUp() {\n    if (!props.disabled) emit('mouseup', props.index);\n}\n\nwatchEffect(() => {\n    menuContext?.addItem?.({ index: props.index, indexPath: indexPath.value, $el: menuItemRef.value });\n});\n\nonBeforeUnmount(() => {\n    menuContext?.removeItem?.({ index: props.index });\n});\n</script>\n","/**\n * Button types\n *\n * @return {string[]}\n */\n\nexport const BORDER_RADIUS = [0, 2, 4, 8, 12, 16, 20, 24, 28];\n\nexport const LAYOUTS = ['right-icon', 'left-icon', 'no-icon', 'only-icon'];\n\nexport const TYPES = ['action', 'main', 'lime', 'secondary', 'inverse', 'inverse-white', 'ghost', 'ai-gradient'];\n\nexport const SIZES = ['s', 'm', 'large', 'medium', 'small', 'tiny', 'micro'];\n\nexport const ALIGNMENTS = ['center', 'start', 'end', 'between'];\n\nexport default {};\n","<template>\n    <div ref=\"container\" class=\"clamp-text\">\n        <span ref=\"content\">{{ clampedText }}</span><!--\n        --><span v-if=\"isClamped\" class=\"ellipsis\">…</span>\n    </div>\n</template>\n\n<script>\nexport default {\n    name: 'ATextClamp',\n    props: {\n        text: {\n            type: String,\n            default: '',\n        },\n        maxLines: {\n            type: Number,\n            default: 2,\n        },\n        // Add some margin of error for the maxHeight calculation.\n        // Should fix the situation when the span's scrollHeight is lineHeight + 1\n        jitterPx: {\n            type: Number,\n            default: 2,\n        },\n    },\n    data() {\n        return {\n            clampedText: '',\n            isClamped: false,\n        };\n    },\n    mounted() {\n        this.calculate();\n        window.addEventListener('resize', this.calculate);\n    },\n    beforeUnmount() {\n        window.removeEventListener('resize', this.calculate);\n    },\n    methods: {\n        async calculate() {\n            const container = this.$refs.container;\n            const content = this.$refs.content;\n            // Force the ellipsis so the fit routine takes it into account\n            this.isClamped = true;\n            // Initially put all the text available\n            content.textContent = this.text;\n            // Allow to redraw\n            await this.$nextTick();\n\n            // Measure the max allowed height\n            const maxHeight = parseFloat(getComputedStyle(container).lineHeight) * this.maxLines + this.jitterPx;\n\n            if (container.scrollHeight <= maxHeight) {\n                // Everything fits, no need to clamp\n                this.clampedText = this.text;\n                this.isClamped = false;\n                return;\n            }\n\n            const words = this.text.split(' ');\n\n            // If no words fit, we'll at least have the 1st word to show.\n            // If this ever happens though, it must be solved on the content level.\n            let bestFit = words[0];\n            let currentAttempt = '';\n\n            // Gradually find the best fit by adding words one by one.\n            // It's technically faster to use binary search,\n            // but the linear search is already fast enough and much simplier.\n            for (let i = 1; i <= words.length; i++) {\n                currentAttempt = words.slice(0, i).join(' ');\n                content.textContent = currentAttempt;\n\n                if (container.scrollHeight > maxHeight) {\n                    break;\n                } else {\n                    bestFit = currentAttempt;\n                }\n            }\n\n            // Set the final content\n            this.clampedText = bestFit;\n            content.textContent = bestFit;\n            this.isClamped = bestFit !== this.text;\n        },\n    },\n};\n</script>\n\n<style>\n.clamp-text {\n    overflow: hidden;\n    word-break: normal;\n    overflow-wrap: anywhere;\n}\n\n.ellipsis {\n    padding-left: 4px;\n}\n</style>\n","<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n    <dynamic-link\n        v-if=\"!isContext\"\n        :tabindex=\"disabled ? -1 : 0\"\n        class=\"a-button\"\n        :class=\"className\"\n        :to=\"to\"\n        :target=\"target\"\n        :title=\"computedTitle\"\n        :event=\"gaEvent\"\n        :type=\"to ? null : nativeType\"\n        :native-type=\"nativeType\"\n        :aria-disabled=\"disabled\"\n        :aria-label=\"onlyIcon ? computedTitle || text : undefined\"\n        @click=\"handleClick\"\n        @keydown.enter.space.prevent=\"!disabled && handleClick($event)\"\n    >\n        <a-text-clamp\n            v-if=\"!disableClamp && text && !onlyIcon\"\n            :key=\"text\"\n            class=\"a-button__content\"\n            :max-lines=\"maxLines\"\n            :text=\"text\"\n        />\n        <span v-if=\"disableClamp && !onlyIcon\" class=\"a-button__content\">{{ text }}</span>\n        <a-glyph\n            v-if=\"glyph && layout !== 'no-icon'\"\n            class=\"a-button__glyph\"\n            :name=\"glyph\"\n            :aria-hidden=\"true\"\n        />\n        <span v-if=\"onlyIcon\" class=\"sr-only\">{{ computedTitle || text || 'Button' }}</span>\n    </dynamic-link>\n    <div v-else class=\"a-button-with-context\">\n        <dynamic-link\n            class=\"a-button\"\n            :tabindex=\"disabled ? -1 : 0\"\n            :class=\"className\"\n            :to=\"to\"\n            :target=\"target\"\n            :title=\"title\"\n            :event=\"gaEvent\"\n            :type=\"to ? null : nativeType\"\n            :native-type=\"nativeType\"\n            :aria-disabled=\"disabled\"\n            :aria-label=\"onlyIcon ? computedTitle || text : undefined\"\n            @click=\"handleClick\"\n            @keydown.enter.space.prevent=\"!disabled && handleClick($event)\"\n        >\n            <a-text-clamp\n                v-if=\"!disableClamp && text && !onlyIcon\"\n                :key=\"text\"\n                class=\"a-button__content\"\n                :max-lines=\"maxLines\"\n                :text=\"text\"\n            />\n            <span v-if=\"srOnly\" class=\"sr-only\">{{ srOnly }}</span>\n            <span v-if=\"disableClamp && !onlyIcon\" class=\"a-button__content\">{{ text }}</span>\n            <a-glyph v-if=\"glyph && layout !== 'no-icon'\" class=\"a-button__glyph\" :name=\"glyph\" />\n        </dynamic-link>\n        <div class=\"a-button-with-context__text\">\n            {{ context }}\n        </div>\n    </div>\n</template>\n\n\n<script>\nimport { upperFirst } from 'lodash-es';\nimport { TYPES, SIZES, LAYOUTS, BORDER_RADIUS, ALIGNMENTS } from '@core/components/button/constants.js';\nimport DynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport ATextClamp from '@core/components/text-clamp/text-clamp.vue';\nimport breakpoint from '@core/mixins/breakpoint.js';\n\nexport default {\n    name: 'AButton',\n\n    components: {\n        AGlyph,\n        DynamicLink,\n        ATextClamp,\n    },\n    mixins: [breakpoint],\n    props: {\n        /**\n         * Button text\n         */\n        text: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * Button title\n         */\n        title: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * Link URL\n         */\n        to: {\n            type: String,\n            default: null,\n        },\n\n        target: {\n            type: String,\n            default: () => undefined,\n        },\n\n        /**\n         * Button type\n         */\n        type: {\n            type: String,\n            default: 'secondary',\n            validator: (value) => !value || TYPES.includes(value),\n        },\n\n        /**\n         * Button native type\n         */\n        nativeType: {\n            type: String,\n            default: 'button',\n        },\n\n        /**\n         * Button layout\n         */\n        layout: {\n            type: String,\n            default: 'right-icon',\n            validator: (value) => !value || LAYOUTS.includes(value),\n        },\n\n        /**\n         * Button size\n         */\n        size: {\n            type: String,\n            default: 'medium',\n            validator: (value) => !value || SIZES.includes(value),\n        },\n\n        /**\n         * Border radius\n         */\n        borderRadius: {\n            type: Number,\n            default: 4,\n            validator: (value) => !value || BORDER_RADIUS.includes(value),\n        },\n        /**\n         * Disabled\n         */\n        disabled: {\n            type: Boolean,\n            default: false,\n        },\n\n        srOnly: {\n            type: String,\n            default: undefined,\n        },\n\n        disableClamp: {\n            type: Boolean,\n            default: false,\n        },\n\n        /**\n         * Glyph name\n         */\n        glyph: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * Context present\n         */\n        isContext: {\n            type: Boolean,\n            default: false,\n        },\n\n        /**\n         * Context\n         */\n        context: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * GA Event\n         */\n        event: {\n            type: Object,\n            default: undefined,\n        },\n        modal: {\n            type: [Object, String],\n            default: undefined,\n        },\n\n        maxLines: {\n            type: Number,\n            default: 1,\n        },\n\n        autoWidth: {\n            type: Boolean,\n            default: false,\n        },\n\n        alignment: {\n            type: String,\n            default: 'center',\n            validator: (value) => !value || ALIGNMENTS.includes(value),\n        },\n    },\n\n    emits: ['click'],\n    data() {\n        return {\n            elem: null,\n        };\n    },\n\n    computed: {\n        onlyIcon() {\n            if (this.layout === 'only-icon') return true;\n            return this.glyph && !this.text;\n        },\n        resolvedLayout() {\n            if (!this.glyph && this.layout !== 'only-icon') return 'no-icon';\n            return this.layout;\n        },\n        /**\n         * Returns classes for component\n         *\n         * @returns {[className]: condition}\n         */\n        className() {\n            const { type, size, maxLines, borderRadius, disabled, glyph, context, alignment, autoWidth } = this;\n            return [\n                'a-button_type',\n                'a-button_layout',\n                `a-button_type_${type}`,\n                `a-button_alignment_${alignment}`,\n                `a-button_size_${size}`,\n                `a-button_layout_${this.resolvedLayout}`,\n                `a-button_radius_${borderRadius}`,\n                `a-button_maxlines_${maxLines}`,\n                {\n                    'auto-width': autoWidth,\n                    'a-button_with-glyph': glyph,\n                    'a-button_only-icon': this.onlyIcon,\n                    'a-button_disabled': disabled,\n                    'a-button-with-context__button': context,\n                },\n            ];\n        },\n        computedTitle() {\n            if (!this.onlyIcon) return this.title;\n            return this.text;\n        },\n\n        gaEvent() {\n            if (this.event?.doNotSendGA) {\n                return this.event;\n            }\n\n            return {\n                event: 'Acronis',\n                category: 'Conversions',\n                action: upperFirst(this.text?.toLowerCase().trim()) || '[no action]',\n                label: this.to || '[no label]',\n                context: 'click',\n                ...this.event,\n            };\n        },\n    },\n\n    mounted() {\n        this.elem = this.$el;\n    },\n\n    methods: {\n        handleClick(event) {\n            if (this.disabled) {\n                event.preventDefault();\n                event.stopImmediatePropagation?.();\n                return;\n            }\n\n            if (this.modal?.events) {\n                if (!this.modal.breakpoint || this.modal.breakpoint?.includes(this.currentBreakpoint)) {\n                    localStorage.setItem('modalEvents', JSON.stringify(this.modal.events));\n                }\n            }\n\n            this.$emit('click', event);\n\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-button {\n    --a-button-outline: none;\n    --a-button-border: none;\n    --a-button-opacity: 1;\n    --a-button-background: transparent;\n    --a-button-text-order: 1;\n    --a-button-icon-order: 2;\n    --a-buton-max-width: calc(100% - 24px);\n\n    display: inline-flex;\n    gap: 8px;\n    justify-content: center;\n    cursor: pointer;\n    text-decoration: none;\n    padding: var(--a-button-padding);\n    border-radius: var(--a-button-border-radius);\n    color: var(--a-button-color);\n    background: var(--a-button-background);\n    border: var(--a-button-border);\n    opacity: var(--a-button-opacity);\n    outline: var(--a-button-outline);\n\n    &.auto-width {\n        width: auto;\n    }\n    &:focus-visible {\n        --a-button-outline: 3px solid var(--av-fixed-focus);\n    }\n    &_maxlines_1 {\n        white-space: nowrap;\n    }\n    &_with-glyph {\n        align-items: center;\n    }\n    &__glyph {\n        order: var(--a-button-icon-order);\n        height: 16px;\n        width: 16px;\n        fill: var(--a-button-fill);\n        margin: 0;\n    }\n\n    &_type {\n        &_ai-gradient {\n            --a-button-color: var(--av-inversed-primary);\n            --a-button-fill: var(--av-inversed-primary);\n            --a-button-background: linear-gradient(75deg, #1F379C 0%, #3849E0 50%, #FC2DF1 100%);\n            &:hover {\n                --a-button-background: linear-gradient(75deg, #142FA0 20%, #E90DDD 100%);\n            }\n            &:active {\n                --a-button-background: linear-gradient(75deg, #0A207B 0%, #CB0AC1 100%);\n            }\n            &.a-button_disabled {\n                --a-button-background: linear-gradient(75deg,\n                rgba(31, 55, 156, 0.3) 0%,\n                rgba(56, 73, 224, 0.3) 50%,\n                rgba(252, 45, 241, 0.3) 100%);\n            }\n        }\n        &_main {\n            --a-button-color: var(--av-inversed-primary);\n            --a-button-fill: var(--av-inversed-primary);\n            --a-button-background: var(--av-button-main);\n            &:hover {\n                --a-button-background: var(--av-button-main-hover);\n            }\n            &:active {\n                --a-button-background: var(--av-button-main-active);\n            }\n            &.a-button_disabled {\n                --a-button-background: var(--av-button-main-light);\n                --a-button-color: var(--av-inversed-light);\n                --a-button-fill: var(--av-inversed-light);\n            }\n        }\n        &_lime {\n            --a-button-color: var(--av-nav-primary);\n            --a-button-fill: var(--av-nav-primary);\n            --a-button-background: rgba(71, 255, 147, 1);\n            &:hover {\n                --a-button-background: rgba(0, 200, 123, 1);\n            }\n            &:active {\n                --a-button-background: rgba(0, 200, 123, 1);\n            }\n            &.a-button_disabled {\n                --a-button-background: rgba(71, 255, 147, 0.3);\n                --a-button-color: var(--av-fixed-secondary);\n                --a-button-fill: var(--av-fixed-secondary);\n            }\n        }\n        &_action {\n            --a-button-color: var(--av-inversed-primary);\n            --a-button-fill: var(--av-inversed-primary);\n            --a-button-background: var(--av-button-action);\n            &:hover {\n                --a-button-background: var(--av-button-action-hover);\n            }\n            &:active {\n                --a-button-background: var(--av-button-action-active);\n            }\n            &.a-button_disabled {\n                --a-button-background: var(--av-button-action-light);\n                --a-button-color: var(--av-inversed-light);\n                --a-button-fill: var(--av-inversed-light);\n            }\n        }\n        &_secondary {\n            --a-button-color: var(--av-link-primary);\n            --a-button-border: 1px solid var(--av-button-secondary);\n            --a-button-fill: var(--av-link-primary);\n            &:hover {\n                --a-button-background: var(--av-button-secondary-hover);\n            }\n            &:active {\n                --a-button-background: var(--av-button-secondary-active);\n            }\n            &.a-button_disabled {\n                --a-button-color: var(--av-link-primary-light);\n                --a-button-border: 1px solid var(--av-button-secondary-light);\n                --a-button-fill: var(--av-link-primary-light);\n            }\n        }\n        &_inverse {\n            --a-button-color: var(--av-link-inversed);\n            --a-button-fill: var(--av-link-inversed);\n            --a-button-border: 1px solid var(--av-link-inversed);\n            &:hover {\n                --a-button-background: var(--av-button-inversed-hover);\n            }\n\n            &:active {\n                --a-button-background: var(--av-button-inversed-active);\n            }\n            &.a-button_disabled {\n                --a-button-color: var(--av-link-inversed-light);\n                --a-button-border: 1px solid var(--av-button-inversed-light);\n                --a-button-fill: var(--av-link-inversed-light);\n            }\n        }\n        &_inverse-white {\n            --a-button-color: var(--av-inversed-primary);\n            --a-button-fill: var(--av-inversed-primary);\n            --a-button-border: 1px solid var(--av-inversed-primary);\n            &:hover {\n                --a-button-background: var(--av-button-inversed-hover);\n            }\n\n            &:active {\n                --a-button-background: var(--av-button-inversed-active);\n            }\n            &.a-button_disabled {\n                --a-button-border: 1px solid var(--av-button-inversed-light);\n                --a-button-color: var(--av-inversed-lighter);\n                --a-button-fill: var(--av-inversed-lighter);\n            }\n        }\n        &_ghost {\n            --a-button-color: var(--av-link-primary);\n            --a-button-fill: var(--av-link-primary);\n            &:hover {\n                --a-button-background: var(--av-button-secondary-hover);\n            }\n\n            &:active {\n                --a-button-background: var(--av-button-secondary-active);\n            }\n            &.a-button_disabled {\n                --a-button-color: var(--av-link-primary);\n                --a-button-fill: var(--av-link-primary);\n            }\n        }\n    }\n\n    &_disabled {\n        pointer-events: none;\n\n        --a-button-opacity: 0.3;\n        &:focus-visible {\n            --a-button-outline: none;\n        }\n    }\n\n    &_radius {\n        &_0 { --a-button-border-radius: 0px }\n        &_2 { --a-button-border-radius: 2px }\n        &_4 { --a-button-border-radius: 4px; }\n        &_8 { --a-button-border-radius: 8px; }\n        &_12 { --a-button-border-radius: 12px; }\n        &_16 { --a-button-border-radius: 16px; }\n        &_20 { --a-button-border-radius: 20px; }\n        &_24 { --a-button-border-radius: 24px; }\n        &_28 { --a-button-border-radius: 28px; }\n    }\n\n    &_alignment {\n        &_center {\n            justify-content: center;\n        }\n        &_start {\n            justify-content: flex-start;\n        }\n        &_end {\n            justify-content: flex-end;\n        }\n        &_between {\n            justify-content: space-between;\n        }\n    }\n    &_size {\n        &_large {\n            --a-button-padding: 16px;\n            @mixin lead-accent;\n        }\n        &_medium, &_m {\n            --a-button-padding: 12px 16px;\n            @mixin paragraph-accent;\n        }\n        &_small, &_s {\n            --a-button-padding: 8px 16px;\n            @mixin paragraph-accent;\n        }\n        &_tiny {\n            --a-button-padding: 4px 8px;\n            @mixin paragraph-accent;\n        }\n        &_micro {\n            --a-button-padding: 4px 8px;\n            @mixin caption-accent;\n        }\n    }\n\n    &__content {\n        order: var(--a-button-text-order);\n        max-width: var(--a-buton-max-width);\n        min-width: 0;\n    }\n\n    &_layout {\n        &_left-icon {\n            --a-button-text-order: 2;\n            --a-button-icon-order: 1;\n        }\n        &_no-icon {\n            --a-buton-max-width: 100%;\n        }\n    }\n\n    &-with-context {\n        position: relative;\n        text-align: center;\n\n        @media (--viewport-desktop) {\n            margin-bottom: -24px;\n        }\n\n        &__button {\n            width: 100%;\n        }\n\n        &__text {\n            display: none;\n            @media (--viewport-desktop) {\n                @mixin caption;\n                display: block;\n                position: absolute;\n                margin-top: 8px;\n                width: 100%;\n                text-align: center;\n            }\n        }\n    }\n}\n\n.a-button.a-button_layout_only-icon {\n    &.a-button_size_large {\n        --a-button-padding: 20px;\n    }\n    &.a-button_size_medium, &.a-button_size_m {\n        --a-button-padding: 16px;\n    }\n    &.a-button_size_small, &.a-button_size_s {\n        --a-button-padding: 12px;\n    }\n    &.a-button_size_tiny {\n        --a-button-padding: 8px;\n    }\n    &.a-button_size_micro {\n        --a-button-padding: 4px;\n    }\n}\n</style>\n","import ResizeObserver from 'resize-observer-polyfill';\nimport { onMounted, onBeforeUnmount } from 'vue';\n\nexport function useResizeObserver(elRef, callback) {\n    let observer;\n\n    onMounted(() => {\n        if (elRef.value) {\n            observer = new ResizeObserver((entries) => {\n                // eslint-disable-next-line no-restricted-syntax\n                for (const entry of entries) callback(entry);\n            });\n            observer.observe(elRef.value);\n        }\n    });\n\n    onBeforeUnmount(() => {\n        if (observer && elRef.value) {\n            observer.unobserve(elRef.value);\n            observer.disconnect();\n        }\n    });\n}\n","/* eslint-disable no-param-reassign */\nexport function useSmoothScroll() {\n    const easeInOutCubic = (t) => (t < 0.5 ? 4 * t * t * t : ((t - 1) * ((2 * t) - 2) * ((2 * t) - 2)) + 1);\n\n    const smoothScrollTo = (el, direction, endPosition, duration) => {\n        const startTime = performance.now();\n        const startPosition = direction === 'horizontal' ? el.scrollLeft : el.scrollTop;\n\n        const step = () => {\n            const elapsed = performance.now() - startTime;\n            let position = endPosition;\n            if (elapsed < duration) {\n                position = startPosition + ((endPosition - startPosition) * easeInOutCubic(elapsed / duration));\n                requestAnimationFrame(step);\n            }\n            if (direction === 'horizontal') el.scrollLeft = position;\n            else el.scrollTop = position;\n        };\n\n        step();\n    };\n\n    return { smoothScrollTo };\n}\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <div\n        ref=\"menu\"\n        class=\"el-menu\"\n        :class=\"menuClass\"\n        :style=\"{ height: computedHeight, minHeight: computedHeight }\"\n    >\n        <ul\n            ref=\"menubar\"\n            class=\"el-menu__bar\"\n            role=\"menubar\"\n            :style=\"{ height: computedHeight, minHeight: computedHeight }\"\n            @scroll=\"debouncedOnMenubarScroll\"\n        >\n            <slot />\n        </ul>\n\n        <div\n            v-if=\"mode === 'horizontal' && isOverflow\"\n            class=\"el-menu__controls\"\n            :class=\"{ 'is-no-gradient': hideControlGradient }\"\n            :style=\"{ height: computedHeight, minHeight: computedHeight }\"\n        >\n            <a-button type=\"ghost\" glyph=\"i-chevron-left--16\" @click=\"scrollMenu(true)\" />\n            <div class=\"el-menu__controls-divider\" />\n            <a-button type=\"ghost\" glyph=\"i-chevron-right--16\" @click=\"scrollMenu(false)\" />\n        </div>\n    </div>\n</template>\n\n<script setup>\nimport {\n    ref, reactive, computed, watch, watchEffect, nextTick,\n    onMounted, onBeforeUnmount, provide,\n} from 'vue';\nimport { useRoute, useRouter } from 'vue-router';\nimport AButton from '@core/components/button/button.vue';\nimport { useDebouncedFn } from '@core/composables/useDebouncedFn.ts';\nimport { useResizeObserver } from '@core/composables/useResizeObserver';\nimport { useSmoothScroll } from '@core/composables/useSmoothScroll';\n\nconst props = defineProps({\n    mode: { type: String, default: 'vertical' },\n    type: { type: String, default: 'primary' },\n    modelValue: { type: String, default: '' },\n    defaultActive: { type: String, default: '' },\n    defaultOpeneds: { type: Array, default: () => [] },\n    collapse: Boolean,\n    scrollIntoExpanded: Boolean,\n    uniqueOpened: Boolean,\n    useRouteMatching: Boolean,\n    background: { type: String, default: '' },\n    noBorderBottom: Boolean,\n    hideAllBorders: Boolean,\n    height: { type: String, default: '64px' },\n});\n\nconst emit = defineEmits(['select', 'open', 'close', 'update:modelValue']);\nconst route = useRoute();\nconst router = useRouter();\nconst menu = ref(null);\nconst menubar = ref(null);\n\nconst activeIndex = ref(props.modelValue || props.defaultActive);\nconst openedMenus = ref([]);\nconst items = reactive({});\nconst submenus = reactive({});\n\nconst state = reactive({\n    itemsList: [],\n    contentWidth: 0,\n    isOverflow: false,\n    hideControlGradient: false,\n    margin: 16,\n});\n\nconst computedHeight = computed(() => (props.mode === 'horizontal' ? props.height : null));\nconst isOverflow = computed(() => state.isOverflow);\nconst hideControlGradient = computed(() => state.hideControlGradient);\nconst menuClass = computed(() => ({\n    [`el-menu--${props.mode}`]: true,\n    [`el-menu--${props.type}`]: true,\n    [`is-${props.background}`]: Boolean(props.background),\n    'el-menu--collapse': props.collapse,\n    'el-menu--without-submenus': Object.keys(submenus).length === 0,\n    'is-borderBottom': props.noBorderBottom || props.hideAllBorders,\n    'is-hide-all-borders': props.hideAllBorders,\n}));\n\nconst { debouncedFn: debouncedOnMenubarScroll, cancel: cancelMenubarScroll } = useDebouncedFn(() => {\n    if (props.mode === 'horizontal') updateControlGradient();\n}, 25);\n\nuseResizeObserver(menu, () => {\n    if (props.mode === 'horizontal') updateControls();\n});\n\nconst { smoothScrollTo } = useSmoothScroll();\n\nfunction getActiveIndexFromRoute(currentRoute) {\n    const { matched, path } = currentRoute;\n    if (items[path]) return path;\n    for (let i = matched.length - 1; i >= 0; i--) {\n        const matchedPath = matched[i].path;\n        const regex = matched[i].regex;\n        for (const key in items) {\n            if (regex.test(key)) return key;\n        }\n        if (items[matchedPath]) return matchedPath;\n    }\n    return null;\n}\n\nfunction updateActiveIndex(currentRoute) {\n    if (!props.useRouteMatching) return;\n    const newActive = getActiveIndexFromRoute(currentRoute);\n    if (newActive && newActive !== activeIndex.value) {\n        activeIndex.value = newActive;\n        updateOpenedMenu();\n        scrollToActiveItem();\n    }\n}\n\nfunction openMenu(index, indexPath) {\n    if (openedMenus.value.includes(index)) return;\n    if (props.uniqueOpened) {\n        openedMenus.value = indexPath.length <= 1\n            ? []\n            : openedMenus.value.filter(i => indexPath.includes(i));\n    }\n    openedMenus.value.push(index);\n}\n\nfunction closeMenu(index) {\n    const i = openedMenus.value.indexOf(index);\n    if (i !== -1) openedMenus.value.splice(i, 1);\n}\n\nfunction handleItemClick(item) {\n    const { index, indexPath } = item;\n    if (indexPath.length === 1) {\n        for (const key of Object.keys(submenus)) closeMenu(key);\n    }\n    if (activeIndex.value !== index) {\n        emit('update:modelValue', index);\n        emit('select', index, indexPath);\n        if (!props.modelValue && item.route) {\n            router.push(item.route).catch(() => {});\n        }\n        activeIndex.value = index;\n    }\n}\n\nfunction handleSubmenuClick(submenu) {\n    const { index, indexPath, $el, slots } = submenu;\n    const isOpened = openedMenus.value.includes(index);\n    if (isOpened && props.type !== 'primary') {\n        closeMenu(index);\n        emit('close', index, indexPath);\n    } else {\n        openMenu(index, indexPath);\n        emit('open', index, indexPath);\n        if (props.type === 'primary') {\n            const defaultSlot = slots?.default?.() || [];\n            const firstItem = defaultSlot.find(v => v?.type?.name === 'ElMenuItem');\n            if (firstItem?.props?.index && items[firstItem.props.index]) {\n                activeIndex.value = firstItem.props.index;\n            }\n        }\n        if (props.scrollIntoExpanded) nextTick(() => scrollToSubmenu($el));\n    }\n}\n\nfunction scrollToSubmenu(el) {\n    const wrap = menu.value?.parentElement?.querySelector('.el-scrollbar__wrap');\n    if (!wrap || !el) return;\n    const top = el.getBoundingClientRect().top - menu.value.getBoundingClientRect().top;\n    const bottom = top + el.offsetHeight;\n    const viewTop = wrap.scrollTop;\n    const viewBottom = viewTop + wrap.clientHeight;\n    if (el.offsetHeight > wrap.clientHeight || top < viewTop) wrap.scrollTop = top;\n    else if (bottom > viewBottom) wrap.scrollTop = bottom - wrap.clientHeight;\n}\n\nfunction scrollToActiveItem() {\n    const item = items[activeIndex.value];\n    if (item && props.mode === 'vertical') {\n        nextTick(() => scrollToSubmenu(item.$el));\n    }\n}\n\nfunction updateControls() {\n    const list = Array.from(menubar.value?.children || []);\n    state.itemsList = list;\n    if (!list.length) return;\n    const last = list[list.length - 1];\n    state.contentWidth = last.offsetLeft + last.offsetWidth + state.margin;\n    state.isOverflow = state.contentWidth + 2 * state.margin > menu.value.offsetWidth;\n}\n\nfunction updateControlGradient() {\n    const last = state.itemsList[state.itemsList.length - 1];\n    const rightOffset = last.getBoundingClientRect().right - menubar.value.getBoundingClientRect().right;\n    state.hideControlGradient = rightOffset < 48;\n}\n\nfunction getScrollItem(dir) {\n    const bounds = menubar.value.getBoundingClientRect();\n    if (dir === 'right') {\n        return state.itemsList.find(item => item.getBoundingClientRect().right > bounds.right);\n    }\n    if (dir === 'left') {\n        for (let i = state.itemsList.length - 2; i >= 0; i--) {\n            const left = state.itemsList[i].getBoundingClientRect().left;\n            if (left < bounds.left) return state.itemsList[i + 1];\n        }\n        return state.itemsList[0];\n    }\n}\n\nfunction scrollMenu(reverse) {\n    const current = menubar.value.scrollLeft;\n    const target = reverse ? getScrollItem('left') : getScrollItem('right');\n    if (target) {\n        const offset = target.getBoundingClientRect().left - menubar.value.getBoundingClientRect().left;\n        smoothScrollTo(menubar.value, 'horizontal', current + offset, 300);\n    }\n}\n\nfunction updateOpenedMenu() {\n    const item = items[activeIndex.value];\n    if (!item || props.mode === 'horizontal') return;\n    nextTick(() => {\n        (item.indexPath || []).forEach(i => {\n            if (submenus[i] && !openedMenus.value.includes(i)) {\n                openMenu(i, submenus[i].indexPath);\n            }\n        });\n    });\n}\n\nonMounted(() => {\n    if (props.useRouteMatching) {\n        activeIndex.value = getActiveIndexFromRoute(route);\n    }\n    emit('select', activeIndex.value);\n    nextTick(() => {\n        updateOpenedMenu();\n        scrollToActiveItem();\n        if (props.mode === 'horizontal') updateControls();\n    });\n});\n\nonBeforeUnmount(cancelMenubarScroll);\n\nwatch(() => props.modelValue, val => {\n    activeIndex.value = val;\n    updateOpenedMenu();\n}, { immediate: true });\n\nwatch(() => route, updateActiveIndex, { immediate: true });\n\nwatch(() => Object.keys(items), () => {\n    if (activeIndex.value && items[activeIndex.value]) updateOpenedMenu();\n});\n\nwatchEffect(() => {\n    if (props.defaultOpeneds.length && Object.keys(submenus).length >= props.defaultOpeneds.length && openedMenus.value.length === 0) {\n        openedMenus.value = [...props.defaultOpeneds];\n    }\n});\n\nprovide('menuContext', {\n    type: props.type,\n    mode: computed(() => props.mode),\n    collapse: computed(() => props.collapse),\n    activeIndex,\n    openedMenus,\n    items,\n    submenus,\n    addItem: (item) => items[item.index] = item,\n    removeItem: (item) => delete items[item.index],\n    addSubmenu: (item) => submenus[item.index] = item,\n    removeSubmenu: (item) => delete submenus[item.index],\n    openMenu,\n    closeMenu,\n    handleItemClick,\n    handleSubmenuClick,\n});\n</script>\n\n<style lang=\"postcss\">\n/* TODO: scoped */\n.el-menu {\n    &__bar {\n        width: 100%;\n        position: relative;\n        margin: 0;\n        padding: 0;\n        overflow: hidden;\n        white-space: nowrap;\n        list-style: none;\n        flex-shrink: 1;\n        li {\n            list-style: none;\n        }\n        &__icon {\n            line-height: 0;\n        }\n    }\n    .el-menu-item,\n    .el-submenu__item {\n        overflow: hidden;\n        text-overflow: ellipsis;\n        white-space: nowrap;\n        -webkit-user-select: none;\n        user-select: none;\n        cursor: pointer;\n        outline: 0;\n        &.is-active {\n            cursor: default;\n        }\n    }\n\n    &--horizontal {\n        display: flex;\n        box-shadow: 0 -1px 0 0 var(--av-brand-light) inset;\n        .el-menu-item {\n            @mixin body;\n            border: none;\n            background-color: transparent;\n            outline: none;\n            cursor: pointer;\n            border-radius: 4px;\n            position: relative;\n            padding: 0 8px;\n            display: inline-flex;\n            transition: transform 0.5s ease;\n            overflow: visible;\n            align-items: center;\n            height: 32px;\n            flex: 0 0 auto;\n            color: var(--av-fixed-primary);\n            font-weight: 600;\n            letter-spacing: 0.3px;\n            &:hover {\n                background-color: var(--av-brand-secondary-hover);\n            }\n            &.is-focus {\n                background-color: var(--av-fixed-focus);\n            }\n            &.is-active {\n                cursor: default;\n                background-color: var(--av-brand-secondary-active);\n                .el-active-indicator {\n                    position: absolute;\n                    display: block;\n                    bottom: -16px;\n                    left: 8px;\n                    width: calc(100% - 16px);\n                    border-bottom: var(--av-border-md) var(--av-brand-secondary);\n                }\n            }\n            &.is-disabled {\n                cursor: default;\n                color: var(--av-fixed-lighter);\n                pointer-events: none;\n            }\n            &:not(:disabled).is-active {\n                background: transparent;\n            }\n            &:not(:disabled).is-selected {\n                background-color: var(--av-brand-secondary-active);\n            }\n            &:not(:first-child) {\n                margin-inline-start: 16px;\n            }\n            & > .el-tag {\n                border-radius: 8px;\n                display: flex;\n                flex-direction: column;\n                justify-content: center;\n                align-items: flex-start;\n                width: 23px;\n                height: 16px;\n                .el-tag__text {\n                    display: flex;\n                    align-items: flex-start;\n                    justify-content: center;\n                    overflow: unset;\n                }\n            }\n        }\n        &.is-borderBottom {\n            box-shadow: none;\n        }\n        &.is-fixed-white {\n            background-color: var(--av-inversed-primary);\n        }\n        &.is-nav-primary {\n            background-color: var(--av-nav-primary);\n        }\n        .el-menu__bar {\n            margin: 0 16px;\n            height: 64px;\n            display: flex;\n            align-items: center;\n        }\n        .el-menu__controls {\n            position: relative;\n            display: flex;\n            align-items: center;\n            justify-content: space-around;\n            outline-style: none;\n            height: 64px;\n            width: 128px;\n            :before {\n                content: \"\";\n                position: absolute;\n                inset-inline-start: -48px;\n                pointer-events: none;\n                top: 0;\n                height: calc(100% - 1px);\n                width: 48px;\n                background: linear-gradient(\n                    to right,\n                    transparent,\n                    var(--av-inversed-primary) 59%\n                );\n            }\n            &.is-no-gradient:before {\n                display: none;\n            }\n            &-divider {\n                width: var(--av-border-width-sm);\n                background-color: var(--av-brand-light);\n                height: 24px;\n            }\n        }\n    }\n\n    &--vertical {\n        max-width: 100%;\n        vertical-align: middle;\n        .is-multiline {\n            white-space: normal;\n            line-height: 20px;\n        }\n        &.is-fixed-white {\n            &.el-menu--primary,\n            &.el-menu--secondary,\n            &.el-menu--tertiary {\n                background-color: var(--av-inversed-primary);\n            }\n        }\n        &.is-nav-primary {\n            &.el-menu--primary,\n            &.el-menu--secondary,\n            &.el-menu--tertiary {\n                background-color: var(--av-nav-primary);\n            }\n        }\n        &.is-hide-all-borders {\n            &.el-menu--primary,\n            &.el-menu--secondary,\n            &.el-menu--tertiary {\n                .el-menu__bar > li {\n                    border-top: none;\n                    box-shadow: none;\n                }\n            }\n        }\n\n        .el-menu-item,\n        .el-submenu__item {\n            padding: 8px 16px;\n            display: flex;\n            align-items: center;\n            min-height: 48px;\n            &:before {\n                content: \"\";\n                display: inline-block;\n                height: 32px;\n                width: 0;\n            }\n        }\n\n        .el-menu-item__content,\n        .el-submenu__item__content {\n            width: 100%;\n            overflow: hidden;\n        }\n\n        &.el-menu--primary {\n            .el-menu-item,\n            .el-submenu__item {\n                color: var(--av-inversed-primary);\n                .el-menu__bar-icon {\n                    padding-right: 16px;\n                }\n                &:not(.is-active).is-focus {\n                    background-color: var(--av-inversed-lightest);\n                }\n                &:not(.is-active):hover {\n                    background-color: var(--av-inversed-lightest);\n                }\n                &:not(.is-active):active {\n                    background-color: var(--av-nav-secondary);\n                }\n            }\n            .is-root {\n                .el-menu-item,\n                .el-submenu__item {\n                    font-weight: 600;\n                    letter-spacing: 0.3px;\n                    min-height: 64px;\n                    padding-top: 16px;\n                    padding-bottom: 16px;\n                }\n            }\n            .el-menu-item.is-active {\n                background-color: var(--av-nav-secondary);\n                color: var(--av-inversed-primary);\n            }\n            .el-submenu__arrow {\n                display: none;\n            }\n\n            .el-menu__bar--level-1 {\n                .el-menu-item,\n                .el-submenu__item,\n                .el-menu-group__title {\n                    padding-left: 16px;\n                }\n            }\n            .el-menu__bar--level-2 {\n                .el-menu-item,\n                .el-submenu__item,\n                .el-menu-group__title {\n                    padding-left: 64px;\n                }\n            }\n            .el-menu__bar--level-3 {\n                .el-menu-item,\n                .el-submenu__item,\n                .el-menu-group__title {\n                    padding-left: 112px;\n                }\n            }\n            .el-menu__bar--level-4 {\n                .el-menu-item,\n                .el-submenu__item,\n                .el-menu-group__title {\n                    padding-left: 160px;\n                }\n            }\n            .el-menu__bar--level-5 {\n                .el-menu-item,\n                .el-submenu__item,\n                .el-menu-group__title {\n                    padding-left: 208px;\n                }\n            }\n        }\n        &.el-menu--secondary,\n        &.el-menu--tertiary {\n            .el-menu-item,\n            .el-submenu__item {\n                font-weight: 600;\n                vertical-align: baseline;\n                color: var(--av-brand-primary);\n                padding-left: 48px;\n                background-clip: padding-box;\n                .el-text {\n                    color: var(--av-brand-primary);\n                }\n                .el-menu__bar-icon {\n                    display: block;\n                    color: var(--av-brand-primary);\n                    padding-right: 16px;\n                    i {\n                        display: block;\n                    }\n                }\n                &__right-icon {\n                    color: var(--av-brand-primary);\n                }\n                &.is-focus,\n                &:focus {\n                    background-color: var(--av-fixed-focus);\n                }\n                &.is-disabled {\n                    pointer-events: none;\n                    color: var(--av-fixed-light);\n                    .el-menu__bar-icon {\n                        color: var(--av-fixed-lighter);\n                    }\n                    .el-menu-item__right-icon {\n                        color: var(--av-brand-light);\n                    }\n                }\n                &:hover {\n                    background-color: var(--av-brand-accent);\n                }\n                &:active {\n                    background-color: var(--av-brand-lightest);\n                }\n                &.is-root {\n                    min-height: 64px;\n                    padding-top: 16px;\n                    padding-bottom: 16px;\n                }\n                &.is-active {\n                    color: var(--av-fixed-primary);\n                }\n            }\n            .el-submenu__item {\n                .is-root {\n                    min-height: 63px;\n                    padding-top: 16px;\n                    padding-bottom: 16px;\n                    &:hover {\n                        background-color: var(--av-inversed-primary);\n                    }\n                    &:focus {\n                        background-color: var(--av-inversed-primary);\n                    }\n                }\n            }\n            &.el-menu--without-submenus {\n                .el-menu-item {\n                    padding-inline-start: 24px;\n                }\n            }\n            .el-menu__bar {\n                padding-bottom: 1px;\n                & > li {\n                    border-top: 1px var(--av-brand-accent);\n                    &:first-child {\n                        min-height: 63px;\n                        border-top: none;\n                    }\n                    &:last-child {\n                        box-shadow: 0 1px 0 0 var(--av-brand-accent);\n                    }\n                }\n            }\n            .el-submenu__arrow {\n                color: var(--av-brand-primary);\n                margin-right: 16px;\n                width: 16px;\n                margin-left: -32px;\n                right: auto;\n            }\n            .is-opened > .el-submenu__item .el-submenu__arrow:before {\n                transform: rotate(90deg);\n            }\n            .el-menu__bar--level-1 {\n                .el-menu-item,\n                .el-submenu__item,\n                .el-menu-group__title {\n                    padding-left: 56px;\n                }\n            }\n            .el-menu__bar--level-2 {\n                .el-menu-item,\n                .el-submenu__item,\n                .el-menu-group__title {\n                    padding-left: 88px;\n                }\n            }\n            .el-menu__bar--level-3 {\n                .el-menu-item,\n                .el-submenu__item,\n                .el-menu-group__title {\n                    padding-left: 120px;\n                }\n            }\n            .el-menu__bar--level-4 {\n                .el-menu-item,\n                .el-submenu__item,\n                .el-menu-group__title {\n                    padding-left: 152px;\n                }\n            }\n            .el-menu__bar--level-5 {\n                .el-menu-item,\n                .el-submenu__item,\n                .el-menu-group__title {\n                    padding-left: 184px;\n                }\n            }\n        }\n\n        &.el-menu--tertiary {\n            .el-menu-item {\n                padding-top: 12px !important;\n                padding-bottom: 12px !important;\n                padding-right: 24px;\n                &__title {\n                    font-weight: 400 !important;\n                    line-height: 24px;\n                    color: var(--av-fixed-primary);\n                }\n                &__content {\n                    line-height: 0 !important;\n                }\n            }\n            .el-menu__bar-icon {\n                padding-right: 16px !important;\n            }\n        }\n\n        .multiline-limit--2 {\n            .el-menu-item__title {\n                overflow: hidden;\n                display: -webkit-box;\n                line-clamp: 2;\n                -webkit-line-clamp: 2;\n                -webkit-box-orient: vertical;\n            }\n        }\n        .multiline-limit--3 {\n            .el-menu-item__title {\n                overflow: hidden;\n                display: -webkit-box;\n                line-clamp: 3;\n                -webkit-line-clamp: 3;\n                -webkit-box-orient: vertical;\n            }\n        }\n        .multiline-limit--4 {\n            .el-menu-item__title {\n                overflow: hidden;\n                display: -webkit-box;\n                line-clamp: 4;\n                -webkit-line-clamp: 4;\n                -webkit-box-orient: vertical;\n            }\n        }\n        .multiline-limit--5 {\n            .el-menu-item__title {\n                overflow: hidden;\n                display: -webkit-box;\n                line-clamp: 5;\n                -webkit-line-clamp: 5;\n                -webkit-box-orient: vertical;\n            }\n        }\n    }\n}\n</style>\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <transition\n        name=\"el-loading-fade\"\n        @after-leave=\"handleAfterLeave\"\n    >\n        <div\n            v-show=\"visible\"\n            class=\"el-loading\"\n            :class=\"{ 'is-fullscreen': fullscreen }\"\n        >\n            <div\n                class=\"el-loading__backdrop\"\n                :style=\"`opacity: ${opacity || 1}`\"\n                :class=\"{ [`el-loading__backdrop--color-${background}`]: !!background }\"\n            />\n            <div class=\"el-loading__content\">\n                <el-spinner\n                    :color=\"color || 'brand-secondary'\"\n                    :size=\"size || 16\"\n                />\n                <div\n                    v-if=\"text\"\n                    class=\"el-loading__text\"\n                >\n                    <span\n                        :class=\"{ [`el-loading__text--color-${textColor}`]: !!textColor }\"\n                    >\n                        {{ text }}\n                    </span>\n                </div>\n            </div>\n        </div>\n    </transition>\n</template>\n\n<script setup>\nimport ElSpinner from '@core/components/spinner/spinner.vue';\n\nconst emit = defineEmits(['after-leave']);\n\ndefineProps({\n    visible: { type: Boolean, default: true },\n    fullscreen: { type: Boolean, default: false },\n    background: { type: String, default: '' },\n    opacity: { type: Number, default: 1 },\n    color: { type: String, default: 'brand-primary' },\n    size: { type: [Number, String], default: 16 },\n    text: { type: String, default: '' },\n    textColor: { type: String, default: 'fixed-primary' },\n});\n\n\nfunction handleAfterLeave() {\n    emit('after-leave');\n}\n</script>\n\n<style scoped lang=\"postcss\">\n.el-loading {\n    line-height: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    position: absolute;\n    top: 0px;\n    right: 0px;\n    bottom: 0px;\n    left: 0px;\n    z-index: 9999;\n    border-radius: inherit;\n    box-sizing: border-box;\n    * {\n        box-sizing: border-box;\n    }\n    &__content {\n        text-align: center;\n    }\n    &__backdrop {\n        background-color: transparent;\n        position: absolute;\n        top: 0px;\n        right: 0px;\n        bottom: 0px;\n        left: 0px;\n        border-radius: inherit;\n        &--color {\n            &-inversed-secondary {\n                background-color: var(--av-inversed-secondary);\n            }\n            &-solid-brand-ightest {\n                opacity: 0.95;\n                background-color: var(--av-solid-brand-lightest);\n            }\n            &-brand-lightest {\n                background-color: var(--av-brand-lightest);\n            }\n            &-brand-accent {\n                background-color: var(--av-brand-accent);\n            }\n            &-brand-primary {\n                background-color: var(--av-brand-primary);\n            }\n            &-brand-light {\n                background-color: var(--av-brand-light);\n            }\n            &-brand-lighter {\n                background-color: var(--av-brand-lighter);\n            }\n            &-fixed-secondary {\n                background-color: var(--av-fixed-secondary);\n            }\n            &-inversed-primary {\n                background-color: var(--av-inversed-primary);\n            }\n            &-fixed-primary {\n                background-color: var(--av-fixed-primary);\n            }\n            &-fixed-primary, &-fixed-white, &-fixed-secondary {\n                opacity: 0.8;\n            }\n        }\n    }\n    &__text {\n        @mixin body;\n        margin-top: 16px;\n        &--color {\n            &-white {\n                color: var(--av-inversed-primary);\n            }\n            &-fixed-primary {\n                color: var(--av-fixed-primary);\n            }\n            &-fixed-light {\n                color: var(--av-fixed-light);\n            }\n        }\n    }\n}\n\n.el-loading-fade-enter-active,\n.el-loading-fade-leave-active {\n  transition: opacity 0.3s ease;\n}\n\n.el-loading-fade-enter-from,\n.el-loading-fade-leave-to {\n  opacity: 0;\n}\n\n.el-loading-fade-enter-to,\n.el-loading-fade-leave-from {\n  opacity: 1;\n}\n</style>\n","import { createApp } from 'vue';\nimport Loading from './loading.vue';\n\nconst mountedInstances = new WeakMap();\n\nconst defaultProps = {\n    fullscreen: false,\n    background: '',\n    opacity: 1,\n    color: 'brand-primary',\n    size: 16,\n    text: '',\n    textColor: 'fixed-primary',\n};\n\nconst loadingPropKeys = Object.keys(defaultProps);\n\nfunction kebabCase(str) {\n    return str.replace(/([A-Z])/g, '-$1').toLowerCase();\n}\n\nfunction extractPropsFromAttrs(el, fallbackProps = {}) {\n    const props = { ...fallbackProps };\n\n    loadingPropKeys.forEach((key) => {\n        if (props[key] !== undefined) return;\n\n        const attrValue = el.getAttribute(`el-loading-${kebabCase(key)}`);\n        if (attrValue !== null) {\n            const defaultVal = defaultProps[key];\n            if (typeof defaultVal === 'boolean') {\n                props[key] = attrValue === 'true';\n            } else if (typeof defaultVal === 'number') {\n                props[key] = Number(attrValue);\n            } else {\n                props[key] = attrValue;\n            }\n        }\n    });\n\n    return props;\n}\n\nexport default {\n    mounted(el, binding) {\n        const { value } = binding;\n        const active = value === true || (typeof value === 'object' && value.loading);\n        if (!active) return;\n\n        const rawProps = typeof value === 'object' ? { ...value } : {};\n        if ('loading' in rawProps) delete rawProps.loading;\n\n        const props = extractPropsFromAttrs(el, rawProps);\n\n        const app = createApp(Loading, props);\n        const instance = app.mount(document.createElement('div'));\n\n        if (props.fullscreen) {\n            document.body.appendChild(instance.$el);\n        } else {\n            // eslint-disable-next-line no-param-reassign\n            el.style.position = 'relative';\n            el.appendChild(instance.$el);\n        }\n\n        mountedInstances.set(el, { app, el: instance.$el });\n    },\n\n    updated(el, binding) {\n        const prev = mountedInstances.get(el);\n        const isVisible = binding.value === true || binding.value?.loading;\n\n        if (!isVisible && prev) {\n            prev.app.unmount();\n            prev.el.remove();\n            mountedInstances.delete(el);\n            return;\n        }\n\n        if (isVisible) {\n        // Unmount old instance if exists\n            if (prev) {\n                prev.app.unmount();\n                prev.el.remove();\n                mountedInstances.delete(el);\n            }\n\n            // Re-extract props on update\n            const props = extractPropsFromAttrs(el, typeof binding.value === 'object' ? { ...binding.value } : {});\n            if ('loading' in props) delete props.loading;\n\n            const app = createApp(Loading, props);\n            const instance = app.mount(document.createElement('div'));\n\n            if (props.fullscreen) {\n                document.body.appendChild(instance.$el);\n            } else {\n                // eslint-disable-next-line no-param-reassign\n                el.style.position = 'relative';\n                el.appendChild(instance.$el);\n            }\n\n            mountedInstances.set(el, { app, el: instance.$el });\n        }\n    },\n\n    unmounted(el) {\n        const prev = mountedInstances.get(el);\n        if (prev) {\n            prev.app.unmount();\n            prev.el.remove();\n            mountedInstances.delete(el);\n        }\n    },\n};\n","import LoadingComponent from './loading.vue';\nimport vLoading from './loadingDirective';\n\nexport const Loading = {\n    install(app: any) {\n        app.directive('loading', vLoading);\n    },\n    directive: vLoading,\n    component: LoadingComponent,\n};\n\nexport default Loading;\n","import MicroModal from 'micromodal';\nimport commonUtils from '@utils/common.ts';\n\n/**\n * ModalController\n * Internal controller used by the `v-modal` Vue 3 directive.\n *\n * - Attaches click + keypress listeners to the bound element to open a MicroModal instance.\n * - Prevents modal stacking by closing any currently open modal before opening a new one\n *   (required for gallery arrows and playlist navigation).\n * - Temporarily moves the modal element to <body> during display to avoid z-index and\n *   stacking-context issues caused by nested layouts.\n * - Restores the modal to its original DOM position on close.\n * - Handles media lifecycle:\n *     • autoplay/pause/reset for video and audio players\n *     • YouTube iframe play/pause messaging\n * - Emits analytics events (open/close/video interactions) via dataLayer.\n * - Reads modal event metadata from localStorage (set by media components).\n * - Emits Vue-compatible events using vnode.props handlers (works with both\n *   Composition API and Options API consumers).\n */\n\nclass ModalController {\n    constructor(el, id, vnode) {\n        this.el = el;\n        this.id = id;\n        this.vnode = vnode;\n\n        this.events = {};\n        this.startTime = null;\n\n        this.originalParent = null;\n        this.originalNextSibling = null;\n\n        this.isOpening = false;\n        this.openLockTimer = null;\n\n        this.openModal = this.openModal.bind(this);\n        this.closeModal = this.closeModal.bind(this);\n\n        if (this.el && this.id) {\n            this.init();\n        }\n    }\n\n    init() {\n        requestAnimationFrame(() => {\n            this.el.addEventListener('click', this.openModal);\n            this.el.addEventListener('keypress', this.openModal);\n        });\n    }\n\n    update(id, vnode) {\n        this.id = id;\n        this.vnode = vnode;\n    }\n\n    moveModalToBody(modal) {\n        if (!modal || !modal.parentNode) return;\n        this.originalParent = modal.parentNode;\n        this.originalNextSibling = modal.nextSibling;\n        document.body.appendChild(modal);\n    }\n\n    moveModalBack(modal) {\n        if (!modal) return;\n\n        if (this.originalParent && this.originalNextSibling) {\n            this.originalParent.insertBefore(modal, this.originalNextSibling);\n        } else if (this.originalParent) {\n            this.originalParent.appendChild(modal);\n        }\n\n        this.originalParent = null;\n        this.originalNextSibling = null;\n    }\n\n    getCurrentOpenModalId() {\n        const openEl = document.querySelector('.a-modal.is-modal-open');\n        return openEl?.id || null;\n    }\n\n    closeCurrentlyOpenModal() {\n        const openId = this.getCurrentOpenModalId();\n        if (openId && openId !== this.id) {\n            try {\n                MicroModal.close(openId);\n            } catch {\n                // avoid throw\n            }\n        }\n    }\n\n    openModal(e) {\n        if (this.isOpening) return;\n        this.isOpening = true;\n        clearTimeout(this.openLockTimer);\n        this.openLockTimer = setTimeout(() => {\n            this.isOpening = false;\n            this.openLockTimer = null;\n        }, 200);\n\n        e.preventDefault();\n        this.closeCurrentlyOpenModal();\n\n        MicroModal.show(this.id, {\n            openClass: 'is-modal-open',\n            disableFocus: true,\n\n            onShow: (modal) => {\n                document.documentElement.classList.add('is-modal-open');\n                this.keyHandler = (event) => {\n                    if (!modal.querySelector('.a-modal-gallery')) return;\n\n                    if (event.key === 'ArrowLeft') {\n                        const prevBtn = modal.querySelector('.a-modal-gallery .prev');\n                        prevBtn?.click();\n                    }\n\n                    if (event.key === 'ArrowRight') {\n                        const nextBtn = modal.querySelector('.a-modal-gallery .next');\n                        nextBtn?.click();\n                    }\n                };\n                document.addEventListener('keydown', this.keyHandler);\n\n                this.moveModalToBody(modal);\n\n                const closeButtons = modal?.querySelectorAll?.('[data-close]') || [];\n                const youtube = modal?.querySelector?.('.a-youtube');\n                const video = modal?.querySelector?.('.a-modal__video-player');\n                const audio = modal?.querySelector?.('.a-modal__audio-player');\n\n                this.startTime = new Date();\n\n                try {\n                    this.events = JSON.parse(localStorage.getItem('modalEvents'));\n                } catch {\n                    this.events = { open: null, close: null };\n                }\n\n                localStorage.removeItem('modalEvents');\n\n                this.sendEvent({\n                    event: 'Acronis',\n                    eventCategory: 'Interactions',\n                    eventAction: 'Start product tour',\n                    ...this.events?.open,\n                });\n\n                if (closeButtons.length > 0) {\n                    closeButtons.forEach((element) => element.addEventListener('click', this.closeModal));\n                }\n\n                if (video) video.play();\n                if (audio) audio.play();\n\n                if (youtube) {\n                    const ytBaseUrl = (youtube.dataset?.src || '').split('?')[0];\n\n                    this.sendEvent({\n                        event: 'Acronis',\n                        eventAction: 'Video',\n                        eventContext: 'Play',\n                        eventCategory: 'Interactions',\n                        eventLabel: youtube.dataset?.title || ytBaseUrl,\n                    });\n\n                    this.toggleIframe(modal, 'playVideo');\n\n                    if (window.OptanonActiveGroups && window.ytTracker) {\n                        const consentGiven = window.OptanonActiveGroups?.includes('C0002');\n                        if (consentGiven) {\n                            window.ytTracker?.init();\n                        }\n                    }\n                }\n\n                /* If you don't use timer here, it will fire onClose before the onShow when using gallery/playlist modals\n                    * Causing it to enable the scroll again, both with commonUtils and witht he native disableScroll function\n                    */\n                setTimeout(() => {\n                    commonUtils.globalOverflowProperty('hidden');\n                });\n            },\n\n            onClose: (modal) => {\n                document.documentElement.classList.remove('is-modal-open');\n                document.removeEventListener('keydown', this.keyHandler);\n                this.moveModalBack(modal);\n\n                const endTime = new Date();\n                const timeOnDemoText = (s) => {\n                    if (s < 10) return '0–10sec';\n                    if (s < 30) return '11–30sec';\n                    if (s < 60) return '31–60sec';\n                    if (s < 180) return '1-3mins';\n                    if (s < 300) return '3-5mins';\n                    if (s < 600) return '5-10mins';\n                    if (s < 900) return '10-15mins';\n                    if (s < 1200) return '15-20mins';\n                    if (s < 1800) return '20-30mins';\n                    return '30+ minutes';\n                };\n\n                this.sendEvent({\n                    event: 'Acronis',\n                    eventCategory: 'Interactions',\n                    eventAction: 'Start product tour',\n                    eventContext: timeOnDemoText((endTime - this.startTime) / 1000),\n                    ...this.events?.close,\n                });\n\n                const closeButtons = modal?.querySelectorAll?.('[data-close]') || [];\n                const video = modal?.querySelector?.('.a-modal__video-player');\n                const audio = modal?.querySelector?.('.a-modal__audio-player');\n\n                if (closeButtons.length > 0) {\n                    closeButtons.forEach((element) => element.removeEventListener('click', this.closeModal));\n                }\n\n                if (video) {\n                    video.pause();\n                    video.currentTime = 0;\n                }\n\n                if (audio) {\n                    audio.pause();\n                    audio.currentTime = 0;\n                }\n\n                this.toggleIframe(modal, 'pauseVideo');\n                this.emit('close', this.el);\n                commonUtils.globalOverflowProperty('auto');\n            },\n        });\n    }\n\n    closeModal(e) {\n        e.preventDefault();\n        e.stopPropagation?.();\n        MicroModal.close(this.id);\n    }\n\n    toggleIframe(modal, func) {\n        const youtube = modal?.querySelector?.('.a-youtube');\n\n        if (!youtube) return false;\n\n        if (!youtube.src) {\n            youtube.src = youtube.dataset?.src;\n        }\n\n        youtube?.contentWindow?.postMessage?.(\n            `{\"event\":\"command\",\"func\":\"${func}\",\"args\":\"\"}`,\n            '*',\n        );\n\n        return true;\n    }\n\n    sendEvent(event) {\n        if (typeof event !== 'object') return;\n\n        window.dataLayer = window.dataLayer || [];\n        window.dataLayer.push(event);\n    }\n\n    emit(name, data) {\n        const props = this.vnode?.props || {};\n        const handler =\n            props[`on${name.charAt(0).toUpperCase()}${name.slice(1)}`] ||\n            props[`on${name}`] ||\n            null;\n\n        if (typeof handler === 'function') {\n            handler(data);\n        }\n    }\n\n    destroy() {\n        this.el.removeEventListener('click', this.openModal);\n        this.el.removeEventListener('keypress', this.openModal);\n        clearTimeout(this.openLockTimer);\n    }\n}\n\nconst controllers = new WeakMap();\nexport default {\n    mounted(el, binding, vnode) {\n        if (!binding?.value) return;\n\n        const controller = new ModalController(el, binding.value, vnode);\n        controllers.set(el, controller);\n    },\n\n    updated(el, binding, vnode) {\n        if (!binding?.value) return;\n\n        controllers.get(el)?.update(binding.value, vnode);\n    },\n\n    unmounted(el) {\n        const controller = controllers.get(el);\n\n        if (controller) {\n            controller.destroy();\n            controllers.delete(el);\n        }\n    },\n};\n","<template>\n    <div\n        :id=\"id\"\n        class=\"a-modal\"\n        :class=\"className\"\n        :aria-hidden=\"true\"\n        v-bind=\"$attrs\"\n    >\n        <div\n            class=\"a-modal__wrapper\"\n            role=\"dialog\"\n            aria-modal=\"true\"\n            :class=\"{'is-visible': showElement}\"\n        >\n            <div\n                class=\"a-modal__overlay\"\n                v-bind=\"isOverlayClose ? { 'data-close': true } : {}\"\n                @click=\"toggleElements\"\n            />\n            <div class=\"a-modal__content\">\n                <div\n                    v-if=\"isScreenshot\"\n                    v-loading=\"true\"\n                    el-loading-text=\"Image is loading\"\n                    el-loading-color=\"inversed-primary\"\n                    el-loading-size=\"48\"\n                    class=\"loader\"\n                />\n                <div class=\"a-modal__inner\">\n                    <slot />\n                    <a-button\n                        data-close\n                        class=\"close\"\n                        glyph=\"close\"\n                        aria-label=\"Close modal\"\n                    />\n                </div>\n            </div>\n            <div v-if=\"$slots.playlist\" class=\"playlist\">\n                <slot name=\"playlist\" />\n            </div>\n            <div v-if=\"$slots.gallery\" class=\"gallery\">\n                <slot name=\"gallery\" />\n            </div>\n            <a-button\n                data-close\n                class=\"close-mobile\"\n                :class=\"{'show': showElement}\"\n                glyph=\"close\"\n                aria-label=\"Close modal\"\n            />\n        </div>\n    </div>\n</template>\n\n<script setup>\nimport { computed, ref } from 'vue';\nimport AButton from '@core/components/button/button.vue';\nimport { Loading } from '@core/components/loading';\nimport Modal from '@core/directives/modal.js';\n\ndefineOptions({\n    name: 'AModal',\n    directives: {\n        Modal,\n        loading: Loading.directive,\n    },\n    inheritAttrs: false,\n});\n\n\nconst props = defineProps({\n    type: { type: String, default: 'modal' },\n    id: { type: String, required: true },\n    isOverlayClose: { type: Boolean, default: false },\n});\n\nconst showElement = ref(true);\nconst isScreenshot = computed(() => ['screenshot', 'gallery'].includes(props.type));\nconst className = computed(() => ({ [`type_${props.type}`]: props.type }));\n\nfunction toggleElements() {\n    if (props.isOverlayClose || props.type !== 'gallery') {\n        showElement.value = true;\n        return;\n    }\n    showElement.value = !showElement.value;\n}\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-modal {\n    display: none;\n    position: fixed;\n    z-index: 2147483650; /* this must be on top of geoIP popup which has z-index: 2147483647 because cookie popup has z-index: 2147483645 */\n    &.is-modal-open {\n        display: block;\n    }\n    &__wrapper {\n        position: fixed;\n        top: 0;\n        inset-inline-start: 0;\n        inset-inline-end: 0;\n        bottom: 0;\n        min-width: 100vw;\n        min-height: 100vh;\n        overflow: auto;\n        user-select: none;\n        background: var(--av-fixed-secondary);\n        padding: 48px 16px;\n        @media (--viewport-mobile-wide) {\n            padding: 48px 32px;\n        }\n        @media (--viewport-desktop) {\n            padding: 48px;\n        }\n        .gallery {\n            display: none;\n            @media (--viewport-tablet) {\n                display: block;\n            }\n        }\n    }\n    &__overlay {\n        position:absolute;\n        top: 0;\n        inset-inline-start: 0;\n        width: 100%;\n        height: 100%;\n        z-index: 0;\n        cursor: default;\n    }\n    &__content {\n        display: flex;\n        flex-direction: column;\n        height: 100%;\n        align-items: center;\n        justify-content: center;\n        @media (--viewport-desktop) {\n            @mixin colls 10;\n            margin: 0 auto;\n        }\n        :deep(> video, > picture) {\n            position: absolute;\n            max-width: 100%;\n            max-height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n        .a-modal__inner {\n            position: relative;\n            max-width: 100%;\n            max-height: 100%;\n            :deep(.a-picture) {\n                height: 100%;\n                transform: none !important;\n            }\n            :deep(video) {\n                max-height: 100%;\n                max-width: 100%;\n            }\n        }\n    }\n    .close, .close-mobile {\n        border: 1px solid var(--av-inversed-primary);\n        border-radius: 50%;\n        padding: 8px;\n        transition: all 0.3s;\n        &:hover {\n            background: var(--av-fixed-secondary);\n        }\n        :deep(.a-glyph) {\n            margin: 0;\n            fill: var(--av-inversed-primary);\n        }\n    }\n    .close-mobile {\n        display: flex;\n        position: absolute;\n        top: 8px;\n        inset-inline-end: 8px;\n        @media (--viewport-desktop) {\n            display: none;\n        }\n    }\n    .close {\n        display: none;\n        position: absolute;\n        top: 0;\n        inset-inline-end: -48px;\n        @media (--viewport-desktop) {\n            display: flex;\n        }\n    }\n    &.type_modal {\n        .a-modal__wrapper {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        .a-modal__content {\n            margin: auto 0;\n            height: auto;\n        }\n        .a-modal__inner {\n            width: 100%;\n        }\n    }\n    &.type_playlist, &.type_youtube {\n        :deep(.a-youtube--modal) {\n            aspect-ratio: 16 / 9;\n            width: 100%;\n            height: auto;\n            max-height: 100%;\n            max-width: 100%;\n            top: 50%;\n            inset-inline-start: 50%;\n            transform: translate(-50%, -50%);\n            @media (--viewport-desktop) {\n                height: 100%;\n                width: auto;\n            }\n        }\n        .a-modal__inner {\n            width: 100%;\n            height: 100%;\n        }\n    }\n    &.type_playlist {\n        .a-modal__content {\n            :deep(.a-youtube--modal) {\n                @media (--viewport-tablet) {\n                    height: 100%;\n                }\n            }\n            height: calc(100% - 230px);\n            @media (--viewport-mobile-wide) {\n                height: calc(100% - 216px);\n            }\n            @media (--viewport-tablet) {\n                height: calc(100% - 168px);\n            }\n            @media (--viewport-desktop) {\n                height: calc(100% - 144px);\n            }\n            @media (--viewport-desktop-wide) {\n                height: calc(100% - 120px);\n            }\n        }\n        .playlist {\n            width: 100%;\n            margin-top: 32px;\n            @media (--viewport-mobile-wide) {\n                margin-top: 40px;\n            }\n            @media (--viewport-desktop) {\n                @mixin colls 10;\n                margin: 40px auto 0;\n            }\n        }\n    }\n    &.type_screenshot, &.type_gallery {\n        .a-modal__content {\n            @mixin colls 12;\n            .loader {\n                position: absolute !important;\n                z-index: 0;\n                pointer-events: none;\n                :deep(.el-loading__text) {\n                    display: block;\n                    padding-top:16px;\n                    width: 250px;\n                    color: var(--av-inversed-primary);\n                    opacity: 0.7;\n                }\n            }\n        }\n        :deep(.a-picture) {\n            box-shadow: var(--av-shadow-modal);\n            width: 100%;\n            height: 100%;\n        }\n        .a-modal__wrapper {\n            padding: 16px;\n            @media (--viewport-mobile-wide) {\n                padding: 16px;\n            }\n            @media (--viewport-tablet) {\n                padding: 48px 32px;\n            }\n            @media (--viewport-desktop-wide) {\n                padding: 48px;\n            }\n        }\n        .close-mobile {\n            background: var(--av-fixed-secondary);\n            @media (--viewport-tablet) {\n                background: transparent;\n                &:hover {\n                    background: var(--av-fixed-secondary);\n                }\n            }\n            @media (--viewport-desktop) {\n                display: flex;\n            }\n            @media (--viewport-desktop-wide) {\n                top: 16px;\n                inset-inline-end: 16px;\n            }\n        }\n        .close {\n            display: none;\n        }\n    }\n    &.type_gallery {\n        .a-modal__wrapper {\n            @media (--viewport-tablet) {\n                padding-bottom: 0;\n            }\n            .close-mobile {\n                display: none;\n                @media (--viewport-tablet) {\n                    display: flex;\n                }\n            }\n            &.is-visible {\n                .close-mobile {\n                    display: flex;\n                }\n                .gallery {\n                    display: block;\n                }\n            }\n        }\n        .a-modal__content {\n            @media (--viewport-tablet) {\n                height: calc(100% - 144px);\n            }\n        }\n    }\n}\n[dir='rtl'] {\n    .a-