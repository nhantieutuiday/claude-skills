d === 'function' &&\n          !isWithinRemoteDecouncePeriod.value && !props.scrollLoading && !props.isScrollEnd) {\n        const scrollWrapEl = dropdownRef.value.$el.querySelector('.el-select-dropdown__wrap');\n        const { scrollTop, clientHeight, scrollHeight } = scrollWrapEl;\n        if (scrollHeight - scrollTop - clientHeight <= 15 && !props.isScrollEnd) {\n            props.remoteScrollMethod(query.value);\n        }\n    }\n};\n\nfunction getValueIndex(arr = [], value) {\n    const isObject = Object.prototype.toString.call(value).toLowerCase() === '[object object]';\n    return isObject\n        ? arr.findIndex(item => isEqual(item, value))\n        : arr.indexOf(value);\n};\n\nfunction handleAllClick() {\n    if (!options.value[0].isSelected) {\n        const newValue = options.value.slice(1).map((option) => option[props.valueKey]);\n\n        changeValue(newValue);\n        syncSelectAllOption(options.value);\n        updateMultipleSelected();\n    } else {\n        changeValue([]);\n        syncSelectAllOption(false);\n        updateMultipleSelected();\n    }\n};\n\nfunction deleteSelected(event) {\n    if (!isClearable.value) return;\n\n    const initialValue = props.multiple ? [] : '';\n    event.stopPropagation();\n    changeValue(initialValue);\n    emit('clear');\n    resetHoverState();\n    if (props.multiple) updateMultipleSelected();\n}\n\nfunction handleRemoteScrollReset() {\n    if (!props.remote) return;\n    nextTick(() => {\n        scrollbar.value?.updateScrollPosition?.();\n    });\n}\n\nfunction maybeCheckDefaultFirstOption() {\n    if (\n        props.defaultFirstOption &&\n    (props.filterable || props.remote) &&\n    filteredOptionsCount.value\n    ) {\n        setDefaultHoverIndex(hoverIndex, options.value, query.value);\n    }\n}\n\nfunction selectOption() {\n    if (!visible.value || isTouchScrolling.value) return;\n\n    const isSingle = !props.multiple;\n\n    let option = options.value[hoverIndex.value];\n\n    if (!option && isSingle && selected.value) {\n        option = selected.value;\n    }\n\n    if (!option || !option.visible || option.disabled || option.groupDisabled) return;\n\n    handleOptionSelect(option);\n\n    if (isSingle) {\n        closeDropdown({ preserveHover: false });\n    }\n}\n\nfunction handleOptionSelect(option) {\n    if (props.selectAll && option === options.value[0]) return;\n\n    if (props.multiple) {\n        const value = props.modelValue.slice();\n        const idx = getValueIndex(value, option.value);\n        if (idx > -1) value.splice(idx, 1);\n        else if (props.multipleLimit <= 0 || value.length < props.multipleLimit) value.push(option.value);\n\n        changeValue(value);\n        if (option.created) {\n            query.value = '';\n            handleQueryChange('');\n        }\n    } else {\n        keyboardNavigate.value = false;\n        changeValue(option.value);\n    }\n\n    if (props.showSelectedIcon && option.icon) {\n        selectedIcon.value = option.icon;\n        selectedIconColor.value = option.iconColor;\n    }\n\n    nextTick(() => scrollToOption(option));\n    elFormItem?.markAsFocused?.();\n}\n\nfunction syncSelectAllOption(val) {\n    if (!props.selectAll || !val.length) return;\n\n    const isAllSelected = val.length - 1 === props.modelValue.length;\n    // eslint-disable-next-line no-param-reassign\n    val[0].isSelected = isAllSelected;\n}\n\nfunction registerOption(option) {\n    cacheDropdownScroll();\n    if (!cachedOptions.value.some(opt => isEqual(opt.value, option.value))) {\n        cachedOptions.value.push(option);\n    }\n    options.value.push(option);\n    optionsCount.value++;\n    filteredOptionsCount.value++;\n    setSelected();\n}\n\nfunction unregisterOption(option) {\n    cacheDropdownScroll();\n    const index = options.value.indexOf(option);\n    if (index !== -1) {\n        optionsCount.value--;\n        filteredOptionsCount.value--;\n        options.value.splice(index, 1);\n    }\n}\n\nfunction handleOptionsRemoval(val) {\n    if (!props.changeOnOptionsRemoval || props.remote) return;\n\n    if (props.multiple) {\n        const newValue = val\n            .filter(option => props.modelValue.some(el => isEqual(el, option.value)))\n            .map(option => option.value);\n\n        changeValue(newValue);\n    } else {\n        const stillExists = val.some(option => isEqual(props.modelValue, option.value));\n        if (!stillExists) {\n            changeValue('');\n            emit('clear');\n        }\n    }\n}\n\nfunction toggleDropdown() {\n    if (visible.value || props.showDropdown) {\n        receiveScrollTop();\n        setScrollPosition();\n    }\n\n    if (!props.disabled) {\n        if (visible.value) {\n            closeDropdown({ preserveHover: false });\n        } else {\n            openDropdown();\n        }\n    }\n}\n\nfunction openDropdown() {\n    if (props.disabled || visible.value) return;\n    visible.value = true;\n    emit('update:showDropdown', true);\n\n\n    if (props.filterable) {\n        handleQueryChange(query.value, true);\n        if (props.remote) {\n            searchUnchangedSinceOpen.value = true;\n            previousSelected.value = selected.value;\n        }\n    }\n\n    nextTick(async () => {\n        resetHoverState();\n        maybeCheckDefaultFirstOption();\n        await initializePopper();\n        requestAnimationFrame(() => {\n            handleDropdownEnter();\n            updatePopper();\n            bindWrapListeners();\n            dropdownRef.value?.$el?.querySelector('.el-input__editor')?.focus?.({ preventScroll: true });\n        });\n    });\n\n    emit('visible-change', true);\n}\n\n/**\n * Closes the dropdown.\n * @param {Object} options\n * @param {boolean} options.blur - Whether to trigger blur events.\n * @param {boolean} options.preserveHover - Keep the current hover state (used in Enter key handling).\n */\nfunction closeDropdown({ blur = true, preserveHover = false } = {}) {\n    if (props.showDropdown || !visible.value) return;\n\n    unbindWrapListeners();\n\n    requestAnimationFrame(() => {\n        visible.value = false;\n        keyboardNavigate.value = false;\n        emit('update:showDropdown', false);\n\n        query.value = '';\n        selectedLabel.value = '';\n\n        if (props.filterable) {\n            handleQueryChange(query.value, false);\n        }\n\n        if (!props.multiple && selected.value) {\n            selectedLabel.value =\n      props.filterable && createdSelected.value\n          ? createdLabel.value\n          : selected.value.currentLabel;\n        }\n\n        nextTick(() => {\n            cacheDropdownScroll();\n            triggerRef.value?.$el?.querySelector('.el-input__editor')?.focus?.({ preventScroll: true });\n            if (!preserveHover) resetHoverState();\n        });\n    });\n\n    if (blur) handleBlur();\n\n    emit('visible-change', false);\n}\n\nwatch([options, () => props.modelValue], () => {\n    setSelected();\n});\n\nwatch(() => props.placeholder, (val) => {\n    cachedPlaceHolder.value = currentPlaceholder.value || val;\n});\n\nwatch(() => props.placeholderIcon, (val) => {\n    selectedIcon.value = val;\n});\n\nwatch(() => props.showDropdown, (val) => {\n    if (val && !visible.value) {\n        openDropdown();\n    } else if (!val && visible.value) {\n        unbindWrapListeners();\n        closeDropdown({ blur: false });\n    }\n});\n\n\nwatch(() => props.modelValue, (val) => {\n    if (props.remote && props.filterable) {\n        updateValueDeb(val);\n    } else {\n        updateValue(val);\n    }\n});\n\nwatch(() => hoverIndex.value, () => {\n    updateHoverOption(hoverIndex.value, options.value, hoverOption);\n});\n\nwatch(() => options.value, (val) => {\n    handleOptionsRemoval(val);\n    handleRemoteScrollReset();\n    maybeCheckDefaultFirstOption();\n    syncSelectAllOption(val);\n    setSelected();\n});\n\nonMounted(() => {\n    updatePlaceholder(currentPlaceholder.value || props.placeholder);\n    if (props.multiple && !Array.isArray(props.modelValue)) {\n        emit('update:modelValue', []);\n    }\n\n    nextTick(async () => {\n        await initializePopper();\n        updatePopper();\n    });\n\n    if (props.multiple && Array.isArray(props.modelValue) && props.modelValue.length > 0) {\n        updatePlaceholder('');\n    }\n\n    if (props.remote && typeof props.remoteMethod === 'function') {\n        debouncedRemoteMethod();\n    }\n    setSelected();\n    resetHoverState();\n});\n\nonBeforeUnmount(() => {\n    destroyPopper();\n});\n\nprovide('select', {\n    props,\n    selected,\n    query,\n    triggerRef,\n    dropdownRef,\n    selectDropdownMounted,\n    registerOption,\n    unregisterOption,\n    handleOptionClick,\n    updateValue,\n    setSelected,\n    keyboardNavigate,\n    previousSelected,\n    options,\n    cachedOptions,\n    optionsCount,\n    filteredOptionsCount,\n    updatePopper,\n    destroyPopper,\n});\n\ndefineExpose({\n    triggerRef,\n    dropdownRef,\n});\n</script>\n\n<style scoped lang=\"postcss\">\n.el-select {\n    display: flex;\n    cursor: pointer;\n    position: relative;\n    :deep(.el-input__container) {\n        cursor: pointer;\n        .el-input__editor {\n            width: 100%;\n        }\n    }\n}\n\n.el-select-dropdown {\n    @mixin paragraph;\n    position: absolute;\n    z-index: 2100;\n    width: auto;\n    max-width: 100%;\n    font-family: var(--font-family-default);\n    background: var(--av-inversed-primary);\n    border: 1px solid var(--av-brand-primary);\n    box-shadow: var(--av-shadow-regular);\n    color: var(--av-fixed-primary);\n    box-sizing: border-box;\n    border-radius: 4px;\n    margin: 8px 0;\n\n    &__wrap {\n        overflow-y: auto;\n        touch-action: pan-y;\n    }\n\n    &__empty {\n        @mixin body;\n        line-height: 32px;\n        color: var(--av-fixed-light);\n        text-align: center;\n        padding: 16px 24px;\n    }\n\n    &__scroll-loading {\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        padding: 0 16px;\n        position: relative;\n        height: 40px;\n    }\n\n    &__search-count {\n        @mixin caption;\n        color: var(--av-fixed-light);\n        padding: 0 16px;\n        position: relative;\n        height: 40px;\n        box-sizing: border-box;\n        text-align: left;\n    }\n\n    :deep(.el-input) {\n        &__container {\n            border: none;\n        }\n        &__wrapper {\n            padding-top: 0;\n        }\n        &__editor {\n            @mixin body;\n            color: var(--av-fixed-primary);\n        }\n    }\n\n    :deep(.el-select-dropdown__list) {\n        list-style: none;\n        padding: 8px 0;\n        margin: 0;\n        &.is-empty {\n            padding: 0;\n        }\n    }\n\n    :deep(.el-divider) {\n        margin: 0;\n    }\n}\n</style>\n","export enum PaginationTheme {\n    Light = 'Light',\n    Navy = 'Navy',\n}\n","<template>\n    <div ref=\"pagination\" class=\"pagination\" :class=\"cssClasses\">\n        <div v-if=\"isMounted\" class=\"pagination-wrapper\">\n            <div\n                class=\"arrow page-button\"\n                :class=\"{ 'arrow--disabled': leftArrowDisabled }\"\n                @click=\"goPrevPage\"\n            >\n                <a-glyph name=\"arrow-left\" />\n            </div>\n\n            <template v-if=\"!isMobileBrowser && totalPages > maxVisiblePages && firstVisiblePage > 1\">\n                <a\n                    :href=\"getPageURL(1)\"\n                    target=\"_self\"\n                    class=\"page-button\"\n                    @click.stop.prevent=\"selectPage(1)\"\n                >\n                    1\n                </a>\n\n                <template v-if=\"firstVisiblePage > 2 && lowerRange.length > 0\">\n                    <el-select\n                        v-if=\"lowerRange.length > 1\"\n                        ref=\"prevSelect\"\n                        v-model=\"selectedPage\"\n                        name=\"page-lower-range\"\n                        class=\"page-button\"\n                        popper-class=\"pagination-dropdown\"\n                        :popper-max-width=\"popperSize.w\"\n                        :popper-max-height=\"popperSize.h\"\n                        placeholder=\"...\"\n                        custom-hint=\"\"\n                        aria-label=\"More pages\"\n                        @change=\"selectPage(pageNum)\"\n                    >\n                        <el-option\n                            v-for=\"pageNum in lowerRange\"\n                            :key=\"pageNum\"\n                            class=\"page-button range-option\"\n                            :value=\"pageNum\"\n                            force-visible\n                        >\n                            <a :href=\"getPageURL(pageNum)\" @click.prevent=\"selectPage(pageNum)\">\n                                {{ pageNum }}\n                            </a>\n                        </el-option>\n                    </el-select>\n                    <a\n                        v-else\n                        :href=\"getPageURL(lowerRange[0])\"\n                        target=\"_self\"\n                        class=\"page-button\"\n                        @click.stop.prevent=\"selectPage(lowerRange[0])\"\n                    >\n                        {{ lowerRange[0] }}\n                    </a>\n                </template>\n            </template>\n\n            <a\n                v-for=\"pageNum in visiblePages\"\n                :key=\"pageNum\"\n                :href=\"getPageURL(pageNum)\"\n                target=\"_self\"\n                class=\"page-button\"\n                :class=\"{ 'page-button--current': pageNum === activePage }\"\n                @click.stop.prevent=\"selectPage(pageNum)\"\n            >\n                {{ pageNum }}\n            </a>\n\n            <template v-if=\"!isMobileBrowser && currentPage !== totalPages && lastVisiblePage !== totalPages\">\n                <template v-if=\"lastVisiblePage !== totalPages - 1 && upperRange.length > 0\">\n                    <el-select\n                        v-if=\"upperRange.length > 1\"\n                        ref=\"nextSelect\"\n                        v-model=\"selectedPage\"\n                        name=\"page-upper-range\"\n                        class=\"page-button\"\n                        popper-class=\"pagination-dropdown\"\n                        aria-label=\"More pages\"\n                        :popper-max-width=\"popperSize.w\"\n                        :popper-max-height=\"popperSize.h\"\n                        placeholder=\"...\"\n                        @change=\"selectPage(pageNum)\"\n                    >\n                        <el-option\n                            v-for=\"pageNum in upperRange\"\n                            :key=\"pageNum\"\n                            class=\"page-button range-option\"\n                            :value=\"pageNum\"\n                            force-visible\n                        >\n                            <a :href=\"getPageURL(pageNum)\" @click.prevent=\"selectPage(pageNum)\">\n                                {{ pageNum }}\n                            </a>\n                        </el-option>\n                    </el-select>\n                    <a\n                        v-else\n                        :href=\"getPageURL(upperRange[0])\"\n                        target=\"_self\"\n                        class=\"page-button\"\n                        @click.stop.prevent=\"selectPage(upperRange[0])\"\n                    >\n                        {{ upperRange[0] }}\n                    </a>\n                </template>\n\n                <a\n                    :href=\"getPageURL(totalPages)\"\n                    target=\"_self\"\n                    class=\"page-button\"\n                    @click.stop.prevent=\"selectPage(totalPages)\"\n                >\n                    {{ totalPages }}\n                </a>\n            </template>\n\n            <div\n                class=\"arrow arrow--right page-button\"\n                :class=\"{ 'arrow--disabled': rightArrowDisabled }\"\n                @click=\"goNextPage\"\n            >\n                <a-glyph name=\"arrow-left\" />\n            </div>\n        </div>\n        <div v-else class=\"ssr-pagination\">\n            <a\n                v-for=\"pageNum in totalPages\"\n                :key=\"pageNum\"\n                :href=\"getPageURL(pageNum)\"\n                target=\"_self\"\n            >\n                {{ pageNum }}\n            </a>\n        </div>\n    </div>\n</template>\n\n<script lang=\"ts\">\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport ElOption from '@core/components/select/option.vue';\nimport ElSelect from '@core/components/select/select.vue';\nimport breakpoint from '@core/mixins/breakpoint.js';\nimport language from '@core/mixins/language';\nimport commonUtils from '@utils/common';\nimport { PaginationTheme } from './constants.ts';\n\nconst MAX_VISIBLE_PAGES = 5;\nconst PAGES_OFFSET = 2;\n\nexport default {\n    name: 'APagination',\n\n    components: {\n        AGlyph,\n        ElSelect,\n        ElOption,\n    },\n\n    mixins: [breakpoint, language],\n\n    props: {\n        theme: {\n            type: String,\n            validator: (value: string) => !value || PaginationTheme[value],\n            default: PaginationTheme.Light,\n        },\n        totalPages: {\n            type: Number,\n            required: true,\n        },\n        currentPage: {\n            type: Number,\n            required: true,\n            validator: (value: number) => value > 0,\n        },\n        urlTemplate: {\n            type: String,\n            required: true,\n        },\n        scrollTo: {\n            type: Object,\n            default: null,\n        },\n        clickHandler: {\n            type: Function,\n            default: null,\n        },\n        pagesToShow: {\n            type: Number,\n            default: MAX_VISIBLE_PAGES,\n        },\n        disabled: {\n            type: Boolean,\n            default: false,\n        },\n    },\n\n    data: () => ({\n        isMounted: false,\n        isLocked: false,\n        activePage: 0,\n        selectedPage: '',\n    }),\n\n    computed: {\n        isMobileBrowser() {\n            if (typeof window === 'undefined') return !this.isDesktop;\n            const hasTouchSupport = 'ontouchstart' in window || navigator.maxTouchPoints > 0;\n            if (!this.isDesktop) return true;\n            return hasTouchSupport;\n        },\n\n        needFix() {\n            return this.totalPages < this.lastVisiblePage;\n        },\n\n        popperSize() {\n            return { w: '66px', h: '256px' };\n        },\n\n        cssClasses() {\n            return {\n                [`pagination--${this.theme.toLowerCase()}`]: true,\n                'pagination--disabled': this.disabled,\n            };\n        },\n\n        leftArrowDisabled() {\n            return this.activePage === 1;\n        },\n\n        rightArrowDisabled() {\n            return this.activePage === this.totalPages;\n        },\n\n        maxVisiblePages() {\n            return Math.min(this.totalPages, this.pagesToShow);\n        },\n\n        pageOffset() {\n            return Math.min(PAGES_OFFSET, Math.floor(this.pagesToShow / 2));\n        },\n\n        firstVisiblePage() {\n            if (this.totalPages <= this.maxVisiblePages) return 1;\n\n            // hacks for edge cases\n            if (!this.isMobileBrowser) {\n                if (this.activePage >= this.totalPages - this.pageOffset + 2) {\n                    return Math.max(this.activePage - this.pageOffset - 4, 1);\n                }\n\n                if (this.activePage >= this.totalPages - this.pageOffset + 1) {\n                    return Math.max(this.activePage - this.pageOffset - 3, 1);\n                }\n\n                if (this.activePage >= this.totalPages - this.pageOffset) {\n                    return Math.max(this.activePage - this.pageOffset - 2, 1);\n                }\n\n                if (this.activePage >= this.totalPages - this.pageOffset - 1) {\n                    return Math.max(this.activePage - this.pageOffset - 1, 1);\n                }\n            }\n\n            if (this.activePage === this.totalPages) {\n                return Math.max(this.activePage - this.maxVisiblePages + 1, 1);\n            }\n\n            return Math.max(this.activePage - this.pageOffset, 1);\n        },\n\n        lastVisiblePage() {\n            if (this.activePage < this.maxVisiblePages) {\n                if (this.isMobileBrowser) {\n                    return Math.min(this.firstVisiblePage + this.pagesToShow - 1, this.totalPages);\n                }\n                const pagesToShow = this.pagesToShow > this.totalPages - 1 ? this.totalPages - 1 : this.pagesToShow;\n                return Math.min(this.activePage + this.pageOffset + (pagesToShow - this.activePage), this.totalPages);\n            }\n\n            if (this.activePage <= this.maxVisiblePages / 2 + 1) {\n                return this.maxVisiblePages;\n            }\n\n            return Math.min(this.activePage + this.pageOffset, this.totalPages);\n        },\n\n        visiblePages() {\n            let lastVisiblePage;\n\n            if (this.needFix) {\n                lastVisiblePage = Math.min(this.lastVisiblePage, this.maxVisiblePages);\n            } else {\n                lastVisiblePage = this.lastVisiblePage;\n            }\n\n            const diff = lastVisiblePage - this.firstVisiblePage;\n\n            const rangeMoreThanAvailable =\n                lastVisiblePage > this.maxVisiblePages &&\n                diff < (this.maxVisiblePages - 1) &&\n                (this.lastVisiblePage - this.maxVisiblePages + 1) > 0;\n\n            // fixing range with last visible page\n            if (rangeMoreThanAvailable) {\n                return commonUtils.range(lastVisiblePage - this.maxVisiblePages + 1, lastVisiblePage);\n            }\n\n            if (this.needFix && this.lastVisiblePage !== lastVisiblePage) {\n                return commonUtils.range(this.firstVisiblePage, lastVisiblePage - 1);\n            }\n            return commonUtils.range(this.firstVisiblePage, lastVisiblePage);\n        },\n\n        lowerRange() {\n            const res = commonUtils.range(2, this.firstVisiblePage - 1);\n            return res.filter((pageNum) => !this.visiblePages.includes(pageNum));\n        },\n\n        upperRange() {\n            const res = commonUtils.range(this.lastVisiblePage + 1, this.totalPages - 1);\n            return res.filter((pageNum) => !this.visiblePages.includes(pageNum));\n        },\n    },\n\n    watch: {\n        selectedPage() {\n            this.selectedPage = '';\n            if (this.$refs?.prevSelect) this.$refs.prevSelect.$el?.querySelector('.el-input')?.classList.remove('is-focus');\n            if (this.$refs?.nextSelect) this.$refs.nextSelect.$el?.querySelector('.el-input')?.classList.remove('is-focus');\n        },\n\n        currentPage(value) {\n            this.activePage = value;\n        },\n    },\n\n    created() {\n        this.activePage = this.currentPage;\n    },\n\n    mounted() {\n        this.isMounted = true;\n    },\n\n    methods: {\n        getPageURL(pageNum: number) {\n            const url = this.urlTemplate.replace('$PAGE_NUMBER$', pageNum);\n            return url.replace('$LOCALE$', this.pageLocaleMarker);\n        },\n\n        async resetSelects() {\n            if (!this.$refs) return;\n\n            await this.$nextTick();\n\n            if (this.$refs.prevSelect) {\n                this.$refs.prevSelect?.updateValue?.('');\n                this.$refs.prevSelect?.handleClose?.();\n            }\n\n            if (this.$refs.nextSelect) {\n                this.$refs.nextSelect?.updateValue?.('');\n                this.$refs.nextSelect?.handleClose?.();\n            }\n        },\n\n        async selectPage(pageNum: number) {\n            if (this.isLocked) return;\n\n            this.isLocked = true;\n\n            this.pushGaClickEvent(pageNum);\n\n            // If clickHandler is provided, call it first and do navigation in the callback.\n            // The caller site can decide for itself\n            // whether to rely on the default navigation or to do its own.\n            if (this.clickHandler) {\n                await this.clickHandler(pageNum, async () => {\n                    await this.$router?.push(this.getPageURL(pageNum));\n                });\n            } else {\n                await this.$router?.push(this.getPageURL(pageNum));\n            }\n\n            this.activePage = pageNum;\n            await this.resetSelects();\n            this.isLocked = false;\n\n            await this.$nextTick();\n\n            const el = this.scrollTo?.$el instanceof HTMLElement\n                ? this.scrollTo.$el\n                : this.scrollTo instanceof HTMLElement\n                    ? this.scrollTo\n                    : null;\n\n            if (el?.scrollIntoView) {\n                el.scrollIntoView({ behavior: 'smooth' });\n            }\n        },\n\n        goPrevPage() {\n            this.selectPage(this.activePage - 1);\n        },\n\n        goNextPage() {\n            this.selectPage(this.activePage + 1);\n        },\n\n        pushGaClickEvent(pageNum: number) {\n            const event = {\n                eventCategory: 'Interactions',\n                eventAction: 'link',\n                eventLabel: this.getPageURL(pageNum),\n                eventContext: 'click',\n                eventContent: `${pageNum}`,\n            };\n            window.dataLayer = window.dataLayer || [];\n            window.dataLayer.push(event);\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.pagination-wrapper {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n}\n\n.ssr-pagination {\n    display: none;\n}\n\n.page-button {\n    @mixin paragraph-accent;\n    width: 44px;\n    height: 32px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-variant-numeric: tabular-nums;\n    user-select: none;\n    cursor: pointer;\n    border-radius: 4px;\n    color: var(--av-brand-primary);\n\n    svg {\n        fill: var(--av-brand-primary);\n    }\n\n    &:hover {\n        background: var(--av-brand-accent);\n    }\n\n    &--current,\n    &:active {\n        color: var(--av-nav-primary);\n        background: var(--el-secondary-active);\n\n        svg {\n            fill: var(--av-nav-primary);\n        }\n    }\n\n    &--current {\n        pointer-events: none;\n    }\n}\n\n.page-button.el-select {\n    &:hover {\n        :deep(.el-input__container) {\n            background: none;\n        }\n    }\n\n    &:active {\n        :deep(.el-input__container) {\n            background: none;\n\n            .el-input__editor::placeholder {\n                color: var(--av-nav-primary);\n            }\n        }\n    }\n\n    :deep(.el-input) {\n        .el-input__wrapper {\n            padding: 0;\n            text-align: center;\n        }\n\n        .el-input__suffix {\n            display: none;\n        }\n\n        .el-input__container {\n            width: 44px;\n            height: 32px;\n            border: 0;\n        }\n\n        .el-select-input {\n            width: 44px;\n        }\n\n        .el-input__editor::placeholder {\n            @mixin paragraph-accent;\n            color: var(--av-nav-primary);\n            transform: translateY(4px);\n        }\n    }\n}\n\n.arrow {\n    width: 32px;\n\n    &--right {\n        transform: scaleX(-1);\n    }\n\n    &--disabled {\n        pointer-events: none;\n        opacity: 0.3;\n    }\n}\n\n.pagination {\n    padding: 16px 24px;\n\n    &--navy {\n        background: var(--av-nav-primary);\n\n        .page-button {\n            color: rgba(166, 203, 255, 1);\n\n            svg {\n                fill: rgba(166, 203, 255, 1);\n            }\n\n            &:hover {\n                color: var(--av-inversed-primary);\n                background: rgba(38, 104, 197, 0.3);\n\n                svg {\n                    fill: var(--av-inversed-primary);\n                }\n            }\n\n            &--current,\n            &:active {\n                color: var(--av-inversed-primary);\n                background: rgba(38, 104, 197, 0.6);\n\n                svg {\n                    fill: var(--av-inversed-primary);\n                }\n            }\n        }\n\n        .page-button.el-select {\n            :deep(.is-focus) {\n                border-radius: 4px;\n                color: var(--av-inversed-primary);\n                background: rgba(38, 104, 197, 0.6);\n            }\n\n            :deep(.el-input__container) {\n                background: transparent;\n            }\n\n            :deep(.el-input__editor) {\n                &::placeholder {\n                    color: #000;\n                }\n            }\n\n            &:hover {\n                :deep(.el-input__container) {\n                    .el-input__editor::placeholder {\n                        color: var(--av-inversed-primary);\n                    }\n                }\n            }\n\n            &:active {\n                :deep(.el-input__container) {\n                    .el-input__editor::placeholder {\n                        color: var(--av-inversed-primary);\n                    }\n                }\n            }\n        }\n    }\n\n    &--disabled {\n        pointer-events: none;\n    }\n}\n\n.pagination--light .page-button.el-select {\n    :deep(.is-focus .el-input__container) {\n        border-radius: 4px;\n        color: #00204D;\n        background: rgba(38, 104, 197, 0.3);\n    }\n}\n</style>\n\n<style lang=\"postcss\">\n.pagination-dropdown .el-scrollbar__bar {\n    display: none;\n}\n\n.pagination-dropdown .el-select-dropdown__list {\n    overflow-x: hidden;\n}\n\n.el-select-dropdown__item.range-option {\n    @mixin paragraph;\n    width: 44px;\n    height: 40px;\n    padding: 0;\n    justify-content: center;\n    overflow-x: hidden;\n    border-radius: 0;\n\n    a {\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        width: 100%;\n        height: 100%;\n        flex-shrink: 0;\n        color: var(--av-brand-primary);\n    }\n}\n</style>\n","<template>\n    <a-svg-sprite\n        class=\"a-icon\"\n        :name=\"name\"\n        :title=\"iconAlt\"\n        :class-name=\"className\"\n    />\n</template>\n\n<script>\nimport ASvgSprite from '@core/components/svg-sprite/svg-sprite.vue';\n\nexport default {\n    name: 'AIcon',\n\n    components: { ASvgSprite },\n\n    props: {\n        number: {\n            type: [String, Number],\n            required: true,\n        },\n\n        iconVariant: {\n            type: Boolean,\n            default: false,\n        },\n\n        iconAlt: {\n            type: String,\n            default: '',\n        },\n\n        className: {\n            type: Object,\n            required: false,\n            default: undefined,\n        },\n\n        theme: {\n            type: String,\n            default: null,\n        },\n    },\n\n    computed: {\n        /**\n         * Returns svg path\n         *\n         * @returns string\n         */\n        name() {\n            const { number, iconVariant } = this;\n            const variant = iconVariant ? 'S' : 'L';\n            let iconName = String(number);\n\n            while (iconName.length < 4) {\n                iconName = `0${iconName}`;\n            }\n\n            return [iconName, variant, this.theme].filter(Boolean).join('_');\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-icon {\n    display: block;\n    vertical-align: bottom;\n    max-width: 100%;\n    max-height: 100%;\n}\n</style>\n","import { ref, computed, onMounted, onBeforeUnmount } from 'vue';\n\nconst defaultBreakpoints = {\n    mobileWide: 576,\n    tablet: 768,\n    desktop: 1024,\n    desktopWide: 1280,\n    desktopLarge: 1440,\n};\n\nexport function useBreakpoint() {\n    const currentBreakpoint = ref('desktop');\n    const breakpoints = defaultBreakpoints;\n    const isMobile = computed(() => ['mobile', 'mobileWide'].includes(currentBreakpoint.value));\n    const isTablet = computed(() => currentBreakpoint.value === 'tablet');\n    const isDesktop = computed(() => ['desktop', 'desktopWide', 'desktopLarge'].includes(currentBreakpoint.value));\n\n    const getDeviceTypeByScreenWidth = (clientWidth: number) => {\n        if (clientWidth < breakpoints.tablet) return 'mobile';\n        if (clientWidth < breakpoints.desktop) return 'tablet';\n        return 'desktop';\n    };\n\n    const updateBreakpoint = () => {\n        if (typeof window === 'undefined') {\n            currentBreakpoint.value = 'desktop';\n            return;\n        }\n\n        const clientWidth = window.innerWidth;\n        const { mobileWide, tablet, desktop, desktopWide, desktopLarge } = breakpoints;\n\n        if (clientWidth < mobileWide) {\n            currentBreakpoint.value = 'mobile';\n        } else if (clientWidth < tablet) {\n            currentBreakpoint.value = 'mobileWide';\n        } else if (clientWidth < desktop) {\n            currentBreakpoint.value = 'tablet';\n        } else if (clientWidth < desktopWide) {\n            currentBreakpoint.value = 'desktop';\n        } else if (clientWidth < desktopLarge) {\n            currentBreakpoint.value = 'desktopWide';\n        } else {\n            currentBreakpoint.value = 'desktopLarge';\n        }\n    };\n\n    const handleResize = () => {\n        updateBreakpoint();\n    };\n\n    onMounted(() => {\n        updateBreakpoint();\n        window.addEventListener('resize', handleResize);\n    });\n\n    onBeforeUnmount(() => {\n        window.removeEventListener('resize', handleResize);\n    });\n\n    return {\n        currentBreakpoint,\n        breakpoints,\n        isMobile,\n        isTablet,\n        isDesktop,\n        getDeviceTypeByScreenWidth,\n        updateBreakpoint,\n        handleResize,\n    };\n}\n","import { getCurrentInstance } from 'vue';\nimport type { SSRContext } from '@model/ssr/context';\n\nexport function useSsrEngineContext() {\n    const instance = getCurrentInstance();\n    if (!instance) return null;\n\n    const ssrContext =\n        instance.appContext.config.globalProperties\n            .$ssrContext as SSRContext | undefined;\n\n    if (!ssrContext) return null;\n\n    function pushHead(entry: any) {\n        ssrContext.res.meta.head.push(entry);\n    }\n\n    function addSvgSymbol(symbol: string) {\n        ssrContext.res.svgSymbols.add(symbol);\n    }\n\n    return {\n        ssrContext,\n        res: ssrContext.res,\n        req: ssrContext.req,\n        public: ssrContext.public,\n\n        pushHead,\n        addSvgSymbol,\n    };\n}\n","export const TYPES = [\n    'content',\n    'content-md',\n    'content-sm',\n    'thumb',\n    'blog-cover',\n    'blog-card',\n    'background',\n];\n\nexport const FIT_TYPES = ['cover', 'contain', 'fill', 'none', 'scale-down'];\n\nexport default {};\n","import { FIT_TYPES } from './constants.js';\n\nconst devices = ['default', 'mobile', 'tablet', 'desktop'];\n\nfunction validateString(fit) {\n    if (!FIT_TYPES.includes(fit)) {\n        throw new Error(`Available fit types: \"${FIT_TYPES.join('m ')}\"\\nInput: \"${fit}\"`);\n    }\n\n    return true;\n}\n\nfunction validateObject(fit) {\n    const invalidDevices = Object.keys(fit).filter((key) => !devices.includes(key));\n    if (invalidDevices.length) {\n        throw new Error(`Available device types: \"${devices.join(', ')}\\nInput: \"${invalidDevices.join(', ')}\"`);\n    }\n\n    const invalidFits = Object.values(fit).filter((val) => !FIT_TYPES.includes(val));\n    if (invalidFits.length) {\n        throw new Error(`Available fit types: \"${FIT_TYPES.join(', ')}\"\\nInput: \"${invalidFits.join(', ')}\"`);\n    }\n\n    return true;\n}\n\nexport default (fit) => {\n    if (typeof fit === 'string') {\n        return validateString(fit);\n    }\n\n    if (typeof fit === 'object') {\n        return validateObject(fit);\n    }\n\n    throw new Error('Fit can only be of type: \"string, object\"');\n};\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <picture class=\"a-picture\" :class=\"pictureClass\" v-bind=\"$attrs\">\n        <template v-if=\"Boolean(background)\">\n            <source v-for=\"(source, i) in backgroundSources\" :key=\"'bg-' + i\" v-bind=\"source\" />\n        </template>\n\n        <template v-else-if=\"!isExternalLink\">\n            <source v-for=\"(source, i) in contentSources\" :key=\"'ct-' + i\" v-bind=\"source\" />\n        </template>\n\n        <img\n            ref=\"image\"\n            class=\"a-picture__img\"\n            :class=\"imageClass\"\n            :alt=\"alt\"\n            :style=\"{ objectFit, objectPosition: position }\"\n            :src=\"fallbackLink\"\n            :loading=\"isEager ? 'eager' : 'lazy'\"\n            :fetchpriority=\"isEager ? 'high' : null\"\n            :decoding=\"isEager ? 'sync' : 'async'\"\n        />\n    </picture>\n</template>\n\n<script setup>\nimport {\n    computed,\n    ref,\n    onMounted,\n    onBeforeUnmount,\n    onServerPrefetch,\n} from 'vue';\nimport { useStore } from 'vuex';\nimport { useBreakpoint } from '@core/composables/useBreakpoint';\nimport { useSsrEngineContext } from '@core/composables/useSsrEngineContext';\nimport { TYPES } from './constants.js';\nimport validateFit from './validateFit.js';\n\nconst props = defineProps({\n    link: { type: String, default: '' },\n    alt: { type: String, default: 'Acronis' },\n    isShadow: { type: Boolean, default: false },\n    isEager: { type: Boolean, default: false },\n    fit: {\n        type: [String, Object],\n        default: undefined,\n        validator: validateFit,\n    },\n    position: { type: String, default: 'center' },\n    isBackground: { type: Boolean, default: false },\n    background: { type: Object, default: undefined },\n    size: {\n        type: String,\n        default: undefined,\n        validator: (v) => v === undefined || TYPES.includes(v),\n    },\n    persistOriginal: { type: Boolean, default: false },\n    observeResize: { type: Boolean, default: false },\n});\n\nconst emit = defineEmits(['imageLoaded', 'imageResized']);\n\nconst store = useStore();\nconst { isMobile, isTablet } = useBreakpoint();\n\nconst $config = computed(() => store.getters['config/$config']);\nconst baseURL = computed(() => $config.value.env.HEAD_SITE_MAIN_PUBLIC_BASE_URL_STORAGE);\nconst supportedExtensions = ['webp', 'png'];\n\nconst pictureClass = computed(() => ({\n    'a-picture_is-background': props.isBackground,\n}));\nconst imageClass = computed(() => ({\n    'a-picture__img_shadow': props.isShadow,\n}));\n\nconst isExternalLink = computed(\n    () =>\n        props.link.startsWith('http:') ||\n        props.link.startsWith('https:') ||\n        props.link.startsWith('//'),\n);\n\nconst device = computed(() => {\n    if (isMobile.value) return 'mobile';\n    if (isTablet.value) return 'tablet';\n    return 'desktop';\n});\n\nconst buildImageLink = (template, filename = '', extension = 'png') => {\n    return filename.startsWith('@') || filename.match(/^[0-9a-f]{32}$/i)\n        ? `${baseURL.value}/images/${template}/${filename.replace('@', '')}.${extension}`\n        : `${filename}${template.endsWith('@2x') ? '@2' : ''}.${extension}`;\n};\n\nconst getBackgroundMedia = (name) => {\n    switch (name) {\n        case 'mobile':\n            return '(max-width: 767px)';\n        case 'tablet':\n            return '(min-width: 768px) and (max-width: 1023px)';\n        case 'desktop':\n            return '(min-width: 1024px)';\n        default:\n            return '(max-width: 767px)';\n    }\n};\n\nconst getMIMEType = (ext) => {\n    switch (ext) {\n        case 'webp':\n            return 'image/webp';\n        case 'png':\n            return 'image/png';\n        case 'jpg':\n        case 'jpeg':\n            return 'image/jpeg';\n        default:\n            return 'application/octet-stream';\n    }\n};\n\nconst fallbackLink = computed(() => {\n    if (props.background) {\n        const hash = props.background[device.value];\n        return buildImageLink('background', hash, 'png');\n    }\n\n    if (props.link) {\n        if (isExternalLink.value) return props.link;\n        const templateType = props.size || 'content';\n        return buildImageLink(templateType, props.link, 'png');\n    }\n\n    return '';\n});\n\nconst objectFit = computed(() => {\n    if (typeof props.fit !== 'object') return props.fit;\n    return props.fit?.[device.value] || props.fit?.default || 'fill';\n});\n\nconst buildBackgroundSource = (name, value, ext) => {\n    const template1x = props.persistOriginal ? 'background@2x' : 'background';\n\n    const template2x = 'background@2x';\n    const descriptor = props.persistOriginal ? '' : '2x';\n\n    return {\n        media: getBackgroundMedia(name),\n        srcset: [\n            buildImageLink(template1x, value, ext),\n            `${buildImageLink(template2x, value, ext)} ${descriptor}`.trim(),\n        ].join(', '),\n        type: getMIMEType(ext),\n    };\n};\n\nconst buildContentSource = (ext) => {\n    const templateType = props.size || 'content';\n    const template1x = props.persistOriginal ? `${templateType}@2x` : templateType;\n\n    const template2x = `${templateType}@2x`;\n    const descriptor = props.persistOriginal ? '' : '2x';\n\n    return {\n        srcset: [\n            buildImageLink(template1x, props.link, ext),\n            `${buildImageLink(template2x, props.link, ext)} ${descriptor}`.trim(),\n        ].join(', '),\n        type: getMIMEType(ext),\n    };\n};\n\nconst backgroundSources = computed(() => {\n    if (!props.background) return [];\n\n    return Object.entries(props.background).flatMap(([name, value]) =>\n        supportedExtensions.map((ext) => buildBackgroundSource(name, value, ext)),\n    );\n});\n\nconst contentSources = computed(() => {\n    if (props.background || isExternalLink.value) return [];\n\n    return supportedExtensions.map((ext) => buildContentSource(ext));\n});\n\nonServerPrefetch(() => {\n    if (!props.isEager) return;\n    const ssr = useSsrEngineContext();\n\n    const candidates = props.background\n        ? backgroundSources.value.filter((s) => s.media?.includes('1024'))\n        : contentSources.value;\n\n    const chosen = candidates.find((s) => s.type === 'image/webp') ||\n        candidates.find((s) => s.type === 'image/png') ||\n        candidates[0];\n\n    if (!chosen?.srcset) return;\n    const parts = chosen.srcset.split(',').map((p) => p.trim());\n    const retina = parts.find((p) => p.includes('2x'));\n    const href = retina ? retina.replace(/\\s+2x$/, '') : parts[0];\n    if (!href) return;\n\n    const hint = {\n        tag: 'link',\n        rel: 'preload',\n        as: 'image',\n        href,\n        fetchpriority: 'high',\n        imagesrcset: chosen.srcset,\n        imagesizes: '100vw',\n        media: chosen.media,\n    };\n    ssr?.pushHead(hint);\n});\n\nconst image = ref(null);\n\nconst handleResize = () => {\n    if (!image.value) return;\n    emit('imageResized', image.value);\n};\n\nonMounted(() => {\n    if (!image.value) return;\n\n    image.value.onload = () => {\n        emit('imageLoaded', image.value);\n    };\n\n    if (props.observeResize) {\n        window.addEventListener('resize', handleResize);\n    }\n});\n\nonBeforeUnmount(() => {\n    if (!image.value) return;\n\n    image.value.onload = null;\n    window.removeEventListener('resize', handleResize);\n});\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-picture {\n    display: block;\n\n    &_is-background {\n        .a-picture__img {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            bottom: 0;\n        }\n    }\n\n    &__img {\n        display: block;\n        max-width: 100%;\n        max-height: 100%;\n        margin: 0 auto;\n\n        &_shadow {\n            box-shadow: var(--av-shadow-regular);\n        }\n    }\n}\n</style>\n","<template>\n    <component :is=\"to ? DynamicLink : 'div'\" :to=\"to ? to : null\" :class=\"['a-small-card', {...className}]\">\n        <template v-if=\"image\">\n            <div v-if=\"image.startsWith('http')\" class=\"a-picture-image\">\n                <img\n                    alt=\"\"\n                    :src=\"image\"\n                    class=\"a-picture__img\"\n                    loading=\"lazy\"\n                />\n            </div>\n            <template v-else>\n                <a-picture :link=\"image\" :alt=\"imageAlt\" class=\"a-picture-image\" />\n            </template>\n        </template>\n\n        <template v-if=\"logo\">\n            <a-picture :link=\"logo\" :alt=\"logoAlt\" class=\"a-picture-logo\" />\n        </template>\n\n        <template v-if=\"icon\">\n            <a-icon :number=\"icon\" :icon-alt=\"iconAlt || title\" :icon-variant=\"iconVariant\" />\n        </template>\n        <template v-else-if=\"glyph\">\n            <a-glyph\n                class=\"a-small-card__glyph\"\n                :name=\"glyph\"\n                size=\"l\"\n                :aria-hidden=\"true\"\n            />\n        </template>\n\n        <template v-if=\"labels?.length\">\n            <ul class=\"labels\">\n                <li v-for=\"(label, labelIndex) in labels\" :key=\"`label-${labelIndex}`\" class=\"labels-item\">\n                    <a-label v-bind=\"label\" :size=\"label.size || 's'\">\n                        {{ label.text }}\n                    </a-label>\n                </li>\n            </ul>\n        </template>\n\n        <a-dangerous-html\n            v-if=\"title\"\n            class=\"title\"\n            :content=\"title\"\n            tag=\"h3\"\n        />\n\n        <a-dangerous-html v-if=\"text\" class=\"text\" :content=\"text\" />\n\n        <div v-if=\"company\" class=\"company\">\n            <div class=\"company-info\">\n                <span v-if=\"company.address\" class=\"company-address\">\n                    {{ company.address }}.\n                </span>\n                <span v-if=\"company.phone?.text \" class=\"company-phone\">\n                    <a-link\n                        v-if=\"company.phone?.to\"\n                        v-bind=\"company.phone\"\n                        :size=\"company.phone.size || 'body'\"\n                    />\n                    <span v-else class=\"company-phone-number\">{{ company.phone.text }}</span>\n                </span>\n            </div>\n        </div>\n\n        <ul v-if=\"rate\" class=\"rate-list\">\n            <li v-for=\"(item, rateIndex) in rate\" :key=\"`rate-${rateIndex}`\" class=\"rate-item\">\n                <div class=\"rate-title\">\n                    {{ item.title }}\n                </div>\n                <div class=\"point-list\">\n                    <div\n                        v-for=\"(point, pointIndex) in 5\"\n                        :key=\"`point-${pointIndex}`\"\n                        :class=\"classNameRate(item, pointIndex)\"\n                    />\n                </div>\n            </li>\n        </ul>\n\n        <div v-if=\"company?.website?.text\" class=\"company-website\">\n            <a-link\n                :to=\"companyLink\"\n                :text=\"company.website.text\"\n                :glyph=\"company.website.glyph || ''\"\n            />\n        </div>\n\n        <ul v-if=\"buttons\" class=\"buttons\">\n            <li v-for=\"(button, buttonIndex) in buttons\" :key=\"`button-${buttonIndex}`\">\n                <a-button\n                    v-bind=\"button\"\n                    :size=\"button.size || 'small'\"\n                    :type=\"button.type || 'main'\"\n                />\n            </li>\n        </ul>\n    </component>\n</template>\n\n<script setup>\nimport { computed } from 'vue';\nimport AButton from '@core/components/button/button.vue';\nimport ADangerousHtml from '@core/components/dangerous-html/dangerous-html.vue';\nimport DynamicLink from '@core/components/dynamic-link/dynamic-link.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport AIcon from '@core/components/icon/icon.vue';\nimport ALabel from '@core/components/label/label.vue';\nimport ALink from '@core/components/link/link.vue';\nimport APicture from '@core/components/picture/picture.vue';\n\ndefineOptions({\n    name: 'ASmallCard',\n});\n\nconst props = defineProps({\n    /**\n     * Title\n     */\n    title: {\n        type: String,\n        default: null,\n    },\n\n    /**\n     * Text\n     */\n    text: {\n        type: String,\n        default: null,\n    },\n\n    /**\n     * Card link\n     */\n    to: {\n        type: String,\n        default: null,\n    },\n\n    /**\n     * Icon String\n     */\n    icon: {\n        type: String,\n        default: null,\n    },\n\n    /**\n     * Icon variant\n     */\n    iconVariant: {\n        type: Boolean,\n        default: false,\n    },\n\n    /**\n     * Icon alt\n     */\n    iconAlt: {\n        type: String,\n        default: null,\n    },\n\n    /**\n     * Glyph name or glyph props object\n     */\n    glyph: {\n        type: [String, Object],\n        default: null,\n    },\n\n    /**\n     * Logo URL\n     */\n    logo: {\n        type: String,\n        default: null,\n    },\n\n    /**\n     * Logo alt\n     */\n    logoAlt: {\n        type: String,\n        default: 'Logo',\n    },\n\n    /**\n     * Image URL\n     */\n    image: {\n        type: String,\n        default: null,\n    },\n\n    /**\n     * Image alt\n     */\n    imageAlt: {\n        type: String,\n        default: 'Acronis',\n    },\n\n    /**\n     * Rate\n     */\n    rate: {\n        type: Array,\n        default: null,\n    },\n\n    /**\n     * Card Labels\n     */\n    labels: {\n        type: Array,\n        default: () => ([]),\n    },\n\n    /**\n     * Company Card\n     */\n    company: {\n        type: Object,\n        default: null,\n    },\n\n    buttons: {\n        type: Array,\n        default: null,\n    },\n\n    /**\n     * Theme\n     */\n    theme: {\n        type: String,\n        validator: (prop) => ['light', 'dark'].includes(prop),\n        default: 'light',\n    },\n});\n\nconst className = computed(() => ({\n    'a-small-card_with-link': props.to,\n    'a-small-card_with-rate': props.rate,\n    'a-small-card_company': props.company,\n    [`${props.theme}-theme`]: true,\n}));\n\nconst companyLink = computed(() => props.company?.website?.to || 'https://www.acronis.com/');\n\nfunction classNameRate(item, pointIndex) {\n    return ['point', { 'point-filled': pointIndex + 1 <= item.points }];\n}\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-small-card {\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    background-color: var(--av-inversed-primary);\n    border: 1px solid var(--av-brand-secondary-light);\n    border-radius: 4px;\n    box-shadow: 0 4px 8px rgba(56, 74, 99, 0.1);\n    overflow: hidden;\n    width: 100%;\n    height: 100%;\n    padding: 16px;\n    text-decoration: none;\n    font-size: 14px;\n    transition: box-shadow linear 0.15s;\n\n    .a-icon {\n        width: 48px;\n        height: 48px;\n    }\n\n    &__glyph {\n        flex-shrink: 0;\n    }\n\n    .a-picture-logo {\n        display: flex;\n        height: 64px;\n        max-width: 208px;\n        align-items: center;\n        justify-content: flex-start;\n\n        :deep(.a-picture__img) {\n            width: auto;\n            margin: 0;\n        }\n    }\n\n    .a-picture-image {\n        display: flex;\n        height: 244px;\n        align-items: center;\n        justify-content: center;\n        margin: -24px -24px 0 -24px;\n\n        @media all and (-ms-high-contrast: none), (-ms-high-contrast: active) {\n            position: relative;\n            overflow: hidden;\n        }\n\n        :deep(.a-picture__img) {\n            object-fit: cover;\n            width: 100%;\n            height: 100%;\n            margin: 0;\n\n            @media all and (-ms-high-contrast: none), (-ms-high-contrast: active) {\n                position: absolute;\n                top: 50%;\n                inset-inline-start: 50%;\n                transform: translate(-50%, -50%);\n                width: 100%;\n                max-width: none;\n                height: auto;\n            }\n        }\n    }\n\n    .labels {\n        display: flex;\n        height: 16px;\n        gap: 8px;\n    }\n\n    .labels-item {\n        .a-label {\n            vertical-align: top;\n        }\n    }\n\n    .title {\n        @mixin lead-accent;\n\n        color: var(--av-nav-primary);\n    }\n\n    .rate-item {\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n\n        &:not(:last-of-type) {\n            margin-bottom: 8px;\n        }\n    }\n\n    .rate-title {\n        @mixin body-accent;\n        line-height: 20px;\n    }\n\n    .point {\n        margin: 0 6px;\n        width: 12px;\n        height: 12px;\n        background-color: var(--av-solid-brand-accent);\n        border-radius: 50%;\n    }\n\n    .point-list {\n        margin: 0 -6px;\n        display: flex;\n    }\n\n    .point-filled {\n        background-color: var(--av-brand-secondary);\n    }\n\n    .buttons {\n        margin-top: auto;\n        padding-top: 40px;\n        display: flex;\n        flex-flow: column;\n        gap: 8px;\n        :deep(.a-button) {\n            width: 100%;\n        }\n    }\n\n    &.dark-theme {\n        background-color: var(--av-nav-primary);\n\n        .title,\n        .text,\n        .rate-list,\n        .company-address {\n            color: var(--av-inversed-primary);\n        }\n\n        .point {\n            background-color: var(--av-inversed-lighter);\n        }\n\n        .point-filled {\n            background-color: rgba(59, 184, 255, 1);\n        }\n    }\n}\n\n.a-small-card_with-link {\n    .title {\n        @mixin lead-accent;\n        color: var(--av-nav-primary);\n        transition: color 0.15s ease-out;\n    }\n\n    .text {\n        color: var(--av-fixed-secondary);\n    }\n\n    &:hover {\n        box-shadow: none;\n    }\n}\n\n.a-small-card_with-rate {\n    display: flex;\n    flex-direction: column;\n}\n\n.a-small-card_company {\n    .text {\n        @mixin paragraph;\n        color: var(--av-fixed-secondary);\n    }\n\n    .company {\n        margin-top: auto;\n    }\n\n    .company-info {\n        @mixin descriptor;\n        color: var(--av-fixed-secondary);\n    }\n\n    .company-phone {\n        font-size: 0;\n\n        .a-link {\n            display: inline;\n        }\n    }\n\n    .company-phone-number {\n        @mixin descriptor;\n    }\n\n    .company-website {\n        font-size: 0;\n\n        :deep(.a-link__content) {\n            @mixin caption-accent;\n            color: var(--av-brand-primary);\n\n            span {\n                margin: 0;\n            }\n        }\n\n        :deep(.a-glyph) {\n            margin: 0;\n            margin-inline-start: 4px;\n        }\n    }\n}\n\n.company-address {\n    color: var(--av-fixed-primary);\n}\n\n.rate-list {\n    margin-top: 0;\n}\n</style>\n","export default function objectToQuerystring(obj) {\n    return Object.keys(obj).reduce((str, key, index) => {\n        const delimiter = index === 0 ? '' : '&';\n        const newKey = encodeURIComponent(key);\n        const value = encodeURIComponent(obj[key]);\n\n        return `${str}${delimiter}${newKey}=${value}`;\n    }, '?');\n}\n","<template>\n    <iframe\n        :id=\"iframeId\"\n        class=\"a-youtube\"\n        :src=\"src\"\n        :data-src=\"src\"\n        :data-title=\"title\"\n        :class=\"{ 'a-youtube--modal': isModal }\"\n        allow=\"accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture\"\n        allowfullscreen\n    />\n</template>\n\n<script>\nimport objectToQueryString from '@utils/objectToQueryString.js';\n\nconst defaultParams = {\n    rel: 0,\n    showinfo: 0,\n    autoplay: 0,\n    enablejsapi: 1,\n};\n\nexport default {\n    name: 'AYoutube',\n    props: {\n        ytId: {\n            type: String,\n            required: true,\n        },\n\n        title: {\n            type: String,\n            default: null,\n        },\n\n        params: {\n            type: Object,\n            default: () => ({}),\n        },\n    },\n    emits: ['progressChanged'],\n\n    data() {\n        return {\n            trackerId: null,\n            playerPositionMonotonic: 0,\n        };\n    },\n\n    computed: {\n        iframeId() {\n            return `yt-${this.ytId}`;\n        },\n\n        isModal() {\n            return ['AModal'].includes(this.$parent.$options.name);\n        },\n\n        src() {\n            const { ytId, params } = this;\n            const newParams = { ...defaultParams, ...params, autoplay: 0 };\n            const queryParams = objectToQueryString(newParams);\n            return `https://www.youtube.com/embed/${ytId}${queryParams}`;\n        },\n    },\n    beforeMount() {\n        window.youtubePlayerReadyBus?.subscribe(() => {\n            this.trackerId = setInterval((this.runTrackerRound), 10000);\n        });\n    },\n\n    beforeUnmount() {\n        clearInterval(this.trackerId);\n        this.playerPositionMonotonic = 0;\n    },\n\n    methods: {\n        runTrackerRound() {\n            if (!window.YT) return;\n\n            const player = window.YT.get(this.iframeId);\n            if (!player?.playerInfo?.duration) return;\n\n            const current = player.playerInfo.currentTime;\n            const duration = player.playerInfo.duration;\n            const progress = (current / duration) * 100;\n\n            if (current <= this.playerPositionMonotonic) return;\n            this.playerPositionMonotonic = current;\n\n            // TODO: the first $emit causes a weird call to https://websiteapi.acronis.com/svc/v1/marketing/forms/leads/null\n            this.$emit('progressChanged', {\n                ytId: this.ytId,\n                progress: progress.toFixed(2),\n                current: current.toFixed(2),\n                duration,\n            });\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-youtube {\n    display: block;\n    width: 100%;\n    height: 100%;\n    border: 0;\n\n    &--modal {\n        position: absolute;\n        top: 0;\n        inset-inline-start: 0;\n        width: 100%;\n        height: 100%;\n    }\n}\n\n.a-modal--youtube .a-modal__content {\n    padding-top: 56%;\n}\n</style>\n","<template>\n    <div v-if=\"title || lead\" class=\"a-slice-header\" :class=\"`is-${theme}`\">\n        <a-dangerous-html\n            v-if=\"title\"\n            class=\"a-slice-header__title\"\n            :content=\"title\"\n            :tag=\"titleTag\"\n        />\n        <a-dangerous-html\n            v-if=\"lead\"\n            class=\"a-slice-header__lead\"\n            :content=\"lead\"\n            :tag=\"'p'\"\n        />\n        <a-dangerous-html\n            v-if=\"bodyText\"\n            class=\"a-slice-header__body-text\"\n            :content=\"bodyText\"\n            :tag=\"'p'\"\n        />\n        <slot />\n    </div>\n</template>\n\n<script>\nimport ADangerousHtml from '@core/components/dangerous-html/dangerous-html.vue';\n\nexport default {\n    name: 'ASliceHeader',\n\n    components: {\n        ADangerousHtml,\n    },\n\n    props: {\n        theme: {\n            type: String,\n            default: 'light',\n        },\n\n        title: {\n            type: String,\n            default: '',\n        },\n\n        lead: {\n            type: String,\n            default: '',\n        },\n\n        bodyText: {\n            type: String,\n            default: '',\n        },\n\n        titleTag: {\n            type: String,\n            default: 'h2',\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-slice-header {\n    margin-bottom: 40px;\n\n    @media (--viewport-desktop) {\n        width: calc(((100% - 32px) / 3) * 2 + 16px);\n    }\n\n    &__title {\n        @mixin display-accent;\n        color: var(--av-nav-primary);\n        margin-bottom: 24px;\n        &:only-child {\n            margin-bottom: 0;\n        }\n    }\n\n\n    &__lead {\n        @mixin title;\n        color: var(--av-nav-primary);\n    }\n\n    &__body-text {\n        @mixin paragraph;\n        margin-top: 24px;\n    }\n}\n\nh1.a-slice-header__title,\nh2.a-slice-header__title {\n    @media (--viewport-mobile-wide) {\n        @mixin hero-accent;\n    }\n}\n\n.is-dark {\n    .a-slice-header__title,\n    .a-slice-header__lead,\n    .a-slice-header__body-text {\n        color: var(--av-inversed-primary);\n    }\n}\n</style>\n","export default {\n    props: {\n        /**\n         * Slice id\n         */\n        id: {\n            type: String,\n        },\n\n        /**\n         * Slice title\n         */\n        title: {\n            type: String,\n        },\n\n        /**\n         * Slice title tag\n         */\n        titleTag: {\n            type: String,\n            default: 'h2',\n            validator: (value) => ['h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'div', 'p'].includes(value),\n        },\n\n        /**\n         * Slice lead\n         */\n        lead: {\n            type: String,\n        },\n\n        /**\n         * Slice body text\n         */\n        bodyText: {\n            type: String,\n        },\n    },\n\n    inheritAttrs: false,\n};\n","/**\n * Basic slice types\n *\n * @return {string[]}\n */\nexport const LAYOUTS = ['row'];\n\n/**\n * Basic background color\n * - white - Solid white (default)\n * - light-blue - Solid light-blue\n * - dark-blue - Solid dark-blue\n * - l-b-gradient-top - Light-blue gradient to top\n * - l-b-gradient-bottom - Light-blue gradient to bottom\n * @return {string[]}\n */\nexport const COLORS = [\n    'white',\n    'light-blue',\n    'dark-blue',\n    'l-b-gradient-top',\n    'l-b-gradient-bottom',\n    'l-b-gradient-right',\n    'd-b-gradient-right',\n    'd-b-gradient-bottom',\n    'n-p-gradient-top',\n    'navy-gradient',\n];\n\n/**\n * Variants of type border\n *\n * @return {string[]}\n */\nexport const BORDERS = ['full-width', 'content-wide', 'short'];\n\n/**\n * Slice indents\n * None - Large indent 80/104 (default)\n * medium - Medium indent 64/88\n * small - Small indent 40/64\n * @return {string[]}\n */\nexport const INDENTS = ['small', 'medium'];\n\n/**\n * Slice bottom paddings\n * None - padding 88 (default)\n * small - padding 64\n * @return {string[]}\n */\nexport const BOTTOM_PADDINGS = ['small'];\n","import { BORDERS, COLORS } from '@model/slices/basic-slice.js';\n\nexport default {\n    props: {\n        margin: {\n            type: String,\n            default: undefined,\n            required: false,\n        },\n        padding: {\n            type: String,\n            default: undefined,\n            required: false,\n        },\n        noBottomPadding: {\n            type: Boolean,\n            default: false,\n        },\n        borderTop: {\n            type: String,\n            validator: (value) => !value || BORDERS.includes(value),\n        },\n        borderBottom: {\n            type: String,\n            validator: (value) => !value || BORDERS.includes(value),\n        },\n        background: {\n            type: String,\n            validator: (value) => value === undefined || COLORS.includes(value),\n            default: 'white',\n        },\n    },\n    computed: {\n        basicClassName() {\n            return {\n                's-slice_no-bottom-padding': this.noBottomPadding,\n                's-slice_border-bottom': this.borderBottom,\n                [`s-slice_border-bottom_${this.borderBottom}`]: this.borderBottom,\n                's-slice_border-top': this.borderTop,\n                [`s-slice_border-top_${this.borderTop}`]: this.borderTop,\n                [`s-slice_background_${this.background}`]: this.background,\n                [this.padding]: this.padding,\n                [this.margin]: this.margin,\n            };\n        },\n    },\n};\n","<template>\n    <section :id=\"id\" :class=\"['s-slice', className, $attrs.class]\" v-bind=\"$attrs\">\n        <div class=\"a-container\">\n            <a-slice-header\n                v-if=\"title || lead || bodyText\"\n                :title=\"title\"\n                :title-tag=\"titleTag\"\n                :lead=\"lead\"\n                :body-text=\"bodyText\"\n                :theme=\"theme\"\n            />\n            <slot />\n        </div>\n    </section>\n</template>\n\n<script>\nimport ASliceHeader from '@core/components/slice-header/slice-header.vue';\nimport contentMixin from '@core/mixins/content.js';\nimport styleMixin from '@core/mixins/style.js';\nimport { LAYOUTS } from '@model/slices/basic-slice.js';\n\nexport default {\n    name: 'SBasicSlice',\n\n    components: {\n        ASliceHeader,\n    },\n\n    mixins: [contentMixin, styleMixin],\n\n    inheritAttrs: false,\n\n    props: {\n        theme: {\n            type: String,\n            default: 'light',\n        },\n\n        layout: {\n            type: String,\n            default: null,\n            validator: (value) => value === null || LAYOUTS.includes(value),\n        },\n    },\n\n    computed: {\n        className() {\n            return {\n                ...this.basicClassName,\n                [ `is-${this.theme}`]: this.theme,\n                [`s-slice_layout_${this.layout}`]: this.layout,\n            };\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.s-slice {\n    @mixin basic-slice-paddings;\n    @mixin border-top;\n    @mixin border-bottom;\n\n    &_background {\n        @mixin background;\n    }\n\n    &_layout_row {\n        @media (--viewport-desktop) {\n            & .a-container {\n                display: flex;\n            }\n\n            & .a-slice-header {\n                width: calc((100% - 48px) / 4);\n                flex-shrink: 0;\n                padding-inline-end: 16px;\n                margin-inline-end: 16px;\n            }\n        }\n    }\n}\n</style>\n","/**\n * Logo types\n *\n * @return {string[]}\n */\nexport const TYPES = ['full'];\n\n/**\n * Logo colors\n *\n * @return {string[]}\n */\nexport const COLORS = ['white', 'dark'];\n","<template>\n    <!-- eslint-disable max-len -->\n    <svg\n        v-if=\"type === 'full'\"\n        class=\"a-logo\"\n        :class=\"className\"\n        title=\"Acronis\"\n        viewBox=\"0 0 158 32\"\n        xmlns=\"http://www.w3.org/2000/svg\"\n    >\n        <path\n            d=\"M0 31.5362H4.82319L7.14203 25.7855H24.2551L26.5275 31.5362H31.3507L18.1797 0H13.171L0 31.5362ZM11.687 14.5159L12.4754 12.4754C13.8203 9.13623 14.9797 6.35362 15.6754 4.26667C16.4174 6.35362 17.5768 9.13623 18.9217 12.4754L19.7565 14.5159H11.687ZM44.2435 32C50.2261 32 54.9565 28.7072 56.4406 22.771H51.6638C50.6435 26.0174 48 27.8261 44.429 27.8261C39.513 27.8261 36.4522 24.3478 36.4522 19.2928C36.4522 14.4696 39.3275 10.7594 44.3826 10.7594C48 10.7594 50.5507 12.429 51.6174 16.1855H56.3942C55.3275 10.1101 50.6435 6.58551 44.4754 6.58551C37.287 6.58551 31.7217 11.7333 31.7217 19.2928C31.7217 26.6203 36.5449 32 44.2435 32ZM60.0116 31.5362H64.6493V18.8754C64.6493 14.5159 65.9942 11.7333 70.8638 11.7333H71.5594V6.58551H71.142C68.2667 6.58551 65.9942 7.97681 64.4638 10.1565L64.2783 7.04928H60.0116V31.5362ZM85.1478 32C92.5681 32 97.9942 26.6203 97.9942 19.2928C97.9942 12.058 92.6609 6.58551 85.1478 6.58551C77.9131 6.58551 72.3015 11.7797 72.3015 19.2928C72.3015 26.6203 77.7275 32 85.1478 32ZM101.426 31.5362H106.064V17.4377C106.064 13.4493 108.614 10.8058 112.742 10.8058C116.545 10.8058 118.122 12.9855 118.122 16.9739V31.5362H122.759V16.0928C122.759 10.0174 119.513 6.58551 113.716 6.58551C110.377 6.58551 107.78 7.6058 105.878 9.6L105.554 7.04928H101.426V31.5362ZM147.988 32C150.957 32 153.275 31.4435 155.038 30.0058C156.707 28.6609 157.588 26.6203 157.588 24.3015C157.588 22.1217 156.615 19.9884 154.574 18.8754C153.043 18.0406 151.374 17.7159 149.565 17.4377C147.664 17.1594 145.438 16.9275 144.232 16.4638C143.026 16 142.377 15.3043 142.377 13.9594C142.377 11.8725 144.186 10.342 147.246 10.342C150.122 10.342 152.348 11.7333 152.626 14.5623H157.032C156.754 9.22898 152.951 6.58551 147.246 6.58551C142.006 6.58551 137.925 9.32174 137.925 14.5159C137.925 16.742 138.806 18.7362 141.032 19.8029C142.47 20.4986 144.139 20.8696 146.551 21.2406C148.87 21.6116 150.029 21.7971 151.142 22.2145C152.301 22.6319 153.043 23.2812 153.043 24.858C153.043 27.1304 150.864 28.2435 147.988 28.2435C144.51 28.2435 142.145 26.9449 141.681 23.9768H137.183C137.646 29.7739 142.006 32 147.988 32ZM127.815 31.5362H132.406V7.04928H127.815V31.5362ZM85.1942 27.8261C80.4638 27.8261 77.0783 24.3478 77.0783 19.2464C77.0783 14.4696 80.0928 10.7594 85.1478 10.7594C90.1102 10.7594 93.2638 14.4232 93.2638 19.2464C93.2638 24.1623 89.971 27.8261 85.1942 27.8261ZM8.71884 21.8435L10.2029 18.2261H21.2406L22.6783 21.8435H8.71884Z\"\n        />\n    </svg>\n    <svg\n        v-else\n        class=\"a-logo\"\n        :class=\"className\"\n        title=\"Acronis\"\n        viewBox=\"0 0 48 48\"\n        xmlns=\"http://www.w3.org/2000/svg\"\n    >\n        <path\n            d=\"M3 46H9.47463L12.5874 38.1588H35.5599L38.6105 46H45.0851L27.4044 3H20.6807L3 46ZM18.6885 22.7926L19.7469 20.0103C21.5523 15.4574 23.1087 11.6632 24.0426 8.81765C25.0387 11.6632 26.5951 15.4574 28.4005 20.0103L29.5211 22.7926H18.6885ZM14.7041 32.7838L16.6963 27.8515H31.5133L33.4432 32.7838H14.7041Z\"\n        />\n    </svg>\n</template>\n\n<script>\nimport { COLORS, TYPES } from '@core/components/logo/constants.js';\n\nexport default {\n    name: 'ALogo',\n    props: {\n        /**\n         * Icon type\n         */\n        type: {\n            type: String,\n            required: false,\n            default: undefined,\n            validator: (value) => value === undefined || TYPES.includes(value),\n        },\n\n        /**\n         * Icon fill\n         * Default color: var(--av-nav-primary)\n         */\n        fill: {\n            type: String,\n            required: false,\n            default: undefined,\n            validator: (value) => value === undefined || COLORS.includes(value),\n        },\n    },\n\n    computed: {\n        /**\n         * Returns classes for component\n         *\n         * @returns {{[className]: condition}\n         */\n        className() {\n            const { type, fill } = this;\n            return {\n                [`a-logo_type_${type}`]: type,\n                [`a-logo_fill_${fill}`]: fill,\n            };\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-logo {\n    fill: var(--av-nav-primary);\n    width: 40px;\n    height: 40px;\n    display: inline-block;\n    vertical-align: bottom;\n\n    @media (--viewport-desktop) {\n        width: 48px;\n        height: 48px;\n    }\n\n    &_type {\n        &_full {\n            height: 27px;\n            width: 133px;\n\n            @media (--viewport-desktop) {\n                height: 32px;\n                width: 158px;\n            }\n        }\n    }\n\n    &_fill {\n        &_white {\n            fill: var(--av-inversed-primary);\n        }\n    }\n}\n</style>\n","<template>\n    <div v-show=\"isVisible\" class=\"a-loader\">\n        <template v-if=\"hasError\">\n            <p v-if=\"slice.glyph\">\n                <a-glyph v-bind=\"slice.glyph\" />\n            </p>\n            <p\n                v-if=\"slice.title\"\n                class=\"title\"\n                v-html=\"slice.title\"\n            />\n            <p\n                v-for=\"(item, itemIndex) in slice.description\"\n                :key=\"`error-${itemIndex}`\"\n                class=\"description\"\n                v-html=\"item\"\n            />\n            <a-button\n                v-bind=\"slice.button\"\n                @click=\"$emit('click')\"\n            />\n        </template>\n        <template v-else>\n            <div\n                v-loading=\"true\"\n                el-loading-size=\"48\"\n                el-loading-color=\"brand-secondary\"\n            />\n            <div class=\"placeholder\">\n                <p\n                    v-for=\"(item, itemIndex) in slice.placeholder\"\n                    :key=\"`placeholder-${itemIndex}`\"\n                    v-html=\"item\"\n                />\n            </div>\n        </template>\n    </div>\n</template>\n\n<script>\nimport { mapState } from 'vuex';\nimport AButton from '@core/components/button/button.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport { Loading } from '@core/components/loading';\nimport { LOCALE_DEFAULT } from '@model/const/locales.ts';\n\nconst STORE_SLICE_NAME = 's-loader';\n\nexport default {\n    name: 'ALoader',\n\n    components: {\n        AButton,\n        AGlyph,\n    },\n\n    directives: {\n        loading: Loading.directive,\n    },\n\n    props: {\n        content: {\n            type: Object,\n            default() {},\n        },\n        hasError: {\n            type: Boolean,\n            default: false,\n        },\n        isVisible: {\n            type: Boolean,\n            default: false,\n        },\n    },\n\n    emits: ['click'],\n\n    computed: {\n        ...mapState({\n            preset: (state) => state.slices.items?.[STORE_SLICE_NAME] || null,\n        }),\n\n        slice() {\n            return { ...this.preset, ...this.content };\n        },\n    },\n\n    watch: {\n        isVisible(active) {\n            if (active) {\n                document.body.classList.add('overflow-hidden');\n                return;\n            }\n            document.body.classList.remove('overflow-hidden');\n        },\n    },\n\n    async serverPrefetch() {\n        if (!import.meta.env.SSR) return;\n\n        const locale = this.$store.state.geolocation.finalLocale || LOCALE_DEFAULT;\n        await this.$store.dispatch('slices/getSyncedData', { slice: STORE_SLICE_NAME, locale });\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-loader {\n    top: 0;\n    inset-inline-start: 0;\n    width: 100%;\n    height: 100%;\n    opacity: .95;\n    display: flex;\n    z-index: 2147483650;\n    position: fixed;\n    padding: 0 16px;\n    text-align: center;\n    align-items: center;\n    flex-direction: column;\n    justify-content: center;\n    background: var(--av-inversed-primary);\n\n    .placeholder {\n        @mixin body;\n        margin-top: 16px;\n    }\n\n    .title {\n        @mixin lead;\n    }\n\n    .title ~ .description {\n        width: 100%;\n        margin-top: 8px;\n    }\n\n    .el-loading {\n        position: relative;\n    }\n\n    .a-glyph {\n        margin-bottom: 16px;\n    }\n\n    .a-button {\n        @mixin body;\n        margin-top: 16px;\n        padding: 4px 16px;\n    }\n}\n\n.overflow-hidden {\n    overflow: hidden;\n\n    .s-purchasing-acp {\n        position: relative;\n        z-index: 2147483647;\n    }\n}\n</style>\n","import { mapState } from 'vuex';\n\nexport default {\n    computed: {\n        ...mapState({\n            promotions: (state) => state.promotions?.data || [],\n            currentPageId: (state) => state.pages?.page?.id,\n            currentLocale: (state) => state.geolocation?.desiredLocale || state.geolocation?.requestedLocale || '',\n        }),\n\n        hasEmailPromo() {\n            const coupon = this.$route.query?.coupon || '';\n            if (!coupon) return false;\n\n            if (!this.$route.path.includes('purchasing')) return false;\n\n            const productID = this.purchasePageCTA?.productId || this.internalProductId;\n            const promotionForEmails = this.findPromotionForEmails(productID, coupon);\n            return promotionForEmails.discount > 0;\n        },\n\n        promotionList() {\n            const coupon = this.$route.query?.coupon || '';\n            const isForEmailsOnly = this.hasEmailPromo;\n\n            return this.promotions.filter((item) => {\n                if (item.is_in_app_only) {\n                    if (!this.isInapp) return false;\n                    if (!item.locales?.length) return true;\n                    return item.locales.some((l) => l.locale === this.currentLocale);\n                }\n                if (item.is_for_targeted_pages_only) {\n                    return item.pages?.some((p) => p.page_id === this.currentPageId);\n                }\n                if (!isForEmailsOnly) return !item.is_for_emails_only;\n                return item.is_for_emails_only && item.coupon_code === coupon;\n            });\n        },\n    },\n\n    methods: {\n        promotionActive(productID) {\n            if (!productID) return {};\n            return this.promotions\n                .filter((item) => !item.is_for_emails_only && !item.is_in_app_only && !item.is_for_targeted_pages_only)\n                .find((item) => item.product_id === productID) || {};\n        },\n\n        findPromotion(productId, cleverBridgeCartIDs) {\n            if (!productId) return {};\n            if (!cleverBridgeCartIDs?.length) return {};\n\n            return this.promotionList.find((item) => {\n                if (item.product_id !== productId) return false;\n                return cleverBridgeCartIDs.find((id) => item.license_ids?.includes(id));\n            }) || {};\n        },\n    },\n};\n","import { chunk, merge } from 'lodash-es';\nimport { mapState, mapActions } from 'vuex';\nimport promotions from '@core/mixins/promotions.js';\n\n/**\n * Check if any of the given license IDs are covered by the promo.\n * Supports both license_ids array and discounts[].list fallback.\n * @param {Object} promo - promotion object\n * @param {number[]} ids - array of license IDs\n */\nexport function isPromoLicenseMatch(promo, ids) {\n    const promoIDs = promo?.license_ids || [];\n    if (promoIDs.length) return promoIDs.some((id) => ids.includes(id));\n\n    const discounts = promo?.discounts || [];\n    return discounts.some((item) => item.list?.some((id) => ids.includes(id)));\n}\n\nexport default {\n    mixins: [promotions],\n\n    computed: {\n        ...mapState({\n            licensesItems: (state) => state.licenses.data,\n            productItems: (state) => state.products.items,\n            internalProductId: (state) => state.pages?.page?.product_id || null,\n        }),\n    },\n\n    methods: {\n        ...mapActions({\n            generateSessionURL: 'cleverbridge/get',\n        }),\n\n        findCleverBridgeCart(slice, settings) {\n            const licenses = this.recursiveSearch(slice || {}, 'cleverBridgeCartID').flat(2);\n            const cleverBridgeCartList = licenses.map((license) => license.cleverBridgeCartID).flat(2);\n            return this.getLicenses({ ...settings, cleverBridgeCartList });\n        },\n\n        productCTA(settings) {\n            const type = settings?.isPurchase ? 'purchasePageCTA' : 'productPageCTA';\n            const productId = settings?.productId || this.internalProductId;\n            return this.productItems[productId]?.parameters?.common?.[type] || {};\n        },\n\n        async getLicenses(settings) {\n            // The currency of the country selected by the user should be used.\n            const locale = settings?.locale || this.$store.state.geolocation.desiredLocale || this.$store.state.geolocation.requestedLocale;\n\n            await this.$store.dispatch('locales/getLocaleData', { locale });\n\n            const PAGINATE_SIZE = 50;\n            const payload = {\n                locale,\n                currency: this.productCurrency,\n                paginate: { number: 1, size: PAGINATE_SIZE },\n            };\n\n            const pageSettingsCTA = this.productCTA(settings);\n\n            const license = merge({}, pageSettingsCTA, settings);\n            const licenses = license?.cleverBridgeCartList || [license?.cleverBridgeCartID] || [];\n\n            if (licenses.length === 1) {\n                const cleverBridgeCartID = licenses[0];\n                const productId = this.settings?.productId || this.internalProductId;\n\n                // The promotion can be added locally in the page settings\n                const promoLocal = this.findPromotion(productId, [cleverBridgeCartID]);\n                const promoLocalLicenseID = Number(promoLocal.license_id_override) || promoLocal.promoSettings?.product_page_license_id;\n\n                // or globally in the promotions section\n                const promoGlobal = this.promotionList.find((item) => item.product_id === productId) || {};\n                const promoGlobalLicenseID = Number(promoGlobal.license_id_override) || promoGlobal.promoSettings?.product_page_license_id;\n\n                licenses.push(promoLocalLicenseID || promoGlobalLicenseID);\n            }\n\n            const promisesWithOutPromo = chunk(licenses.filter(Number), PAGINATE_SIZE)\n                .map((cleverbridgeIDs) => this.$store.dispatch('licenses/getList', { ...payload, cleverbridgeIDs }));\n\n            await Promise.all(promisesWithOutPromo);\n        },\n\n        licenseData({ cleverBridgeCartID, settingsCTA }) {\n            const resultDefault = { price: 0, price_promo: 0 };\n            const cleverbBridgeID = (cleverBridgeCartID || settingsCTA?.cleverBridgeCartID || '').toString();\n            if (!cleverbBridgeID) return resultDefault;\n\n            const compare = (i) => i.cleverbridge_id === cleverbBridgeID && i.currency === this.productCurrency;\n            const license = this.licensesItems.find(compare) || resultDefault;\n            const productId = license.product_id;\n            const promotionActive = this.findPromotion(productId, [cleverBridgeCartID]);\n            const promotion = merge({}, promotionActive, settingsCTA);\n            const discounts = promotion.discounts || [];\n            const promotionItem = discounts.find((item) => item.list.includes(cleverBridgeCartID)) || {};\n            const discount = discounts.length\n                ? (promotionItem.discount || 0)\n                : (promotion.discount || 0);\n\n            if (discount) {\n                const priceDiscount = (license.price * discount) / 100;\n                const pricePromo = license.price - priceDiscount;\n                return {\n                    ...license,\n                    ...promotion,\n                    discount,\n                    cleverbridge_id: cleverBridgeCartID,\n                    price_promo: Math.floor(pricePromo * 100) / 100,\n                };\n            }\n\n            return license;\n        },\n\n        setPromo() {\n            const productId = this.purchasePageCTA?.productId || this.internalProductId;\n            const cleverBridgeCartIDs = this.licensesItems.map((item) => Number(item.cleverbridge_id));\n            const promotionActive = this.findPromotion(productId, cleverBridgeCartIDs);\n\n            this.promotion = merge({}, promotionActive, this.purchasePageCTA);\n\n            const hasDiscount = this.promotion.discount || this.promotion.discounts?.length;\n            this.promotion.isActive = Boolean(hasDiscount && !this.promotion?.doNotApplyPromo);\n\n            if (!this.promotion.isActive) return;\n            if (!this.products?.items) return;\n\n            this.products.selected = Number(this.promotion?.selected_licenses_count || 0);\n\n            this.products.items = this.products.items.map((item) => ({\n                ...item,\n                pc: {\n                    ...item.pc,\n                    selected: Number(this.promotion?.selected_computers_count || 0),\n                },\n                cloud: {\n                    ...item.cloud,\n                    selected: Number(this.promotion?.[`default_cloud_capacity_${item.id}`] || 0),\n                },\n            }));\n        },\n\n        isPromoLicenseMatch,\n\n        initSettingsCTA(list) {\n            const settings = (list || []).filter((item) => item?.productPageCTA?.productId);\n            return settings.map((product) => this.getLicenses(product.productPageCTA));\n        },\n\n        recursiveSearch(obj, searchKey, results = []) {\n            Object.keys(obj || {}).forEach((key) => {\n                if (key === searchKey) {\n                    results.push(obj);\n                    return;\n                }\n                if (typeof obj[key] === 'object') {\n                    this.recursiveSearch(obj[key], searchKey, results);\n                }\n            });\n            return results;\n        },\n    },\n};\n","export const TYPES = ['main', 'promo'];\n\nexport default {};\n","<template>\n    <div class=\"a-product-card\" :class=\"className\">\n        <div>\n            <div class=\"a-product-card__header\">\n                <div class=\"a-product-card__title\">\n                    {{ title }}\n                </div>\n                <a-picture\n                    v-if=\"logo\"\n                    class=\"a-product-card__logo\"\n                    :link=\"logo\"\n                    :alt=\"title\"\n                />\n            </div>\n            <div class=\"a-product-card__content\">\n                <a-label\n                    v-if=\"labelTarget\"\n                    size=\"l\"\n                    type=\"text-label\"\n                >\n                    {{ labelTarget }}\n                </a-label>\n                <a-label\n                    v-if=\"labelFlag\"\n                    size=\"l\"\n                    variant=\"success\"\n                    type=\"text-label\"\n                    :glyph=\"labelFlagIcon\"\n                >\n                    {{ labelFlag }}\n                </a-label>\n                <p v-if=\"$slots.default\" class=\"a-product-card__text\">\n                    <slot />\n                </p>\n            </div>\n        </div>\n        <div v-if=\"isFooter\" class=\"a-product-card__footer\">\n            <a-button\n                v-if=\"learnLink\"\n                class=\"a-product-card__button\"\n                v-bind=\"learnLink\"\n                :size=\"learnLink.size || 'small'\"\n                :text=\"learnLink.text || 'Learn More'\"\n                :event=\"{ content: title, ...learnLink.event }\"\n                native-type=\"a\"\n            />\n            <a-button\n                v-if=\"tryLink\"\n                class=\"a-product-card__button\"\n                v-bind=\"tryLink\"\n                :size=\"tryLink.size || 'small'\"\n                :type=\"tryLink.type || 'action'\"\n                :text=\"tryLink.text || 'Try Now'\"\n                :event=\"{ content: title, ...tryLink.event }\"\n                native-type=\"a\"\n                @click=\"handleClick(tryLink.optionsSURL)\"\n            />\n        </div>\n        <a-loader :is-visible=\"isVisibleSURL\" />\n    </div>\n</template>\n\n<script>\nimport AButton from '@core/components/button/button.vue';\nimport ALabel from '@core/components/label/label.vue';\nimport ALoader from '@core/components/loader/loader.vue';\nimport APicture from '@core/components/picture/picture.vue';\nimport analytics from '@core/mixins/analytics.js';\nimport cleverbridge from '@core/mixins/cleverbridge.js';\nimport purchasing from '@core/mixins/purchasing.js';\nimport { TYPES } from './constants.js';\n\nexport default {\n    name: 'AProductCard',\n\n    components: {\n        AButton,\n        ALabel,\n        ALoader,\n        APicture,\n    },\n\n    mixins: [purchasing, analytics, cleverbridge],\n\n    props: {\n        /**\n         * Card type: default state / promo state\n         */\n        type: {\n            type: String,\n            default: undefined,\n            validator: (value) => value === undefined || TYPES.includes(value),\n        },\n\n        /**\n         * Logo URL\n         */\n        logo: {\n            type: String,\n            default: undefined,\n        },\n\n        title: {\n            type: String,\n            required: true,\n        },\n\n        text: {\n            type: String,\n            default: undefined,\n        },\n\n        labelTarget: {\n            type: String,\n            default: undefined,\n        },\n\n        labelFlag: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * Label flag Icon name\n         */\n        labelFlagIcon: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * Is Footer exists\n         */\n        isFooter: {\n            type: Boolean,\n            default: true,\n        },\n\n        /**\n         * Button Try\n         */\n        tryLink: {\n            type: Object,\n            default: undefined,\n        },\n\n        /**\n         * Button Learn\n         */\n        learnLink: {\n            type: Object,\n            default: undefined,\n        },\n    },\n\n    computed: {\n        className() {\n            return {\n                [`a-product-card_type_${this.type}`]: this.type,\n            };\n        },\n    },\n\n    methods: {\n        handleClick(optionsSURL) {\n            if (optionsSURL) {\n                const options = this.storeOptionsSURL(optionsSURL);\n                this.redirectToCleverbridge(options);\n            }\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-product-card {\n    border-radius: 4px;\n    box-shadow: var(--av-shadow-small);\n    border: var(--av-border);\n    background-color: var(--av-inversed-primary);\n    position: relative;\n    padding: 24px;\n    display: flex;\n    flex-direction: column;\n    width: 100%;\n    height: 100%;\n\n    &__header {\n        display: flex;\n        justify-content: space-between;\n        margin-bottom: 8px;\n    }\n\n    &__title {\n        color: var(--av-nav-primary);\n        @mixin title-accent;\n    }\n\n    &__logo {\n        height: 56px;\n        width: auto;\n        flex-shrink: 0;\n        margin-inline-start: 8px;\n    }\n\n    &__content {\n        flex: 1 1 auto;\n        margin-bottom: 16px;\n    }\n\n    &__text {\n        @mixin body;\n\n        color: var(--av-fixed-secondary);\n    }\n\n    .a-label {\n        display: flex;\n        margin-bottom: 8px;\n    }\n\n    &__label {\n        @mixin paragraph-accent;\n\n        margin-bottom: 8px;\n\n        &_target {\n            color: var(--av-nav-secondary);\n        }\n\n        &_flag {\n            color: var(--av-button-action);\n        }\n    }\n\n    &__glyph {\n        fill: var(--av-fixed-success);\n        margin-inline-end: 8px;\n    }\n\n    &__footer {\n        gap: 8px 0;\n        display: flex;\n        justify-content: space-between;\n        flex-wrap: wrap;\n        margin: auto 0 -8px;\n    }\n\n    &__button {\n        margin: 0 8px;\n        white-space: nowrap;\n        text-align: center;\n        flex: 1 0 50%;\n    }\n\n    @media (--viewport-desktop-wide) {\n        &__button {\n            flex: 1 0 0;\n        }\n    }\n}\n</style>\n","export default {\n    props: {\n        margin: {\n            type: String,\n            default: undefined,\n            required: false,\n        },\n        padding: {\n            type: String,\n            default: undefined,\n            required: false,\n        },\n    },\n    computed: {\n        marginClasses() {\n            return this.margin || [];\n        },\n        paddingClasses() {\n            return this.padding || [];\n        },\n    },\n};\n","/**\n * Feature card title sizes\n *\n * @type {string[]}\n */\nexport const SIZES = ['m', 's', 'xs'];\nexport const DIRECTIONS = ['column', 'row'];\n\nexport default {};\n","<template>\n    <div class=\"a-feature-card\" :class=\"{ [`a-feature-card_size_${size}`]: size, [`a-feature-card_layout_${direction}`]: direction }\">\n        <div v-if=\"icon\" class=\"a-feature-card__image-container\">\n            <a-icon\n                class=\"a-feature-card__image\"\n                :class=\"{ 'a-feature-card__image_s': iconSmall }\"\n                :number=\"icon\"\n                :icon-alt=\"iconAlt || title\"\n                :icon-variant=\"iconVariant\"\n            />\n        </div>\n        <div class=\"a-feature-card__desc\">\n            <a-label\n                v-if=\"label\"\n                size=\"s\"\n                variant=\"success\"\n                class=\"a-feature-card__label\"\n                :class=\"{ 'a-feature-card__label_with-image': icon, 'a-feature-card__label_with-image_small': icon && iconSmall }\"\n            >\n                {{ label }}\n            </a-label>\n            <a-link\n                v-if=\"to && title\"\n                class=\"a-feature-card__title a-feature-card__link\"\n                :to=\"to\"\n                :text=\"title\"\n                :target=\"target\"\n            />\n            <component :is=\"titleTagName\" v-if=\"!to && title\" class=\"a-feature-card__title\">\n                {{ title }}\n            </component>\n            <a-dangerous-html v-if=\"content\" class=\"a-feature-card__text\" :content=\"content\" />\n            <div v-if=\"tags.length\" class=\"a-feature-card__tags\">\n                <div v-for=\"(item, index) in tags\" :key=\"index\" class=\"a-feature-card__tag-item\">\n                    <a-label class=\"a-feature-card__tag-label\" variant=\"info\" size=\"s\">\n                        {{ item }}\n                    </a-label>\n                </div>\n            </div>\n            <a-link\n                v-if=\"link\"\n                class=\"a-feature-card__bottom-link\"\n                v-bind=\"link\"\n                :size=\"link.size || 'body'\"\n            />\n        </div>\n    </div>\n</template>\n\n<script>\nimport ADangerousHtml from '@core/components/dangerous-html/dangerous-html.vue';\nimport AIcon from '@core/components/icon/icon.vue';\nimport ALabel from '@core/components/label/label.vue';\nimport ALink from '@core/components/link/link.vue';\nimport { SIZES, DIRECTIONS } from './constants.js';\n\nexport default {\n    name: 'AFeatureCard',\n\n    components: {\n        ALink,\n        ALabel,\n        AIcon,\n        ADangerousHtml,\n    },\n\n    props: {\n        /**\n         * Title\n         */\n        title: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * Title Tag\n         */\n        titleTag: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * Title size\n         */\n        size: {\n            type: String,\n            default: 'm',\n            validator: (value) => value === undefined || SIZES.includes(value),\n        },\n\n        /**\n         * Image URL\n         */\n        icon: {\n            type: [String, Number],\n            default: '',\n        },\n\n        /**\n         * Icon small\n         */\n        iconSmall: {\n            type: Boolean,\n            default: false,\n        },\n\n        /**\n         * Icon variant\n         */\n        iconVariant: {\n            type: Boolean,\n            default: false,\n        },\n\n        /**\n         * Image alt\n         */\n        iconAlt: {\n            type: String,\n            default: '',\n        },\n\n        /**\n         * Label text\n         */\n        label: {\n            type: String,\n            default: '',\n        },\n\n        /**\n         * Icon content\n         */\n        content: {\n            type: String,\n            default: '',\n        },\n\n        /**\n         * card layout direction\n         */\n        direction: {\n            type: String,\n            default: 'column',\n            validator: (value) => value === undefined || DIRECTIONS.includes(value),\n        },\n\n        /**\n         * card link to\n         */\n        to: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * card link target\n         */\n        target: {\n            type: String,\n            default: undefined,\n        },\n\n        /**\n         * tags\n         */\n        tags: {\n            type: Array,\n            default: () => [],\n        },\n\n        /**\n         * Optional link\n         */\n        link: {\n            type: Object,\n            default: undefined,\n        },\n    },\n\n    data() {\n        return {\n            titleTagName: this.titleTag || 'div',\n        };\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n\n.a-feature-card {\n    position: relative;\n    display: flex;\n    align-items: flex-start;\n    height: 100%;\n\n    &__desc {\n        display: flex;\n        flex-direction: column;\n        align-items: flex-start;\n        width: 100%;\n        height: 100%;\n    }\n\n    &__label {\n        position: absolute;\n        inset-inline-start: 0;\n        bottom: 100%;\n\n        &_with-image {\n            top: 96px;\n            bottom: auto;\n        }\n\n        &_with-image_small {\n            top: 48px;\n        }\n    }\n\n    &__image-container {\n        margin-bottom: 16px;\n    }\n\n    &__image {\n        width: 96px;\n        height: 96px;\n\n        &_s {\n            width: 48px;\n            height: 48px;\n        }\n    }\n\n    &__title {\n        width: 100%;\n        font-weight: 600;\n        color: var(--av-nav-primary);\n        :deep(.a-link__content) {\n            width: 100%;\n            font-weight: 600;\n        }\n    }\n\n    &__link {\n        color: var(--av-brand-secondary);\n    }\n\n    &__bottom-link {\n        margin-top: auto;\n        padding-top: 8px;\n\n        :deep(.a-link__content) {\n            font-weight: 700;\n        }\n    }\n\n    &__text {\n        max-width: 100%;\n        margin-top: 8px;\n    }\n\n    &__tags {\n        display: flex;\n        flex-wrap: wrap;\n        margin: 16px 0 -8px;\n    }\n\n    &__tag-item {\n        margin-inline-end: 8px;\n        margin-bottom: 8px;\n    }\n\n    &__tag-label {\n        display: block;\n    }\n\n    &_size {\n        &_m {\n            .a-feature-card__title {\n                @mixin title;\n                :deep(.a-link__content) {\n                    @mixin title;\n                }\n            }\n        }\n\n        &_s {\n            .a-feature-card__title {\n                @mixin lead;\n                :deep(.a-link__content) {\n                    @mixin lead;\n                }\n            }\n        }\n\n        &_xs {\n            .a-feature-card__title {\n                @mixin paragraph;\n                :deep(.a-link__content) {\n                    @mixin paragraph;\n                }\n            }\n        }\n    }\n\n    &_layout {\n        &_row {\n            flex-direction: row;\n\n            .a-feature-card__label {\n                position: static;\n            }\n\n            .a-feature-card__image-container {\n                margin-inline-end: 16px;\n                flex-shrink: 0;\n\n                @media (--viewport-desktop) {\n                    margin-inline-end: 28px;\n                }\n\n                @media (--viewport-desktop-wide) {\n                    margin-inline-end: 36px;\n                }\n\n                @media (--viewport-desktop-large) {\n                    margin-inline-end: 41px;\n                }\n            }\n        }\n\n        &_column {\n            flex-direction: column;\n        }\n    }\n}\n</style>\n","import { merge } from 'lodash-es';\n\nexport default {\n    props: {\n        translations: {\n            type: Object,\n            default: () => ({}),\n        },\n    },\n    computed: {\n        l10n() {\n            return merge({}, this.$attrs, this.$props, this.$props.translations);\n        },\n    },\n};\n","<template>\n    <div class=\"a-rate\">\n        <div class=\"a-rate__back\">\n            <a-svg-sprite\n                v-for=\"i in 5\"\n                :key=\"`back_rate_${i}`\"\n                class=\"a-rate__icon\"\n                name=\"star\"\n                title=\"Rate\"\n            />\n        </div>\n        <div class=\"a-rate__front\" :style=\"{ width: percent }\">\n            <a-svg-sprite\n                v-for=\"i in 5\"\n                :key=\"`front_rate_${i}`\"\n                class=\"a-rate__icon a-rate__icon_action\"\n                name=\"star\"\n                title=\"Rate\"\n            />\n        </div>\n    </div>\n</template>\n\n<script>\nimport ASvgSprite from '@core/components/svg-sprite/svg-sprite.vue';\n\nexport default {\n    name: 'ARate',\n\n    components: {\n        ASvgSprite,\n    },\n\n    props: {\n        /**\n         * Rating\n         */\n        rate: {\n            type: [Number, String],\n            default: 5,\n            validator: (value) => value <= 5,\n        },\n    },\n\n    computed: {\n        percent() {\n            const value = this.parseRate(this.rate);\n            return `${(value * 100) / 5}%`;\n        },\n    },\n\n    methods: {\n        parseRate(raw) {\n            const n = Number(raw);\n            const prohibitRounding = n % 0.5 === 0;\n\n            return prohibitRounding ? n.toFixed(1) : Math.round(n).toFixed(1);\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-rate {\n    display: inline-block;\n    position: relative;\n    margin: 0 -2px;\n\n    &__front,\n    &__back {\n        display: flex;\n    }\n\n    &__front {\n        position: absolute;\n        top: 0;\n        inset-inline-start: 0;\n        overflow: hidden;\n\n        .a-rate__icon {\n            flex-shrink: 0;\n        }\n    }\n\n    &__icon {\n        width: 20px;\n        height: 20px;\n        fill: var(--av-fixed-invisible);\n        margin: 0 0;\n\n        &_action {\n            fill: var(--av-fixed-success);\n        }\n    }\n}\n</style>\n","<template>\n    <div class=\"a-review-card\" :class=\"{ 'dark': isDarkTheme }\">\n        <div class=\"a-review-card__content\">\n            <a-svg-sprite class=\"a-review-card__quotes\" name=\"quote-mark\" />\n            <div class=\"a-review-card__review\">\n                <h3 v-if=\"title\" class=\"a-review-card__title\">\n                    {{ title }}\n                </h3>\n                <v-clamp class=\"a-review-card__text\" tag=\"p\" :max-lines=\"5\">\n                    {{ text }}\n                    <template #after=\"{ clamped, expand, collapse, expanded }\">\n                        <a-link\n                            v-if=\"cta\"\n                            :text=\"`&nbsp;${cta.text}`\"\n                            style=\"vertical-align: top\"\n                            :type=\"isDarkTheme ? 'light' : 'regular'\"\n                            @click=\"handleCta\"\n                        />\n                        <a-link\n                            v-else-if=\"clamped\"\n                            :text=\"`&nbsp;${lm}`\"\n                            style=\"vertical-align: top\"\n                            :type=\"isDarkTheme ? 'light' : 'regular'\"\n                            @click=\"expand\"\n                        />\n                        <a-link\n                            v-else-if=\"expanded\"\n                            :text=\"`&nbsp;${ll}`\"\n                            style=\"vertical-align: top; margin-inline-start: 5px\"\n                            :type=\"isDarkTheme ? 'light' : 'regular'\"\n                            @click=\"collapse\"\n                        />\n                    </template>\n                </v-clamp>\n            </div>\n        </div>\n        <div class=\"a-review-card__bottom\" :class=\"{ 'a-review-card__bottom--logo-top': companyLogo }\">\n            <div v-if=\"logo && companyLogo\" class=\"a-review-card__company\">\n                <a-tooltip v-if=\"companyName\" :content=\"companyName\" placement=\"top\">\n                    <a-picture class=\"a-review-card__logo a-review-card__logo--large\" :link=\"logo\" />\n                </a-tooltip>\n                <a-picture v-else class=\"a-review-card__logo a-review-card__logo--large\" :link=\"logo\" />\n            </div>\n            <div v-else-if=\"type !== 'company' && !noImage\" class=\"a-review-card__user\">\n                <a-svg-sprite\n                    v-if=\"!image\"\n                    class=\"a-review-card__user profile-svg\"\n                    name=\"default-user\"\n                    :class-name=\"{ 'a-review-card__default-icon': true }\"\n                />\n                <a-picture v-else class=\"a-review-card__image\" :link=\"image\" />\n            </div>\n            <div class=\"a-review-card__author\">\n                <div class=\"a-review-card__author__base-info\">\n                    <div class=\"a-review-card__author__base-info__name\">\n                        {{ author }}\n                    </div>\n                    <a-dangerous-html class=\"a-review-card__author__base-info__role\" :content=\"userRole\" />\n                </div>\n                <div v-if=\"rate || personalCompanyLogo\" class=\"a-review-card__author__company-details\">\n                    <template v-if=\"logo && personalCompanyLogo\">\n                        <a-tooltip v-if=\"companyName\" :content=\"companyName\" placement=\"top\">\n                            <a-picture class=\"a-review-card__logo\" :link=\"logo\" />\n                        </a-tooltip>\n                        <a-picture v-else class=\"a-review-card__logo\" :link=\"logo\" />\n                    </template>\n                    <div v-if=\"rate\" class=\"a-review-card__rate\">\n                        <a-rate class=\"a-review-card__rate__stars\" :rate=\"rate\" />\n                        <div class=\"a-review-card__rate__value\">\n                            {{ rate }}\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</template>\n\n<script>\nimport VClamp from 'vue3-clamp';\nimport ADangerousHtml from '@core/components/dangerous-html/dangerous-html.vue';\nimport ALink from '@core/components/link/link.vue';\nimport APicture from '@core/components/picture/picture.vue';\nimport ARate from '@core/components/rate/rate.vue';\nimport ASvgSprite from '@core/components/svg-sprite/svg-sprite.vue';\nimport ATooltip from '@core/components/tooltip/tooltip.vue';\n\nexport default {\n    name: 'AReviewCard',\n\n    components: {\n        ARate,\n        ALink,\n        ASvgSprite,\n        VClamp,\n        ADangerousHtml,\n        APicture,\n        ATooltip,\n    },\n\n    props: {\n        title: {\n            type: String,\n            required: false,\n            default: undefined,\n        },\n\n        text: {\n            type: String,\n            required: true,\n        },\n\n        /**\n         * Company type\n         */\n        type: {\n            type: String,\n            required: false,\n            default: '',\n            validator: (val) => ['personal', 'company', ''].includes(val),\n        },\n\n        logo: {\n            type: String,\n            required: false,\n            default: undefined,\n        },\n\n        image: {\n            type: String,\n            required: false,\n            default: undefined,\n        },\n\n        /**\n         * Author name\n         */\n        author: {\n            type: String,\n            required: false,\n            default: undefined,\n        },\n\n        companyName: {\n            type: String,\n            required: false,\n            default: undefined,\n        },\n\n        /**\n         * Author role\n         */\n        role: {\n            type: String,\n            required: false,\n            default: undefined,\n        },\n\n        /**\n         * Author rate\n         */\n        rate: {\n            type: [Number, String],\n            required: false,\n            default: undefined,\n            validator: (value) => value <= 5,\n        },\n\n        isDarkTheme: {\n            type: Boolean,\n            default: false,\n        },\n\n        noImage: Boolean,\n\n        lm: {\n            type: String,\n            default: 'Show more',\n        },\n        ll: {\n            type: String,\n            default: 'Show less',\n        },\n\n        cta: {\n            type: Object,\n            default: undefined,\n        },\n    },\n\n    computed: {\n        companyLogo() {\n            return this.logo && this.logoPosition === 'top';\n        },\n        logoPosition() {\n            return this.type === 'company' ? 'top' : 'bottom';\n        },\n        personalCompanyLogo() {\n            return this.logo && this.type === 'personal' && this.logoPosition === 'bottom';\n        },\n        userRole() {\n            let role = '';\n\n            if (this.role) {\n                role = this.role;\n            }\n\n            if (this.companyName) {\n                role = this.role ? `${role}, ${this.companyName}` : this.companyName;\n            }\n\n            return role || 'Verified Acronis user';\n        },\n    },\n\n    methods: {\n        handleCta() {\n            window.open(this.cta.link);\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\">\n.a-review-card {\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    @media (--viewport-desktop-wide) {\n        padding-inline-start: 97px;\n    }\n    @media (--viewport-desktop-large) {\n        padding-inline-start: 111px;\n    }\n\n    &.dark {\n        .a-rate__icon {\n            fill: rgba(255, 255, 255, 0.2);\n            &_action {\n                fill: var(--av-fixed-success);\n            }\n        }\n    }\n\n    &__content {\n        margin-bottom: 32px;\n    }\n\n    &__quotes {\n        display: none;\n        position: absolute;\n        inset-inline-start: 0;\n\n        @media (--viewport-desktop-wide) {\n            fill: var(--av-brand-accent);\n            display: block;\n            width: 160px;\n            height: 131px;\n        }\n    }\n\n    &__review {\n        @mixin colls 12;\n    }\n    &__text {\n        @mixin paragraph;\n        color: var(--av-fixed-secondary);\n        .a-link {\n            .a-link__content {\n                font-size: inherit;\n                line-height: inherit;\n                background: none !important;\n                font-weight: 600;\n            }\n        }\n    }\n    &__title {\n        @mixin title-accent;\n        margin-bottom: 16px;\n        color: var(--av-nav-primary);\n        &:before {\n            content: '“';\n            @media (--viewport-desktop-wide) {\n                display: none;\n            }\n        }\n        &:after {\n            content: '”';\n            @media (--viewport-desktop-wide) {\n                display: none;\n            }\n        }\n    }\n\n    &__clamp {\n        cursor: pointer;\n        padding-inline-start: 7px;\n    }\n\n    &__bottom {\n        display: flex;\n        flex-direction: column;\n\n        &--logo-top {\n            flex-direction: column;\n            align-items: flex-start;\n        }\n\n        @media (--viewport-mobile-wide) {\n            &:not(.a-review-card__bottom--logo-top) {\n                flex-direction: row;\n                align-items: center;\n            }\n        }\n    }\n\n    &__company {\n        margin-bottom: 8px;\n        .a-review-card__logo {\n            max-width: 227px;\n            height: 40px;\n        }\n    }\n\n    &__logo {\n        margin-inline-end: 15px;\n\n        &--large {\n            opacity: 1;\n        }\n    }\n\n    &__user {\n        border-radius: 50%;\n        overflow: hidden;\n        width: 80px;\n        height: 80px;\n        margin-bottom: 8px;\n\n        @media (--viewport-mobile-wide) {\n            width: 96px;\n            height: 96px;\n            margin-bottom: 0;\n            margin-inline-end: 16px;\n        }\n    }\n\n    &__default-icon {\n        width: 80px;\n        height: 80px;\n        background-color: var(--av-brand-accent);\n\n        @media (--viewport-mobile-wide) {\n            width: 96px;\n            height: 96px;\n        }\n    }\n\n    &__image {\n        width: 100%;\n        height: 100%;\n        object-fit: cover;\n\n        .a-picture__img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n        }\n    }\n\n    &__author {\n        @mixin paragraph;\n        color: var(--av-fixed-secondary);\n        display: flex;\n        flex-direction: column;\n        justify-content: center;\n\n        &__base-info {\n            display: flex;\n            flex-direction: column;\n\n            &__name {\n                color: var(--av-nav-primary);\n                font-weight: 700;\n            }\n        }\n\n        &__company-details {\n            display: flex;\n            align-items: center;\n            margin-top: 8px;\n            .v-popover {\n                display: flex;\n            }\n            .a-review-card__logo {\n                max-width: 227px;\n                height: 40px;\n            }\n        }\n    }\n\n    &__rate {\n        display: flex;\n        align-items: center;\n\n        &__stars {\n            margin-inline-end: 10px;\n\n            .a-rate__icon {\n                width: 24px;\n                height: 24px;\n            }\n        }\n\n        &__value {\n            @mixin lead-accent;\n            color: var(--av-nav-primary);\n        }\n    }\n}\n</style>\n","<template>\n    <li class=\"a-slide\" :class=\"className\">\n        <slot />\n    </li>\n</template>\n\n<script>\nexport default {\n    name: 'ASlide',\n\n    inject: ['slideWithBorder'],\n\n    computed: {\n        className() {\n            return {\n                'a-slide_with-border': this.slideWithBorder,\n            };\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-slide {\n    @media (--viewport-desktop) {\n        &_with-border {\n            border-inline-start: var(--av-border);\n            padding-inline-start: 24px;\n        }\n    }\n\n    &:only-child {\n        opacity: 1;\n    }\n}\n\n.a-slide {\n    position: relative;\n    inset-inline-start: 0;\n    width: 85%;\n\n    @media (--viewport-tablet) {\n        width: 60%;\n    }\n\n    @media (--viewport-desktop) {\n        width: 40%;\n    }\n\n    .a-slider_off & {\n        width: 100%;\n        max-width: 100%;\n    }\n}\n</style>\n","import { Fragment, Slot, VNode } from 'vue';\n\nexport function VSlotUnwrap(slot?: Slot): VNode[] {\n    if (!slot) return [];\n\n    const flatten = (nodes: VNode[]): VNode[] => nodes.flatMap((node) => {\n        if (!node) return [];\n        if (node.type === Fragment && Array.isArray(node.children)) {\n            return flatten(node.children as VNode[]);\n        }\n        return [node];\n    });\n\n    return flatten(slot());\n}\n","<template>\n    <div\n        ref=\"slider\"\n        class=\"a-slider\"\n        :class=\"className\"\n    >\n        <ul class=\"a-slider__wrapper\">\n            <slot />\n        </ul>\n\n        <div v-if=\"showControls\" class=\"a-slider__nav\">\n            <ul v-if=\"options.showPagination\" class=\"a-slider__dots\">\n                <li v-for=\"i in sliderLength\" :key=\"i\" class=\"a-slider__dot\" />\n            </ul>\n\n            <div v-if=\"options.showNavigation\" class=\"a-slider__controls\">\n                <button class=\"a-slider__control a-slider__control_prev\" aria-label=\"Previous slide\">\n                    <a-glyph class=\"a-slider__control-arrow\" :name=\"options.glyphs?.left || 'icon-pointer-left'\" />\n                </button>\n\n                <button class=\"a-slider__control a-slider__control_next\" aria-label=\"Next slide\">\n                    <a-glyph class=\"a-slider__control-arrow\" :name=\"options.glyphs?.right || 'icon-pointer-right'\" />\n                </button>\n            </div>\n\n            <div v-if=\"options.showCounter\" class=\"a-slider__counter\">\n                <div class=\"a-slider__dots\" />\n            </div>\n        </div>\n\n        <div\n            v-if=\"options.useBarsPagination\"\n            class=\"a-slider__nav a-slider__nav--bars\"\n            :class=\"barsClasses\"\n            :style=\"cssVars\"\n        >\n            <template v-if=\"showCompactLayout\">\n                <div ref=\"paginationWrapper\" class=\"pagination-items pagination-items--compact\" />\n                <div v-if=\"options.showNavigation\" class=\"compact-wrapper\">\n                    <button class=\"a-slider__control a-slider__control_prev\" aria-label=\"Previous slide\">\n                        <a-glyph class=\"a-slider__control-arrow\" name=\"icon-pointer-left\" />\n                    </button>\n                    <button class=\"a-slider__control a-slider__control_next\" aria-label=\"Next slide\">\n                        <a-glyph class=\"a-slider__control-arrow\" name=\"icon-pointer-right\" />\n                    </button>\n                </div>\n            </template>\n            <template v-else>\n                <button v-if=\"options.showNavigation\" class=\"a-slider__control a-slider__control_prev\" aria-label=\"Previous slide\">\n                    <a-glyph class=\"a-slider__control-arrow\" name=\"icon-pointer-left\" />\n                </button>\n\n                <div ref=\"paginationWrapper\" class=\"pagination-items\" />\n\n                <button v-if=\"options.showNavigation\" class=\"a-slider__control a-slider__control_next\" aria-label=\"Next slide\">\n                    <a-glyph class=\"a-slider__control-arrow\" name=\"icon-pointer-right\" />\n                </button>\n            </template>\n        </div>\n    </div>\n</template>\n\n<script>\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport breakpoint from '@core/mixins/breakpoint.js';\nimport { VSlotUnwrap } from '@utils/v-slot';\n\nconst AUTOPLAY_DEFAULT_DELAY_SEC = 4;\nconst MIN_SLIDES_FOR_COMPACT_LAYOUT = 7;\nconst DEFAULT_CHANGE_SPEED_MS = 550;\n\nconst BARS_CLASS = 'pagination-item';\nconst BARS_ACTIVE_CLASS = 'pagination-item--active';\n\nexport default {\n    name: 'ASlider',\n\n    components: {\n        AGlyph,\n    },\n\n    mixins: [breakpoint],\n\n    provide() {\n        return {\n            slideWithBorder: this.slideWithBorder,\n        };\n    },\n\n    props: {\n        options: {\n            type: Object,\n            default: () => ({}),\n        },\n\n        slideWithBorder: {\n            type: Boolean,\n            default: false,\n        },\n\n        theme: {\n            type: String,\n            default: 'light',\n            validator: (val) => ['light', 'dark'].includes(val),\n        },\n\n        paginationAlignment: {\n            type: String,\n            default: 'left',\n            validator: (val) => ['left', 'center', 'right'].includes(val),\n        },\n    },\n\n    emits: ['change'],\n\n    data() {\n        return {\n            activeSlideProgress: this.options.useAutoplay ? -100 : 0,\n        };\n    },\n\n    computed: {\n        barsClasses() {\n            const alignment = this.showCompactLayout ? 'left' : this.paginationAlignment;\n            return [\n                `a-slider__nav--align-${alignment}`,\n                { 'a-slider__nav--compact': this.showCompactLayout },\n            ];\n        },\n\n        showCompactLayout() {\n            return this.isMobile && this.sliderLength > MIN_SLIDES_FOR_COMPACT_LAYOUT;\n        },\n\n        showControls() {\n            const options = this.options;\n            if (options.useBarsPagination) return false;\n            return options.showPagination || options.showNavigation || options.showCounter;\n        },\n\n        sliderLength() {\n            return VSlotUnwrap(this.$slots.default)?.length ? VSlotUnwrap(this.$slots.default).filter((s) => s.tag).length : 0;\n        },\n\n        className() {\n            return {\n                'a-slider_theme_dark': this.theme === 'dark',\n                'a-slider_theme_light': this.theme === 'light',\n            };\n        },\n\n        cssVars() {\n            const progress = this.options.useAutoplay ? this.activeSlideProgress : 0;\n            const res = {\n                '--active-slide-progress': `${progress}%`,\n            };\n\n            if (this.options.useBarsPagination) {\n                res['--swap-speed'] = `${this.options.speed || DEFAULT_CHANGE_SPEED_MS}ms`;\n            }\n\n            return res;\n        },\n\n        getPaginationOptions() {\n            if (this.options.useBarsPagination) return this.getBarsPaginationOptions;\n            if (this.options.showPagination || this.options.showCounter) return this.getDefaultPaginationOptions;\n            return {};\n        },\n\n        getBarsPaginationOptions() {\n            return {\n                el: this.$refs.paginationWrapper,\n                type: 'bullets',\n                bulletClass: BARS_CLASS,\n                bulletActiveClass: BARS_ACTIVE_CLASS,\n                clickable: true,\n                renderBullet: (index, className) => `<div class=\"${className}\"><div class=\"inner\"></div></div>`,\n                ...this.options.customPagination,\n            };\n        },\n\n        getDefaultPaginationOptions() {\n            return {\n                el: this.$refs.slider?.querySelector('.a-slider__dots'),\n                type: this.options.paginationType || 'fraction',\n                bulletElement: 'li',\n                bulletClass: 'a-slider__dot',\n                bulletActiveClass: 'a-slider__dot_active',\n                clickable: true,\n                currentClass: 'a-slider__counter-current',\n                totalClass: 'a-slider__counter-total',\n                renderFraction: (currentClass, totalClass) => `\n                        <span class=\"${currentClass}\"></span>\n                        <span class=\"a-slider__counter-text\">${this.options.counterText || 'of'}</span>\n                        <span class=\"${totalClass}\"></span>\n                    `,\n                ...this.options.customPagination,\n            };\n        },\n    },\n\n    async mounted() {\n        if (this.options.skipInit) return;\n        await this.$nextTick(); // await to properly bind button controls for compact layout\n        await this.initSwiper();\n    },\n\n    beforeUnmount() {\n        this.$refs.slider?.removeEventListener('click', this.handleSlideClick);\n        this.$refs.slider?.removeEventListener('mouseenter', this.handleWrapperMouseEnter);\n        this.$refs.slider?.removeEventListener('mouseleave', this.handleWrapperMouseLeave);\n        this.swiper?.destroy();\n    },\n\n    methods: {\n        async initSwiper() {\n            const SwiperImport = await import('swiper');\n            const Swiper = SwiperImport.default;\n            const { Navigation, Pagination } = await import('swiper/modules');\n\n            const swiperOptions = {\n                modules: [Navigation, Pagination],\n                wrapperClass: 'a-slider__wrapper',\n                slideClass: 'a-slide',\n                slideActiveClass: 'a-slide_active',\n                slideNextClass: 'a-slide_next',\n                slideToClickedSlide: true,\n                observer: true,\n                observeParents: true,\n                observeSlideChildren: true,\n                watchOverflow: false,\n                watchSlidesProgress: true,\n                navigation: {\n                    nextEl: '.a-slider__control_next',\n                    prevEl: '.a-slider__control_prev',\n                    disabledClass: 'a-slider__control_disabled',\n                },\n                pagination: this.getPaginationOptions,\n                ...this.options,\n                on: {\n                    afterInit: this.onSwiperInit,\n                    slideChange: this.onSlideChange,\n                    ...this.options.on,\n                },\n                loop: Boolean(this.options.useLoop),\n            };\n\n            if (this.options.useAutoplay) {\n                await this.attachAutoplayOptions(swiperOptions);\n            }\n\n            this.swiper = new Swiper(this.$refs.slider, swiperOptions);\n\n            this.attachSmallCardsListeners();\n        },\n\n        async attachAutoplayOptions(swiperOptions) {\n            const { Autoplay } = await import('swiper/modules');\n\n            const delay = this.options.slideChangeSeconds || AUTOPLAY_DEFAULT_DELAY_SEC;\n            swiperOptions.modules.push(Autoplay);\n            // eslint-disable-next-line no-param-reassign\n            swiperOptions.autoplay = {\n                delay: delay * 1000,\n                disableOnInteraction: false,\n                pauseOnMouseEnter: false,\n            };\n            // eslint-disable-next-line no-param-reassign\n            swiperOptions.on.autoplayTimeLeft = (instance, time, progress) => {\n                this.activeSlideProgress = -100 + (1 - progress) * 100;\n            };\n\n            this.$refs.slider?.addEventListener('mouseenter', this.handleWrapperMouseEnter, true);\n            this.$refs.slider?.addEventListener('mouseleave', this.handleWrapperMouseLeave, true);\n        },\n\n        handleWrapperMouseEnter(event) {\n            if (!event.target.classList.contains('a-slider__wrapper')) return;\n            this.swiper?.autoplay.pause();\n        },\n\n        handleWrapperMouseLeave(event) {\n            if (!event.target.classList.contains('a-slider__wrapper')) return;\n            this.swiper?.autoplay.resume();\n        },\n\n        attachSmallCardsListeners() {\n            if (this.options.sliderType !== 'card-small') return;\n            this.$refs.slider?.addEventListener('click', this.handleSlideClick, true);\n        },\n\n        handleSlideClick(event) {\n            if (!event.target.classList.contains('a-slide')) return;\n            this.swiper?.slideNext();\n        },\n\n        onSwiperInit(instance) {\n            const sliderElement = this.$refs.slider;\n\n            if (this.options.sendEvent) {\n                // eslint-disable-next-line no-param-reassign\n                instance.previousIndex = instance.activeIndex;\n            }\n\n            // Hack for https://github.com/nolimits4web/swiper/issues/4052\n            // Unfortunately proposed solutions don't work\n            // Instead, we check if all slides are fully visible and disable buttons manually in this case\n            window.setTimeout(() => {\n                const slides = [...sliderElement.querySelectorAll('.a-slide')];\n                const fullFit = slides.every((slide) => slide.classList.contains('swiper-slide-fully-visible'));\n                if (fullFit) {\n                    const buttons = [...sliderElement.querySelectorAll('.a-slider__control')];\n                    buttons.forEach((button) => button.classList.add('a-slider__control_disabled'));\n                }\n            }, 500);\n        },\n\n        onSlideChange(instance) {\n            this.$emit('change', instance.activeIndex);\n            if (!this.options.sendEvent) return;\n            // eslint-disable-next-line no-param-reassign\n            instance.previousIndex = instance.activeIndex;\n        },\n    },\n};\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-slider {\n    position: relative;\n    width: 100%;\n    overflow: hidden;\n\n    &:not(.a-slider_off) {\n        .a-slider__wrapper {\n            position: relative;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            transition-property: transform;\n            box-sizing: content-box;\n            transform: translate3d(0, 0, 0);\n        }\n        :deep(.a-slide) {\n            flex-shrink: 0;\n            transition: opacity 0.2s ease-in-out;\n            user-select: none;\n        }\n    }\n\n    &__nav {\n        margin-top: 24px;\n        display: flex;\n        flex-wrap: wrap;\n\n        &--bars {\n            gap: 20px;\n\n            @media (--viewport-mobile-wide) {\n                gap: 32px;\n            }\n\n            .a-slider__control {\n                margin: 0;\n            }\n        }\n\n        &--align-left {\n            justify-content: flex-start;\n        }\n\n        &--align-center {\n            justify-content: center;\n        }\n\n        &--align-right {\n            justify-content: flex-end;\n        }\n\n        &--compact {\n            flex-direction: column;\n            justify-content: initial;\n            gap: 16px;\n            padding: 0 16px;\n\n            .compact-wrapper {\n                display: flex;\n                gap: 16px;\n            }\n        }\n    }\n\n    &__content {\n        display: flex;\n    }\n\n    &__dots {\n        display: flex;\n        align-items: center;\n        margin: 0 -4px;\n    }\n\n    &__controls {\n        margin: 0 -12px;\n        display: flex;\n    }\n\n    &__control {\n        margin: 0 12px;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        width: 32px;\n        height: 32px;\n        border: 1px solid var(--av-button-secondary);\n        border-radius: 50%;\n        background-color: rgba(255, 255, 255, 0);\n        cursor: pointer;\n        transition: background-color 0.2s ease-in-out;\n\n        @media (--viewport-mobile-wide) {\n            width: 48px;\n            height: 48px;\n        }\n\n        &:hover {\n            background-color: var(--el-secondary-hover);\n        }\n\n        &:active {\n            background-color: var(--el-secondary-active);\n        }\n\n        &_disabled {\n            cursor: default;\n            border-color: var(--av-button-secondary-light);\n\n            .a-slider__control-arrow {\n                fill: var(--av-button-secondary-light);\n            }\n\n            &:hover,\n            &:active,\n            &:focus {\n                background: transparent;\n            }\n        }\n    }\n\n    &__control-arrow {\n        fill: var(--av-button-secondary);\n        transition: fill 0.2s ease-in-out;\n    }\n\n    &_theme {\n        &_dark {\n            .a-slider__dot {\n                &::before {\n                    background-color: var(--av-brand-secondary);\n                }\n\n                &_active {\n                    &::before {\n                        background-color: var(--av-inversed-primary);\n                    }\n                }\n            }\n        }\n    }\n\n    @media (--viewport-mobile-wide) {\n        &__controls {\n            margin: 0 -12px;\n        }\n    }\n\n    @media (--viewport-desktop) {\n        &__control_next {\n            display: flex;\n\n            &:hover {\n                fill: var(--av-nav-primary);\n            }\n\n            &:focus {\n                outline: none;\n            }\n        }\n    }\n}\n\n/* This part has been moved from leaked webinar.vue slice; TODO: check if it works as intended */\n.a-slider {\n    &__counter {\n        &-total,\n        &-text,\n        &-current {\n            color: var(--av-fixed-light);\n            font-size: 18px;\n        }\n    }\n\n    /* Swiper.js has a bug with looped slides when there are only 2 slides\n     * when the same slide is visible 2 times, \"next\" button doesnt generate additional looped slides\n     * Solution: only when there are 2 slides, give them each 50% width on desktop+\n     */\n    &[data-slides='2'] {\n        .a-slide {\n            @media (--viewport-desktop) {\n                width: 50%;\n            }\n        }\n    }\n}\n\n.slide-storybook {\n    background: #d0caca;\n    text-align: center;\n    padding: 24px 48px;\n}\n\n/* new pagination */\n.pagination-items {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n\n    :deep(.pagination-item) {\n        position: relative;\n        display: flex;\n        align-items: center;\n        width: 24px;\n        height: 24px;\n        cursor: pointer;\n        will-change: width;\n        transition: width var(--swap-speed) ease;\n\n        @media (--viewport-mobile-wide) {\n            width: 48px;\n        }\n\n        .inner {\n            overflow: hidden;\n            width: 100%;\n            height: 8px;\n            border-radius: 4px;\n            background: var(--el-secondary-active);\n        }\n\n        &--active {\n            width: 40px;\n\n            @media (--viewport-mobile-wide) {\n                width: 96px;\n            }\n\n            .inner:after {\n                content: '';\n                display: block;\n                border-radius: 4px;\n                width: 100%;\n                height: 100%;\n                background: var(--av-brand-primary);\n                will-change: transform;\n                transform: translateX(var(--active-slide-progress));\n            }\n        }\n    }\n\n    &--compact {\n        justify-content: flex-start;\n    }\n}\n\n.a-slider_theme_dark {\n    background: var(--av-nav-primary);\n    padding-bottom: 56px;\n\n    @media (--viewport-mobile-wide) {\n        padding-bottom: 64px;\n    }\n\n    @media (--viewport-tablet) {\n        padding-bottom: 48px;\n    }\n\n    .pagination-items {\n        :deep(.pagination-item) {\n            .inner {\n                background: #677994;\n            }\n\n            &:not(.pagination-item--active) {\n                &:hover {\n                    .inner {\n                        background: var(--av-inversed-light);\n                    }\n                }\n            }\n\n            &--active {\n                .inner:after {\n                    background: #f0f2f4;\n                }\n            }\n        }\n    }\n\n    .a-slider__control {\n        border-color: var(--av-button-inversed);\n\n        &-arrow {\n            fill: var(--av-button-inversed);\n        }\n\n        &:hover {\n            background-color: var(--av-button-inversed-hover);\n        }\n\n        &:active {\n            background-color: var(--av-button-inversed-active);\n        }\n\n        &_disabled {\n            border-color: var(--av-button-inversed-light);\n\n            &:hover,\n            &:active,\n            &:focus {\n                background: transparent;\n            }\n\n            .a-slider__control-arrow {\n                fill: var(--av-button-inversed-light);\n            }\n        }\n    }\n\n    .a-slider__counter {\n        color: var(--av-inversed-primary);\n    }\n}\n</style>\n\n<style lang=\"postcss\">\n/*\n * It looks like Swiper doesn't reuse existing markup for &__dot and &__counter_* we put in template.\n * Therefore scoped styles will never apply just because Swiper doesn't render IDs for it for obvious reasons.\n * Given that Vue doesn't actually provide a public API for these IDs (see https://github.com/vuejs/vue-loader/issues/851)\n * we have nothing left but to un-scope them.\n * TODO: is it possible to do it better? Otherwise we'll have to have an unscoped block in every component which wants to override this\n */\n.a-slider {\n    li.a-slider__dot {\n        position: relative;\n        width: 16px;\n        height: 16px;\n        margin: 0 4px;\n        cursor: pointer;\n\n        &::before {\n            content: '';\n            position: absolute;\n            top: 50%;\n            inset-inline-start: 50%;\n            width: 6px;\n            height: 6px;\n            transform: translate(-50%, -50%);\n            background-color: var(--av-brand-secondary);\n            border-radius: 100%;\n        }\n\n        &:focus {\n            outline: none;\n        }\n\n        &_active {\n            &::before {\n                background-color: var(--av-inversed-primary);\n            }\n        }\n    }\n\n    .a-slider__counter {\n        margin-inline-start: 24px;\n        display: flex;\n        align-items: center;\n        font-size: 18px;\n        line-height: 29px;\n    }\n\n    .a-slider__counter-current {\n        font-weight: 600;\n    }\n\n    .a-slider__counter-text {\n        margin: 0 8px;\n    }\n\n    .a-slider__counter-totals {\n        margin: 0 8px;\n    }\n}\n[dir=\"rtl\"] {\n    .a-slider__control-arrow {\n        transform: rotate(180deg);\n    }\n}\n</style>\n","<template>\n    <li class=\"a-accordion-item\" :class=\"{ active: isActive }\">\n        <component\n            :is=\"titleTag\"\n            class=\"title\"\n            role=\"button\"\n            :tabindex=\"0\"\n            :aria-expanded=\"isActive\"\n            @click=\"onClick\"\n            @keydown.enter.space.prevent=\"onClick\"\n        >\n            <template v-if=\"title\">\n                <a-glyph class=\"icon\" :name=\"glyph\" />\n                {{ title }}\n            </template>\n            <template v-else-if=\"$slots.title\">\n                <slot name=\"title\" />\n            </template>\n        </component>\n        <div\n            v-if=\"$slots.default\"\n            ref=\"content\"\n            class=\"content\"\n            role=\"region\"\n        >\n            <div ref=\"inner\" class=\"content-wrapper\" :aria-hidden=\"!isActive\">\n                <slot />\n            </div>\n        </div>\n    </li>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, inject, onMounted, onBeforeUnmount } from 'vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport { getElementPath } from '@utils/analytics';\n\ndefineOptions({ name: 'AAccordionItem' });\n\nconst props = defineProps({\n    glyph: { type: String, default: 'icon-pointer-right' },\n    title: { type: String, default: '' },\n    titleTag: { type: String, default: 'div' },\n    event: { type: Object, default: null },\n    active: Boolean,\n});\n\nconst isActive = ref(props.active);\nconst content = ref<HTMLElement | null>(null);\n\nconst parent: any = inject('accordionParent');\nconst register = inject('registerAccordionItem') as (item: any) => void;\n\nlet observer: MutationObserver | null = null;\n\nconst changeHeight = () => {\n    const el = content.value;\n    if (!el) return;\n    el.style.height = `${el.scrollHeight}px`;\n};\n\nconst changeHeightIfActive = () => {\n    if (isActive.value) changeHeight();\n};\n\nconst onClick = (event: any) => {\n    const willOpen = !isActive.value;\n    parent?.handleAllActives?.();\n    isActive.value = willOpen;\n    changeHeightIfActive();\n    parent?.emitActiveChanged?.(isActive.value);\n    parent?.emitChangeEvent?.();\n\n    if (!props.event) return;\n\n    window.dataLayer = window.dataLayer || [];\n    window.dataLayer.push({\n        event: 'Acronis',\n        eventCategory: 'Interactions',\n        eventContext: willOpen ? 'show' : 'hide',\n        eventLocation: getElementPath(event.target),\n        ...props.event,\n    });\n};\n\nonMounted(() => {\n    isActive.value = props.active;\n\n    register?.({\n        isActive: () => isActive.value,\n        removeActive: () => (isActive.value = false),\n    });\n\n    changeHeightIfActive();\n    window.addEventListener('resize', changeHeightIfActive);\n\n    // MutationObserver for dynamic inner content\n    if (content.value) {\n        observer = new MutationObserver((mutations) => {\n            if (mutations.some((x) => x.type === 'childList')) {\n                changeHeightIfActive();\n            }\n        });\n        observer.observe(content.value, {\n            childList: true,\n            subtree: true,\n        });\n    }\n});\n\nonBeforeUnmount(() => {\n    window.removeEventListener('resize', changeHeightIfActive);\n    observer?.disconnect();\n});\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-accordion-item {\n    border-top: var(--av-border);\n\n    &:not(.active) {\n        .content {\n            height: 0 !important;\n        }\n    }\n\n    .title {\n        cursor: pointer;\n        display: flex;\n        color: var(--av-nav-primary);\n        transition: color ease-out 0.3s;\n        padding: 16px 40px 16px 16px;\n\n        &:hover {\n            color: var(--av-nav-secondary);\n\n            :deep(.icon) {\n                fill: var(--av-nav-secondary);\n            }\n        }\n    }\n\n    .content {\n        overflow: hidden;\n        max-height: max-content;\n        font-size: 14px;\n        line-height: 20px;\n        transition: height 0.2s ease-in-out;\n    }\n\n    .content-wrapper {\n        padding: 8px 40px 16px;\n    }\n\n    :deep(.icon) {\n        margin-top: 4px;\n        transition: fill ease-out 0.3s, transform 0.25s ease-out;\n        flex-shrink: 0;\n        fill: var(--av-brand-secondary);\n        margin-inline-end: 8px;\n    }\n\n    &.active :deep(.icon) {\n        transform: rotate(90deg);\n    }\n}\n\n[dir=\"rtl\"] {\n    .a-accordion-item :deep(.icon) {\n        transform: rotate(180deg);\n    }\n    .a-accordion-item.active :deep(.icon) {\n        transform: rotate(90deg);\n    }\n}\n</style>\n","<!-- eslint-disable vue/multi-word-component-names -->\n<template>\n    <ul class=\"a-accordion\" :class=\"className\">\n        <slot />\n    </ul>\n</template>\n\n<script setup lang=\"ts\">\nimport { provide, ref, computed } from 'vue';\n\nconst props = defineProps<{\n    isWide?: boolean,\n    oneOnlyMode?: boolean,\n}>();\n\nconst emit = defineEmits<{\n  (event: 'change', value: number): void;\n  (event: 'changedActive', isActive: boolean): void;\n}>();\n\nconst items = ref<any[]>([]);\n\nprovide('registerAccordionItem', (item: any) => {\n    items.value.push(item);\n});\n\nconst handleAllActives = () => {\n    if (props.oneOnlyMode) {\n        items.value.forEach((item) => item.removeActive?.());\n    }\n};\n\nconst emitChangeEvent = () => {\n    const activeIndex = items.value.findIndex((item) => item.isActive?.());\n    emit('change', activeIndex);\n};\n\nconst emitActiveChanged = (state: boolean) => {\n    emit('changedActive', state);\n};\n\nprovide('accordionParent', {\n    handleAllActives,\n    emitChangeEvent,\n    emitActiveChanged,\n});\n\nconst className = computed(() => ({ 'is-wide': props.isWide }));\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-accordion {\n  &.is-wide :deep(.a-accordion-item) {\n    position: relative;\n\n    &::before {\n      content: \"\";\n      position: absolute;\n      top: 0;\n      inset-inline-start: 0;\n      margin-inline-start: calc(50% - 50vw);\n      width: 100vw;\n      height: 1px;\n      background-color: var(--av-brand-accent);\n    }\n\n    &:last-of-type {\n      border-bottom: 0;\n    }\n\n    &:last-of-type::after {\n      content: \"\";\n      position: absolute;\n      bottom: 0;\n      inset-inline-start: 0;\n      margin-inline-start: calc(50% - 50vw);\n      width: 100vw;\n      height: 1px;\n      background-color: var(--av-brand-accent);\n    }\n\n    &.active {\n      background-color: var(--av-brand-lightest);\n      margin: 0 var(--container-paddings-mobile);\n      padding: 0 var(--container-paddings-mobile);\n      box-shadow: inset 0 5px 6px rgba(138, 173, 207, 0.1865);\n\n      @media (--viewport-mobile-wide) {\n        margin: 0 var(--container-paddings-mobile-wide);\n        padding: 0 var(--container-paddings-mobile-wide);\n      }\n\n      @media (--viewport-desktop-wide) {\n        margin: 0 var(--container-paddings-desktop-wide);\n        padding: 0 var(--container-paddings-desktop-wide);\n      }\n\n      @media (--viewport-desktop-large) {\n        margin: 0 -100%;\n        padding: 0 100%;\n      }\n    }\n\n    .title {\n      padding: 16px 0;\n\n      @mixin lead-strong;\n\n      &:hover {\n        color: var(--av-nav-primary);\n      }\n    }\n\n    .icon {\n      margin-inline-end: 16px;\n    }\n\n    .content {\n      @mixin paragraph;\n    }\n\n    .content-wrapper {\n      padding: 8px 32px 56px;\n    }\n  }\n\n  :deep(.a-accordion-item) {\n    &:last-of-type {\n      border-bottom: var(--av-border);\n      margin-bottom: 40px;\n    }\n  }\n}\n</style>\n\n","import { LOCALE_DEFAULT } from '@model/const/locales';\n\nexport const DEFAULT_LANGUAGE = 'English';\nexport const BANNERS_COUNT = 10;\nexport const ARCHIVE_EVENTS_COUNT = 6;\nexport const IN_PERSON_EVENTS_COUNT = 36;\nexport const OT_EVENTS_COUNT = 36;\nexport const OT_EVENTS_TO_SHOW = 6;\nexport const WEBINARS_AND_VIRTUAL_COUNT = 36;\nexport const WEBINARS_AND_VIRTUAL_TO_SHOW = 6;\nexport const AUDIENCES_ID = {\n    serviceProviders: 1,\n    business: 2,\n    resellers: 3,\n    home: 4,\n};\nexport const AUDIENCES_COUNT = 36;\nexport const CATEGORIES_COUNT = 36;\nexport const LANGUAGES_COUNT = 50;\nexport const DEFAULT_COUNTRY_ID = 238; // U.S.\nexport const OTHER_EVENTS_COUNT = 3;\nexport const VIDEOS_LIMIT = 3;\nexport const RESOURCES_LIMIT = 6;\nexport const LANGUAGES_MAP = {\n    'Chinese (Simplified)': 'zh-cn',\n    'Chinese (Traditional)': 'zh-tw',\n    'Portuguese (Brazilian)': 'pt-br',\n    Bulgarian: 'bg-bg',\n    Czech: 'cs-cz',\n    English: 'en-us',\n    French: 'fr-fr',\n    German: 'de-de',\n    Italian: 'it-it',\n    Japanese: 'ja-jp',\n    Korean: 'ko-kr',\n    Polish: 'pl-pl',\n    Portuguese: 'pt-br',\n    Spanish: 'es-es',\n    Turkish: 'tr-tr',\n};\n\nexport const SLICE_DATA_FOOTER = {\n    sliceSettingsName: 's-events-footer',\n    locale: LOCALE_DEFAULT,\n    type: 'short',\n    theme: 'light',\n    hasLocaleSelector: false,\n    hasBorderTopSocials: false,\n};\n","class Sticky {\n    constructor(el, options) {\n        this.el = el;\n        this.options = options || {};\n        this.className = this.options.activeClass || 'is-sticky';\n        this.pageOffsetTop = 0;\n\n        this.el.classList.add('directive-v-sticky');\n\n        const page = document.querySelector('.page');\n\n        if (page) {\n            this.pageOffsetTop = page.offsetTop;\n        }\n\n        this.parent = this.el.closest(this.options.parent);\n\n        this.isSticky = false;\n\n        this.sticky = this.sticky.bind(this);\n\n        this.init();\n    }\n\n    init() {\n        window.addEventListener('load', this.sticky);\n        window.addEventListener('scroll', this.sticky, {\n            capture: true,\n            passive: true,\n        });\n        window.addEventListener('resize', this.sticky, {\n            capture: true,\n            passive: true,\n        });\n    }\n\n    sticky() {\n        const ribbonHeight = document.querySelector('.locale-selector-ribbon')?.offsetHeight || 0;\n\n        const mainHeaderHeight = document.querySelector('.s-main-header')?.offsetHeight || 0;\n\n        const parentOffset = this.parent ? this.parent.offsetTop + this.parent.offsetHeight : 0;\n        let treshold = parentOffset + this.pageOffsetTop - this.el.offsetHeight;\n\n        treshold = this.options.stickyHeader ? treshold - mainHeaderHeight : treshold + ribbonHeight;\n\n        this.isSticky = window.pageYOffset > treshold;\n\n        if (this.isSticky) {\n            this.el.classList.add(this.className);\n        } else {\n            this.el.classList.remove(this.className);\n        }\n    }\n\n    destroy() {\n        window.removeEventListener('load', this.sticky);\n        window.removeEventListener('scroll', this.sticky, {\n            capture: true,\n            passive: true,\n        });\n        window.removeEventListener('resize', this.sticky, {\n            capture: true,\n            passive: true,\n        });\n    }\n}\n\nexport default {\n    mounted(el, binding) {\n        el.sticky = new Sticky(el, binding.value);\n    },\n\n    unmounted(el) {\n        if (el.sticky) {\n            el.sticky.destroy();\n            el.sticky = null;\n        }\n    },\n};\n","// This is a cheap implementation of a pub-sub bus based on https://github.com/developit/mitt project\n// Used for now to replace `.$on` / `.$off` / `.$once` APIs removed in Vue3\n\n// It's used for one single particular reason (tabChangeActive broadcast) and might be not needed at all.\n// TODO: consider finding other options which don't utilize an external dependency (even though it's a tiny one)\n\n// NOTE: it's useless during SSR phase\n\nimport mitt from 'mitt';\n\nconst instance = mitt();\n\nexport default instance;\n","import Cookies from 'js-cookie';\nimport { mapState } from 'vuex';\nimport { DEFAULT_COUNTRY_ID } from '@model/const/events.ts';\nimport GlobalPubSub from '@utils/global-pub-sub.ts';\n\nexport default {\n    async beforeMount() {\n        if (this.$store.state.events.country?.id) return;\n\n        const countryId = await this.getCountryFromGeoAPI();\n        if (!countryId) return;\n\n        await this.$store.dispatch('events/setCountry', { countryId, isConfirmed: false });\n        GlobalPubSub.emit('onLocationSet');\n    },\n\n    computed: {\n        ...mapState({ eventsStore: (state) => state.events }),\n\n        countryId() {\n            return this.eventsStore.country?.id || DEFAULT_COUNTRY_ID;\n        },\n\n        locale() {\n            return this.$store.state.geolocation.finalLocale;\n        },\n\n        countries() {\n            return this.$store.state.countries.items || [];\n        },\n\n        translations() {\n            return this.$store.state.slices.items['events-interface-translations'] || {};\n        },\n\n        audiences() {\n            return (this.eventsStore.audiences.items || []).map((item) => ({\n                ...item,\n                title: this.translations.audiences?.[item.title] || item.title,\n            }));\n        },\n\n        categories() {\n            return (this.eventsStore.categories.items || []).map((item) => ({\n                ...item,\n                title: this.translations.categoryNames?.[item.title] || item.title,\n            }));\n        },\n\n        localeSelect() {\n            const countryId = this.eventsStore.country?.id || null;\n            return {\n                isReady: countryId !== null,\n                countries: this.countries,\n                countryIdentifiedTitle: this.translations.countryIdentifiedTitle,\n                changeCountryTitle: this.translations.changeCountryTitle,\n                confirmCountryButtonTitle: this.translations.confirmCountryButtonTitle,\n                countryChangedLabel: this.translations.countryChanged,\n                countryId,\n                isConfirmed: this.eventsStore.country?.isConfirmed,\n                theme: this.theme,\n            };\n        },\n    },\n\n    methods: {\n        getYoutubeIdFromUrl(url) {\n            const regExp = /^.*((youtu.be\\/)|(v\\/)|(\\/u\\/\\w\\/)|(embed\\/)|(watch\\?))\\??v?=?([^#&?]*).*/;\n            const match = url.match(regExp);\n            return match && match[7].length === 11 ? match[7] : false;\n        },\n\n        videoDurationToTimeString(duration) {\n            const durationNum = parseInt(duration, 10);\n            const hours = Math.floor(durationNum / 3600);\n            const minutes = Math.floor(durationNum / 60) % 60;\n            const seconds = durationNum % 60;\n\n            return [hours, minutes, seconds]\n                .map((v) => (v < 10 ? `0${v}` : v))\n                .filter((v, i) => v !== '00' || i > 0)\n                .join(':');\n        },\n\n        async getCountryFromGeoAPI() {\n            await this.$store.dispatch('geolocation/getGeoLocation');\n            const location = this.$store.state.geolocation.location;\n\n            if (!location) return null;\n\n            const countries = this.$store.state.countries.items || [];\n            const country = countries.find((item) => item.iso_code === location.data.country.code);\n\n            if (!country) return null;\n\n            return country.id;\n        },\n\n        setCountryCookie(countryID) {\n            Cookies.set('events_country', countryID, {\n                path: '/',\n                expires: 30, // days\n            });\n        },\n    },\n};\n","<!-- eslint-disable vue/no-multiple-template-root -->\n<template>\n    <template v-if=\"show\">\n        <slot />\n    </template>\n</template>\n\n<script setup>\nimport { ref, onMounted } from 'vue';\n\ndefineOptions({ name: 'AClientOnly' });\n\nconst show = ref(false);\nonMounted(() => {\n    show.value = true;\n});\n</script>\n","/* eslint-disable max-len */\nexport const firstDayMap: Record<number, string[]> = {\n    1: ['AD', 'AI', 'AL', 'AM', 'AN', 'AT', 'AX', 'AZ', 'BA', 'BE', 'BG', 'BM', 'BN', 'BY', 'CH', 'CL', 'CM', 'CR', 'CY', 'CZ', 'DE', 'DK', 'EC', 'EE', 'ES', 'FI', 'FJ', 'FO', 'FR', 'GB', 'GE', 'GF', 'GP', 'GR', 'HR', 'HU', 'IS', 'IT', 'KG', 'KZ', 'LB', 'LI', 'LK', 'LT', 'LU', 'LV', 'MC', 'MD', 'ME', 'MK', 'MN', 'MQ', 'MY', 'NL', 'NO', 'PL', 'PT', 'RE', 'RO', 'RS', 'RU', 'SE', 'SI', 'SK', 'SM', 'TJ', 'TM', 'TR', 'UA', 'UY', 'UZ', 'VA', 'VN', 'XK'],\n    2: [],\n    3: [],\n    4: [],\n    5: ['BD', 'MV'],\n    6: ['AE', 'AF', 'BH', 'DJ', 'DZ', 'EG', 'IQ', 'IR', 'JO', 'KW', 'LY', 'MA', 'OM', 'QA', 'SD', 'SY'],\n    7: ['AG', 'AR', 'AS', 'AU', 'BR', 'BS', 'BT', 'BW', 'BZ', 'CA', 'CN', 'CO', 'DM', 'DO', 'ET', 'GT', 'GU', 'HK', 'HN', 'ID', 'IE', 'IL', 'IN', 'JM', 'JP', 'KE', 'KH', 'KR', 'LA', 'MH', 'MM', 'MO', 'MT', 'MX', 'MZ', 'NI', 'NP', 'NZ', 'PA', 'PE', 'PH', 'PK', 'PR', 'PY', 'SA', 'SG', 'SV', 'TH', 'TN', 'TT', 'TW', 'UM', 'US', 'VE', 'VI', 'WS', 'YE', 'ZA', 'ZW'],\n};\n\nexport function getFirstDayOfWeek(region?: string) {\n    let firstDay: number | null = null;\n    // eslint-disable-next-line no-restricted-syntax\n    for (const day of Object.keys(firstDayMap)) {\n        if (firstDayMap[+Number(day)].includes((region || '').toUpperCase())) {\n            firstDay = +Number(day);\n            break;\n        }\n    }\n    return firstDay ?? 7;\n}\n","import { getCurrentInstance, onMounted, ref } from 'vue';\nimport { getFirstDayOfWeek } from './first-day-map';\n\nexport function useFirstDayOfWeek(defaultFirstDay = 7) {\n    const firstDayOfWeek = ref(defaultFirstDay);\n\n    onMounted(() => {\n        const inst = getCurrentInstance();\n        const proxy: any = inst?.proxy;\n        const parentI18n = proxy?.$i18n || proxy?.$root?.$i18n;\n        if (!parentI18n) return;\n        const locale: string = parentI18n.locale;\n        const region = locale?.split('-')[1];\n        if (region) {\n            const deduced = getFirstDayOfWeek(region);\n            if (deduced) firstDayOfWeek.value = deduced;\n        }\n    });\n\n    return { firstDayOfWeek };\n}\n","/* Modified from https://github.com/taylorhakes/fecha\n * Imported mostly 1:1 from uikit legacy\n * MIT License (c) 2015 Taylor Hakes\n */\n\n/*eslint-disable*/\n// 把 YYYY-MM-DD 改成了 yyyy-MM-dd\n\nconst token = /d{1,4}|M{1,4}|yy(?:yy)?|S{1,3}|Do|ZZ|([HhMsDm])\\1?|[aA]|\"[^\"]*\"|'[^']*'/g;\nconst twoDigits = /\\d\\d?/;\nconst threeDigits = /\\d{3}/;\nconst fourDigits = /\\d{4}/;\nconst word = /[0-9]*['a-z\\u00A0-\\u05FF\\u0700-\\uD7FF\\uF900-\\uFDCF\\uFDF0-\\uFFEF]+|[\\u0600-\\u06FF\\/]+(\\s*?[\\u0600-\\u06FF]+){1,2}/i;\n\nconst noop = () => { };\nconst pad = (val, len = 2) => String(val).padStart(len, '0');\n\nconst shorten = (arr, sLen) => arr.map((x) => x.substr(0, sLen));\nconst monthUpdate = (arrName) => (d, v, i18n) => {\n    const index = i18n[arrName].indexOf(\n        v.charAt(0).toUpperCase() + v.substr(1).toLowerCase()\n    );\n    if (~index) d.month = index;\n};\n\nconst dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];\nconst monthNames = [\n    'January', 'February', 'March', 'April', 'May', 'June',\n    'July', 'August', 'September', 'October', 'November', 'December'\n];\nconst monthNamesShort = shorten(monthNames, 3);\nconst dayNamesShort = shorten(dayNames, 3);\n\nexport const i18n = {\n    dayNamesShort,\n    dayNames,\n    monthNamesShort,\n    monthNames,\n    amPm: ['am', 'pm'],\n    DoFn(D) {\n        return D + ['th', 'st', 'nd', 'rd'][D % 10 > 3 ? 0 : (D - D % 10 !== 10) * D % 10];\n    }\n};\n\nconst formatFlags = {\n    D: (d) => d.getDay(),\n    DD: (d) => pad(d.getDay()),\n    Do: (d, i18n) => i18n.DoFn(d.getDate()),\n    d: (d) => d.getDate(),\n    dd: (d) => pad(d.getDate()),\n    ddd: (d, i18n) => i18n.dayNamesShort[d.getDay()],\n    dddd: (d, i18n) => i18n.dayNames[d.getDay()],\n    M: (d) => d.getMonth() + 1,\n    MM: (d) => pad(d.getMonth() + 1),\n    MMM: (d, i18n) => i18n.monthNamesShort[d.getMonth()],\n    MMMM: (d, i18n) => i18n.monthNames[d.getMonth()],\n    yy: (d) => String(d.getFullYear()).substr(2),\n    yyyy: (d) => d.getFullYear(),\n    h: (d) => d.getHours() % 12 || 12,\n    hh: (d) => pad(d.getHours() % 12 || 12),\n    H: (d) => d.getHours(),\n    HH: (d) => pad(d.getHours()),\n    m: (d) => d.getMinutes(),\n    mm: (d) => pad(d.getMinutes()),\n    s: (d) => d.getSeconds(),\n    ss: (d) => pad(d.getSeconds()),\n    S: (d) => Math.round(d.getMilliseconds() / 100),\n    SS: (d) => pad(Math.round(d.getMilliseconds() / 10), 2),\n    SSS: (d) => pad(d.getMilliseconds(), 3),\n    a: (d, i18n) => d.getHours() < 12 ? i18n.amPm[0] : i18n.amPm[1],\n    A: (d, i18n) => d.getHours() < 12 ? i18n.amPm[0].toUpperCase() : i18n.amPm[1].toUpperCase(),\n    ZZ: (d) => {\n        const o = d.getTimezoneOffset();\n        return (o > 0 ? '-' : '+') +\n            pad(Math.floor(Math.abs(o) / 60) * 100 + Math.abs(o) % 60, 4);\n    }\n};\n\nexport const masks = {\n    default: 'ddd MMM dd yyyy HH:mm:ss',\n    shortDate: 'M/D/yy',\n    mediumDate: 'MMM d, yyyy',\n    longDate: 'MMMM d, yyyy',\n    fullDate: 'dddd, MMMM d, yyyy',\n    shortTime: 'HH:mm',\n    mediumTime: 'HH:mm:ss',\n    longTime: 'HH:mm:ss.SSS'\n};\n\nexport function format(dateObj, mask, i18nSettings) {\n    const i18nLocal = i18nSettings || i18n;\n    if (typeof dateObj === 'number') dateObj = new Date(dateObj);\n    if (!(dateObj instanceof Date) || isNaN(dateObj.getTime())) {\n        throw new Error('Invalid Date in fecha.format');\n    }\n    mask = masks[mask] || mask || masks.default;\n    return mask.replace(token, ($0) =>\n        $0 in formatFlags ? formatFlags[$0](dateObj, i18nLocal) : $0.slice(1, -1)\n    );\n}\n\nconst parseFlags = {\n    d: [twoDigits, (d, v) => { d.day = v; }],\n    M: [twoDigits, (d, v) => { d.month = v - 1; }],\n    yy: [twoDigits, (d, v) => {\n        const da = new Date();\n        const cent = +('' + da.getFullYear()).substr(0, 2);\n        d.year = '' + (v > 68 ? cent - 1 : cent) + v;\n    }],\n    h: [twoDigits, (d, v) => { d.hour = v; }],\n    m: [twoDigits, (d, v) => { d.minute = v; }],\n    s: [twoDigits, (d, v) => { d.second = v; }],\n    yyyy: [fourDigits, (d, v) => { d.year = v; }],\n    S: [/\\d/, (d, v) => { d.millisecond = v * 100; }],\n    SS: [/\\d{2}/, (d, v) => { d.millisecond = v * 10; }],\n    SSS: [threeDigits, (d, v) => { d.millisecond = v; }],\n    D: [twoDigits, noop],\n    ddd: [word, noop],\n    MMM: [word, monthUpdate('monthNamesShort')],\n    MMMM: [word, monthUpdate('monthNames')],\n    a: [word, (d, v, i18n) => {\n        const val = v.toLowerCase();\n        if (val === i18n.amPm[0]) d.isPm = false;\n        else if (val === i18n.amPm[1]) d.isPm = true;\n    }],\n    ZZ: [/[\\+\\-]\\d\\d:?\\d\\d/, (d, v) => {\n        const parts = (v + '').match(/([\\+\\-]|\\d\\d)/gi);\n        if (parts) {\n            const minutes = +(parts[1] * 60) + parseInt(parts[2], 10);\n            d.timezoneOffset = parts[0] === '+' ? minutes : -minutes;\n        }\n    }]\n};\nparseFlags.DD = parseFlags.D;\nparseFlags.dddd = parseFlags.ddd;\nparseFlags.Do = parseFlags.dd = parseFlags.d;\nparseFlags.mm = parseFlags.m;\nparseFlags.hh = parseFlags.H = parseFlags.HH = parseFlags.h;\nparseFlags.MM = parseFlags.M;\nparseFlags.ss = parseFlags.s;\nparseFlags.A = parseFlags.a;\n\nexport function parse(dateStr, format, i18nSettings) {\n    const i18nLocal = i18nSettings || i18n;\n    if (typeof format !== 'string') throw new Error('Invalid format in fecha.parse');\n    format = masks[format] || format;\n    if (dateStr.length > 1000) return false;\n\n    let isValid = true;\n    const dateInfo = {};\n    format.replace(token, ($0) => {\n        if (parseFlags[$0]) {\n            const info = parseFlags[$0];\n            const index = dateStr.search(info[0]);\n            if (!~index) isValid = false;\n            else {\n                dateStr.replace(info[0], (result) => {\n                    info[1](dateInfo, result, i18nLocal);\n                    dateStr = dateStr.substr(index + result.length);\n                    return result;\n                });\n            }\n        }\n        return parseFlags[$0] ? '' : $0.slice(1, -1);\n    });\n    if (!isValid) return false;\n\n    const today = new Date();\n    if (dateInfo.isPm === true && dateInfo.hour != null && +dateInfo.hour !== 12)\n        dateInfo.hour = +dateInfo.hour + 12;\n    else if (dateInfo.isPm === false && +dateInfo.hour === 12)\n        dateInfo.hour = 0;\n\n    let date;\n    if (dateInfo.timezoneOffset != null) {\n        dateInfo.minute = +(dateInfo.minute || 0) - +dateInfo.timezoneOffset;\n        date = new Date(Date.UTC(\n            dateInfo.year || today.getFullYear(),\n            dateInfo.month || 0,\n            dateInfo.day || 1,\n            dateInfo.hour || 0,\n            dateInfo.minute || 0,\n            dateInfo.second || 0,\n            dateInfo.millisecond || 0\n        ));\n    } else {\n        date = new Date(\n            dateInfo.year || today.getFullYear(),\n            dateInfo.month || 0,\n            dateInfo.day || 1,\n            dateInfo.hour || 0,\n            dateInfo.minute || 0,\n            dateInfo.second || 0,\n            dateInfo.millisecond || 0\n        );\n    }\n    return date;\n}\n\nexport default { format, parse, masks, i18n };\n","/* eslint-disable max-len */\nimport { format, parse } from './date.js';\n\nconst weeks = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'] as const;\nconst months = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'] as const;\n\nconst getLabels = () => ({\n    dayNamesShort: weeks.map((w) => w),\n    dayNames: weeks.map((w) => w),\n    monthNamesShort: months.map((m) => m),\n    monthNames: months.map((m, i) => i + 1),\n    amPm: ['am', 'pm'],\n});\n\nexport const isDate = (date: unknown) => !(date == null || Number.isNaN(new Date(date as any).getTime()));\nexport const toDate = (date: unknown) => (isDate(date) ? new Date(date as any) : null);\nexport const isDateObject = (val: unknown): val is Date => val instanceof Date;\n\nexport const formatDate = (date: unknown, fmt?: string) => {\n    const d = toDate(date);\n    if (!d) return '';\n    return format(d, fmt || 'yyyy-MM-dd', getLabels());\n};\nexport const parseDate = (s: string, fmt?: string) => parse(s, fmt || 'yyyy-MM-dd', getLabels());\n\nexport const getDayCountOfMonth = (year: number, month: number) => {\n    if ([3, 5, 8, 10].includes(month)) return 30;\n    if (month === 1) return ((year % 4 === 0 && year % 100 !== 0) || year % 400 === 0) ? 29 : 28;\n    return 31;\n};\nexport const getDayCountOfYear = (year: number) => ((year % 400 === 0 || (year % 100 !== 0 && year % 4 === 0)) ? 366 : 365);\n\nexport const getFirstDayOfMonth = (date: Date) => {\n    const d = new Date(date);\n    d.setDate(1);\n    return d.getDay();\n};\nexport const prevDate = (date: Date, amount = 1) => new Date(date.getFullYear(), date.getMonth(), date.getDate() - amount);\nexport const nextDate = (date: Date, amount = 1) => new Date(date.getFullYear(), date.getMonth(), date.getDate() + amount);\n\nexport const getStartDateOfMonth = (year: number, month: number) => {\n    const result = new Date(year, month, 1);\n    const day = result.getDay();\n    return day === 0 ? prevDate(result, 7) : prevDate(result, day);\n};\n\nexport const range = (n: number) => Array.from({ length: n }, (_, i) => i);\n\nexport const modifyDate = (date: Date, y: number, m: number, d: number) => new Date(y, m, d, date.getHours(), date.getMinutes(), date.getSeconds(), date.getMilliseconds());\n\nexport const clearTime = (date: Date) => new Date(date.getFullYear(), date.getMonth(), date.getDate());\n\nexport const prevMonth = (date: Date) => {\n    let y = date.getFullYear();\n    let m = date.getMonth();\n    if (m === 0) {\n        y -= 1;\n        m = 11;\n    } else {\n        m -= 1;\n    }\n    const md = Math.min(date.getDate(), getDayCountOfMonth(y, m));\n    return modifyDate(date, y, m, md);\n};\n\nexport const nextMonth = (date: Date) => {\n    let y = date.getFullYear();\n    let m = date.getMonth();\n    if (m === 11) {\n        y += 1;\n        m = 0;\n    } else {\n        m += 1;\n    }\n    const md = Math.min(date.getDate(), getDayCountOfMonth(y, m));\n    return modifyDate(date, y, m, md);\n};\nexport const thisMonth = (date: Date) => {\n    const y = date.getFullYear();\n    const m = date.getMonth();\n    const md = Math.min(date.getDate(), getDayCountOfMonth(y, m));\n    return modifyDate(date, y, m, md);\n};\nexport const prevYear = (date: Date, amount = 1) => {\n    const y = date.getFullYear() - amount;\n    const m = date.getMonth();\n    const md = Math.min(date.getDate(), getDayCountOfMonth(y, m));\n    return modifyDate(date, y, m, md);\n};\nexport const nextYear = (date: Date, amount = 1) => {\n    const y = date.getFullYear() + amount;\n    const m = date.getMonth();\n    const md = Math.min(date.getDate(), getDayCountOfMonth(y, m));\n    return modifyDate(date, y, m, md);\n};\n\n// eslint-disable-next-line no-nested-ternary\nexport const minToMax = (a: number, b: number) => (a < b ? -1 : a > b ? 1 : 0);\n\nconst getMinMaxDate = (minDate: Date, maxDate: Date) => ({\n    minDate: new Date(minDate.getFullYear(), minDate.getMonth(), 1),\n    maxDate: new Date(maxDate.getFullYear(), maxDate.getMonth() + 1, 0),\n});\n\nexport const getLastMonths = (date: Date, n: number) => getMinMaxDate(\n    new Date(new Date(date).setMonth(date.getMonth() - n)),\n    new Date(new Date(date).setMonth(date.getMonth() - 1)),\n);\nexport const getLastMonth = (value: Date) => {\n    const d = prevMonth(value);\n    return getMinMaxDate(d, d);\n};\nexport const getNextMonth = (value: Date) => {\n    const d = nextMonth(value);\n    return getMinMaxDate(d, d);\n};\nexport const getThisMonth = (value: Date) => {\n    const d = thisMonth(value);\n    return getMinMaxDate(d, d);\n};\nexport const getNextMonths = (date: Date, n: number) => getMinMaxDate(\n    new Date(new Date(date).setMonth(date.getMonth() + 1)),\n    new Date(new Date(date).setMonth(date.getMonth() + n)),\n);\n\nexport const getLastDay = (date: Date) => ({ minDate: new Date(date.getTime() - 24 * 3600 * 1000), maxDate: date });\nexport const getToday = (date: Date) => ({ minDate: date, maxDate: date });\nexport const getLastSevenDays = (date: Date) => ({ minDate: new Date(date.getTime() - 6 * 24 * 3600 * 1000), maxDate: date });\nexport const getLastThreeDays = (date: Date) => ({ minDate: new Date(date.getTime() - 2 * 24 * 3600 * 1000), maxDate: date });\nexport const getLastThirtyDays = (date: Date) => ({ minDate: new Date(date.getTime() - 29 * 24 * 3600 * 1000), maxDate: date });\n\nexport type PredefinedType =\n  | 'lastTwelveMonths' | 'lastSixMonths' | 'lastThreeMonths' | 'lastMonth' | 'nextMonth' | 'thisMonth'\n  | 'nextThreeMonths' | 'nextSixMonths' | 'today' | 'lastday' | 'lastDay'\n  | 'lastseven' | 'lastSeven' | 'lastthirty' | 'lastThirty' | 'lastthree' | 'lastThree';\n\nexport const getPreDefinedDates = (type: PredefinedType, value?: Date | string | number) => {\n    const date = value ? new Date(value as any) : new Date();\n    switch (type) {\n        case 'lastTwelveMonths': return getLastMonths(date, 12);\n        case 'lastSixMonths': return getLastMonths(date, 6);\n        case 'lastThreeMonths': return getLastMonths(date, 3);\n        case 'lastMonth': return getLastMonth(date);\n        case 'nextMonth': return getNextMonth(date);\n        case 'thisMonth': return getThisMonth(date);\n        case 'nextThreeMonths': return getNextMonths(date, 3);\n        case 'nextSixMonths': return getNextMonths(date, 6);\n        case 'today': return getToday(date);\n        case 'lastday':\n        case 'lastDay': return getLastDay(date);\n        case 'lastseven':\n        case 'lastSeven': return getLastSevenDays(date);\n        case 'lastthirty':\n        case 'lastThirty': return getLastThirtyDays(date);\n        case 'lastthree':\n        case 'lastThree': return getLastThreeDays(date);\n        default: return { minDate: date, maxDate: date };\n    }\n};\n","<template>\n    <table\n        class=\"el-date-table\"\n        cellspacing=\"0\"\n        cellpadding=\"0\"\n        @mousedown.prevent\n    >\n        <thead>\n            <tr>\n                <th\n                    v-for=\"w in weekHeaders\"\n                    :key=\"w.key\"\n                    class=\"el-date-table__weekday-name\"\n                    :class=\"{ weekends: w.isWeekend }\"\n                >\n                    {{ w.label }}\n                </th>\n            </tr>\n        </thead>\n        <tbody>\n            <tr\n                v-for=\"(row, rIdx) in rows\"\n                :key=\"rIdx\"\n                class=\"el-date-table__row\"\n                :class=\"{ 'el-date-table__row--hidden': row.hidden }\"\n            >\n                <td\n                    v-for=\"cell in row.cells\"\n                    :key=\"cell.key\"\n                    :class=\"cell.classes\"\n                    @click=\"onPickCell(cell)\"\n                    @mouseenter=\"onHoverCell(cell)\"\n                >\n                    <div :class=\"cell.innerClass\">\n                        <span>{{ cell.text }}</span>\n                    </div>\n                </td>\n            </tr>\n        </tbody>\n    </table>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed } from 'vue';\nimport { clearTime } from '@core/components/date-picker/util/index';\n\nconst props = withDefaults(\n    defineProps<{\n    modelValue?: Date | null;\n    firstDayOfWeek?: number;\n    panelDate?: Date | null;\n    rangeStart?: Date | null;\n    rangeEnd?: Date | null;\n  }>(),\n    {\n        firstDayOfWeek: 1,\n        modelValue: null,\n        rangeStart: null,\n        panelDate: null,\n        rangeEnd: null,\n    },\n);\n\nconst emit = defineEmits<{\n  (e: 'pick', d: Date): void;\n  (e: 'update:modelValue', d: Date): void;\n  (e: 'hover', d: Date): void;\n}>();\n\nconst panelDate = computed(() => props.panelDate ?? new Date());\nconst today = clearTime(new Date());\nconst selected = computed(() => (props.modelValue ? clearTime(props.modelValue) : null));\n\nconst weekHeaders = computed(() => {\n    const labels = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];\n    const shift = props.firstDayOfWeek % 7;\n    const ordered = labels.slice(shift).concat(labels.slice(0, shift));\n    const mapIdx = (idx: number) => (shift + idx) % 7;\n    return ordered.map((label, i) => ({\n        key: `${i}-${label}`,\n        label,\n        isWeekend: [0, 6].includes(mapIdx(i)),\n    }));\n});\n\nfunction startOfGrid(year: number, month: number, firstDayOfWeek: number) {\n    const fd = firstDayOfWeek === 7 ? 0 : firstDayOfWeek;\n    const first = new Date(year, month, 1);\n    const delta = (7 + (first.getDay() - fd)) % 7;\n    return new Date(year, month, 1 - delta);\n}\nfunction isSameDay(a?: Date | null, b?: Date | null) {\n    if (!a || !b) return false;\n    return clearTime(a).getTime() === clearTime(b).getTime();\n}\n\nconst rows = computed(() => {\n    const year = panelDate.value.getFullYear();\n    const month = panelDate.value.getMonth();\n\n    const start = startOfGrid(year, month, props.firstDayOfWeek);\n    const out: Array<{ hidden?: boolean; cells: any[] }> = [];\n\n    let cursor = new Date(start);\n    for (let r = 0; r < 6; r++) {\n        const cells: any[] = [];\n        for (let c = 0; c < 7; c++) {\n            const d = clearTime(cursor);\n\n            const inPrev =\n        d.getFullYear() < year || (d.getFullYear() === year && d.getMonth() < month);\n            const inNext =\n        d.getFullYear() > year || (d.getFullYear() === year && d.getMonth() > month);\n            const inMonth = !inPrev && !inNext;\n\n            const weekend = d.getDay() === 0 || d.getDay() === 6;\n\n            const isStart = props.rangeStart ? isSameDay(d, props.rangeStart) : false;\n            const isEnd = props.rangeEnd ? isSameDay(d, props.rangeEnd) : false;\n            const isInRange =\n        props.rangeStart && props.rangeEnd\n            ? d.getTime() >= clearTime(props.rangeStart).getTime() &&\n            d.getTime() <= clearTime(props.rangeEnd).getTime()\n            : false;\n\n            const classes = {\n                'prev-month': inPrev,\n                'next-month': inNext,\n                available: inMonth,\n                weekends: weekend,\n                today: inMonth && isSameDay(d, today),\n                current: isSameDay(d, selected.value),\n                'in-range': Boolean(isInRange),\n                'start-date': isStart,\n                'end-date': isEnd,\n                'start-date-consecutive':\n          isStart && props.rangeEnd && d.getTime() < props.rangeEnd.getTime(),\n            };\n\n            cells.push({\n                key: d.toISOString(),\n                date: d,\n                text: d.getDate(),\n                classes,\n                innerClass: isStart ? 'el-date-table--start' : isEnd ? 'el-date-table--end' : '',\n            });\n\n            cursor.setDate(cursor.getDate() + 1);\n        }\n        out.push({ cells });\n    }\n\n    const last = out[5];\n    if (last && last.cells.every((cell: any) => cell.classes['next-month'])) {\n        last.hidden = true;\n    }\n\n    return out;\n});\n\nfunction onPickCell(cell: any) {\n    if (!cell.classes.available) return;\n    emit('pick', cell.date);\n    emit('update:modelValue', cell.date);\n}\nfunction onHoverCell(cell: any) {\n    emit('hover', cell.date);\n}\n</script>\n","<template>\n    <table class=\"el-month-table\" @mousedown.prevent>\n        <tbody>\n            <tr v-for=\"r in 4\" :key=\"r\">\n                <td\n                    v-for=\"c in 3\"\n                    :key=\"c\"\n                    :class=\"getCellClass((r - 1) * 3 + (c - 1))\"\n                    @click=\"pickMonth((r - 1) * 3 + (c - 1))\"\n                >\n                    <a class=\"cell\">{{ monthLabel((r - 1) * 3 + (c - 1)) }}</a>\n                </td>\n            </tr>\n        </tbody>\n    </table>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed } from 'vue';\n\nconst props = withDefaults(defineProps<{\n  date?: Date;\n  modelValue?: Date | null;\n}>(), {\n    date: () => new Date(),\n    modelValue: null,\n});\n\nconst emit = defineEmits<{\n  (e: 'update:modelValue', v: Date | null): void;\n  (e: 'pick', v: Date): void;\n}>();\n\nconst panel = computed(() => props.date ?? new Date());\n\nconst months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];\n\nfunction monthLabel(i: number) {\n    return months[i];\n}\n\nfunction getCellClass(i: number) {\n    const sel = props.date ? new Date(props.date) : null;\n    const isCurrent = sel ? (sel.getFullYear() === panel.value.getFullYear() && sel.getMonth() === i) : false;\n\n    const now = new Date();\n    const isTodayYearMonth = now.getFullYear() === panel.value.getFullYear() && now.getMonth() === i;\n\n    return {\n        'current': isCurrent,\n        'today': isTodayYearMonth,\n    };\n}\n\nfunction pickMonth(i: number) {\n    const d = new Date(panel.value.getFullYear(), i, 1);\n    emit('update:modelValue', d);\n    emit('pick', d);\n}\n</script>\n","<template>\n    <table class=\"el-year-table\" @mousedown.prevent>\n        <tbody>\n            <tr v-for=\"(row, rIdx) in grid\" :key=\"rIdx\">\n                <td\n                    v-for=\"y in row\"\n                    :key=\"y\"\n                    :class=\"getCellClass(y)\"\n                    @click=\"pickYear(y)\"\n                >\n                    <a class=\"cell\">{{ y }}</a>\n                </td>\n            </tr>\n        </tbody>\n    </table>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed } from 'vue';\n\nconst props = withDefaults(defineProps<{\n  date?: Date;\n  modelValue?: Date | null;\n}>(), {\n    date: () => new Date(),\n    modelValue: null,\n});\n\nconst emit = defineEmits<{\n  (e: 'update:modelValue', v: Date | null): void;\n  (e: 'pick', v: Date): void;\n}>();\n\nconst panel = computed(() => props.date ?? new Date());\n\nconst startYear = computed(() => {\n    const y = panel.value.getFullYear();\n    return Math.floor(y / 10) * 10 - 1;\n});\n\nconst grid = computed(() => {\n    const start = startYear.value;\n    const years: number[] = Array.from({ length: 12 }, (_, i) => start + i);\n    return [years.slice(1, 5), years.slice(5, 9), years.slice(9, 11)];\n});\n\nfunction getCellClass(y: number) {\n    const todayYear = new Date().getFullYear();\n    const selectedYear = props.date ? new Date(props.date).getFullYear() : null;\n\n    return {\n        'current': selectedYear === y,\n        'today': todayYear === y,\n    };\n}\n\nfunction pickYear(y: number) {\n    const d = new Date(y, panel.value.getMonth(), 1);\n    emit('update:modelValue', d);\n    emit('pick', d);\n}\n</script>\n","<template>\n    <div class=\"el-picker-panel__content\">\n        <div class=\"el-date-picker__header\">\n            <AGlyph\n                name=\"chevron-double-left--16\"\n                class=\"el-date-picker__header-btn\"\n                :aria-label=\"currentView === 'year' ? 'Previous Decade' : 'Previous Year'\"\n                @click=\"prevYear\"\n            />\n            <AGlyph\n                v-if=\"currentView === 'date'\"\n                name=\"i-chevron-left--16\"\n                class=\"el-date-picker__header-btn el-date-picker__header-btn--with-spacer-left\"\n                aria-label=\"Previous Month\"\n                @click=\"prevMonth\"\n            />\n            <span class=\"el-date-picker__label-wrapper\">\n                <span\n                    v-show=\"currentView === 'date'\"\n                    role=\"button\"\n                    class=\"el-date-picker__header-label el-date-picker__header-label-month\"\n                    :class=\"{ active: currentView === 'month' }\"\n                    :title=\"monthLabel\"\n                    @click=\"showMonthPicker\"\n                >\n                    {{ monthLabel }}\n                </span>\n                <span\n                    role=\"button\"\n                    class=\"el-date-picker__header-label el-date-picker__header-label-year\"\n                    :class=\"{\n                        disabled: currentView === 'year',\n                        'el-date-picker__header-label-year--full-width': currentView !== 'date',\n                    }\"\n                    @click=\"showYearPicker\"\n                >\n                    {{ yearLabel }}\n                </span>\n            </span>\n            <AGlyph\n                v-if=\"currentView === 'date'\"\n                name=\"i-chevron-right--16\"\n                class=\"el-date-picker__header-btn el-date-picker__header-btn--with-spacer-right\"\n                aria-label=\"Next Month\"\n                @click=\"nextMonth\"\n            />\n            <AGlyph\n                name=\"chevron-double-right--16\"\n                class=\"el-date-picker__header-btn\"\n                :aria-label=\"currentView === 'year' ? 'Next Decade' : 'Next Year'\"\n                @click=\"nextYear\"\n            />\n        </div>\n\n        <DateTable\n            v-show=\"currentView === 'date'\"\n            :first-day-of-week=\"firstDayOfWeek\"\n            :panel-date=\"panelDate\"\n            :model-value=\"modelValue\"\n            @pick=\"emit('pick', $event)\"\n        />\n\n        <MonthTable\n            v-show=\"currentView === 'month'\"\n            :date=\"panelDate\"\n            :model-value=\"modelValue\"\n            @pick=\"onPickMonth\"\n        />\n\n        <YearTable\n            v-show=\"currentView === 'year'\"\n            :date=\"panelDate\"\n            :model-value=\"modelValue\"\n            @pick=\"onPickYear\"\n        />\n    </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed, ref, watch } from 'vue';\nimport DateTable from '@core/components/date-picker/basic/DateTable.vue';\nimport MonthTable from '@core/components/date-picker/basic/MonthTable.vue';\nimport YearTable from '@core/components/date-picker/basic/YearTable.vue';\nimport {\n    prevMonth as _prevMonth,\n    nextMonth as _nextMonth,\n    prevYear as _prevYear,\n    nextYear as _nextYear,\n} from '@core/components/date-picker/util/index';\nimport AGlyph from '@core/components/glyph/glyph.vue';\n\nconst props = withDefaults(\n    defineProps<{\n    modelValue?: Date | null;\n    firstDayOfWeek?: number;\n  }>(),\n    {\n        modelValue: null,\n        firstDayOfWeek: 1,\n    },\n);\n\nconst emit = defineEmits<{ (e: 'pick', d: Date): void }>();\n\nconst currentView = ref<'date' | 'month' | 'year'>('date');\n\nconst inner = ref<Date>(props.modelValue ? new Date(props.modelValue) : new Date());\nwatch(\n    () => props.modelValue,\n    (v) => {\n        if (v) inner.value = new Date(v);\n    },\n);\n\nconst panelDate = computed(() => inner.value);\nconst monthLabel = computed(() =>\n    panelDate.value.toLocaleString('en-US', { month: 'short' }),\n);\n\nfunction decadeStart(d: Date) {\n    const y = d.getFullYear();\n    return Math.floor(y / 10) * 10 - 1;\n}\nconst yearLabel = computed(() => {\n    if (currentView.value === 'year') {\n        const s = decadeStart(panelDate.value);\n        return `${s + 1} - ${s + 10}`;\n    }\n    return String(panelDate.value.getFullYear());\n});\n\nfunction prevMonth() {\n    inner.value = _prevMonth(inner.value);\n}\nfunction nextMonth() {\n    inner.value = _nextMonth(inner.value);\n}\nfunction prevYear() {\n    inner.value = _prevYear(inner.value, currentView.value === 'year' ? 10 : 1);\n}\nfunction nextYear() {\n    inner.value = _nextYear(inner.value, currentView.value === 'year' ? 10 : 1);\n}\n\nfunction showMonthPicker() {\n    currentView.value = 'month';\n}\nfunction showYearPicker() {\n    currentView.value = 'year';\n}\n\nfunction onPickMonth(d: Date) {\n    inner.value = new Date(inner.value.getFullYear(), d.getMonth(), 1);\n    currentView.value = 'date';\n}\nfunction onPickYear(d: Date) {\n    inner.value = new Date(d.getFullYear(), inner.value.getMonth(), 1);\n    currentView.value = 'month';\n}\n</script>\n","<template>\n    <div class=\"el-date-range-picker__content is-left\">\n        <div class=\"el-date-range-picker__header\">\n            <AGlyph\n                name=\"chevron-double-left--16\"\n                class=\"el-date-picker__header-btn\"\n                :aria-label=\"leftCurrentView === 'year' ? 'Previous Decade' : 'Previous Year'\"\n                @click=\"leftPrevYear\"\n            />\n            <AGlyph\n                v-if=\"leftCurrentView === 'date'\"\n                name=\"i-chevron-left--16\"\n                class=\"el-date-picker__header-btn el-date-picker__header-btn--with-spacer-left\"\n                aria-label=\"Previous Month\"\n                @click=\"leftPrevMonth\"\n            />\n            <span class=\"el-date-picker__label-wrapper\">\n                <span\n                    v-show=\"leftCurrentView === 'date'\"\n                    role=\"button\"\n                    class=\"el-date-picker__header-label el-date-picker__header-label-month\"\n                    :class=\"{ active: leftCurrentView === 'month' }\"\n                    @click=\"leftShowMonth\"\n                >\n                    {{ leftMonthLabel }}\n                </span>\n                <span\n                    role=\"button\"\n                    class=\"el-date-picker__header-label el-date-picker__header-label-year\"\n                    :class=\"{\n                        disabled: leftCurrentView === 'year',\n                        'el-date-picker__header-label-year--full-width': leftCurrentView === 'year',\n                    }\"\n                    @click=\"leftShowYear\"\n                >\n                    {{ leftYearLabel }}\n                </span>\n            </span>\n            <AGlyph\n                v-if=\"leftCurrentView === 'date'\"\n                name=\"i-chevron-right--16\"\n                class=\"el-date-picker__header-btn el-date-picker__header-btn--with-spacer-right\"\n                aria-label=\"Next Month\"\n                @click=\"leftNextMonth\"\n            />\n            <AGlyph\n                name=\"chevron-double-right--16\"\n                class=\"el-date-picker__header-btn\"\n                :aria-label=\"leftCurrentView === 'year' ? 'Next Decade' : 'Next Year'\"\n                @click=\"leftNextYear\"\n            />\n        </div>\n\n        <DateTable\n            v-show=\"leftCurrentView === 'date'\"\n            :first-day-of-week=\"firstDayOfWeek\"\n            :panel-date=\"leftDate\"\n            :range-start=\"effectiveRange.start\"\n            :range-end=\"effectiveRange.end\"\n            @pick=\"onPickLeft\"\n            @hover=\"onHoverLeft\"\n        />\n        <MonthTable\n            v-show=\"leftCurrentView === 'month'\"\n            :date=\"leftDate\"\n            @pick=\"onPickLeftMonth\"\n        />\n        <YearTable\n            v-show=\"leftCurrentView === 'year'\"\n            :date=\"leftDate\"\n            @pick=\"onPickLeftYear\"\n        />\n    </div>\n\n    <div class=\"el-date-range-picker__content is-right\">\n        <div class=\"el-date-range-picker__header\">\n            <AGlyph\n                name=\"chevron-double-left--16\"\n                class=\"el-date-picker__header-btn\"\n                :aria-label=\"rightCurrentView === 'year' ? 'Previous Decade' : 'Previous Year'\"\n                @click=\"rightPrevYear\"\n            />\n            <AGlyph\n                v-if=\"rightCurrentView === 'date'\"\n                name=\"i-chevron-left--16\"\n                class=\"el-date-picker__header-btn el-date-picker__header-btn--with-spacer-left\"\n                aria-label=\"Previous Month\"\n                @click=\"rightPrevMonth\"\n            />\n            <span class=\"el-date-picker__label-wrapper\">\n                <span\n                    v-show=\"rightCurrentView === 'date'\"\n                    role=\"button\"\n                    class=\"el-date-picker__header-label el-date-picker__header-label-month\"\n                    :class=\"{ active: rightCurrentView === 'month' }\"\n                    @click=\"rightShowMonth\"\n                >\n                    {{ rightMonthLabel }}\n                </span>\n                <span\n                    role=\"button\"\n                    class=\"el-date-picker__header-label el-date-picker__header-label-year\"\n                    :class=\"{\n                        disabled: rightCurrentView === 'year',\n                        'el-date-picker__header-label-year--full-width': rightCurrentView === 'year',\n                    }\"\n                    @click=\"rightShowYear\"\n                >\n                    {{ rightYearLabel }}\n                </span>\n            </span>\n            <AGlyph\n                v-if=\"rightCurrentView === 'date'\"\n                name=\"i-chevron-right--16\"\n                class=\"el-date-picker__header-btn el-date-picker__header-btn--with-spacer-right\"\n                aria-label=\"Next Month\"\n                @click=\"rightNextMonth\"\n            />\n            <AGlyph\n                name=\"chevron-double-right--16\"\n                class=\"el-date-picker__header-btn\"\n                :aria-label=\"rightCurrentView === 'year' ? 'Next Decade' : 'Next Year'\"\n                @click=\"rightNextYear\"\n            />\n        </div>\n\n        <DateTable\n            v-show=\"rightCurrentView === 'date'\"\n            :first-day-of-week=\"firstDayOfWeek\"\n            :panel-date=\"rightDate\"\n            :range-start=\"effectiveRange.start\"\n            :range-end=\"effectiveRange.end\"\n            @pick=\"onPickRight\"\n            @hover=\"onHoverRight\"\n        />\n        <MonthTable\n            v-show=\"rightCurrentView === 'month'\"\n            :date=\"rightDate\"\n            @pick=\"onPickRightMonth\"\n        />\n        <YearTable\n            v-show=\"rightCurrentView === 'year'\"\n            :date=\"rightDate\"\n            @pick=\"onPickRightYear\"\n        />\n    </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed, ref, watch } from 'vue';\nimport DateTable from '@core/components/date-picker/basic/DateTable.vue';\nimport MonthTable from '@core/components/date-picker/basic/MonthTable.vue';\nimport YearTable from '@core/components/date-picker/basic/YearTable.vue';\nimport {\n    prevMonth,\n    nextMonth,\n    prevYear,\n    nextYear,\n    clearTime,\n} from '@core/components/date-picker/util/index';\nimport AGlyph from '@core/components/glyph/glyph.vue';\n\nconst props = withDefaults(\n    defineProps<{\n    start: Date | null;\n    end: Date | null;\n    firstDayOfWeek?: number;\n    unlinkPanels?: boolean;\n  }>(),\n    { firstDayOfWeek: 1, unlinkPanels: false },\n);\n\nconst emit = defineEmits<{\n  (e: 'update:start', d: Date | null): void;\n  (e: 'update:end', d: Date | null): void;\n  (e: 'pick', range: [Date, Date]): void;\n  (e: 'apply'): void;\n}>();\n\nconst modelStart = ref<Date | null>(props.start);\nconst modelEnd = ref<Date | null>(props.end);\n\nwatch(\n    () => props.start,\n    (v) => (modelStart.value = v),\n);\nwatch(\n    () => props.end,\n    (v) => (modelEnd.value = v),\n);\n\nconst today = new Date();\nconst leftDate = ref(new Date(today.getFullYear(), today.getMonth(), 1));\nconst rightDate = ref(new Date(today.getFullYear(), today.getMonth() + 1, 1));\n\nconst leftCurrentView = ref<'date' | 'month' | 'year'>('date');\nconst rightCurrentView = ref<'date' | 'month' | 'year'>('date');\n\nconst leftMonthLabel = computed(() =>\n    leftDate.value.toLocaleString('en-US', { month: 'short' }),\n);\nconst rightMonthLabel = computed(() =>\n    rightDate.value.toLocaleString('en-US', { month: 'short' }),\n);\n\nfunction decadeStart(d: Date) {\n    const y = d.getFullYear();\n    return Math.floor(y / 10) * 10 - 1;\n}\n\nconst leftYearLabel = computed(() => {\n    if (leftCurrentView.value === 'year') {\n        const s = decadeStart(leftDate.value);\n        return `${s + 1} - ${s + 10}`;\n    }\n    return String(leftDate.value.getFullYear());\n});\n\nconst rightYearLabel = computed(() => {\n    if (rightCurrentView.value === 'year') {\n        const s = decadeStart(rightDate.value);\n        return `${s + 1} - ${s + 10}`;\n    }\n    return String(rightDate.value.getFullYear());\n});\n\nconst hoverDate = ref<Date | null>(null);\n\nconst effectiveRange = computed(() => {\n    const s = modelStart.value ? clearTime(modelStart.value) : null;\n    const rawEnd = modelEnd.value ?? hoverDate.value ?? null;\n    const e = rawEnd ? clearTime(rawEnd) : null;\n    if (s && e)\n        return s.getTime() <= e.getTime() ? { start: s, end: e } : { start: e, end: s };\n    return { start: s, end: e };\n});\n\nfunction leftPrevMonth() {\n    leftDate.value = prevMonth(leftDate.value);\n    if (!props.unlinkPanels) rightDate.value = nextMonth(leftDate.value);\n}\nfunction leftNextMonth() {\n    leftDate.value = nextMonth(leftDate.value);\n    if (!props.unlinkPanels) rightDate.value = nextMonth(leftDate.value);\n}\n\n// DOUBLE CHEVRONS: ±10yrs in year view, ±1yr otherwise\nfunction leftPrevYear() {\n    const step = leftCurrentView.value === 'year' ? 10 : 1;\n    leftDate.value = prevYear(leftDate.value, step);\n    if (!props.unlinkPanels) rightDate.value = nextMonth(leftDate.value);\n}\nfunction leftNextYear() {\n    const step = leftCurrentView.value === 'year' ? 10 : 1;\n    leftDate.value = nextYear(leftDate.value, step);\n    if (!props.unlinkPanels) rightDate.value = nextMonth(leftDate.value);\n}\nfunction rightPrevMonth() {\n    rightDate.value = prevMonth(rightDate.value);\n}\nfunction rightNextMonth() {\n    rightDate.value = nextMonth(rightDate.value);\n}\nfunction rightPrevYear() {\n    const step = rightCurrentView.value === 'year' ? 10 : 1;\n    rightDate.value = prevYear(rightDate.value, step);\n}\nfunction rightNextYear() {\n    const step = rightCurrentView.value === 'year' ? 10 : 1;\n    rightDate.value = nextYear(rightDate.value, step);\n}\n\nfunction leftShowMonth() {\n    leftCurrentView.value = 'month';\n}\nfunction leftShowYear() {\n    leftCurrentView.value = 'year';\n}\nfunction rightShowMonth() {\n    rightCurrentView.value = 'month';\n}\nfunction rightShowYear() {\n    rightCurrentView.value = 'year';\n}\n\nfunction beginNewRange(d: Date) {\n    modelStart.value = d;\n    modelEnd.value = null;\n    hoverDate.value = null;\n    emit('update:start', modelStart.value);\n    emit('update:end', modelEnd.value);\n}\nfunction finalizeRange(a: Date, b: Date) {\n    const s = clearTime(a);\n    const e = clearTime(b);\n    const [min, max] = s.getTime() <= e.getTime() ? [s, e] : [e, s];\n    modelStart.value = min;\n    modelEnd.value = max;\n    emit('update:start', modelStart.value);\n    emit('update:end', modelEnd.value);\n    emit('pick', [modelStart.value!, modelEnd.value!]);\n    hoverDate.value = null;\n}\n\nfunction onPickLeft(d: Date) {\n    return !modelStart.value || modelEnd.value\n        ? beginNewRange(d)\n        : finalizeRange(modelStart.value, d);\n}\n\nfunction onPickRight(d: Date) {\n    onPickLeft(d);\n}\nfunction onHoverLeft(d: Date) {\n    if (modelStart.value && !modelEnd.value) hoverDate.value = d;\n}\nfunction onHoverRight(d: Date) {\n    if (modelStart.value && !modelEnd.value) hoverDate.value = d;\n}\n\nfunction onPickLeftMonth(d: Date) {\n    leftDate.value = new Date(leftDate.value.getFullYear(), d.getMonth(), 1);\n    leftCurrentView.value = 'date';\n}\nfunction onPickRightMonth(d: Date) {\n    rightDate.value = new Date(rightDate.value.getFullYear(), d.getMonth(), 1);\n    rightCurrentView.value = 'date';\n}\nfunction onPickLeftYear(d: Date) {\n    leftDate.value = new Date(d.getFullYear(), leftDate.value.getMonth(), 1);\n    leftCurrentView.value = 'month';\n}\nfunction onPickRightYear(d: Date) {\n    rightDate.value = new Date(d.getFullYear(), rightDate.value.getMonth(), 1);\n    rightCurrentView.value = 'month';\n}\n</script>\n","<template>\n    <div class=\"el-date-editor el-input el-input--suffix\" :class=\"editorClasses\">\n        <div ref=\"triggerRef\" class=\"el-date-editor__trigger\">\n            <ElInput\n                ref=\"inputRef\"\n                :placeholder=\"placeholder\"\n                :model-value=\"displayValue\"\n                :label=\"label\"\n                readonly\n                suffix-icon=\"i-calendar--16\"\n                :clearable=\"clearable\"\n                :on-icon-click=\"togglePanel\"\n                @click=\"openPanel\"\n                @input=\"onInput\"\n                @keydown=\"onKeydown\"\n                @clear=\"onClear\"\n            />\n        </div>\n\n        <transition :name=\"transition\" @after-leave=\"onClosed\">\n            <div\n                v-show=\"visible\"\n                ref=\"dropdownRef\"\n                v-clickoutside=\"{ handler: onClosed, include: [triggerRef, dropdownRef] }\"\n                class=\"el-picker-panel\"\n                :class=\"panelClasses\"\n            >\n                <div v-if=\"isReady\" class=\"el-picker-panel__body-wrapper\">\n                    <div class=\"el-picker-panel__body\">\n                        <DateRangePanel\n                            v-if=\"isRange\"\n                            :key=\"'range-' + panelKey\"\n                            v-model:start=\"rangeState.start\"\n                            v-model:end=\"rangeState.end\"\n                            :first-day-of-week=\"firstDayOfWeek\"\n                            :unlink-panels=\"unlinkPanels\"\n                            @pick=\"onPickRange\"\n                        />\n\n                        <DatePanel\n                            v-else\n                            :key=\"'single-' + panelKey\"\n                            v-model=\"innerDate\"\n                            :first-day-of-week=\"firstDayOfWeek\"\n                            @pick=\"onPickSingle\"\n                        />\n                    </div>\n                </div>\n            </div>\n        </transition>\n    </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { onMounted, computed, ref, watch, nextTick, onBeforeUnmount } from 'vue';\nimport { useFirstDayOfWeek } from '@core/components/date-picker/mixins/use-first-day-of-week';\nimport DatePanel from '@core/components/date-picker/panel/DatePanel.vue';\nimport DateRangePanel from '@core/components/date-picker/panel/DateRangePanel.vue';\nimport { formatDate, parseDate } from '@core/components/date-picker/util/index';\nimport ElInput from '@core/components/input/input.vue';\nimport { usePopper } from '@core/composables/usePopper';\nimport Clickoutside from '@core/directives/v-clickoutside';\n// import '@core/styles/date-picker.scss';\n\ndefineOptions({\n    directives: { clickoutside: Clickoutside },\n});\n\nconst props = withDefaults(\n    defineProps<{\n    modelValue?: Date | [Date, Date] | null;\n    type?: 'date' | 'daterange';\n    placeholder?: string;\n    label?: string;\n    placement?: string;\n    popperClass?: string;\n    format?: string;\n    transition?: string;\n    clearable?: boolean;\n    unlinkPanels?: boolean;\n    isFormatForPayload?: boolean;\n  }>(),\n    {\n        type: 'date',\n        placement: 'bottom-start',\n        modelValue: null,\n        placeholder: '',\n        transition: '',\n        label: '',\n        popperClass: '',\n        format: 'yyyy-MM-dd',\n        clearable: true,\n        unlinkPanels: false,\n        isFormatForPayload: false,\n    },\n);\n\nconst emit = defineEmits<{\n  (e: 'update:modelValue', v: any): void;\n  (e: 'change', v: any): void;\n}>();\n\nconst { firstDayOfWeek } = useFirstDayOfWeek(1);\nconst visible = ref(false);\nconst isReady = ref(false);\nconst inputRef = ref<HTMLInputElement | null>(null);\nconst triggerRef = ref<HTMLInputElement | null>(null);\nconst dropdownRef = ref<HTMLInputElement | null>(null);\n\nconst panelKey = ref(0);\nconst isRange = computed(() => props.type === 'daterange');\n\nconst innerDate = ref<Date | null>(\n    Array.isArray(props.modelValue) ? null : (props.modelValue as Date | null) || null,\n);\nconst rangeState = ref<{ start: Date | null; end: Date | null }>({\n    start: Array.isArray(props.modelValue) ? props.modelValue?.[0] || null : null,\n    end: Array.isArray(props.modelValue) ? props.modelValue?.[1] || null : null,\n});\n\nwatch(\n    () => props.modelValue,\n    (v) => {\n        if (Array.isArray(v)) {\n            rangeState.value = { start: v?.[0] || null, end: v?.[1] || null };\n        } else {\n            innerDate.value = (v as Date) || null;\n        }\n        if (!v) {\n            onClear();\n        }\n    },\n);\n\nconst displayValue = computed(() => {\n    if (isRange.value) {\n        const s = rangeState.value.start\n            ? formatDate(rangeState.value.start, props.format)\n            : '';\n        const e = rangeState.value.end ? formatDate(rangeState.value.end, props.format) : '';\n        return s && e ? `${s} - ${e}` : '';\n    }\n    return innerDate.value ? formatDate(innerDate.value, props.format) : '';\n});\n\nconst editorClasses = computed(() => ({\n    'el-date-editor--daterange': isRange.value,\n}));\n\nconst panelClasses = computed(() => ({\n    'el-date-range-picker': isRange.value,\n    'el-date-picker': !isRange.value,\n}));\n\nconst popperOptions = computed(() => ({\n    placement: props.placement,\n    modifiers: [\n        { name: 'offset', options: { offset: [0, 8] } },\n        { name: 'preventOverflow', options: { boundary: 'viewport' } },\n        { name: 'flip', options: { fallbackPlacements: ['top-start', 'bottom-start'] } },\n    ],\n}));\n\nconst { initializePopper, updatePopper, destroyPopper } = usePopper(\n    triggerRef,\n    dropdownRef,\n    popperOptions.value,\n);\n\nwatch(visible, (val) => {\n    if (val) {\n        nextTick(async () => {\n            await initializePopper();\n            requestAnimationFrame(() => updatePopper());\n            isReady.value = true;\n        });\n    } else {\n        destroyPopper();\n        isReady.value = false;\n    }\n});\n\nfunction onClear() {\n    innerDate.value = null;\n    rangeState.value = { start: null, end: null };\n\n    emit('update:modelValue', null);\n    emit('change', null);\n\n    panelKey.value++;\n}\n\nfunction openPanel(e: MouseEvent) {\n    e.stopPropagation();\n    visible.value = true;\n}\nfunction togglePanel() {\n    visible.value = !visible.value;\n}\nfunction onClosed() {\n    visible.value = false;\n    destroyPopper();\n}\n\nfunction onPickSingle(d: Date) {\n    innerDate.value = d;\n    const value = props.isFormatForPayload ? formatDate(d, props.format) : d;\n    emit('update:modelValue', value);\n    emit('change', value);\n    visible.value = false;\n}\n\nfunction onPickRange([start, end]: [Date, Date]) {\n    rangeState.value = { start, end };\n    emit('update:modelValue', [start, end]);\n    emit('change', [start, end]);\n    visible.value = false;\n}\n\nfunction onInput(e: Event) {\n    const v = (e.target as HTMLInputElement)?.value;\n    if (!v || isRange.value) return;\n    const d = parseDate(v, props.format);\n    if (d && d instanceof Date && !Number.isNaN(d.getTime())) onPickSingle(d);\n}\n\nfunction onKeydown(e: KeyboardEvent) {\n    if (e.key === 'Escape') visible.value = false;\n    if (e.key === 'Tab') visible.value = false;\n}\n\nonMounted(() => {\n    nextTick(() => visible.value && initializePopper());\n    window.addEventListener('resize', updatePopper);\n});\n\nonBeforeUnmount(() => {\n    window.removeEventListener('resize', updatePopper);\n    destroyPopper();\n});\n</script>\n\n<style lang=\"scss\">\n/* TODO: must be scoped */\n\n/* Panel shell */\n.el-picker-panel {\n  position: absolute;\n  color: var(--av-fixed-primary);\n  border: 1px solid var(--av-brand-primary);\n  box-shadow: var(--el-shadow-regular);\n  background-color: var(--av-inversed-primary);\n  border-radius: 4px;\n  z-index: 1030;\n  margin: 5px 0;\n}\n\n.el-picker-panel__body-wrapper {\n  display: inline-block;\n}\n\n.el-picker-panel__body-wrapper::after,\n.el-picker-panel__body::after {\n  content: \"\";\n  display: table;\n  clear: both;\n}\n\n.el-picker-panel__body {\n  position: relative;\n}\n\n.el-picker-panel__content {\n  position: relative;\n}\n\n.el-date-picker {\n  display: inline-block;\n}\n\n.el-picker-panel__content--multi {\n  border-bottom: 1px solid var(--av-brand-lighter);\n}\n\n.el-picker-panel__footer {\n  border-top: 1px solid var(--av-brand-lighter);\n  padding: 4px;\n  text-align: right;\n  background-color: var(--av-inversed-primary);\n  position: relative;\n  font-size: 0;\n}\n\n.el-picker-panel__footer-multi {\n  height: 64px;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 0 16px;\n}\n\n.el-picker-panel__footer-multi.is-one-day {\n  justify-content: flex-end;\n}\n\n.el-picker-panel__footer-multi--clear-btn {\n  max-width: 158px;\n  margin-left: 4px;\n  font-weight: 400 !important;\n}\n\n.el-picker-panel__footer-multi--all-btn {\n  max-width: 90px;\n  margin-left: 16px;\n}\n\n/* Sidebar / predefined */\n.el-picker-panel__sidebar {\n  position: absolute;\n  top: 0;\n  bottom: 0;\n  width: 160px;\n  border-right: 1px solid var(--av-brand-lighter);\n  box-sizing: border-box;\n  padding: 12px 16px;\n  background-color: var(--av-inversed-primary);\n  overflow: auto;\n}\n\n.el-picker-panel__shortcut {\n  display: block;\n  width: 100%;\n  border: none;\n  background-color: transparent;\n  line-height: 28px;\n  font-size: 14px;\n  color: var(--av-fixed-primary);\n  padding-left: 12px;\n  text-align: left;\n  outline: none;\n  cursor: pointer;\n}\n\n.el-picker-panel__shortcut.active,\n.el-picker-panel__shortcut:hover {\n  background-color: var(--av-brand-accent);\n}\n\n.el-picker-panel__btn {\n  border: 1px solid var(--av-fixed-light);\n  color: var(--av-fixed-light);\n  line-height: 24px;\n  border-radius: 2px;\n  padding: 0 20px;\n  cursor: pointer;\n  background-color: transparent;\n  outline: none;\n  font-size: 12px;\n}\n\n.el-picker-panel__btn[disabled] {\n  color: var(--av-fixed-lighter);\n  cursor: default;\n}\n\n.el-picker-panel__icon-btn {\n  font-size: 12px;\n  color: var(--av-fixed-primary);\n  border: none;\n  background: transparent;\n  cursor: pointer;\n  outline: none;\n  margin-top: 8px;\n}\n.el-picker-panel__icon-btn:hover {\n  color: var(--av-brand-primary);\n}\n.el-picker-panel__icon-btn.is-disabled {\n  color: var(--av-fixed-light);\n}\n.el-picker-panel__icon-btn.is-disabled:hover {\n  cursor: default;\n}\n\n/* Date picker header */\n.el-date-picker__header,\n.el-date-range-picker__header {\n  height: 48px;\n  padding: 0 16px;\n  font-size: 16px;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  border-bottom: 1px solid var(--av-brand-lighter);\n  max-width: 296px;\n}\n\n.el-date-picker__header--multi {\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n  width: 100%;\n}\n\n.el-date-picker__label-wrapper {\n  height: 100%;\n  display: inline-block;\n}\n.el-date-picker__header > span,\n.el-date-range-picker__header > span {\n  flex: 1;\n  text-align: center;\n}\n\n.el-date-picker__header-btn {\n  color: var(--av-brand-primary);\n  cursor: pointer;\n}\n\n.el-date-picker__header-btn--with-spacer-left {\n  margin-left: 8px;\n}\n.el-date-picker__header-btn--with-spacer-right {\n  margin-right: 8px;\n}\n.el-date-picker__header-btn.disabled {\n  cursor: default;\n}\n\n.el-date-picker__header-label {\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n  display: inline-block;\n  font-size: 18px;\n  font-weight: 400;\n  padding: 0 8px;\n  line-height: 48px;\n  text-align: center;\n  cursor: pointer;\n  color: var(--av-fixed-primary);\n}\n.el-date-picker__header-label:hover {\n  background-color: var(--av-brand-accent);\n}\n.el-date-picker__header-label.disabled {\n  cursor: default;\n}\n.el-date-picker__header-label.disabled.active,\n.el-date-picker__header-label.disabled:hover {\n  background-color: inherit;\n}\n\n.el-date-picker__header-label-month {\n  max-width: 68px;\n}\n.el-date-picker__header-label-year {\n  max-width: 100px;\n}\n.el-date-picker__header-label-year--full-width {\n  max-width: 200px;\n}\n\n/* Date table (days grid) */\n.el-date-table {\n  font-size: 14px;\n  font-weight: 400;\n  user-select: none;\n  margin: 0;\n  table-layout: fixed;\n  line-height: 32px;\n  width: auto;\n}\n.el-date-table__row {\n  font-size: 14px;\n}\n.el-date-table__row--hidden {\n  display: none;\n}\n.el-date-table__weekday-name {\n  max-width: 40px;\n  text-align: center;\n}\n\n.el-date-table tbody::before,\n.el-date-table thead::before {\n  content: \"\";\n  display: block;\n  height: 8px;\n}\n\n.el-date-table thead th {\n  font-size: 14px;\n  font-weight: 400;\n  line-height: 32px;\n  width: 40px;\n  text-align: center;\n  height: 32px;\n  box-sizing: border-box;\n  border-bottom: 1px solid var(--av-brand-lighter);\n  padding: 0;\n}\n.el-date-table tbody::after,\n.el-date-table thead th::after {\n  content: \"\";\n  display: block;\n  height: 8px;\n}\n\n.el-date-table tbody td {\n  font-size: 14px;\n  font-weight: 400;\n  width: 40px;\n  text-align: center;\n  height: 32px;\n  cursor: pointer;\n  position: relative;\n  border: none;\n  padding: 0;\n}\n.el-date-table tbody td div {\n  height: 100%;\n  box-sizing: border-box;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n.el-date-table tbody td span {\n  width: 40px;\n  height: 32px;\n  display: block;\n  text-align: center;\n  line-height: 32px;\n}\n\n/* Day states */\n.el-date-table tbody td.available:hover div,\n.el-date-table tbody td.in-range div,\n.el-date-table tbody td.in-range div:hover {\n  background-color: var(--av-brand-accent);\n}\n\n.el-date-table tbody td.start-date div,\n.el-date-table tbody td.start-date div:hover,\n.el-date-table tbody td.end-date div,\n.el-date-table tbody td.end-date div:hover {\n  background-color: var(--av-brand-light);\n}\n\n.el-date-table tbody td.current div,\n.el-date-table tbody td.current div:hover {\n  background-color: var(--av-brand-accent);\n}\n\n.el-date-table tbody td.today span {\n  font-weight: 600;\n}\n\n.el-date-table tbody td.disabled div {\n  opacity: 1;\n  cursor: default;\n  color: var(--av-fixed-lightest);\n}\n\n.el-date-table tbody td.prev-month div,\n.el-date-table tbody td.next-month div {\n  color: var(--av-inversed-primary);\n  cursor: default;\n}\n\n.el-date-table tbody td.prev-month.current div,\n.el-date-table tbody td.prev-month.disabled div,\n.el-date-table tbody td.prev-month.in-range div,\n.el-date-table tbody td.prev-month.start-date div,\n.el-date-table tbody td.prev-month.end-date div,\n.el-date-table tbody td.prev-month.start-date-consecutive div,\n.el-date-table tbody td.next-month.current div,\n.el-date-table tbody td.next-month.disabled div,\n.el-date-table tbody td.next-month.in-range div,\n.el-date-table tbody td.next-month.start-date div,\n.el-date-table tbody td.next-month.end-date div,\n.el-date-table tbody td.next-month.start-date-consecutive div {\n  background-color: var(--av-inversed-primary);\n  color: var(--av-inversed-primary);\n  cursor: default;\n}\n.el-date-table tbody td.prev-month:hover div,\n.el-date-table tbody td.next-month:hover div {\n  background-color: var(--av-inversed-primary);\n}\n\n.el-date-table .weekends {\n  color: var(--av-fixed-light);\n}\n.el-date-table.is-multi-mode .weekends {\n  color: var(--av-fixed-primary);\n}\n\n/* Month table */\n.el-month-table {\n  margin: 32px 8px;\n  border-collapse: collapse;\n}\n.el-month-table td {\n  text-align: center;\n  padding: 16px 0;\n  border: none;\n}\n.el-month-table td .cell {\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n  width: 70px;\n  height: 32px;\n  display: block;\n  line-height: 32px;\n  margin: 0 auto;\n  color: var(--av-fixed-primary);\n  cursor: pointer;\n}\n.el-month-table td .cell:hover {\n  color: var(--av-fixed-primary);\n}\n.el-month-table td .cell:hover,\n.el-month-table td.current:not(.disabled) .cell {\n  background-color: var(--av-brand-accent);\n}\n.el-month-table td.disabled .cell {\n  cursor: default;\n}\n.el-month-table td.disabled .cell,\n.el-month-table td.disabled .cell:hover {\n  background-color: var(--av-inversed-primary);\n  color: var(--av-fixed-lightest);\n}\n\n/* Year table */\n.el-year-table {\n  margin: 32px 8px;\n  border-collapse: collapse;\n}\n.el-year-table td {\n  text-align: center;\n  padding: 16px 0;\n  border: none;\n}\n.el-year-table td .cell {\n  width: 70px;\n  height: 32px;\n  display: block;\n  line-height: 32px;\n  margin: 0 auto;\n  color: var(--av-fixed-primary);\n  cursor: pointer;\n}\n.el-year-table td .cell:hover {\n  color: var(--av-fixed-primary);\n}\n.el-year-table td .cell:hover,\n.el-year-table td.current:not(.disabled) .cell {\n  background-color: var(--av-brand-accent);\n}\n.el-year-table td.disabled .cell {\n  cursor: default;\n}\n.el-year-table td.disabled .cell,\n.el-year-table td.disabled .cell:hover {\n  background-color: var(--av-inversed-primary);\n  color: var(--av-fixed-lightest);\n}\n\n/* Date editor / input */\n.el-date-editor {\n  position: relative;\n  text-align: left;\n}\n.el-date-editor .el-input__suffix i,\n.el-date-editor.is-non-editable .el-input__container,\n.el-date-editor.is-non-editable .el-input__container input {\n  cursor: pointer;\n}\n.el-date-editor.is-non-editable.is-disabled .el-input__container,\n.el-date-editor.is-non-editable.is-disabled .el-input__container input {\n  cursor: default;\n}\n\n/* Range picker layout */\n.el-date-range-picker {\n  display: inline-flex;\n}\n.el-date-range-picker .el-picker-panel__body {\n  display: inline-block;\n  flex-flow: row wrap;\n  width: auto;\n}\n@media (--viewport-tablet) {\n  .el-date-range-picker .el-picker-panel__body {\n    display: flex;\n    flex-flow: row nowrap;\n  }\n}\n.el-date-range-picker__content {\n  box-sizing: border-box;\n  margin: 0;\n}\n.el-date-range-picker__content.is-right .el-date-range-picker__header div {\n  margin-left: 50px;\n  margin-right: 50px;\n}\n.el-date-range-picker__content:not(:first-child) {\n  border-left: 1px solid var(--av-brand-accent);\n}\n\n.el-date-range-picker__predefined {\n  border-left: 1px solid var(--av-brand-accent);\n  width: 160px;\n  padding: 12px 16px;\n}\n.el-date-range-picker__predefined-setting {\n  display: inline-block;\n}\n\n.el-date-range-picker__action-panel {\n  border-top: 1px solid var(--av-brand-accent);\n  height: 64px;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0 16px;\n}\n\n/* Custom options checklist */\n.el-custom-options {\n  position: relative;\n  border-bottom: 1px solid var(--av-bran