 Math.ceil(parseInt(sizeHeight.value) / 100 * el.clientHeight);\n    const scrollWidth = Math.ceil(parseInt(sizeWidth.value) / 100 * el.clientWidth);\n\n    if (scrollHeight <= minSize) {\n        moveY.value = (el.scrollTop / (el.scrollHeight - el.clientHeight)) * (el.clientHeight - minSize) / minSize * 100;\n    }\n    if (scrollWidth <= minSize) {\n        moveX.value = (el.scrollLeft / (el.scrollWidth - el.clientWidth)) * (el.clientWidth - minSize) / minSize * 100;\n    }\n}\n\nfunction update() {\n    const el = wrap.value;\n    if (!el) return;\n\n    const minSize = 40;\n    const rect = el.getBoundingClientRect();\n\n    const isHeightOverflow = Math.abs(el.clientHeight - el.scrollHeight) > 1;\n    const isWidthOverflow = Math.abs(el.clientWidth - el.scrollWidth) > 1;\n\n    const heightAccurate = Math.abs(rect.height - el.offsetHeight) <= 1;\n    const widthAccurate = Math.abs(rect.width - el.offsetWidth) <= 1;\n\n    let widthPercent = widthAccurate && isWidthOverflow ? (el.clientWidth * 100 / el.scrollWidth) : 100;\n    let heightPercent = heightAccurate && isHeightOverflow ? (el.clientHeight * 100 / el.scrollHeight) : 100;\n\n    const minHeightPercent = (minSize * 100 / el.clientHeight);\n    const minWidthPercent = (minSize * 100 / el.clientWidth);\n\n    heightPercent = Math.max(heightPercent, minHeightPercent);\n    widthPercent = Math.max(widthPercent, minWidthPercent);\n\n    sizeHeight.value = heightPercent < 100 && el.scrollHeight > minSize ? `${heightPercent}%` : '';\n    sizeWidth.value = widthPercent < 100 && el.scrollWidth > minSize ? `${widthPercent}%` : '';\n\n    gutter.value = getScrollbarWidth();\n\n    emit('overflow-update', isHeightOverflow, isWidthOverflow);\n}\n\nfunction handleScroll(e) {\n    updateScrollPosition();\n    emit('scroll', e);\n}\n\nfunction setPosition(top, left) {\n    if (wrap.value) {\n        if (top != null) wrap.value.scrollTop = top;\n        if (left != null) wrap.value.scrollLeft = left;\n    }\n}\n\ndefineE