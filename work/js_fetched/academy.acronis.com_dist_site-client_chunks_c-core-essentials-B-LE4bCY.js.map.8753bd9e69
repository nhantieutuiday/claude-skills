  </template>\n                                        <template v-else>\n                                            <a-link\n                                                v-if=\"cell.to\"\n                                                v-bind=\"cell\"\n                                                class=\"a-table__category-link\"\n                                                :text=\"cell.val\"\n                                                :size=\"cell.size || 'paragraph'\"\n                                            />\n                                            <span v-else v-html=\"cell.val\" />\n                                        </template>\n                                        <a-tooltip v-if=\"cell.tooltip\" class=\"a-table__tooltip\" :content=\"cell.tooltip\" />\n                                    </div>\n                                </template>\n                                <template v-if=\"cell.expand\">\n                                    <div\n                                        :class=\"[`a-table__${cell.type}`, `a-table__expand`]\"\n                                        @click=\"toggleExpand(cellIndex, rowIndex)\"\n                                    >\n                                        <a-glyph\n                                            :name=\"isExpand(cellIndex, rowIndex) ? 'chevron-big-down' : 'i-chevron-big-right--16'\"\n                                            class=\"toggleIcon\"\n                                        />\n                                        <template v-if=\"cell.productPageCTA\">\n                                            <a-product-cta\n                                                :settings=\"{ hasDescription: true, ...cell.productPageCTA }\"\n                                            />\n                                        </template>\n                                        <template v-else>\n                                            <a-link\n                                                v-if=\"cell.to\"\n                                                v-bind=\"cell\"\n                                                class=\"a-table__category-link\"\n                                                :text=\"cell.val\"\n                                                :size=\"cell.size || 'paragraph'\"\n                                            />\n                                            <span v-else v-html=\"cell.val\" />\n                                        </template>\n                                        <template v-if=\"cell.tooltips\">\n                                            <a-tooltip\n                                                v-for=\"tooltip in cell.tooltips\"\n                                                :key=\"tooltip.text\"\n                                                :glyph=\"tooltip.glyph\"\n                                                class=\"a-table__tooltip\"\n                                                :content=\"tooltip.text\"\n                                            />\n                                        </template>\n                                        <a-tooltip v-if=\"cell.tooltip\" class=\"a-table__tooltip\" :content=\"cell.tooltip\" />\n                                    </div>\n                                </template>\n                                <template v-else-if=\"cell.type === 'list'\">\n                                    <div class=\"a-table__list-wrap\">\n                                        <ul class=\"a-table__list\">\n                                            <li v-for=\"(item, i) in cell.list\" :key=\"i\" class=\"a-table__list-item\">\n                                                {{ item }}\n                                            </li>\n                                        </ul>\n                                    </div>\n                                </template>\n                                <template v-else-if=\"cell.type === 'checked'\">\n                                    <div class=\"a-table__check\">\n                                        <div v-if=\"translated && translated.checked\" class=\"a-table__check-text\">\n                                            {{ translated.checked[cell.val] }}\n                                        </div>\n                                        <div v-else class=\"a-table__check-icon\" :class=\"[`a-table__check-icon_${cell.val}`]\" />\n                                    </div>\n                                </template>\n                                <template v-else-if=\"cell.type === 'button'\">\n                                    <div class=\"a-table__button-wrapper\">\n                                        <a-button\n                                            v-modal=\"getButtonModalId(cell.val)\"\n                                            v-bind=\"cell.val\"\n                                            :to=\"getButtonModalId(cell.val) ? null : cell.val.link\"\n                                        />\n                                    </div>\n                                </template>\n                                <template v-if=\"cell.description && (!cell.expand || isExpand(cellIndex, rowIndex))\">\n                                    <div\n                                        class=\"a-table__description\"\n                                        :class=\"{ 'a-table__description-full': cell.description.full }\"\n                                    >\n                                        <a-icon\n                                            v-if=\"cell.description.icon\"\n                                            class=\"a-table__description-icon\"\n                                            icon-variant\n                                            :number=\"cell.description.icon\"\n                                        />\n                                        <div v-if=\"cell.description.title\" class=\"a-table__description-title\">\n                                            {{ cell.description.title }}\n                                        </div>\n                                        <div v-if=\"cell.description.text\" class=\"a-table__description-text\">\n                                            {{ cell.description.text }}\n                                        </div>\n                                        <a-link\n                                            v-if=\"cell.description.link\"\n                                            class=\"a-table__description-link\"\n                                            v-bind=\"cell.description.link\"\n                                        />\n                                        <div\n                                            v-if=\"cell.description.note\"\n                                            class=\"a-table__description-note\"\n                                        >\n                                            {{ cell.description.note }}\n                                        </div>\n                                    </div>\n                                </template>\n                            </td>\n                        </tr>\n                    </tbody>\n                </table>\n            </template>\n        </div>\n        <a-modal\n            v-for=\"ytId in youtubeIds\"\n            :id=\"`yt_id-${ytId}`\"\n            :key=\"ytId\"\n            type=\"youtube\"\n            is-youtube\n            is-overlay-close\n        >\n            <a-youtube :yt-id=\"ytId\" :params=\"{ autoplay: 1 }\" />\n        </a-modal>\n        <a-demo-modal\n            v-for=\"modal in demoModals\"\n            :key=\"modal.id\"\n            :modal=\"modal\"\n        />\n    </div>\n</template>\n\n<script setup>\nimport { throttle } from 'lodash-es';\nimport {\n    computed,\n    nextTick,\n    onBeforeUnmount,\n    onMounted,\n    onServerPrefetch,\n    ref,\n    watch,\n} from 'vue';\nimport { useStore } from 'vuex';\nimport AButton from '@core/components/button/button.vue';\nimport ADangerousHtml from '@core/components/dangerous-html/dangerous-html.vue';\nimport ADemoModal from '@core/components/demo-modal/demo-modal.vue';\nimport AGlyph from '@core/components/glyph/glyph.vue';\nimport AIcon from '@core/components/icon/icon.vue';\nimport ALink from '@core/components/link/link.vue';\nimport AModal from '@core/components/modal/modal.vue';\nimport AProductCta from '@core/components/product-cta/product-cta.vue';\nimport ATooltip from '@core/components/tooltip/tooltip.vue';\nimport AYoutube from '@core/components/youtube/youtube.vue';\nimport { useBreakpoint } from '@core/composables/useBreakpoint';\nimport { useL10n } from '@core/composables/useL10n';\nimport { usePurchasing } from '@core/composables/usePurchasing';\nimport Modal from '@core/directives/modal.js';\nimport STableHeadCell from './components/table-head-cell.vue';\nimport STableHeadSwitcher from './components/table-head-switcher.vue';\nimport STableMobileHeadCell from './components/table-mobile-head-cell.vue';\n\ndefineOptions({\n    name: 'ATableNew',\n    directives: { Modal },\n});\n\nconst props = defineProps({\n    translations: {\n        type: Object,\n        default: () => ({}),\n    },\n\n    translated: {\n        type: Object,\n        default: undefined,\n    },\n\n    settings: {\n        type: Object,\n        required: true,\n    },\n\n    head: {\n        type: Array,\n        required: true,\n    },\n\n    rows: {\n        type: Array,\n        required: true,\n    },\n\n    theme: {\n        type: String,\n        validator: (prop) => ['light', 'dark'].includes(prop),\n        default: 'light',\n    },\n});\n\n// Taken from @core/slices/pages/anchor-menu/anchor-menu.vue.\n// Do NOT import it, this will break dependencies graph.\n// If it necessary, move the val to @model/slices.\nconst ANCHOR_HEIGHT = 52;\nconst TEXT_CELL_TYPES = new Set(['subtitle', 'category', 'text']);\nconst getExpandKey = (rowIndex, cellIndex) => `row_${rowIndex}_cell_${cellIndex}`;\n\nconst store = useStore();\nconst { l10n } = useL10n(props);\nconst { currentBreakpoint, getDeviceTypeByScreenWidth, isDesktop } = useBreakpoint();\nconst { initSettingsCTA } = usePurchasing({\n    productCurrency: computed(() => undefined),\n});\n\nconst withOptionalRows = ref(true);\nconst submenuOnPage = ref(false);\nconst countHeadStylesThrottled = ref(null);\nconst expandedRowsLookup = ref({});\nconst syncScrollCleanup = ref(null);\nconst headRef = ref(null);\nconst bodyRef = ref(null);\n\nconst effectiveMobileType = computed(() => l10n.value?.settings?.mobileType ?? props.settings?.mobileType ?? '');\n\nconst cssVars = computed(() => {\n    let stickyOffset = ANCHOR_HEIGHT;\n    const anchorMenu = store.state.pages?.page?.body?.find((s) => s.name === 's-anchor-menu');\n\n    if (anchorMenu?.data?.stickyOffset) {\n        let deviceType;\n\n        if (typeof window !== 'undefined') {\n            deviceType = getDeviceTypeByScreenWidth(window.outerWidth);\n        } else {\n            deviceType = currentBreakpoint.value;\n        }\n\n        const offsetConfig = anchorMenu.data.stickyOffset;\n        const addOffset = offsetConfig[deviceType] || offsetConfig.default || 0;\n        stickyOffset += addOffset;\n    }\n\n    return {\n        '--table-sticky-offset': `${stickyOffset}px`,\n    };\n});\n\nconst className = computed(() => ({\n    [`a-table_layout_${l10n.value.settings.layout}`]: l10n.value.settings.layout,\n    [`a-table_height_${l10n.value.settings.height}`]: l10n.value.settings.height,\n    [`a-table_align_${l10n.value.settings.align}`]: l10n.value.settings.align,\n    'a-table_sticky': l10n.value.settings.sticky,\n    'a-table_without-optional': !withOptionalRows.value,\n    'a-table_with_submenu': submenuOnPage.value,\n    'a-table_mobile-type-column': effectiveMobileType.value === 'column',\n    [`a-table_type-${l10n.value.settings.type}`]: l10n.value.settings.type,\n    'a-table_lte-3-cols': l10n.value.rows[0].content.length <= 3,\n    'theme-dark': props.theme === 'dark',\n}));\n\nconst teardownSyncScroll = () => {\n    syncScrollCleanup.value?.();\n    syncScrollCleanup.value = null;\n};\n\nconst setupSyncScroll = () => {\n    teardownSyncScroll();\n\n    const headElement = headRef.value;\n    const bodyElement = bodyRef.value;\n    if (!headElement || !bodyElement) return;\n\n    const state = new WeakMap([\n        [headElement, { x: 0 }],\n        [bodyElement, { x: 0 }],\n    ]);\n\n    const getMaxScrollLeft = (element) => element.scrollWidth - element.clientWidth;\n\n    const syncByRate = (sourceElement, targetElement) => {\n        const sourceState = state.get(sourceElement);\n        const targetState = state.get(targetElement);\n        if (!sourceState || !targetState) return;\n\n        const sourceLeft = sourceElement.scrollLeft;\n        const sourceMax = getMaxScrollLeft(sourceElement);\n        const sourceRate = sourceMax > 0 ? sourceLeft / sourceMax : 0;\n        const hasUserUpdate = sourceLeft !== sourceState.x;\n        sourceState.x = sourceLeft;\n        if (!hasUserUpdate) return;\n\n        const targetMax = getMaxScrollLeft(targetElement);\n        const nextTargetLeft = Math.round(sourceRate * targetMax);\n        targetState.x = nextTargetLeft;\n\n        if (Math.round(targetElement.scrollLeft - nextTargetLeft)) {\n            const target = targetElement;\n            target.scrollLeft = nextTargetLeft;\n        }\n    };\n\n    const onHeadScroll = () => syncByRate(headElement, bodyElement);\n    const onBodyScroll = () => syncByRate(bodyElement, headElement);\n\n    headElement.addEventListener('scroll', onHeadScroll, { passive: true });\n    bodyElement.addEventListener('scroll', onBodyScroll, { passive: true });\n\n    syncScrollCleanup.value = () => {\n        headElement.removeEventListener('scroll', onHeadScroll);\n        bodyElement.removeEventListener('scroll', onBodyScroll);\n    };\n};\n\nconst isExpand = (cellIndex, rowIndex) => Boolean(expandedRowsLookup.value[getExpandKey(rowIndex, cellIndex)]);\n\nconst toggleExpand = (cellIndex, rowIndex) => {\n    const key = getExpandKey(rowIndex, cellIndex);\n    const isExpanded = Boolean(expandedRowsLookup.value[key]);\n\n    if (isExpanded) {\n        const nextLookup = { ...expandedRowsLookup.value };\n        delete nextLookup[key];\n        expandedRowsLookup.value = nextLookup;\n        return;\n    }\n\n    expandedRowsLookup.value = {\n        ...expandedRowsLookup.value,\n        [key]: true,\n    };\n};\n\nconst isTextCell = (cell) => {\n    const type = (cell?.type ?? '').toString().trim();\n    return TEXT_CELL_TYPES.has(type);\n};\n\nconst getButtonModalId = (val) => {\n    if (!isDesktop.value) return null;\n    if (val?.ytId) return `yt_id-${val.ytId}`;\n    if (val?.modal?.id) return val.modal.id;\n    if (val?.modalId) return val.modalId;\n    return null;\n};\n\nconst getClassNameForTableCell = (cell) => ({\n    [`a-table__cell_colspan_${cell.colspan}`]: cell.colspan,\n    [`a-table__cell_align_${cell.align}`]: cell.align,\n    'a-table__cell_without_border': cell.withoutBorder,\n});\n\nconst getClassNameForTableRow = (row) => ({\n    'a-table__row_has-expandable': row.content && row.content?.some(cell => cell.expand),\n    'a-table__row_optional': row.optional,\n    'a-table__row_with-indent': row.subtitleIndent,\n    'a-table__row_no-scroll': row.mobileType === 'no-scroll',\n    'a-table__row_multirow': row.mobileType === 'multirow',\n    [`a-table__row_vertical_${row.vertical}`]: row.vertical,\n});\n\nconst countHeadStyles = () => {\n    if (!headRef.value) return;\n\n    const containerWidth = 1312;\n\n    if (currentBreakpoint.value === 'desktopLarge') {\n        headRef.value.style.margin = `0 ${\n            (containerWidth - document.documentElement.clientWidth) / 2\n        }px`;\n        headRef.value.style.padding = `0 ${\n            (document.documentElement.clientWidth - containerWidth) / 2\n        }px`;\n    } else {\n        headRef.value.style = '';\n    }\n};\n\nwatch(\n    () => l10n.value?.settings?.type,\n    async () => {\n        await nextTick();\n        setupSyncScroll();\n    },\n);\n\nonMounted(async () => {\n    if (typeof window !== 'undefined') {\n        await nextTick();\n        setupSyncScroll();\n    }\n\n    if (l10n.value.settings.sticky) {\n        const submenu = document.querySelector('.a-submenu');\n        const productSticky = document.querySelector('.s-header-product-new');\n\n        if (submenu || productSticky) {\n            submenuOnPage.value = true;\n        }\n\n        if (currentBreakpoint.value === 'desktopLarge') {\n            countHeadStyles();\n        }\n\n        countHeadStylesThrottled.value = throttle(countHeadStyles, 200);\n        window.addEventListener('resize', countHeadStylesThrottled.value);\n    }\n});\n\nonBeforeUnmount(() => {\n    teardownSyncScroll();\n    if (!l10n.value.settings.sticky) return;\n    window.removeEventListener('resize', countHeadStylesThrottled.value);\n    countHeadStylesThrottled.value?.cancel?.();\n});\n\nonServerPrefetch(async () => {\n    if (!import.meta.env.SSR) return;\n\n    const rows = props.translations?.rows || props.rows;\n    await initSettingsCTA(rows.flatMap((item) => item?.content));\n});\n</script>\n\n<style lang=\"postcss\" scoped>\n.a-table__wrapper_type-1 {\n  overflow-x: auto;\n  max-width: 100%;\n    .a-table__scroll-container {\n        overflow-x: auto;\n        display: block;\n        max-width: 100%;\n    }\n}\n\n.a-table {\n    tbody {\n        display: block;\n    }\n    &_layout {\n        &_8-2 {\n            .a-table__cell,\n            .a-table__head-cell {\n                @mixin colspan 50%, 50%;\n\n                flex: 0 0 50%;\n\n                @media (--viewport-tablet) {\n                    @mixin colspan 25%, 25%;\n\n                    flex: 0 0 25%;\n                }\n\n                @media (--viewport-desktop) {\n                    @mixin colspan 9%, 9%;\n\n                    flex: 0 0 9%;\n\n                    &:first-of-type {\n                        @mixin colspan 37%, 9%;\n\n                        flex: 0 0 37%;\n                    }\n                }\n            }\n        }\n\n        &_7-1 {\n            .a-table__cell,\n            .a-table__head-cell {\n                @mixin colspan 50%, 50%;\n\n                flex: 0 0 50%;\n\n                @media (--viewport-tablet) {\n                    @mixin colspan 25%, 25%;\n\n                    flex: 0 0 25%;\n                }\n\n                @media (--viewport-desktop) {\n                    @mixin colspan 14.286%, 14.286%;\n\n                    flex: 0 0 14.286%;\n                }\n            }\n        }\n\n        &_6-1 {\n            .a-table__cell,\n            .a-table__head-cell {\n                @mixin colspan 50%, 50%;\n\n                flex: 0 0 50%;\n\n                @media (--viewport-tablet) {\n                    @mixin colspan 25%, 25%;\n\n                    flex: 0 0 25%;\n                }\n\n                @media (--viewport-desktop) {\n                    @mixin colspan 16.66%, 16.66%;\n\n                    flex: 0 0 16.66%;\n                }\n            }\n        }\n\n        &_6-2 {\n            .a-table__cell,\n            .a-table__head-cell {\n                @mixin colspan 50%, 50%;\n\n                flex: 0 0 50%;\n\n                @media (--viewport-tablet) {\n                    @mixin colspan 33.33%, 33.33%;\n\n                    flex: 0 0 33.3%;\n                }\n\n                @media (--viewport-desktop) {\n                    @mixin colspan 25%, 25%;\n\n                    flex: 0 0 25%;\n                }\n\n                @media (--viewport-desktop-wide) {\n                    @mixin colspan 20%, 20%;\n\n                    flex: 0 0 20%;\n                }\n            }\n        }\n\n        &_5-1 {\n 